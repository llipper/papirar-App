    "preambulo": [
        {
            "texto": "LEI Nº 9.455, DE 7 DE ABRIL DE 1997.",
            "linha": 1
        },
        {
            "texto": "Define os crimes de tortura e dá outras providências.",
            "linha": 3
        },
        {
            "texto": "O PRESIDENTE DA REPÚBLICA Faço saber que o Congresso Nacional decreta e eu sanciono a seguinte Lei:",
            "linha": 5
        },
        {
            "texto": "Art. 1º Constitui crime de tortura:",
            "linha": 7
        },
        {
            "texto": "I - constranger alguém com emprego de violência ou grave ameaça, causando-lhe sofrimento físico ou mental:",
            "linha": 9
        }
    ],
    "divisoes": [
        {
            "tipo": "texto",
            "rotulo": "TEXTO",
            "linha": 44,
            "artigos": [
                {
                    "numero": "2º",
                    "rotulo": "Art. 2º",
                    "linha": 44,
                    "caput": "O disposto nesta Lei aplica-se ainda quando o crime não tenha sido cometido em território nacional, sendo a vítima brasileira ou encontrando-se o agente em local sob jurisdição brasileira."
                },
                {
                    "numero": "3º",
                    "rotulo": "Art. 3º",
                    "linha": 46,
                    "caput": "Esta Lei entra em vigor na data de sua publicação."
                },
                {
                    "numero": "4º",
                    "rotulo": "Art. 4º",
                    "linha": 48,
                    "caput": "Revoga-se o art. 233 da Lei nº 8.069, de 13 de julho de 1990 - Estatuto da Criança e do Adolescente."
                }
            ]
