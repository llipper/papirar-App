                                                                                                                                                                                                                        "linha":    4245,
                                                                                                                                                                                                                        "caput":    "Amotinarem-se prisioneiros em presença do inimigo:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Amotinamento de prisioneiros"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA LIBERTAÇÃO, DA EVASÃO E DO AMOTINAMENTO",
                                                                                                                                                                                "linhaTitulo":    4226
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO XIV",
                                                                                                                                                                                "linha":    4249,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "397º",
                                                                                                                                                                                                                        "rotulo":    "Art. 397º.",
                                                                                                                                                                                                                        "linha":    4253,
                                                                                                                                                                                                                        "caput":    "Contribuir culposamente para que alguém pratique crime que favoreça o inimigo:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a quatro anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Favorecimento culposo"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO FAVORECIMENTO CULPOSO AO INIMIGO",
                                                                                                                                                                                "linhaTitulo":    4250
                                                                                                                                                                        }
                                                                                                                                                                ],
