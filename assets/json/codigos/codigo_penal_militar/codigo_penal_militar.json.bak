                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "398º",
                                                                                                                                                                             "rotulo":    "Art. 398º.",
                                                                                                                                                                             "linha":    4262,
                                                                                                                                                                             "caput":    "Prolongar o comandante as hostilidades, depois de oficialmente saber celebrada a paz ou ajustado o armistício.",
                                                                                                                                                                             "pena":    "reclusão, de dois a dez anos.",
                                                                                                                                                                             "rubrica":    "Prolongamento de hostilidades"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "399º",
                                                                                                                                                                             "rotulo":    "Art. 399º.",
                                                                                                                                                                             "linha":    4268,
                                                                                                                                                                             "caput":    "Ordenar o comandante contribuição de guerra, sem autorização, ou excedendo os limites desta:",
                                                                                                                                                                             "pena":    "reclusão, até três anos.",
                                                                                                                                                                             "rubrica":    "Ordem arbritária"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DA HOSTILIDADE E DA ORDEM ARBITRÁRIA",
                                                                                                                                     "linhaTitulo":    4258
