                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "404º",
                                                                                                                                                                             "rotulo":    "Art. 404º.",
                                                                                                                                                                             "linha":    4340,
                                                                                                                                                                             "caput":    "Praticar crime de furto definido nos arts. 240 e 241 e seus parágrafos, em zona de operações militares ou em território militarmente ocupado:",
                                                                                                                                                                             "pena":    "reclusão, no dôbro da pena cominada para o tempo de paz.",
                                                                                                                                                                             "rubrica":    "Furto"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "405º",
                                                                                                                                                                             "rotulo":    "Art. 405º.",
                                                                                                                                                                             "linha":    4346,
                                                                                                                                                                             "caput":    "Praticar crime de roubo, ou de extorsão definidos nos arts. 242, 243 e 244, em zona de operações militares ou em território militarmente ocupado:",
                                                                                                                                                                             "pena":    "morte, grau máximo, se cominada pena de reclusão de trinta anos; reclusão pelo dôbro da pena para o tempo de paz, nos outros casos.",
                                                                                                                                                                             "rubrica":    "Roubo ou extorsão"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "406º",
                                                                                                                                                                             "rotulo":    "Art. 406º.",
                                                                                                                                                                             "linha":    4352,
                                                                                                                                                                             "caput":    "Praticar o saque em zona de operações militares ou em território militarmente ocupado:",
                                                                                                                                                                             "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                             "rubrica":    "Saque"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA O PATRIMÔNIO",
                                                                                                                                     "linhaTitulo":    4337
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO V",
                                                                                                                                     "linha":    4356,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "407º",
                                                                                                                                                                             "rotulo":    "Art. 407º.",
                                                                                                                                                                             "linha":    4360,
                                                                                                                                                                             "caput":    "Raptar mulher honesta, mediante violência ou grave ameaça, para fim libidinoso, em lugar de efetivas operações militares:",
                                                                                                                                                                             "pena":    "reclusão, de dois a quatro anos.",
                                                                                                                                                                             "rubrica":    "Rapto",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    4366,
                                                                                                                                                                                                                            "texto":    "Se da violência resulta lesão grave:",
                                                                                                                                                                                                                            "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    4370,
                                                                                                                                                                                                                            "texto":    "Se resulta morte:",
                                                                                                                                                                                                                            "rubrica":    "Pena - reclusão, de seis a dez anos."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    4376,
                                                                                                                                                                                                                            "texto":    "Se o autor, ao efetuar o rapto, ou em seguida a êste, pratica outro crime contra a raptada, aplicam-se, cumulativamente, a pena correspondente ao rapto e a cominada ao outro crime.",
                                                                                                                                                                                                                            "rubrica":    "Cumulação de pena"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "408º",
                                                                                                                                                                             "rotulo":    "Art. 408º.",
                                                                                                                                                                             "linha":    4380,
                                                                                                                                                                             "caput":    "Praticar qualquer dos crimes de violência carnal definidos nos arts. 232 e 233, em lugar de efetivas operações militares:",
                                                                                                                                                                             "pena":    "reclusão, de quatro a doze anos.",
                                                                                                                                                                             "rubrica":    "Violência carnal",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    4386,
                                                                                                                                                                                                                            "texto":    "Se da violência resulta:",
                                                                                                                                                                                                                            "rubrica":    "Resultado mais grave",
                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "letra":    "a",
                                                                                                                                                                                                                                                                    "rotulo":    "a)",
                                                                                                                                                                                                                                                                    "linha":    4388,
                                                                                                                                                                                                                                                                    "texto":    "lesão grave:",
                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                            "letra":    "b",
                                                                                                                                                                                                                                                                                                            "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                            "linha":    4392,
                                                                                                                                                                                                                                                                                                            "texto":    "morte:",
                                                                                                                                                                                                                                                                                                            "rubrica":    "Pena - reclusão, de oito a vinte anos;"
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "409º",
                                                                                                                                                                             "rotulo":    "Art. 409º.",
                                                                                                                                                                             "linha":    4397,
                                                                                                                                                                             "caput":    "São revogados o Decreto-lei número 6.227, de 24 de janeiro de 1944, e demais disposições contrárias a êste Código, salvo as leis especiais que definem os crimes contra a segurança nacional e a ordem política e social.",
                                                                                                                                                                             "rubrica":    "DISPOSIÇÕES FINAIS"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "410º",
                                                                                                                                                                             "rotulo":    "Art. 410º.",
                                                                                                                                                                             "linha":    4399,
                                                                                                                                                                             "caput":    "Êste Código entrará em vigor no dia 1º de janeiro de 1970."
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DO RAPTO E DA VIOLÊNCIA CARNAL",
                                                                                                                                     "linhaTitulo":    4357
