                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "401º",
                                                                                                                                                                                                                        "rotulo":    "Art. 401º.",
                                                                                                                                                                                                                        "linha":    4296,
                                                                                                                                                                                                                        "caput":    "Praticar, em zona militarmente ocupada, o crime previsto no art. 208:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Genocídio"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "402º",
                                                                                                                                                                                                                        "rotulo":    "Art. 402º.",
                                                                                                                                                                                                                        "linha":    4302,
                                                                                                                                                                                                                        "caput":    "Praticar, com o mesmo fim e na zona referida no artigo anterior, qualquer dos atos previstos nos ns. I, II, III, IV ou V, do parágrafo único, do art. 208:",
                                                                                                                                                                                                                        "pena":    "reclusão, de seis a vinte e quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Casos assimilados"
                                                                                                                                                                                                                }
