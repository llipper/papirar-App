{
        "id":    "Codigo_Penal_Militar",
        "titulo":    "Código Penal Militar",
        "apelido":    "Código Penal Militar.",
        "sigla":    "CPM",
        "fonte":    "Codigo_Penal_Militar.txt",
        "fonteHtmlLocal":    "codigos/Codigo_Penal_Militar/del1001.htm",
        "fonteOficial":    "https://www.planalto.gov.br/ccivil_03/decreto-lei/del1001.htm",
        "ementa":    "Código Penal Militar.",
        "preambulo":    [
                                            {
                                                    "texto":    "DECRETO-LEI Nº 1.001, DE 21 DE OUTUBRO DE 1969.",
                                                    "linha":    1
                                            },
                                            {
                                                    "texto":    "Código Penal Militar",
                                                    "linha":    3
                                            },
                                            {
                                                    "texto":    "Os Ministros da Marinha de Guerra, do Exército e da Aeronáutica Militar, usando das atribuições que lhes confere o art. 3º do Ato Institucional nº 16, de 14 de outubro de 1969, combinado com o § 1° do art. 2°, do Ato Institucional n° 5, de 13 de dezembro de 1968, decretam:",
                                                    "linha":    5
                                            },
                                            {
                                                    "texto":    "CÓDIGO PENAL MILITAR",
                                                    "linha":    7
                                            }
                                    ],
        "divisoes":    [
                                         {
                                                 "tipo":    "parte",
                                                 "rotulo":    "PARTE GERAL",
                                                 "linha":    8,
                                                 "divisoes":    [
                                                                                    {
                                                                                            "tipo":    "livro",
                                                                                            "rotulo":    "LIVRO ÚNICO",
                                                                                            "linha":    9,
                                                                                            "divisoes":    [
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO I",
                                                                                                                                     "linha":    10,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "1º",
                                                                                                                                                                             "rotulo":    "Art. 1º.",
                                                                                                                                                                             "linha":    14,
                                                                                                                                                                             "caput":    "Não há crime sem lei anterior que o defina, nem pena sem prévia cominação legal.",
                                                                                                                                                                             "rubrica":    "Princípio de legalidade"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "2º",
                                                                                                                                                                             "rotulo":    "Art. 2º.",
                                                                                                                                                                             "linha":    20,
                                                                                                                                                                             "caput":    "Ninguémpode ser punido por fato que lei posterior deixa de considerar crime, cessando em virtude dela a execução e os efeitos penais da sentença condenatória.",
                                                                                                                                                                             "rubrica":    "Lei supressiva de incriminação",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    24,
                                                                                                                                                                                                                            "texto":    "A lei posterior que, de qualquer outro modo, favorece o agente, aplica-se retroativamente, ainda quando já tenha sobrevindo sentença condenatória irrecorrível.",
                                                                                                                                                                                                                            "rubrica":    "Retroatividade de lei mais benigna"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    28,
                                                                                                                                                                                                                            "texto":    "Para se reconhecer qual a mais favorável, a lei posterior e a anterior devem ser consideradas separadamente, cada qual no conjunto de suas normas aplicáveis ao fato.",
                                                                                                                                                                                                                            "rubrica":    "Apuração da maior benignidade"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "3º",
                                                                                                                                                                             "rotulo":    "Art. 3º.",
                                                                                                                                                                             "linha":    32,
                                                                                                                                                                             "caput":    "As medidas de segurança regem-se pela lei vigente ao tempo da sentença, prevalecendo, entretanto, se diversa, a lei vigente ao tempo da execução.",
                                                                                                                                                                             "rubrica":    "Medidas de segurança"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "4º",
                                                                                                                                                                             "rotulo":    "Art. 4º.",
                                                                                                                                                                             "linha":    36,
                                                                                                                                                                             "caput":    "A lei excepcional ou temporária, embora decorrido o período de sua duração ou cessadas as circunstâncias que a determinaram, aplica-se ao fato praticado durante sua vigência.",
                                                                                                                                                                             "rubrica":    "Lei excepcional ou temporária"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "5º",
                                                                                                                                                                             "rotulo":    "Art. 5º.",
                                                                                                                                                                             "linha":    40,
                                                                                                                                                                             "caput":    "Considera-se praticado o crime no momento da ação ou omissão, ainda que outro seja o do resultado.",
                                                                                                                                                                             "rubrica":    "Tempo do crime"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "6º",
                                                                                                                                                                             "rotulo":    "Art. 6º.",
                                                                                                                                                                             "linha":    44,
                                                                                                                                                                             "caput":    "Considera-se praticado o fato, no lugar em que se desenvolveu a atividade criminosa, no todo ou em parte, e ainda que sob forma de participação, bem como onde se produziu ou deveria produzir-se o resultado. Nos crimes omissivos, o fato considera-se praticado no lugar em que deveria realizar-se a ação omitida.",
                                                                                                                                                                             "rubrica":    "Lugar do crime"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "7º",
                                                                                                                                                                             "rotulo":    "Art. 7º.",
                                                                                                                                                                             "linha":    48,
                                                                                                                                                                             "caput":    "Aplica-se a lei penal militar, sem prejuízo de convenções, tratados e regras de direito internacional, ao crime cometido, no todo ou em parte no território nacional, ou fora dêle, ainda que, neste caso, o agente esteja sendo processado ou tenha sido julgado pela justiça estrangeira.",
                                                                                                                                                                             "rubrica":    "Territorialidade, Extraterritorialidade",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    52,
                                                                                                                                                                                                                            "texto":    "Para os efeitos da lei penal militar consideram-se como extensão do território nacional as aeronaves e os navios brasileiros, onde quer que se encontrem, sob comando militar ou militarmente utilizados ou ocupados por ordem legal de autoridade competente, ainda que de propriedade privada.",
                                                                                                                                                                                                                            "rubrica":    "Território nacional por extensão"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    56,
                                                                                                                                                                                                                            "texto":    "É também aplicável a lei penal militar ao crime praticado a bordo de aeronaves ou navios estrangeiros, desde que em lugar sujeito à administração militar, e o crime atente contra as instituições militares.",
                                                                                                                                                                                                                            "rubrica":    "Ampliação a aeronaves ou navios estrangeiros"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    60,
                                                                                                                                                                                                                            "texto":    "Para efeito da aplicação dêste Código, considera-se navio tôda embarcação sob comando militar.",
                                                                                                                                                                                                                            "rubrica":    "Conceito de navio"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "8º",
                                                                                                                                                                             "rotulo":    "Art. 8º.",
                                                                                                                                                                             "linha":    64,
                                                                                                                                                                             "caput":    "A pena cumprida no estrangeiro atenua a pena imposta no Brasil pelo mesmo crime, quando diversas, ou nela é computada, quando idênticas.",
                                                                                                                                                                             "rubrica":    "Pena cumprida no estrangeiro"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "9º",
                                                                                                                                                                             "rotulo":    "Art. 9º.",
                                                                                                                                                                             "linha":    68,
                                                                                                                                                                             "caput":    "Consideram-se crimes militares, em tempo de paz:",
                                                                                                                                                                             "rubrica":    "Crimes militares em tempo de paz",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    70,
                                                                                                                                                                                                                     "texto":    "os crimes de que trata êste Código, quando definidos de modo diverso na lei penal comum, ou nela não previstos, qualquer que seja o agente, salvo disposição especial;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    73,
                                                                                                                                                                                                                     "texto":    "os crimes previstos neste Código e os previstos na legislação penal, quando praticados:",
                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                             "letra":    "a",
                                                                                                                                                                                                                                                             "rotulo":    "a)",
                                                                                                                                                                                                                                                             "linha":    75,
                                                                                                                                                                                                                                                             "texto":    "por militar da ativa contra militar na mesma situação;",
                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                     "letra":    "b",
                                                                                                                                                                                                                                                                                                     "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                     "linha":    77,
                                                                                                                                                                                                                                                                                                     "texto":    "por militar da ativa, em lugar sujeito à administração militar, contra militar da reserva ou reformado ou contra civil;",
                                                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                                                             "letra":    "c",
                                                                                                                                                                                                                                                                                                                                             "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                             "linha":    81,
                                                                                                                                                                                                                                                                                                                                             "texto":    "por militar em serviço ou atuando em razão da função, em comissão de natureza militar, ou em formatura, ainda que fora do lugar sujeito à administração militar contra militar da reserva, ou reformado, ou civil;",
                                                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                                                     "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                     "linha":    83,
                                                                                                                                                                                                                                                                                                                                                                                     "texto":    "por militar, durante o período de manobras ou exercício, contra militar da reserva ou reformado ou contra civil;",
                                                                                                                                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                                                                                                                                             "letra":    "e",
                                                                                                                                                                                                                                                                                                                                                                                                                             "rotulo":    "e)",
                                                                                                                                                                                                                                                                                                                                                                                                                             "linha":    85,
                                                                                                                                                                                                                                                                                                                                                                                                                             "texto":    "por militar da ativa contra o patrimônio sob a administração militar ou contra a ordem administrativa militar;",
                                                                                                                                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "letra":    "f",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "f)",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "linha":    89,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "texto":    "revogada. (Redação dada pela Lei nº 9.299, de 8.8.1996)"
                                                                                                                                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    91,
                                                                                                                                                                                                                     "texto":    "os crimes praticados por militar da reserva, ou reformado, ou por civil, contra as instituições militares, considerando-se como tais não só os compreendidos no inciso I, como os do inciso II, nos seguintes casos:",
                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                             "letra":    "a",
                                                                                                                                                                                                                                                             "rotulo":    "a)",
                                                                                                                                                                                                                                                             "linha":    93,
                                                                                                                                                                                                                                                             "texto":    "contra o patrimônio sob a administração militar, ou contra a ordem administrativa militar;",
                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                     "letra":    "b",
                                                                                                                                                                                                                                                                                                     "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                     "linha":    95,
                                                                                                                                                                                                                                                                                                     "texto":    "em lugar sujeito à administração militar, contra militar da ativa ou contra servidor público das instituições militares ou da Justiça Militar, no exercício de função inerente ao seu cargo;",
                                                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                                                             "letra":    "c",
                                                                                                                                                                                                                                                                                                                                             "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                             "linha":    97,
                                                                                                                                                                                                                                                                                                                                             "texto":    "contra militar em formatura, ou durante o período de prontidão, vigilância, observação, exploração, exercício, acampamento, acantonamento ou manobras;",
                                                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                                                     "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                     "linha":    99,
                                                                                                                                                                                                                                                                                                                                                                                     "texto":    "ainda que fora do lugar sujeito à administração militar, contra militar em função de natureza militar, ou no desempenho de serviço de vigilância, garantia e preservação da ordem pública, administrativa ou judiciária, quando legalmente requisitado para aquêle fim, ou em obediência a determinação legal superior."
                                                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    102,
                                                                                                                                                                                                                            "texto":    "Os crimes de que trata este artigo, quando dolosos contra a vida e cometidos por militares contra civil, serão da competência do Tribunal do Júri."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    104,
                                                                                                                                                                                                                            "texto":    "Os crimes militares de que trata este artigo, incluídos os previstos na legislação penal, nos termos do inciso II do caput deste artigo, quando dolosos contra a vida e cometidos por militares das Forças Armadas contra civil, serão da competência da Justiça Militar da União, se praticados no contexto:",
                                                                                                                                                                                                                            "incisos":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "I",
                                                                                                                                                                                                                                                                    "rotulo":    "I",
                                                                                                                                                                                                                                                                    "linha":    106,
                                                                                                                                                                                                                                                                    "texto":    "do cumprimento de atribuições que lhes forem estabelecidas pelo Presidente da República ou pelo Ministro de Estado da Defesa;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "II",
                                                                                                                                                                                                                                                                    "rotulo":    "II",
                                                                                                                                                                                                                                                                    "linha":    108,
                                                                                                                                                                                                                                                                    "texto":    "de ação que envolva a segurança de instituição militar ou de missão militar, mesmo que não beligerante; ou"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "III",
                                                                                                                                                                                                                                                                    "rotulo":    "III",
                                                                                                                                                                                                                                                                    "linha":    110,
                                                                                                                                                                                                                                                                    "texto":    "de atividade de natureza militar, de operação de paz, de garantia da lei e da ordem ou de atribuição subsidiária, realizadas em conformidade com o disposto no art. 142 da Constituição Federal e na forma dos seguintes diplomas legais:",
                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                            "letra":    "a",
                                                                                                                                                                                                                                                                                                            "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                            "linha":    112,
                                                                                                                                                                                                                                                                                                            "texto":    "Lei no 7.565, de 19 de dezembro de 1986 - Código Brasileiro de Aeronáutica;",
                                                                                                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                    "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                    "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                    "linha":    114,
                                                                                                                                                                                                                                                                                                                                                    "texto":    "Lei Complementar no 97, de 9 de junho de 1999;",
                                                                                                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                            "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                                                            "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                                                            "linha":    116,
                                                                                                                                                                                                                                                                                                                                                                                            "texto":    "Decreto-Lei no 1.002, de 21 de outubro de 1969 - Código de Processo Penal Militar; e",
                                                                                                                                                                                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                                                                                                    "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                                                                    "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                                                                    "linha":    118,
                                                                                                                                                                                                                                                                                                                                                                                                                                    "texto":    "Lei no 4.737, de 15 de julho de 1965 - Código Eleitoral."
                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "10º",
                                                                                                                                                                             "rotulo":    "Art. 10º.",
                                                                                                                                                                             "linha":    122,
                                                                                                                                                                             "caput":    "Consideram-se crimes militares, em tempo de guerra:",
                                                                                                                                                                             "rubrica":    "Crimes militares em tempo de guerra",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    124,
                                                                                                                                                                                                                     "texto":    "os especialmente previstos neste Código para o tempo de guerra;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    126,
                                                                                                                                                                                                                     "texto":    "os crimes militares previstos para o tempo de paz;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    128,
                                                                                                                                                                                                                     "texto":    "os crimes previstos neste Código, embora também o sejam com igual definição na lei penal comum ou especial, quando praticados, qualquer que seja o agente:",
                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                             "letra":    "a",
                                                                                                                                                                                                                                                             "rotulo":    "a)",
                                                                                                                                                                                                                                                             "linha":    130,
                                                                                                                                                                                                                                                             "texto":    "em território nacional, ou estrangeiro, militarmente ocupado;",
                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                     "letra":    "b",
                                                                                                                                                                                                                                                                                                     "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                     "linha":    132,
                                                                                                                                                                                                                                                                                                     "texto":    "em qualquer lugar, se comprometem ou podem comprometer a preparação, a eficiência ou as operações militares ou, de qualquer outra forma, atentam contra a segurança externa do País ou podem expô-la a perigo;"
                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "IV",
                                                                                                                                                                                                                     "rotulo":    "IV",
                                                                                                                                                                                                                     "linha":    134,
                                                                                                                                                                                                                     "texto":    "os crimes definidos na lei penal comum ou especial, embora não previstos neste Código, quando praticados em zona de efetivas operações militares ou em território estrangeiro, militarmente ocupado."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "11º",
                                                                                                                                                                             "rotulo":    "Art. 11º.",
                                                                                                                                                                             "linha":    139,
                                                                                                                                                                             "caput":    "Os militares estrangeiros, quando em comissão ou em estágio em instituições militares, ficam sujeitos à lei penal militar brasileira, ressalvado o disposto em tratados ou em convenções internacionais.",
                                                                                                                                                                             "rubrica":    "Militares estrangeiros"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "12º",
                                                                                                                                                                             "rotulo":    "Art. 12º.",
                                                                                                                                                                             "linha":    143,
                                                                                                                                                                             "caput":    "O militar da reserva ou reformado, quando empregado na administração militar, equipara-se ao militar da ativa, para o efeito da aplicação da lei penal militar.",
                                                                                                                                                                             "rubrica":    "Equiparação a militar da ativa"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "13º",
                                                                                                                                                                             "rotulo":    "Art. 13º.",
                                                                                                                                                                             "linha":    147,
                                                                                                                                                                             "caput":    "O militar da reserva, ou reformado, conserva as responsabilidades e prerrogativas do pôsto ou graduação, para o efeito da aplicação da lei penal militar, quando pratica ou contra êle é praticado crime militar.",
                                                                                                                                                                             "rubrica":    "Militar da reserva ou reformado"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "14º",
                                                                                                                                                                             "rotulo":    "Art. 14º.",
                                                                                                                                                                             "linha":    153,
                                                                                                                                                                             "caput":    "O defeito do ato de incorporação ou de matrícula não exclui a aplicação da lei penal militar, salvo se alegado ou conhecido antes da prática do crime.",
                                                                                                                                                                             "rubrica":    "Defeito de incorporação ou de matrícula"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "15º",
                                                                                                                                                                             "rotulo":    "Art. 15º.",
                                                                                                                                                                             "linha":    157,
                                                                                                                                                                             "caput":    "O tempo de guerra, para os efeitos da aplicação da lei penal militar, começa com a declaração ou o reconhecimento do estado de guerra, ou com o decreto de mobilização se nêle estiver compreendido aquêle reconhecimento; e termina quando ordenada a cessação das hostilidades.",
                                                                                                                                                                             "rubrica":    "Tempo de guerra"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "16º",
                                                                                                                                                                             "rotulo":    "Art. 16º.",
                                                                                                                                                                             "linha":    161,
                                                                                                                                                                             "caput":    "No cômputo dos prazos inclui-se o dia do comêço. Contam-se os dias, os meses e os anos pelo calendário comum.",
                                                                                                                                                                             "rubrica":    "Contagem de prazo"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "17º",
                                                                                                                                                                             "rotulo":    "Art. 17º.",
                                                                                                                                                                             "linha":    165,
                                                                                                                                                                             "caput":    "As regras gerais dêste Código aplicam-se aos fatos incriminados por lei penal militar especial, se esta não dispõe de modo diverso. Para os efeitos penais, salário mínimo é o maior mensal vigente no país, ao tempo da sentença.",
                                                                                                                                                                             "rubrica":    "Legislação especial. Salário-mínimo"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "18º",
                                                                                                                                                                             "rotulo":    "Art. 18º.",
                                                                                                                                                                             "linha":    169,
                                                                                                                                                                             "caput":    "Ficam sujeitos às disposições dêste Código os crimes praticados em prejuízo de país em guerra contra país inimigo do Brasil:",
                                                                                                                                                                             "rubrica":    "Crimes praticados em prejuízo de país aliado",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    171,
                                                                                                                                                                                                                     "texto":    "se o crime é praticado por brasileiro;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    173,
                                                                                                                                                                                                                     "texto":    "se o crime é praticado no território nacional, ou em território estrangeiro, militarmente ocupado por fôrça brasileira, qualquer que seja o agente."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "19º",
                                                                                                                                                                             "rotulo":    "Art. 19º.",
                                                                                                                                                                             "linha":    177,
                                                                                                                                                                             "caput":    "Êste Código não compreende as infrações dos regulamentos disciplinares.",
                                                                                                                                                                             "rubrica":    "Infrações disciplinares"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "20º",
                                                                                                                                                                             "rotulo":    "Art. 20º.",
                                                                                                                                                                             "linha":    181,
                                                                                                                                                                             "caput":    "Aos crimes praticados em tempo de guerra, salvo disposição especial, aplicam-se as penas cominadas para o tempo de paz, com o aumento de um têrço.",
                                                                                                                                                                             "rubrica":    "Crimes praticados em tempo de guerra"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "22º",
                                                                                                                                                                             "rotulo":    "Art. 22º.",
                                                                                                                                                                             "linha":    187,
                                                                                                                                                                             "caput":    "É militar, para o efeito da aplicação deste Código, qualquer pessoa que, em tempo de paz ou de guerra, seja incorporada a instituições militares ou nelas matriculada, para servir em posto ou em graduação ou em regime de sujeição à disciplina militar.",
                                                                                                                                                                             "rubrica":    "Pessoa considerada militar"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "23º",
                                                                                                                                                                             "rotulo":    "Art. 23º.",
                                                                                                                                                                             "linha":    191,
                                                                                                                                                                             "caput":    "Equipara-se ao comandante, para o efeito da aplicação da lei penal militar, tôda autoridade com função de direção.",
                                                                                                                                                                             "rubrica":    "Equiparação a comandante"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "24º",
                                                                                                                                                                             "rotulo":    "Art. 24º.",
                                                                                                                                                                             "linha":    197,
                                                                                                                                                                             "caput":    "Considera-se superior para fins de aplicação da lei penal militar:",
                                                                                                                                                                             "rubrica":    "Conceito de superior",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    199,
                                                                                                                                                                                                                     "texto":    "militar que ocupa nível hierárquico, posto ou graduação superiores, conforme a antiguidade, nos termos da Lei nº 6.880, de 9 de dezembro de 1980 (Estatuto dos Militares), e de leis das unidades da Federação que regulam o regime jurídico de seus militares;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    201,
                                                                                                                                                                                                                     "texto":    "militar que, em virtude da função, exerce autoridade sobre outro de igual posto ou graduação."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    203,
                                                                                                                                                                                                                            "texto":    "O militar sobre o qual se exerce autoridade nas condições descritas nos incisos I e II do caput deste artigo é considerado inferior hierárquico para fins de aplicação da lei penal militar."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "25º",
                                                                                                                                                                             "rotulo":    "Art. 25º.",
                                                                                                                                                                             "linha":    207,
                                                                                                                                                                             "caput":    "Diz-se crime praticado em presença do inimigo, quando o fato ocorre em zona de efetivas operações militares, ou na iminência ou em situação de hostilidade.",
                                                                                                                                                                             "rubrica":    "Crime praticado em presença do inimigo"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "26º",
                                                                                                                                                                             "rotulo":    "Art. 26º.",
                                                                                                                                                                             "linha":    211,
                                                                                                                                                                             "caput":    "Quando a lei penal militar se refere a \"brasileiro\" ou \"nacional\", compreende as pessoas enumeradas como brasileiros na Constituição do Brasil.",
                                                                                                                                                                             "rubrica":    "Referência a \"brasileiro\" ou \"nacional\"",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    215,
                                                                                                                                                                                                                            "texto":    "Para os efeitos da lei penal militar, são considerados estrangeiros os apátridas e os brasileiros que perderam a nacionalidade.",
                                                                                                                                                                                                                            "rubrica":    "Estrangeiros"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "27º",
                                                                                                                                                                             "rotulo":    "Art. 27º.",
                                                                                                                                                                             "linha":    221,
                                                                                                                                                                             "caput":    "Para o efeito da aplicação deste Código, consideram-se servidores da Justiça Militar os juízes, os servidores públicos e os auxiliares da Justiça Militar.",
                                                                                                                                                                             "rubrica":    "Servidores da Justiça Militar"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "28º",
                                                                                                                                                                             "rotulo":    "Art. 28º.",
                                                                                                                                                                             "linha":    225,
                                                                                                                                                                             "caput":    "Os crimes contra a segurança externa do país ou contra as instituições militares, definidos neste Código, excluem os da mesma natureza definidos em outras leis.",
                                                                                                                                                                             "rubrica":    "Casos de prevalência do Código Penal Militar"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DA APLICAÇÃO DA LEI PENAL MILITAR",
                                                                                                                                     "linhaTitulo":    11
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO II",
                                                                                                                                     "linha":    227,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "29º",
                                                                                                                                                                             "rotulo":    "Art. 29º.",
                                                                                                                                                                             "linha":    231,
                                                                                                                                                                             "caput":    "O resultado de que depende a existência do crime sòmente é imputável a quem lhe deu causa. Considera-se causa a ação ou omissão sem a qual o resultado não teria ocorrido.",
                                                                                                                                                                             "rubrica":    "Relação de causalidade",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    233,
                                                                                                                                                                                                                            "texto":    "A superveniência de causa relativamente independente exclui a imputação quando, por si só, produziu o resultado. Os fatos anteriores, imputam-se, entretanto, a quem os praticou."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    235,
                                                                                                                                                                                                                            "texto":    "A omissão é relevante como causa quando o omitente devia e podia agir para evitar o resultado. O dever de agir incumbe a quem tenha por lei obrigação de cuidado, proteção ou vigilância; a quem, de outra forma, assumiu a responsabilidade de impedir o resultado; e a quem, com seu comportamento anterior, criou o risco de sua superveniência."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "30º",
                                                                                                                                                                             "rotulo":    "Art. 30º.",
                                                                                                                                                                             "linha":    237,
                                                                                                                                                                             "caput":    "Diz-se o crime:",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    241,
                                                                                                                                                                                                                     "texto":    "consumado, quando nêle se reúnem todos os elementos de sua definição legal;",
                                                                                                                                                                                                                     "rubrica":    "Crime consumado"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    245,
                                                                                                                                                                                                                     "texto":    "tentado, quando, iniciada a execução, não se consuma por circunstâncias alheias à vontade do agente.",
                                                                                                                                                                                                                     "rubrica":    "Tentativa"
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    249,
                                                                                                                                                                                                                            "texto":    "Pune-se a tentativa com a pena correspondente ao crime, diminuída de um a dois terços, podendo o juiz, no caso de excepcional gravidade, aplicar a pena do crime consumado.",
                                                                                                                                                                                                                            "rubrica":    "Pena de tentativa"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "31º",
                                                                                                                                                                             "rotulo":    "Art. 31º.",
                                                                                                                                                                             "linha":    253,
                                                                                                                                                                             "caput":    "O agente que, voluntàriamente, desiste de prosseguir na execução ou impede que o resultado se produza, só responde pelos atos já praticados.",
                                                                                                                                                                             "rubrica":    "Desistência voluntária e arrependimento eficaz"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "32º",
                                                                                                                                                                             "rotulo":    "Art. 32º.",
                                                                                                                                                                             "linha":    257,
                                                                                                                                                                             "caput":    "Quando, por ineficácia absoluta do meio empregado ou por absoluta impropriedade do objeto, é impossível consumar-se o crime, nenhuma pena é aplicável.",
                                                                                                                                                                             "rubrica":    "Crime impossível"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "33º",
                                                                                                                                                                             "rotulo":    "Art. 33º.",
                                                                                                                                                                             "linha":    259,
                                                                                                                                                                             "caput":    "Diz-se o crime:",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    263,
                                                                                                                                                                                                                     "texto":    "doloso, quando o agente quis o resultado ou assumiu o risco de produzi-lo;",
                                                                                                                                                                                                                     "rubrica":    "Culpabilidade"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    265,
                                                                                                                                                                                                                     "texto":    "culposo, quando o agente, deixando de empregar a cautela, atenção, ou diligência ordinária, ou especial, a que estava obrigado em face das circunstâncias, não prevê o resultado que podia prever ou, prevendo-o, supõe levianamente que não se realizaria ou que poderia evitá-lo."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    269,
                                                                                                                                                                                                                            "texto":    "Salvo os casos expressos em lei, ninguém pode ser punido por fato previsto como crime, senão quando o pratica dolosamente.",
                                                                                                                                                                                                                            "rubrica":    "Excepcionalidade do crime culposo"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "34º",
                                                                                                                                                                             "rotulo":    "Art. 34º.",
                                                                                                                                                                             "linha":    273,
                                                                                                                                                                             "caput":    "Pelos resultados que agravam especialmente as penas só responde o agente quando os houver causado, pelo menos, culposamente.",
                                                                                                                                                                             "rubrica":    "Nenhuma pena sem culpabilidade"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "35º",
                                                                                                                                                                             "rotulo":    "Art. 35º.",
                                                                                                                                                                             "linha":    277,
                                                                                                                                                                             "caput":    "A pena pode ser atenuada ou substituída por outra menos grave quando o agente, salvo em se tratando de crime que atente contra o dever militar, supõe lícito o fato, por ignorância ou êrro de interpretação da lei, se escusáveis.",
                                                                                                                                                                             "rubrica":    "Êrro de direito"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "36º",
                                                                                                                                                                             "rotulo":    "Art. 36º.",
                                                                                                                                                                             "linha":    281,
                                                                                                                                                                             "caput":    "É isento de pena quem, ao praticar o crime, supõe, por êrro plenamente escusável, a inexistência de circunstância de fato que o constitui ou a existência de situação de fato que tornaria a ação legítima.",
                                                                                                                                                                             "rubrica":    "Êrro de fato",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    285,
                                                                                                                                                                                                                            "texto":    "Se o êrro deriva de culpa, a êste título responde o agente, se o fato é punível como crime culposo.",
                                                                                                                                                                                                                            "rubrica":    "Êrro culposo"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    289,
                                                                                                                                                                                                                            "texto":    "Se o êrro é provocado por terceiro, responderá êste pelo crime, a título de dolo ou culpa, conforme o caso.",
                                                                                                                                                                                                                            "rubrica":    "Êrro provocado"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "37º",
                                                                                                                                                                             "rotulo":    "Art. 37º.",
                                                                                                                                                                             "linha":    293,
                                                                                                                                                                             "caput":    "Quando o agente, por êrro de percepção ou no uso dos meios de execução, ou outro acidente, atinge uma pessoa em vez de outra, responde como se tivesse praticado o crime contra aquela que realmente pretendia atingir. Devem ter-se em conta não as condições e qualidades da vítima, mas as da outra pessoa, para configuração, qualificação ou exclusão do crime, e agravação ou atenuação da pena.",
                                                                                                                                                                             "rubrica":    "Êrro sôbre a pessoa",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    297,
                                                                                                                                                                                                                            "texto":    "Se, por êrro ou outro acidente na execução, é atingido bem jurídico diverso do visado pelo agente, responde êste por culpa, se o fato é previsto como crime culposo.",
                                                                                                                                                                                                                            "rubrica":    "Êrro quanto ao bem jurídico"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    301,
                                                                                                                                                                                                                            "texto":    "Se, no caso do artigo, é também atingida a pessoa visada, ou, no caso do parágrafo anterior, ocorre ainda o resultado pretendido, aplica-se a regra do art. 79.",
                                                                                                                                                                                                                            "rubrica":    "Duplicidade do resultado"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "38º",
                                                                                                                                                                             "rotulo":    "Art. 38º.",
                                                                                                                                                                             "linha":    303,
                                                                                                                                                                             "caput":    "Não é culpado quem comete o crime:",
                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "letra":    "a",
                                                                                                                                                                                                                     "rotulo":    "a)",
                                                                                                                                                                                                                     "linha":    307,
                                                                                                                                                                                                                     "texto":    "sob coação irresistível ou que lhe suprima a faculdade de agir segundo a própria vontade;",
                                                                                                                                                                                                                     "rubrica":    "Coação irresistível",
                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                             "letra":    "b",
                                                                                                                                                                                                                                                             "rotulo":    "b)",
                                                                                                                                                                                                                                                             "linha":    311,
                                                                                                                                                                                                                                                             "texto":    "em estrita obediência a ordem direta de superior hierárquico, em matéria de serviços.",
                                                                                                                                                                                                                                                             "rubrica":    "Obediência hierárquica"
                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    313,
                                                                                                                                                                                                                            "texto":    "Responde pelo crime o autor da coação ou da ordem."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    316,
                                                                                                                                                                                                                            "texto":    "Se a ordem do superior tem por objeto a prática de ato manifestamente criminoso, ou há excesso nos atos ou na forma da execução, é punível também o inferior hierárquico."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "39º",
                                                                                                                                                                             "rotulo":    "Art. 39º.",
                                                                                                                                                                             "linha":    320,
                                                                                                                                                                             "caput":    "Não é igualmente culpado quem, para proteger direito próprio ou de pessoa a quem está ligado por estreitas relações de parentesco ou afeição, contra perigo certo e atual, que não provocou, nem podia de outro modo evitar, sacrifica direito alheio, ainda quando superior ao direito protegido, desde que não lhe era razoàvelmente exigível conduta diversa.",
                                                                                                                                                                             "rubrica":    "Estado de necessidade, com excludente de culpabilidade"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "40º",
                                                                                                                                                                             "rotulo":    "Art. 40º.",
                                                                                                                                                                             "linha":    324,
                                                                                                                                                                             "caput":    "Nos crimes em que há violação do dever militar, o agente não pode invocar coação irresistível senão quando física ou material.",
                                                                                                                                                                             "rubrica":    "Coação física ou material"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "41º",
                                                                                                                                                                             "rotulo":    "Art. 41º.",
                                                                                                                                                                             "linha":    328,
                                                                                                                                                                             "caput":    "Nos casos do art. 38, letras a e b , se era possível resistir à coação, ou se a ordem não era manifestamente ilegal; ou, no caso do art. 39, se era razoàvelmente exigível o sacrifício do direito ameaçado, o juiz, tendo em vista as condições pessoais do réu, pode atenuar a pena.",
                                                                                                                                                                             "rubrica":    "Atenuação de pena"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "42º",
                                                                                                                                                                             "rotulo":    "Art. 42º.",
                                                                                                                                                                             "linha":    332,
                                                                                                                                                                             "caput":    "Não há crime quando o agente pratica o fato:",
                                                                                                                                                                             "rubrica":    "Exclusão de crime",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    334,
                                                                                                                                                                                                                     "texto":    "em estado de necessidade;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    336,
                                                                                                                                                                                                                     "texto":    "em legítima defesa;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    338,
                                                                                                                                                                                                                     "texto":    "em estrito cumprimento do dever legal;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "IV",
                                                                                                                                                                                                                     "rotulo":    "IV",
                                                                                                                                                                                                                     "linha":    340,
                                                                                                                                                                                                                     "texto":    "em exercício regular de direito."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    342,
                                                                                                                                                                                                                            "texto":    "Não há igualmente crime quando o comandante de navio, aeronave ou praça de guerra, na iminência de perigo ou grave calamidade, compele os subalternos, por meios violentos, a executar serviços e manobras urgentes, para salvar a unidade ou vidas, ou evitar o desânimo, o terror, a desordem, a rendição, a revolta ou o saque."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "43º",
                                                                                                                                                                             "rotulo":    "Art. 43º.",
                                                                                                                                                                             "linha":    346,
                                                                                                                                                                             "caput":    "Considera-se em estado de necessidade quem pratica o fato para preservar direito seu ou alheio, de perigo certo e atual, que não provocou, nem podia de outro modo evitar, desde que o mal causado, por sua natureza e importância, é consideràvelmente inferior ao mal evitado, e o agente não era legalmente obrigado a arrostar o perigo.",
                                                                                                                                                                             "rubrica":    "Estado de necessidade, como excludente do crime"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "44º",
                                                                                                                                                                             "rotulo":    "Art. 44º.",
                                                                                                                                                                             "linha":    350,
                                                                                                                                                                             "caput":    "Entende-se em legítima defesa quem, usando moderadamente dos meios necessários, repele injusta agressão, atual ou iminente, a direito seu ou de outrem.",
                                                                                                                                                                             "rubrica":    "Legítima defesa"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "45º",
                                                                                                                                                                             "rotulo":    "Art. 45º.",
                                                                                                                                                                             "linha":    354,
                                                                                                                                                                             "caput":    "O agente que, em qualquer dos casos de exclusão de crime, excede culposamente os limites da necessidade, responde pelo fato, se êste é punível, a título de culpa.",
                                                                                                                                                                             "rubrica":    "Excesso culposo",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    358,
                                                                                                                                                                                                                            "texto":    "Não é punível o excesso quando resulta de escusável surprêsa ou perturbação de ânimo, em face da situação.",
                                                                                                                                                                                                                            "rubrica":    "Excesso escusável"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "46º",
                                                                                                                                                                             "rotulo":    "Art. 46º.",
                                                                                                                                                                             "linha":    362,
                                                                                                                                                                             "caput":    "O juiz pode atenuar a pena ainda quando punível o fato por excesso doloso.",
                                                                                                                                                                             "rubrica":    "Excesso doloso"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "47º",
                                                                                                                                                                             "rotulo":    "Art. 47º.",
                                                                                                                                                                             "linha":    366,
                                                                                                                                                                             "caput":    "Deixam de ser elementos constitutivos do crime:",
                                                                                                                                                                             "rubrica":    "Elementos não constitutivos do crime",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    369,
                                                                                                                                                                                                                     "texto":    "a qualidade de superior ou a de inferior hierárquico, quando não conhecida do agente;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    372,
                                                                                                                                                                                                                     "texto":    "a qualidade de superior ou a de inferior hierárquico, a de oficial de dia, de serviço ou de quarto, ou a de sentinela, vigia ou plantão, quando a ação é praticada em repulsa a agressão."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ]
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DO CRIME",
                                                                                                                                     "linhaTitulo":    228
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO III",
                                                                                                                                     "linha":    374,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "48º",
                                                                                                                                                                             "rotulo":    "Art. 48º.",
                                                                                                                                                                             "linha":    378,
                                                                                                                                                                             "caput":    "Não é imputável quem, no momento da ação ou da omissão, não possui a capacidade de entender o caráter ilícito do fato ou de determinar-se de acôrdo com êsse entendimento, em virtude de doença mental, de desenvolvimento mental incompleto ou retardado.",
                                                                                                                                                                             "rubrica":    "Inimputáveis",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    384,
                                                                                                                                                                                                                            "texto":    "Se a doença ou a deficiência mental não suprime, mas diminui consideravelmente a capacidade de entendimento da ilicitude do fato ou a de autodeterminação, não fica excluída a imputabilidade, mas a pena pode ser reduzida de 1/3 (um terço) a 2/3 (dois terços), sem prejuízo do disposto no art. 113 deste Código.",
                                                                                                                                                                                                                            "rubrica":    "Redução Facultativa da Pena"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "49º",
                                                                                                                                                                             "rotulo":    "Art. 49º.",
                                                                                                                                                                             "linha":    388,
                                                                                                                                                                             "caput":    "Não é igualmente imputável o agente que, por embriaguez completa proveniente de caso fortuito ou fôrça maior, era, ao tempo da ação ou da omissão, inteiramente incapaz de entender o caráter criminoso do fato ou de determinar-se de acôrdo com êsse entendimento.",
                                                                                                                                                                             "rubrica":    "Embriaguez",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    390,
                                                                                                                                                                                                                            "texto":    "A pena pode ser reduzida de um a dois terços, se o agente por embriaguez proveniente de caso fortuito ou fôrça maior, não possuía, ao tempo da ação ou da omissão, a plena capacidade de entender o caráter criminoso do fato ou de determinar-se de acôrdo com êsse entendimento."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "50º",
                                                                                                                                                                             "rotulo":    "Art. 50º.",
                                                                                                                                                                             "linha":    396,
                                                                                                                                                                             "caput":    "O menorde 18 (dezoito) anos é penalmente inimputável, ficando sujeito às normas estabelecidas na legislação especial.",
                                                                                                                                                                             "rubrica":    "Menores"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DA IMPUTABILIDADE PENAL",
                                                                                                                                     "linhaTitulo":    375
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO IV",
                                                                                                                                     "linha":    398,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "53º",
                                                                                                                                                                             "rotulo":    "Art. 53º.",
                                                                                                                                                                             "linha":    403,
                                                                                                                                                                             "caput":    "Quem, de qualquer modo, concorre para o crime incide nas penas a êste cominadas.",
                                                                                                                                                                             "rubrica":    "Coautoria",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    407,
                                                                                                                                                                                                                            "texto":    "A punibilidade de qualquer dos concorrentes é independente da dos outros, determinando-se segundo a sua própria culpabilidade. Não se comunicam, outrossim, as condições ou circunstâncias de caráter pessoal, salvo quando elementares do crime.",
                                                                                                                                                                                                                            "rubrica":    "Condições ou circunstâncias pessoais"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    411,
                                                                                                                                                                                                                            "texto":    "A pena é agravada em relação ao agente que:",
                                                                                                                                                                                                                            "rubrica":    "Agravação de pena",
                                                                                                                                                                                                                            "incisos":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "I",
                                                                                                                                                                                                                                                                    "rotulo":    "I",
                                                                                                                                                                                                                                                                    "linha":    413,
                                                                                                                                                                                                                                                                    "texto":    "promove ou organiza a cooperação no crime ou dirige a atividade dos demais agentes;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "II",
                                                                                                                                                                                                                                                                    "rotulo":    "II",
                                                                                                                                                                                                                                                                    "linha":    415,
                                                                                                                                                                                                                                                                    "texto":    "coage outrem à execução material do crime;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "III",
                                                                                                                                                                                                                                                                    "rotulo":    "III",
                                                                                                                                                                                                                                                                    "linha":    417,
                                                                                                                                                                                                                                                                    "texto":    "instiga ou determina a cometer o crime alguém sujeito à sua autoridade, ou não punível em virtude de condição ou qualidade pessoal;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "IV",
                                                                                                                                                                                                                                                                    "rotulo":    "IV",
                                                                                                                                                                                                                                                                    "linha":    419,
                                                                                                                                                                                                                                                                    "texto":    "executa o crime, ou nêle participa, mediante paga ou promessa de recompensa."
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    423,
                                                                                                                                                                                                                            "texto":    "A pena é atenuada com relação ao agente, cuja participação no crime é de somenos importância.",
                                                                                                                                                                                                                            "rubrica":    "Atenuação de pena"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "4",
                                                                                                                                                                                                                            "rotulo":    "§ 4",
                                                                                                                                                                                                                            "linha":    427,
                                                                                                                                                                                                                            "texto":    "Na prática de crime de autoria coletiva necessária, reputam-se cabeças os que dirigem, provocam, instigam ou excitam a ação.",
                                                                                                                                                                                                                            "rubrica":    "Cabeças"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "5",
                                                                                                                                                                                                                            "rotulo":    "§ 5",
                                                                                                                                                                                                                            "linha":    430,
                                                                                                                                                                                                                            "texto":    "Quando o crime é cometido por inferiores hierárquicos e um ou mais oficiais, são estes considerados cabeças, assim como os inferiores hierárquicos que exercem função de oficial."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "54º",
                                                                                                                                                                             "rotulo":    "Art. 54º.",
                                                                                                                                                                             "linha":    434,
                                                                                                                                                                             "caput":    "O ajuste, a determinação ou instigação e o auxílio, salvo disposição em contrário, não são puníveis se o crime não chega, pelo menos, a ser tentado.",
                                                                                                                                                                             "rubrica":    "Casos de impunibilidade"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DO CONCURSO DE AGENTES",
                                                                                                                                     "linhaTitulo":    399
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO V",
                                                                                                                                     "linha":    436,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    438,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "55º",
                                                                                                                                                                                                                        "rotulo":    "Art. 55º.",
                                                                                                                                                                                                                        "linha":    442,
                                                                                                                                                                                                                        "caput":    "As penas principais são:",
                                                                                                                                                                                                                        "rubrica":    "Penas principais",
                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "letra":    "a",
                                                                                                                                                                                                                                                                "rotulo":    "a)",
                                                                                                                                                                                                                                                                "linha":    444,
                                                                                                                                                                                                                                                                "texto":    "morte;",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "b",
                                                                                                                                                                                                                                                                                                        "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                        "linha":    446,
                                                                                                                                                                                                                                                                                                        "texto":    "reclusão;",
                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                "linha":    448,
                                                                                                                                                                                                                                                                                                                                                "texto":    "detenção;",
                                                                                                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                        "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                        "linha":    450,
                                                                                                                                                                                                                                                                                                                                                                                        "texto":    "prisão;",
                                                                                                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                "letra":    "e",
                                                                                                                                                                                                                                                                                                                                                                                                                                "rotulo":    "e)",
                                                                                                                                                                                                                                                                                                                                                                                                                                "linha":    452,
                                                                                                                                                                                                                                                                                                                                                                                                                                "texto":    "impedimento;"
                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "56º",
                                                                                                                                                                                                                        "rotulo":    "Art. 56º.",
                                                                                                                                                                                                                        "linha":    460,
                                                                                                                                                                                                                        "caput":    "A pena de morte é executada por fuzilamento.",
                                                                                                                                                                                                                        "rubrica":    "Pena de morte"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "57º",
                                                                                                                                                                                                                        "rotulo":    "Art. 57º.",
                                                                                                                                                                                                                        "linha":    464,
                                                                                                                                                                                                                        "caput":    "A sentença definitiva de condenação à morte é comunicada, logo que passe em julgado, ao Presidente da República, e não pode ser executada senão depois de sete dias após a comunicação.",
                                                                                                                                                                                                                        "rubrica":    "Comunicação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    466,
                                                                                                                                                                                                                                                                     "texto":    "Se a pena é imposta em zona de operações de guerra, pode ser imediatamente executada, quando o exigir o interêsse da ordem e da disciplina militares."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "58º",
                                                                                                                                                                                                                        "rotulo":    "Art. 58º.",
                                                                                                                                                                                                                        "linha":    470,
                                                                                                                                                                                                                        "caput":    "O mínimo da pena de reclusão é de um ano, e o máximo de trinta anos; o mínimo da pena de detenção é de trinta dias, e o máximo de dez anos.",
                                                                                                                                                                                                                        "pena":    "até dois anos imposta a militar",
                                                                                                                                                                                                                        "rubrica":    "Mínimos e máximos genéricos"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "59º",
                                                                                                                                                                                                                        "rotulo":    "Art. 59º.",
                                                                                                                                                                                                                        "linha":    475,
                                                                                                                                                                                                                        "caput":    "- A pena de reclusão ou de detenção até 2 (dois) anos, aplicada a militar, é convertida em pena de prisão e cumprida, quando não cabível a suspensão condicional:",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    477,
                                                                                                                                                                                                                                                                "texto":    "pelo oficial, em recinto de estabelecimento militar;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    479,
                                                                                                                                                                                                                                                                "texto":    "pela praça, em estabelecimento penal militar, onde ficará separada de presos que estejam cumprindo pena disciplinar ou pena privativa de liberdade por tempo superior a dois anos."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    483,
                                                                                                                                                                                                                                                                     "texto":    "Para efeito de separação, no cumprimento da pena de prisão, atender-se-á, também, à condição das praças especiais e à das graduadas, ou não; e, dentre as graduadas, à das que tenham graduação especial.",
                                                                                                                                                                                                                                                                     "rubrica":    "Separação de praças especiais e graduadas"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "61º",
                                                                                                                                                                                                                        "rotulo":    "Art. 61º.",
                                                                                                                                                                                                                        "linha":    496,
                                                                                                                                                                                                                        "caput":    "- A pena privativa da liberdade por mais de 2 (dois) anos, aplicada a militar, é cumprida em penitenciária militar e, na falta dessa, em estabelecimento prisional civil, ficando o recluso ou detento sujeito ao regime conforme a legislação penal comum, de cujos benefícios e concessões, também, poderá gozar.",
                                                                                                                                                                                                                        "pena":    "privativa da liberdade imposta a civil",
                                                                                                                                                                                                                        "rubrica":    "Pena superior a dois anos, imposta a militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "62º",
                                                                                                                                                                                                                        "rotulo":    "Art. 62º.",
                                                                                                                                                                                                                        "linha":    501,
                                                                                                                                                                                                                        "caput":    "- O civil cumpre a pena aplicada pela Justiça Militar, em estabelecimento prisional civil, ficando ele sujeito ao regime conforme a legislação penal comum, de cujos benefícios e concessões, também, poderá gozar.",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    506,
                                                                                                                                                                                                                                                                     "texto":    "- Por crime militar praticado em tempo de guerra poderá o civil ficar sujeito a cumprir a pena, no todo ou em parte em penitenciária militar, se, em benefício da segurança nacional, assim o determinar a sentença.(Redação dada pela Lei nº 6.544, de 30.6.1978)",
                                                                                                                                                                                                                                                                     "rubrica":    "Cumprimento em penitenciária militar"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "63º",
                                                                                                                                                                                                                        "rotulo":    "Art. 63º.",
                                                                                                                                                                                                                        "linha":    510,
                                                                                                                                                                                                                        "caput":    "A pena de impedimento sujeita o condenado a permanecer no recinto da unidade, sem prejuízo da instrução militar.",
                                                                                                                                                                                                                        "rubrica":    "Pena de impedimento"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "66º",
                                                                                                                                                                                                                        "rotulo":    "Art. 66º.",
                                                                                                                                                                                                                        "linha":    526,
                                                                                                                                                                                                                        "caput":    "O condenado a que sobrevenha doença mental deve ser recolhido a manicômio judiciário ou, na falta dêste, a outro estabelecimento adequado, onde lhe seja assegurada custódia e tratamento.",
                                                                                                                                                                                                                        "rubrica":    "Superveniência de doença mental"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "67º",
                                                                                                                                                                                                                        "rotulo":    "Art. 67º.",
                                                                                                                                                                                                                        "linha":    530,
                                                                                                                                                                                                                        "caput":    "Computam-se na pena privativa de liberdade o tempo de prisão provisória, no Brasil ou no estrangeiro, e o de internação em hospital ou manicômio, bem como o excesso de tempo, reconhecido em decisão judicial irrecorrível, no cumprimento da pena, por outro crime, desde que a decisão seja posterior ao crime de que se trata.",
                                                                                                                                                                                                                        "rubrica":    "Tempo computável"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "68º",
                                                                                                                                                                                                                        "rotulo":    "Art. 68º.",
                                                                                                                                                                                                                        "linha":    534,
                                                                                                                                                                                                                        "caput":    "O condenado pela Justiça Militar de uma região, distrito ou zona pode cumprir pena em estabelecimento de outra região, distrito ou zona.",
                                                                                                                                                                                                                        "rubrica":    "Transferência de condenados"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DAS PENAS PRINCIPAIS",
                                                                                                                                                                                "linhaTitulo":    439
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    536,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "69º",
                                                                                                                                                                                                                        "rotulo":    "Art. 69º.",
                                                                                                                                                                                                                        "linha":    540,
                                                                                                                                                                                                                        "caput":    "Para fixação da pena privativa de liberdade, o juiz aprecia a gravidade do crime praticado e a personalidade do réu, devendo ter em conta a intensidade do dolo ou grau da culpa, a maior ou menor extensão do dano ou perigo de dano, os meios empregados, o modo de execução, os motivos determinantes, as circunstâncias de tempo e lugar, os antecedentes do réu e sua atitude de insensibilidade, indiferença ou arrependimento após o crime.",
                                                                                                                                                                                                                        "rubrica":    "Fixação da pena privativa de liberdade",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    544,
                                                                                                                                                                                                                                                                     "texto":    "Se são cominadas penas alternativas, o juiz deve determinar qual delas é aplicável.",
                                                                                                                                                                                                                                                                     "rubrica":    "Determinação da pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    548,
                                                                                                                                                                                                                                                                     "texto":    "Salvo o disposto no art. 76, é fixada dentro dos limites legais a quantidade da pena aplicável.",
                                                                                                                                                                                                                                                                     "rubrica":    "Limites legais da pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "70º",
                                                                                                                                                                                                                        "rotulo":    "Art. 70º.",
                                                                                                                                                                                                                        "linha":    552,
                                                                                                                                                                                                                        "caput":    "São circunstâncias que sempre agravam a pena, quando não integrantes ou qualificativas do crime:",
                                                                                                                                                                                                                        "rubrica":    "Circunstâncias agravantes",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    554,
                                                                                                                                                                                                                                                                "texto":    "a reincidência;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    556,
                                                                                                                                                                                                                                                                "texto":    "ter o agente cometido o crime:",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "a",
                                                                                                                                                                                                                                                                                                        "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                        "linha":    558,
                                                                                                                                                                                                                                                                                                        "texto":    "por motivo fútil ou torpe;",
                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                "linha":    560,
                                                                                                                                                                                                                                                                                                                                                "texto":    "para facilitar ou assegurar a execução, a ocultação, a impunidade ou vantagem de outro crime;",
                                                                                                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                        "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                                                        "linha":    562,
                                                                                                                                                                                                                                                                                                                                                                                        "texto":    "depois de embriagar-se, salvo se a embriaguez decorre de caso fortuito, engano ou fôrça maior;",
                                                                                                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                                                                "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                                                                "linha":    564,
                                                                                                                                                                                                                                                                                                                                                                                                                                "texto":    "à traição, de emboscada, com surprêsa, ou mediante outro recurso insidioso que dificultou ou tornou impossível a defesa da vítima;",
                                                                                                                                                                                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "letra":    "e",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "e)",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "linha":    566,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "texto":    "com o emprêgo de veneno, asfixia, tortura, fogo, explosivo, ou qualquer outro meio dissimulado ou cruel, ou de que podia resultar perigo comum;",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "letra":    "f",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "rotulo":    "f)",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "linha":    568,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "texto":    "contra ascendente, descendente, irmão ou cônjuge;",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "@{letra=g; rotulo=g); linha=570; texto=com abuso de poder ou violação de dever inerente a cargo, ofício, ministério ou profissão;; alineas=System.Object[]}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    587,
                                                                                                                                                                                                                                                                     "texto":    "As circunstâncias das letras c , salvo no caso de embriaguez preordenada, l , m e o , só agravam o crime quando praticado por militar."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "71º",
                                                                                                                                                                                                                        "rotulo":    "Art. 71º.",
                                                                                                                                                                                                                        "linha":    591,
                                                                                                                                                                                                                        "caput":    "Verifica-se a reincidência quando o agente comete nôvo crime, depois de transitar em julgado a sentença que, no país ou no estrangeiro, o tenha condenado por crime anterior.",
                                                                                                                                                                                                                        "rubrica":    "Reincidência",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    595,
                                                                                                                                                                                                                                                                     "texto":    "Não se toma em conta, para efeito da reincidência, a condenação anterior, se, entre a data do cumprimento ou extinção da pena e o crime posterior, decorreu período de tempo superior a cinco anos.",
                                                                                                                                                                                                                                                                     "rubrica":    "Temporariedade da reincidência"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    599,
                                                                                                                                                                                                                                                                     "texto":    "Para efeito da reincidência, não se consideram os crimes anistiados.",
                                                                                                                                                                                                                                                                     "rubrica":    "Crimes não considerados para efeito da reincidência"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "72º",
                                                                                                                                                                                                                        "rotulo":    "Art. 72º.",
                                                                                                                                                                                                                        "linha":    601,
                                                                                                                                                                                                                        "caput":    "São circunstâncias que sempre atenuam a pena:",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    605,
                                                                                                                                                                                                                                                                "texto":    "ser o agente menor de vinte e um ou maior de setenta anos;",
                                                                                                                                                                                                                                                                "rubrica":    "Circunstância atenuantes"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    607,
                                                                                                                                                                                                                                                                "texto":    "ser meritório seu comportamento anterior;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    609,
                                                                                                                                                                                                                                                                "texto":    "ter o agente:",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "a",
                                                                                                                                                                                                                                                                                                        "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                        "linha":    611,
                                                                                                                                                                                                                                                                                                        "texto":    "cometido o crime por motivo de relevante valor social ou moral;",
                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                "linha":    613,
                                                                                                                                                                                                                                                                                                                                                "texto":    "procurado, por sua espontânea vontade e com eficiência, logo após o crime, evitar-lhe ou minorar-lhe as conseqüências, ou ter, antes do julgamento, reparado o dano;",
                                                                                                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                        "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                                                        "linha":    615,
                                                                                                                                                                                                                                                                                                                                                                                        "texto":    "cometido o crime sob a influência de violenta emoção, provocada por ato injusto da vítima;",
                                                                                                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                                                                "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                                                                "linha":    617,
                                                                                                                                                                                                                                                                                                                                                                                                                                "texto":    "confessado espontâneamente, perante a autoridade, a autoria do crime, ignorada ou imputada a outrem;",
                                                                                                                                                                                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "letra":    "e",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "e)",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "linha":    619,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "texto":    "sofrido tratamento com rigor não permitido em lei. Não atendimento de atenuantes"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    621,
                                                                                                                                                                                                                                                                     "texto":    "Nos crimes em que a pena máxima cominada é de morte, ao juiz é facultado atender, ou não, às circunstâncias atenuantes enumeradas no artigo."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "73º",
                                                                                                                                                                                                                        "rotulo":    "Art. 73º.",
                                                                                                                                                                                                                        "linha":    625,
                                                                                                                                                                                                                        "caput":    "Quando a lei determina a agravação ou atenuação da pena sem mencionar o quantum , deve o juiz fixá-lo entre um quinto e um têrço, guardados os limites da pena cominada ao crime.",
                                                                                                                                                                                                                        "rubrica":    "Quantum da agravação ou atenuação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "74º",
                                                                                                                                                                                                                        "rotulo":    "Art. 74º.",
                                                                                                                                                                                                                        "linha":    629,
                                                                                                                                                                                                                        "caput":    "Quando ocorre mais de uma agravante ou mais de uma atenuante, o juiz poderá limitar-se a uma só agravação ou a uma só atenuação.",
                                                                                                                                                                                                                        "rubrica":    "Mais de uma agravante ou atenuante"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "75º",
                                                                                                                                                                                                                        "rotulo":    "Art. 75º.",
                                                                                                                                                                                                                        "linha":    633,
                                                                                                                                                                                                                        "caput":    "No concurso de agravantes e atenuantes, a pena deve aproximar-se do limite indicado pelas circunstâncias preponderantes, entendendo-se como tais as que resultam dos motivos determinantes do crime, da personalidade do agente, e da reincidência. Se há equivalência entre umas e outras, é como se não tivessem ocorrido.",
                                                                                                                                                                                                                        "rubrica":    "Concurso de agravantes e atenuantes"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "76º",
                                                                                                                                                                                                                        "rotulo":    "Art. 76º.",
                                                                                                                                                                                                                        "linha":    637,
                                                                                                                                                                                                                        "caput":    "Quando a lei prevê causas especiais de aumento ou diminuição da pena, não fica o juiz adstrito aos limites da pena cominada ao crime, senão apenas aos da espécie de pena aplicável (art. 58).",
                                                                                                                                                                                                                        "rubrica":    "Majorantes e minorantes",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    639,
                                                                                                                                                                                                                                                                     "texto":    "No concurso dessas causas especiais, pode o juiz limitar-se a um só aumento ou a uma só diminuição, prevalecendo, todavia, a causa que mais aumente ou diminua."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "77º",
                                                                                                                                                                                                                        "rotulo":    "Art. 77º.",
                                                                                                                                                                                                                        "linha":    645,
                                                                                                                                                                                                                        "caput":    "A pena-base será fixada de acordo com o critério definido no art. 69 deste Código e, em seguida, serão consideradas as circunstâncias atenuantes e agravantes e, por último, as causas de diminuição e de aumento de pena.",
                                                                                                                                                                                                                        "rubrica":    "Cálculo da pena",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    647,
                                                                                                                                                                                                                                                                     "texto":    "Salvo na aplicação das causas de diminuição e de aumento, a pena não poderá ser fixada aquém do mínimo nem acima do máximo previsto em abstrato para o crime."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "79º",
                                                                                                                                                                                                                        "rotulo":    "Art. 79º.",
                                                                                                                                                                                                                        "linha":    683,
                                                                                                                                                                                                                        "caput":    "Quandoo agente, mediante mais de uma ação ou omissão, pratica dois ou mais crimes, idênticos ou não, aplicam-se-lhe cumulativamente as penas privativas de liberdade em que haja incorrido.",
                                                                                                                                                                                                                        "rubrica":    "Concurso material",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    685,
                                                                                                                                                                                                                                                                     "texto":    "No caso de aplicação cumulativa de penas de reclusão e de detenção, executa-se primeiro aquela."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "79º-A",
                                                                                                                                                                                                                        "rotulo":    "Art. 79º-A.",
                                                                                                                                                                                                                        "linha":    689,
                                                                                                                                                                                                                        "caput":    "Quando o agente, mediante uma só ação ou omissão, pratica dois ou mais crimes, idênticos ou não, aplica-se-lhe a mais grave das penas cabíveis ou, se iguais, somente uma delas, mas aumentada, em qualquer caso, de 1/6 (um sexto) até metade.",
                                                                                                                                                                                                                        "rubrica":    "Concurso formal",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    691,
                                                                                                                                                                                                                                                                     "texto":    "As penas aplicam-se, entretanto, cumulativamente, se a ação ou omissão é dolosa e os crimes concorrentes resultam de desígnios autônomos, consoante o disposto no art. 79 deste Código."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    693,
                                                                                                                                                                                                                                                                     "texto":    "Não poderá a pena exceder a que seria cabível pela regra do art. 79 deste Código."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "80º",
                                                                                                                                                                                                                        "rotulo":    "Art. 80º.",
                                                                                                                                                                                                                        "linha":    700,
                                                                                                                                                                                                                        "caput":    "Quando o agente, mediante mais de uma ação ou omissão, pratica dois ou mais crimes da mesma espécie e, pelas condições de tempo, lugar, maneira de execução e outras semelhantes, devem os subsequentes ser havidos como continuação do primeiro, aplica-se-lhe a pena de um só dos crimes, se idênticas, ou a mais grave, se diversas, aumentada, em qualquer caso, de 1/6 (um sexto) a 2/3 (dois terços).",
                                                                                                                                                                                                                        "rubrica":    "Crime continuado",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    702,
                                                                                                                                                                                                                                                                     "texto":    "Nos crimes dolosos contra vítimas diferentes cometidos com violência ou grave ameaça à pessoa, poderá o juízo, considerando a culpabilidade, os antecedentes, a conduta social e a personalidade do agente, bem como os motivos e as circunstâncias, aumentar a pena de um só dos crimes, se idênticas, ou a mais grave, se diversas, até o triplo, observadas as regras dos §§ 1º e 2º do art. 79-A e do art. 81 deste Código."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "81º",
                                                                                                                                                                                                                        "rotulo":    "Art. 81º.",
                                                                                                                                                                                                                        "linha":    706,
                                                                                                                                                                                                                        "caput":    "A pena unificada não pode ultrapassar de trinta anos, se é de reclusão, ou de quinze anos, se é de detenção.",
                                                                                                                                                                                                                        "rubrica":    "Limite da pena unificada",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    710,
                                                                                                                                                                                                                                                                     "texto":    "A pena unificada pode ser diminuída de um sexto a um quarto, no caso de unidade de ação ou omissão, ou de crime continuado.",
                                                                                                                                                                                                                                                                     "rubrica":    "Redução facultativa da pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    714,
                                                                                                                                                                                                                                                                     "texto":    "Quando cominada a pena de morte como grau máximo e a de reclusão como grau mínimo, aquela corresponde, para o efeito de graduação, à de reclusão por trinta anos.",
                                                                                                                                                                                                                                                                     "rubrica":    "Graduação no caso de pena de morte"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    718,
                                                                                                                                                                                                                                                                     "texto":    "Nos crimes punidos com a pena de morte, esta corresponde à de reclusão por trinta anos, para cálculo da pena aplicável à tentativa, salvo disposição especial.",
                                                                                                                                                                                                                                                                     "rubrica":    "Cálculo da pena aplicável à tentativa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "83º",
                                                                                                                                                                                                                        "rotulo":    "Art. 83º.",
                                                                                                                                                                                                                        "linha":    726,
                                                                                                                                                                                                                        "caput":    "As penas não privativas de liberdade são aplicadas distinta e integralmente, ainda que previstas para um só dos crimes concorrentes.",
                                                                                                                                                                                                                        "rubrica":    "Penas não privativas de liberdade"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA APLICAÇÃO DA PENA",
                                                                                                                                                                                "linhaTitulo":    537
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    728,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "84º",
                                                                                                                                                                                                                        "rotulo":    "Art. 84º.",
                                                                                                                                                                                                                        "linha":    734,
                                                                                                                                                                                                                        "caput":    "A execução da pena privativa de liberdade não superior a 2 (dois) anos pode ser suspensa por 3 (três) a 5 (cinco) anos, no caso de pena de reclusão, e por 2 (dois) a 4 (quatro) anos, no caso de pena de detenção, desde que:",
                                                                                                                                                                                                                        "rubrica":    "Pressupostos da suspensão",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    737,
                                                                                                                                                                                                                                                                "texto":    "sentenciado não haja sofrido no País ou no estrangeiro, condenação irrecorrível por outro crime a pena privativa da liberdade, salvo o disposto no 1º do art. 71;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    741,
                                                                                                                                                                                                                                                                "texto":    "a culpabilidade, os antecedentes, a conduta social e a personalidade do agente, bem como os motivos e as circunstâncias do crime, autorizem a concessão do benefício."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    746,
                                                                                                                                                                                                                                                                     "texto":    "A suspensão não se estende à pena acessória nem exclui a aplicação de medida de segurança não detentiva.",
                                                                                                                                                                                                                                                                     "rubrica":    "Restrições"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    748,
                                                                                                                                                                                                                                                                     "texto":    "A execução da pena privativa de liberdade não superior a 4 (quatro) anos poderá ser suspensa por 4 (quatro) a 6 (seis) anos, desde que o condenado seja maior de 70 (setenta) anos de idade ou existam razões de saúde que justifiquem a suspensão."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "85º",
                                                                                                                                                                                                                        "rotulo":    "Art. 85º.",
                                                                                                                                                                                                                        "linha":    752,
                                                                                                                                                                                                                        "caput":    "A sentença deve especificar as condições a que fica subordinada a suspensão.",
                                                                                                                                                                                                                        "rubrica":    "Condições"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "86º",
                                                                                                                                                                                                                        "rotulo":    "Art. 86º.",
                                                                                                                                                                                                                        "linha":    756,
                                                                                                                                                                                                                        "caput":    "A suspensão é revogada se, no curso do prazo, o beneficiário:",
                                                                                                                                                                                                                        "rubrica":    "Revogação obrigatória da suspensão",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    759,
                                                                                                                                                                                                                                                                "texto":    "é condenado por crime doloso, na Justiça Militar ou na Justiça Comum, por sentença irrecorrível;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    761,
                                                                                                                                                                                                                                                                "texto":    "não efetua, sem motivo justificado, a reparação do dano;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    765,
                                                                                                                                                                                                                                                                "texto":    ".",
                                                                                                                                                                                                                                                                "rubrica":    "Vigência"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    771,
                                                                                                                                                                                                                                                                     "texto":    "A suspensão também pode ser revogada se o condenado deixar de cumprir qualquer das obrigações constantes da sentença ou, se militar, for punido por infração disciplinar considerada grave.",
                                                                                                                                                                                                                                                                     "rubrica":    "Revogação facultativa"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    775,
                                                                                                                                                                                                                                                                     "texto":    "Quando facultativa a revogação, o juiz pode, ao invés de decretá-la, prorrogar o período de prova até o máximo, se êste não foi o fixado.",
                                                                                                                                                                                                                                                                     "rubrica":    "Prorrogação de prazo"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    777,
                                                                                                                                                                                                                                                                     "texto":    "Se o beneficiário está respondendo a processo que, no caso de condenação, pode acarretar a revogação, considera-se prorrogado o prazo da suspensão até o julgamento definitivo."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "87º",
                                                                                                                                                                                                                        "rotulo":    "Art. 87º.",
                                                                                                                                                                                                                        "linha":    781,
                                                                                                                                                                                                                        "caput":    "Se o prazo expira sem que tenha sido revogada a suspensão, fica extinta a pena privativa de liberdade.",
                                                                                                                                                                                                                        "rubrica":    "Extinção da pena"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "88º",
                                                                                                                                                                                                                        "rotulo":    "Art. 88º.",
                                                                                                                                                                                                                        "linha":    785,
                                                                                                                                                                                                                        "caput":    "A suspensão condicional da pena não se aplica:",
                                                                                                                                                                                                                        "rubrica":    "Não aplicação da suspensão condicional da pena",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    787,
                                                                                                                                                                                                                                                                "texto":    "ao condenado por crime cometido em tempo de guerra;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    789,
                                                                                                                                                                                                                                                                "texto":    "em tempo de paz:",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "a",
                                                                                                                                                                                                                                                                                                        "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                        "linha":    791,
                                                                                                                                                                                                                                                                                                        "texto":    "por crime contra a segurança nacional, de aliciação e incitamento, de violência contra superior, oficial de dia, de serviço ou de quarto, sentinela, vigia ou plantão, de desrespeito a superior, de insubordinação, ou de deserção;",
                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                "linha":    793,
                                                                                                                                                                                                                                                                                                                                                "texto":    "pelos crimes previstos nos arts. 160, 161, 162, 235, 291 e seu parágrafo único, ns. I a IV."
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA SUSPENSÃO CONDICIONAL DA PENA",
                                                                                                                                                                                "linhaTitulo":    729
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    795,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "89º",
                                                                                                                                                                                                                        "rotulo":    "Art. 89º.",
                                                                                                                                                                                                                        "linha":    799,
                                                                                                                                                                                                                        "caput":    "O condenado a pena de reclusão ou de detenção por tempo igual ou superior a dois anos pode ser liberado condicionalmente, desde que:",
                                                                                                                                                                                                                        "rubrica":    "Requisitos",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    801,
                                                                                                                                                                                                                                                                "texto":    "tenha cumprido:",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "a",
                                                                                                                                                                                                                                                                                                        "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                        "linha":    803,
                                                                                                                                                                                                                                                                                                        "texto":    "metade da pena, se primário;",
                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                "linha":    805,
                                                                                                                                                                                                                                                                                                                                                "texto":    "dois terços, se reincidente;"
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    807,
                                                                                                                                                                                                                                                                "texto":    "tenha reparado, salvo impossibilidade de fazê-lo, o dano causado pelo crime;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    809,
                                                                                                                                                                                                                                                                "texto":    "sua boa conduta durante a execução da pena, sua adaptação ao trabalho e às circunstâncias atinentes a sua personalidade, ao meio social e à sua vida pregressa permitem supor que não voltará a delinqüir."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    813,
                                                                                                                                                                                                                                                                     "texto":    "No caso de condenação por infrações penais em concurso, deve ter-se em conta a pena unificada.",
                                                                                                                                                                                                                                                                     "rubrica":    "Penas em concurso de infrações"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    817,
                                                                                                                                                                                                                                                                     "texto":    "Se o condenado é primário e menor de vinte e um ou maior de setenta anos, o tempo de cumprimento da pena pode ser reduzido a um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Condenação de menor de 21 ou maior de 70 anos"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "90º",
                                                                                                                                                                                                                        "rotulo":    "Art. 90º.",
                                                                                                                                                                                                                        "linha":    821,
                                                                                                                                                                                                                        "caput":    "A sentença deve especificar as condições a que fica subordinado o livramento.",
                                                                                                                                                                                                                        "rubrica":    "Especificações das condições"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "91º",
                                                                                                                                                                                                                        "rotulo":    "Art. 91º.",
                                                                                                                                                                                                                        "linha":    825,
                                                                                                                                                                                                                        "caput":    "O livramento sòmente se concede mediante parecer do Conselho Penitenciário, ouvidos o diretor do estabelecimento em que está ou tenha estado o liberando e o representante do Ministério Público da Justiça Militar; e, se imposta medida de segurança detentiva, após perícia conclusiva da não periculosidade do liberando.",
                                                                                                                                                                                                                        "rubrica":    "Preliminares da concessão"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "92º",
                                                                                                                                                                                                                        "rotulo":    "Art. 92º.",
                                                                                                                                                                                                                        "linha":    829,
                                                                                                                                                                                                                        "caput":    "O liberado fica sob observação cautelar e proteção realizadas por patronato oficial ou particular, dirigido aquêle e inspecionado êste pelo Conselho Penitenciário. Na falta de patronato, o liberado fica sob observação cautelar realizada por serviço social penitenciário ou órgão similar.",
                                                                                                                                                                                                                        "rubrica":    "Observação cautelar e proteção do liberado"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "93º",
                                                                                                                                                                                                                        "rotulo":    "Art. 93º.",
                                                                                                                                                                                                                        "linha":    833,
                                                                                                                                                                                                                        "caput":    "Revoga-se o livramento, se o liberado vem a ser condenado, em sentença irrecorrível, a penal privativa de liberdade:",
                                                                                                                                                                                                                        "rubrica":    "Revogação obrigatória",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    835,
                                                                                                                                                                                                                                                                "texto":    "por infração penal cometida durante a vigência do benefício;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    837,
                                                                                                                                                                                                                                                                "texto":    "por infração penal anterior, salvo se, tendo de ser unificadas as penas, não fica prejudicado o requisito do art. 89, nº I, letra a"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    841,
                                                                                                                                                                                                                                                                     "texto":    "O juiz pode, também, revogar o livramento se o liberado deixa de cumprir qualquer das obrigações constantes da sentença ou é irrecorrìvelmente condenado, por motivo de contravenção, a pena que não seja privativa de liberdade; ou, se militar, sofre penalidade por transgressão disciplinar considerada grave.",
                                                                                                                                                                                                                                                                     "rubrica":    "Revogação facultativa"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    845,
                                                                                                                                                                                                                                                                     "texto":    "Para os efeitos da revogação obrigatória, são tomadas, também, em consideração, nos têrmos dos ns. I e II dêste artigo, as infrações sujeitas à jurisdição penal comum; e, igualmente, a contravenção compreendida no § 1º, se assim, com prudente arbítrio, o entender o juiz.",
                                                                                                                                                                                                                                                                     "rubrica":    "Infração sujeita à jurisdição penal comum"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "94º",
                                                                                                                                                                                                                        "rotulo":    "Art. 94º.",
                                                                                                                                                                                                                        "linha":    849,
                                                                                                                                                                                                                        "caput":    "Revogado o livramento, não pode ser novamente concedido e, salvo quando a revogação resulta de condenação por infração penal anterior ao benefício, não se desconta na pena o tempo em que estêve sôlto o condenado.",
                                                                                                                                                                                                                        "rubrica":    "Efeitos da revogação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "95º",
                                                                                                                                                                                                                        "rotulo":    "Art. 95º.",
                                                                                                                                                                                                                        "linha":    853,
                                                                                                                                                                                                                        "caput":    "Se, até o seu têrmo, o livramento não é revogado, considera-se extinta a pena privativa de liberdade.",
                                                                                                                                                                                                                        "rubrica":    "Extinção da pena",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    855,
                                                                                                                                                                                                                                                                     "texto":    "Enquanto não passa em julgado a sentença em processo, a que responde o liberado por infração penal cometida na vigência do livramento, deve o juiz abster-se de declarar a extinção da pena."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "96º",
                                                                                                                                                                                                                        "rotulo":    "Art. 96º.",
                                                                                                                                                                                                                        "linha":    859,
                                                                                                                                                                                                                        "caput":    "O livramento condicional não se aplica ao condenado por crime cometido em tempo de guerra.",
                                                                                                                                                                                                                        "rubrica":    "Não aplicação do livramento condicional"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "97º",
                                                                                                                                                                                                                        "rotulo":    "Art. 97º.",
                                                                                                                                                                                                                        "linha":    863,
                                                                                                                                                                                                                        "caput":    "Em tempo de paz, o livramento condicional por crime contra a segurança externa do país, ou de revolta, motim, aliciação e incitamento, violência contra superior ou militar de serviço, só será concedido após o cumprimento de dois terços da pena, observado ainda o disposto no art. 89, preâmbulo, seus números II e III e §§ 1º e 2º.",
                                                                                                                                                                                                                        "rubrica":    "Casos especiais do livramento condicional"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO LIVRAMENTO CONDICIONAL",
                                                                                                                                                                                "linhaTitulo":    796
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO V",
                                                                                                                                                                                "linha":    865,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "98º",
                                                                                                                                                                                                                        "rotulo":    "Art. 98º.",
                                                                                                                                                                                                                        "linha":    869,
                                                                                                                                                                                                                        "caput":    "São penas acessórias:",
                                                                                                                                                                                                                        "rubrica":    "Penas Acessórias",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    871,
                                                                                                                                                                                                                                                                "texto":    "a perda de pôsto e patente;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    873,
                                                                                                                                                                                                                                                                "texto":    "a indignidade para o oficialato;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    875,
                                                                                                                                                                                                                                                                "texto":    "a incompatibilidade com o oficialato;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    877,
                                                                                                                                                                                                                                                                "texto":    "a exclusão das fôrças armadas;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "V",
                                                                                                                                                                                                                                                                "rotulo":    "V",
                                                                                                                                                                                                                                                                "linha":    879,
                                                                                                                                                                                                                                                                "texto":    "a perda da função pública, ainda que eletiva;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "VI",
                                                                                                                                                                                                                                                                "rotulo":    "VI",
                                                                                                                                                                                                                                                                "linha":    881,
                                                                                                                                                                                                                                                                "texto":    "a inabilitação para o exercício de função pública;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "VII",
                                                                                                                                                                                                                                                                "rotulo":    "VII",
                                                                                                                                                                                                                                                                "linha":    884,
                                                                                                                                                                                                                                                                "texto":    "a incapacidade para o exercício do poder familiar, da tutela ou da curatela, quando tal medida for determinante para salvaguardar os interesses do filho, do tutelado ou do curatelado;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "VIII",
                                                                                                                                                                                                                                                                "rotulo":    "VIII",
                                                                                                                                                                                                                                                                "linha":    886,
                                                                                                                                                                                                                                                                "texto":    "a suspensão dos direitos políticos."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    890,
                                                                                                                                                                                                                                                                     "texto":    "Equipara-se à função pública a que é exercida em emprêsa pública, autarquia, sociedade de economia mista, ou sociedade de que participe a União, o Estado ou o Município como acionista majoritário.",
                                                                                                                                                                                                                                                                     "rubrica":    "Função pública equiparada"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "99º",
                                                                                                                                                                                                                        "rotulo":    "Art. 99º.",
                                                                                                                                                                                                                        "linha":    896,
                                                                                                                                                                                                                        "caput":    "A perda de posto e patente resulta da condenação a pena privativa de liberdade por tempo superior a 2 (dois) anos, por crimes comuns e militares, e importa a perda das condecorações, desde que submetido o oficial ao julgamento previsto no inciso VI do § 3º do art. 142 da Constituição Federal.",
                                                                                                                                                                                                                        "rubrica":    "Perda de posto e patente"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "100º",
                                                                                                                                                                                                                        "rotulo":    "Art. 100º.",
                                                                                                                                                                                                                        "linha":    900,
                                                                                                                                                                                                                        "caput":    "Fica sujeito à declaração de indignidade para o oficialato o militar condenado, qualquer que seja a pena, nos crimes de traição, espionagem ou cobardia, ou em qualquer dos definidos nos arts. 161, 235, 240, 242, 243, 244, 245, 251, 252, 303, 304, 311 e 312.",
                                                                                                                                                                                                                        "rubrica":    "Indignidade para o oficialato"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "101º",
                                                                                                                                                                                                                        "rotulo":    "Art. 101º.",
                                                                                                                                                                                                                        "linha":    904,
                                                                                                                                                                                                                        "caput":    "Fica sujeito à declaração de incompatibilidade com o oficialato o militar condenado nos crimes dos arts. 141 e 142.",
                                                                                                                                                                                                                        "rubrica":    "Incompatibilidade com o oficialato"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "102º",
                                                                                                                                                                                                                        "rotulo":    "Art. 102º.",
                                                                                                                                                                                                                        "linha":    908,
                                                                                                                                                                                                                        "caput":    "A condenação da praça a pena privativa de liberdade, por tempo superior a dois anos, importa sua exclusão das fôrças armadas.",
                                                                                                                                                                                                                        "rubrica":    "Exclusão das fôrças armadas"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "103º",
                                                                                                                                                                                                                        "rotulo":    "Art. 103º.",
                                                                                                                                                                                                                        "linha":    914,
                                                                                                                                                                                                                        "caput":    "Incorre na perda da função pública o civil:",
                                                                                                                                                                                                                        "rubrica":    "Perda da função pública",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    916,
                                                                                                                                                                                                                                                                "texto":    "condenado a pena privativa de liberdade por crime cometido com abuso de poder ou violação de dever inerente à função pública;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    918,
                                                                                                                                                                                                                                                                "texto":    "condenado, por outro crime, a pena privativa de liberdade por mais de dois anos."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    920,
                                                                                                                                                                                                                                                                     "texto":    "O disposto no artigo aplica-se ao militar da reserva, ou reformado, se estiver no exercício de função pública de qualquer natureza."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "104º",
                                                                                                                                                                                                                        "rotulo":    "Art. 104º.",
                                                                                                                                                                                                                        "linha":    924,
                                                                                                                                                                                                                        "caput":    "Incorre na inabilitação para o exercício de função pública, pelo prazo de dois até vinte anos, o condenado a reclusão por mais de quatro anos, em virtude de crime praticado com abuso de poder ou violação do dever militar ou inerente à função pública.",
                                                                                                                                                                                                                        "rubrica":    "Inabilitação para o exercício de função pública",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    928,
                                                                                                                                                                                                                                                                     "texto":    "O prazo da inabilitação para o exercício de função pública começa ao têrmo da execução da pena privativa de liberdade ou da medida de segurança imposta em substituição, ou da data em que se extingue a referida pena.",
                                                                                                                                                                                                                                                                     "rubrica":    "Têrmo inicial"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "105º",
                                                                                                                                                                                                                        "rotulo":    "Art. 105º.",
                                                                                                                                                                                                                        "linha":    936,
                                                                                                                                                                                                                        "caput":    "O condenado por cometimento de crime doloso sujeito a pena de reclusão praticado contra outrem igualmente titular do mesmo poder familiar ou contra filho, tutelado ou curatelado poderá, justificadamente e em atendimento ao melhor interesse do menor ou do curatelado, ter decretada a incapacidade para o exercício do poder familiar, da tutela ou da curatela, enquanto durar a execução da pena ou da medida de segurança imposta em substituição nos termos do art. 113 deste Código.",
                                                                                                                                                                                                                        "rubrica":    "Incapacidade para o exercício do poder familiar, da tutela ou da curatela",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    940,
                                                                                                                                                                                                                                                                     "texto":    "Durante o processo para apuração dos crimes descritos no caput deste artigo, poderá o juízo, justificadamente e em atendimento ao melhor interesse do menor ou do curatelado, decretar a incapacidade provisória para o exercício do poder familiar, da tutela ou da curatela.",
                                                                                                                                                                                                                                                                     "rubrica":    "Incapacidade provisória"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "106º",
                                                                                                                                                                                                                        "rotulo":    "Art. 106º.",
                                                                                                                                                                                                                        "linha":    944,
                                                                                                                                                                                                                        "caput":    "Durante a execução da pena privativa de liberdade ou da medida de segurança ìmposta em substituição, ou enquanto perdura a inabilitação para função pública, o condenado não pode votar, nem ser votado.",
                                                                                                                                                                                                                        "rubrica":    "Suspensão dos direitos políticos"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "107º",
                                                                                                                                                                                                                        "rotulo":    "Art. 107º.",
                                                                                                                                                                                                                        "linha":    948,
                                                                                                                                                                                                                        "caput":    "Salvo os casos dos arts. 99, 103, nº II, e 106, a imposição da pena acessória deve constar expressamente da sentença.",
                                                                                                                                                                                                                        "rubrica":    "Imposição de pena acessória"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "108º",
                                                                                                                                                                                                                        "rotulo":    "Art. 108º.",
                                                                                                                                                                                                                        "linha":    952,
                                                                                                                                                                                                                        "caput":    "Computa-se no prazo das inabilitações temporárias o tempo de liberdade resultante da suspensão condicional da pena ou do livramento condicional, se não sobrevém revogação.",
                                                                                                                                                                                                                        "rubrica":    "Tempo computável"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DAS PENAS ACESSÓRIAS",
                                                                                                                                                                                "linhaTitulo":    866
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VI",
                                                                                                                                                                                "linha":    954,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "109º",
                                                                                                                                                                                                                        "rotulo":    "Art. 109º.",
                                                                                                                                                                                                                        "linha":    958,
                                                                                                                                                                                                                        "caput":    "São efeitos da condenação:",
                                                                                                                                                                                                                        "rubrica":    "Obrigação de reparar o dano",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    960,
                                                                                                                                                                                                                                                                "texto":    "tornar certa a obrigação de reparar o dano resultante do crime;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    966,
                                                                                                                                                                                                                                                                "texto":    "a perda em favor da Fazenda Pública, ressalvado o direito do lesado ou de terceiro de boa-fé:",
                                                                                                                                                                                                                                                                "rubrica":    "Perda em favor da Fazenda Pública",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "a",
                                                                                                                                                                                                                                                                                                        "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                        "linha":    968,
                                                                                                                                                                                                                                                                                                        "texto":    "dos instrumentos do crime, desde que consistam em coisas cujo fabrico, alienação, uso, porte ou detenção constitua fato ilícito;",
                                                                                                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                "linha":    970,
                                                                                                                                                                                                                                                                                                                                                "texto":    "do produto do crime ou de qualquer bem ou valor que constitua proveito auferido pelo agente com a sua prática."
                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS EFEITOS DA CONDENAÇÃO",
                                                                                                                                                                                "linhaTitulo":    955
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DAS PENAS",
                                                                                                                                     "linhaTitulo":    437
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO VI",
                                                                                                                                     "linha":    972,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "110º",
                                                                                                                                                                             "rotulo":    "Art. 110º.",
                                                                                                                                                                             "linha":    977,
                                                                                                                                                                             "caput":    "As medidas de segurança são pessoais ou patrimoniais.",
                                                                                                                                                                             "rubrica":    "Espécies de medidas de segurança",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    979,
                                                                                                                                                                                                                            "texto":    "As medidas de segurança pessoais subdividem-se em:",
                                                                                                                                                                                                                            "incisos":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "I",
                                                                                                                                                                                                                                                                    "rotulo":    "I",
                                                                                                                                                                                                                                                                    "linha":    981,
                                                                                                                                                                                                                                                                    "texto":    "detentivas: compreendem a internação em estabelecimento de custódia e tratamento ou em seção especial de estabelecimento penal;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "II",
                                                                                                                                                                                                                                                                    "rotulo":    "II",
                                                                                                                                                                                                                                                                    "linha":    983,
                                                                                                                                                                                                                                                                    "texto":    "não detentivas: compreendem o tratamento ambulatorial, a interdição de licença para direção de veículos motorizados, o exílio local e a proibição de frequentar determinados lugares."
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    985,
                                                                                                                                                                                                                            "texto":    "As medidas de segurança patrimoniais compreendem a interdição de estabelecimento ou sede de sociedade ou associação e o confisco."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "111º",
                                                                                                                                                                             "rotulo":    "Art. 111º.",
                                                                                                                                                                             "linha":    989,
                                                                                                                                                                             "caput":    "As medidas de segurança sòmente podem ser impostas:",
                                                                                                                                                                             "rubrica":    "Pessoas sujeitas às medidas de segurança",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    991,
                                                                                                                                                                                                                     "texto":    "aos civis;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    994,
                                                                                                                                                                                                                     "texto":    "aos militares condenados a pena privativa de liberdade por tempo superior a 2 (dois) anos, aos que de outro modo hajam perdido função, posto ou patente ou aos que tenham sido excluídos das Forças Armadas;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    997,
                                                                                                                                                                                                                     "texto":    "aos militares, no caso do art. 48 deste Código;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "IV",
                                                                                                                                                                                                                     "rotulo":    "IV",
                                                                                                                                                                                                                     "linha":    1000,
                                                                                                                                                                                                                     "texto":    "aos militares, no caso do art. 115 deste Código, com aplicação dos seus §§ 1º, 2º e 3º."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "112º",
                                                                                                                                                                             "rotulo":    "Art. 112º.",
                                                                                                                                                                             "linha":    1007,
                                                                                                                                                                             "caput":    "Quando o agente é inimputável, nos termos do art. 48 deste Código, o juiz poderá determinar sua internação em estabelecimento de custódia e tratamento.",
                                                                                                                                                                             "rubrica":    "Estabelecimento de custódia e tratamento",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1012,
                                                                                                                                                                                                                            "texto":    "A internação ou o tratamento ambulatorial será por tempo indeterminado, perdurando enquanto não for averiguada, mediante perícia médica, a cessação da periculosidade, observado que o prazo mínimo deverá ser de 1 (um) a 3 (três) anos.",
                                                                                                                                                                                                                            "rubrica":    "Prazo de internação"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1017,
                                                                                                                                                                                                                            "texto":    "A perícia médica realizar-se-á ao término do prazo mínimo fixado e deverá ser repetida de ano em ano, ou a qualquer tempo, se o determinar o juiz da execução.",
                                                                                                                                                                                                                            "rubrica":    "Perícia médica"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1024,
                                                                                                                                                                                                                            "texto":    "A desinternação ou a liberação será sempre condicional, devendo ser restabelecida a situação anterior se o agente, antes do decurso de 1 (um) ano, praticar fato indicativo de persistência de sua periculosidade.",
                                                                                                                                                                                                                            "rubrica":    "Desinternação ou liberação condicional"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "4",
                                                                                                                                                                                                                            "rotulo":    "§ 4",
                                                                                                                                                                                                                            "linha":    1026,
                                                                                                                                                                                                                            "texto":    "Durante o período previsto no § 3º deste artigo, aplicar-se-á o disposto no art. 92 deste Código."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "5",
                                                                                                                                                                                                                            "rotulo":    "§ 5",
                                                                                                                                                                                                                            "linha":    1028,
                                                                                                                                                                                                                            "texto":    "Em qualquer fase do tratamento ambulatorial, poderá o juiz determinar a internação do agente, se essa providência for necessária para fins curativos."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "113º",
                                                                                                                                                                             "rotulo":    "Art. 113º.",
                                                                                                                                                                             "linha":    1034,
                                                                                                                                                                             "caput":    "Na hipótese do parágrafo único do art. 48 deste Código, e se o condenado necessitar de especial tratamento curativo destinado aos inimputáveis, a pena privativa de liberdade poderá ser substituída por internação ou por tratamento ambulatorial, pelo prazo mínimo de 1 (um) a 3 (três) anos, nos termos do art. 112 deste Código.",
                                                                                                                                                                             "rubrica":    "Substituição da pena por internação",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1038,
                                                                                                                                                                                                                            "texto":    "Sobrevindo a cura, pode o internado ser transferido para o estabelecimento penal, não ficando excluído o seu direito a livramento condicional.",
                                                                                                                                                                                                                            "rubrica":    "Superveniência de cura"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1042,
                                                                                                                                                                                                                            "texto":    "Se, ao término do prazo, persistir o mórbido estado psíquico do internado, condicionante de periculosidade atual, a internação passa a ser por tempo indeterminado, aplicando-se o disposto nos §§ 1º a 4º do artigo anterior.",
                                                                                                                                                                                                                            "rubrica":    "Persistência do estado mórbido"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1046,
                                                                                                                                                                                                                            "texto":    "À idêntica internação para fim curativo, sob as mesmas normas, ficam sujeitos os condenados reconhecidos como ébrios habituais ou toxicômanos.",
                                                                                                                                                                                                                            "rubrica":    "Ébrios habituais ou toxicômanos"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "114º",
                                                                                                                                                                             "rotulo":    "Art. 114º.",
                                                                                                                                                                             "linha":    1050,
                                                                                                                                                                             "caput":    "A internação, em qualquer dos casos previstos nos artigos precedentes, deve visar não apenas ao tratamento curativo do internado, senão também ao seu aperfeiçoamento, a um regime educativo ou de trabalho, lucrativo ou não, segundo o permitirem suas condições pessoais.",
                                                                                                                                                                             "rubrica":    "Regime de internação"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "115º",
                                                                                                                                                                             "rotulo":    "Art. 115º.",
                                                                                                                                                                             "linha":    1054,
                                                                                                                                                                             "caput":    "Ao condenado por crime cometido na direção ou relacionadamente à direção de veículos motorizados, deve ser cassada a licença para tal fim, pelo prazo mínimo de um ano, se as circunstâncias do caso e os antecedentes do condenado revelam a sua inaptidão para essa atividade e conseqüente perigo para a incolumidade alheia.",
                                                                                                                                                                             "rubrica":    "Cassação de licença para dirigir veículos motorizados",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1056,
                                                                                                                                                                                                                            "texto":    "O prazo da interdição se conta do dia em que termina a execução da pena privativa de liberdade ou da medida de segurança detentiva, ou da data da suspensão condicional da pena ou da concessão do livramento ou desinternação condicionais."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1058,
                                                                                                                                                                                                                            "texto":    "Se, antes de expirado o prazo estabelecido, é averiguada a cessação do perigo condicionante da interdição, esta é revogada; mas, se o perigo persiste ao têrmo do prazo, prorroga-se êste enquanto não cessa aquêle."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1060,
                                                                                                                                                                                                                            "texto":    "A cassação da licença deve ser determinada ainda no caso de absolvição do réu em razão de inimputabilidade."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "116º",
                                                                                                                                                                             "rotulo":    "Art. 116º.",
                                                                                                                                                                             "linha":    1064,
                                                                                                                                                                             "caput":    "O exílio local, aplicável quando o juiz o considera necessário como medida preventiva, a bem da ordem pública ou do próprio condenado, consiste na proibição de que êste resida ou permaneça, durante um ano, pelo menos, na localidade, município ou comarca em que o crime foi praticado.",
                                                                                                                                                                             "rubrica":    "Exílio local",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1066,
                                                                                                                                                                                                                            "texto":    "O exílio deve ser cumprido logo que cessa ou é suspensa condicionalmente a execução da pena privativa de liberdade."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "117º",
                                                                                                                                                                             "rotulo":    "Art. 117º.",
                                                                                                                                                                             "linha":    1070,
                                                                                                                                                                             "caput":    "A proibição de freqüentar determinados lugares consiste em privar o condenado, durante um ano, pelo menos, da faculdade de acesso a lugares que favoreçam, por qualquer motivo, seu retôrno à atividade criminosa.",
                                                                                                                                                                             "rubrica":    "Proibição de freqüentar determinados lugares",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1072,
                                                                                                                                                                                                                            "texto":    "Para o cumprimento da proibição, aplica-se o disposto no parágrafo único do artigo anterior."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "118º",
                                                                                                                                                                             "rotulo":    "Art. 118º.",
                                                                                                                                                                             "linha":    1076,
                                                                                                                                                                             "caput":    "A interdição de estabelecimento comercial ou industrial, ou de sociedade ou associação, pode ser decretada por tempo não inferior a quinze dias, nem superior a seis meses, se o estabelecimento, sociedade ou associação serve de meio ou pretexto para a prática de infração penal.",
                                                                                                                                                                             "rubrica":    "Interdição de estabelecimento, sociedade ou associação",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1078,
                                                                                                                                                                                                                            "texto":    "A interdição consiste na proibição de exercer no local o mesmo comércio ou indústria, ou a atividade social."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1080,
                                                                                                                                                                                                                            "texto":    "A sociedade ou associação, cuja sede é interditada, não pode exercer em outro local as suas atividades."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "119º",
                                                                                                                                                                             "rotulo":    "Art. 119º.",
                                                                                                                                                                             "linha":    1084,
                                                                                                                                                                             "caput":    "O juiz, embora não apurada a autoria, ou ainda quando o agente é inimputável, ou não punível, deve ordenar o confisco dos instrumentos e produtos do crime, desde que consistam em coisas:",
                                                                                                                                                                             "rubrica":    "Confisco",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    1086,
                                                                                                                                                                                                                     "texto":    "cujo fabrico, alienação, uso, porte ou detenção constitui fato ilícito;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    1088,
                                                                                                                                                                                                                     "texto":    "que, pertencendo às fôrças armadas ou sendo de uso exclusivo de militares, estejam em poder ou em uso do agente, ou de pessoa não devidamente autorizada;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    1090,
                                                                                                                                                                                                                     "texto":    "abandonadas, ocultas ou desaparecidas."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1092,
                                                                                                                                                                                                                            "texto":    "É ressalvado o direito do lesado ou de terceiro de boa-fé, nos casos dos ns. I e III."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "120º",
                                                                                                                                                                             "rotulo":    "Art. 120º.",
                                                                                                                                                                             "linha":    1096,
                                                                                                                                                                             "caput":    "A medida de segurança é imposta em sentença, que lhe estabelecerá as condições, nos têrmos da lei penal militar.",
                                                                                                                                                                             "rubrica":    "Imposição da medida de segurança",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1098,
                                                                                                                                                                                                                            "texto":    "A imposição da medida de segurança não impede a expulsão do estrangeiro."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DAS MEDIDAS DE SEGURANÇA",
                                                                                                                                     "linhaTitulo":    973
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO VII",
                                                                                                                                     "linha":    1100,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "121º",
                                                                                                                                                                             "rotulo":    "Art. 121º.",
                                                                                                                                                                             "linha":    1105,
                                                                                                                                                                             "caput":    "A ação penal é promovida pelo Ministério Público, na forma da lei.",
                                                                                                                                                                             "rubrica":    "Propositura da ação penal",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1107,
                                                                                                                                                                                                                            "texto":    "Será admitida ação privada, se a ação pública não for intentada no prazo legal."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "122º",
                                                                                                                                                                             "rotulo":    "Art. 122º.",
                                                                                                                                                                             "linha":    1112,
                                                                                                                                                                             "caput":    "Nos crimes previstos nos arts. 136 a 141 deste Código, a ação penal, quando o agente for militar, depende da requisição do Comando da Força a que aquele estiver subordinado, observado que, no caso do art. 141, quando o agente for civil e não houver coautor militar, a requisição será do Ministério da Justiça.",
                                                                                                                                                                             "rubrica":    "Dependência de requisição"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DA AÇÃO PENAL",
                                                                                                                                     "linhaTitulo":    1101
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO VIII",
                                                                                                                                     "linha":    1114,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "123º",
                                                                                                                                                                             "rotulo":    "Art. 123º.",
                                                                                                                                                                             "linha":    1118,
                                                                                                                                                                             "caput":    "Extingue-se a punibilidade:",
                                                                                                                                                                             "rubrica":    "Causas extintivas",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    1120,
                                                                                                                                                                                                                     "texto":    "pela morte do agente;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    1123,
                                                                                                                                                                                                                     "texto":    "pela anistia, graça ou indulto;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    1125,
                                                                                                                                                                                                                     "texto":    "pela retroatividade de lei que não mais considera o fato como criminoso;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "IV",
                                                                                                                                                                                                                     "rotulo":    "IV",
                                                                                                                                                                                                                     "linha":    1127,
                                                                                                                                                                                                                     "texto":    "pela prescrição;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "V",
                                                                                                                                                                                                                     "rotulo":    "V",
                                                                                                                                                                                                                     "linha":    1131,
                                                                                                                                                                                                                     "texto":    ";",
                                                                                                                                                                                                                     "rubrica":    "Vigência"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "VI",
                                                                                                                                                                                                                     "rotulo":    "VI",
                                                                                                                                                                                                                     "linha":    1133,
                                                                                                                                                                                                                     "texto":    "pelo ressarcimento do dano, no peculato culposo (art. 303, § 4º)."
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "VII",
                                                                                                                                                                                                                     "rotulo":    "VII",
                                                                                                                                                                                                                     "linha":    1135,
                                                                                                                                                                                                                     "texto":    "pelo perdão judicial, nos casos previstos em lei."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1137,
                                                                                                                                                                                                                            "texto":    "A extinção da punibilidade de crime, que é pressuposto, elemento constitutivo ou circunstância agravante de outro, não se estende a êste. Nos crimes conexos, a extinção da punibilidade de um dêles não impede, quanto aos outros, a agravação da pena resultante da conexão."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "124º",
                                                                                                                                                                             "rotulo":    "Art. 124º.",
                                                                                                                                                                             "linha":    1143,
                                                                                                                                                                             "caput":    "A prescrição refere-se à pretensão punitiva ou à executória.",
                                                                                                                                                                             "rubrica":    "Espécies de prescrição"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "125º",
                                                                                                                                                                             "rotulo":    "Art. 125º.",
                                                                                                                                                                             "linha":    1150,
                                                                                                                                                                             "caput":    "A prescrição da pretensão punitiva, salvo o disposto no § 1º deste artigo, regula-se pelo máximo da pena privativa de liberdade cominada ao crime, verificando-se:",
                                                                                                                                                                             "rubrica":    "Prescrição da pretensão punitiva",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    1152,
                                                                                                                                                                                                                     "texto":    "em trinta anos, se a pena é de morte;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    1154,
                                                                                                                                                                                                                     "texto":    "em vinte anos, se o máximo da pena é superior a doze;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    1156,
                                                                                                                                                                                                                     "texto":    "em dezesseis anos, se o máximo da pena é superior a oito e não excede a doze;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "IV",
                                                                                                                                                                                                                     "rotulo":    "IV",
                                                                                                                                                                                                                     "linha":    1158,
                                                                                                                                                                                                                     "texto":    "em doze anos, se o máximo da pena é superior a quatro e não excede a oito;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "V",
                                                                                                                                                                                                                     "rotulo":    "V",
                                                                                                                                                                                                                     "linha":    1160,
                                                                                                                                                                                                                     "texto":    "em oito anos, se o máximo da pena é superior a dois e não excede a quatro;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "VI",
                                                                                                                                                                                                                     "rotulo":    "VI",
                                                                                                                                                                                                                     "linha":    1162,
                                                                                                                                                                                                                     "texto":    "em quatro anos, se o máximo da pena é igual a um ano ou, sendo superior, não excede a dois;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "VII",
                                                                                                                                                                                                                     "rotulo":    "VII",
                                                                                                                                                                                                                     "linha":    1165,
                                                                                                                                                                                                                     "texto":    "em 3 (três) anos, se o máximo da pena é inferior a 1 (um) ano."
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ],
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1169,
                                                                                                                                                                                                                            "texto":    "Sobrevindo sentença condenatória, de que sòmente o réu tenha recorrido, a prescrição passa a regular-se pela pena imposta, e deve ser logo declarada, sem prejuízo do andamento do recurso se, entre a última causa interruptiva do curso da prescrição (§ 5°) e a sentença, já decorreu tempo suficiente.",
                                                                                                                                                                                                                            "rubrica":    "Superveniência de sentença condenatória de que sòmente o réu recorre"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1173,
                                                                                                                                                                                                                            "texto":    "A prescrição da ação penal começa a correr:",
                                                                                                                                                                                                                            "rubrica":    "Têrmo inicial da prescrição da ação penal",
                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "letra":    "a",
                                                                                                                                                                                                                                                                    "rotulo":    "a)",
                                                                                                                                                                                                                                                                    "linha":    1175,
                                                                                                                                                                                                                                                                    "texto":    "do dia em que o crime se consumou;",
                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                            "letra":    "b",
                                                                                                                                                                                                                                                                                                            "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                            "linha":    1177,
                                                                                                                                                                                                                                                                                                            "texto":    "no caso de tentativa, do dia em que cessou a atividade criminosa;",
                                                                                                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                    "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                    "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                    "linha":    1179,
                                                                                                                                                                                                                                                                                                                                                    "texto":    "nos crimes permanentes, do dia em que cessou a permanência;",
                                                                                                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                            "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                            "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                            "linha":    1181,
                                                                                                                                                                                                                                                                                                                                                                                            "texto":    "nos crimes de falsidade, da data em que o fato se tornou conhecido."
                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1185,
                                                                                                                                                                                                                            "texto":    "No caso de concurso de crimes ou de crime continuado, a prescrição é referida, não à pena unificada, mas à de cada crime considerado isoladamente.",
                                                                                                                                                                                                                            "rubrica":    "Caso de concurso de crimes ou de crime continuado"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "4",
                                                                                                                                                                                                                            "rotulo":    "§ 4",
                                                                                                                                                                                                                            "linha":    1189,
                                                                                                                                                                                                                            "texto":    "A prescrição da ação penal não corre:",
                                                                                                                                                                                                                            "rubrica":    "Suspensão da prescrição",
                                                                                                                                                                                                                            "incisos":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "I",
                                                                                                                                                                                                                                                                    "rotulo":    "I",
                                                                                                                                                                                                                                                                    "linha":    1191,
                                                                                                                                                                                                                                                                    "texto":    "enquanto não resolvida, em outro processo, questão de que dependa o reconhecimento da existência do crime;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "II",
                                                                                                                                                                                                                                                                    "rotulo":    "II",
                                                                                                                                                                                                                                                                    "linha":    1193,
                                                                                                                                                                                                                                                                    "texto":    "enquanto o agente cumpre pena no estrangeiro."
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "III",
                                                                                                                                                                                                                                                                    "rotulo":    "III",
                                                                                                                                                                                                                                                                    "linha":    1195,
                                                                                                                                                                                                                                                                    "texto":    "enquanto pendentes embargos de declaração ou recursos ao Supremo Tribunal Federal, se estes forem considerados inadmissíveis."
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "5",
                                                                                                                                                                                                                            "rotulo":    "§ 5",
                                                                                                                                                                                                                            "linha":    1199,
                                                                                                                                                                                                                            "texto":    "O curso da prescrição da ação penal interrompe-se:",
                                                                                                                                                                                                                            "rubrica":    "Interrupção da prescrição",
                                                                                                                                                                                                                            "incisos":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "I",
                                                                                                                                                                                                                                                                    "rotulo":    "I",
                                                                                                                                                                                                                                                                    "linha":    1201,
                                                                                                                                                                                                                                                                    "texto":    "pela instauração do processo;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "II",
                                                                                                                                                                                                                                                                    "rotulo":    "II",
                                                                                                                                                                                                                                                                    "linha":    1204,
                                                                                                                                                                                                                                                                    "texto":    "pela sentença condenatória ou acórdão condenatório recorríveis;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "III",
                                                                                                                                                                                                                                                                    "rotulo":    "III",
                                                                                                                                                                                                                                                                    "linha":    1206,
                                                                                                                                                                                                                                                                    "texto":    "pelo início ou continuação da execução provisória ou definitiva da pena; e"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "IV",
                                                                                                                                                                                                                                                                    "rotulo":    "IV",
                                                                                                                                                                                                                                                                    "linha":    1208,
                                                                                                                                                                                                                                                                    "texto":    "pela reincidência."
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "6",
                                                                                                                                                                                                                            "rotulo":    "§ 6",
                                                                                                                                                                                                                            "linha":    1210,
                                                                                                                                                                                                                            "texto":    "A interrupção da prescrição produz efeito relativamente a todos os autores do crime; e nos crimes conexos, que sejam objeto do mesmo processo, a interrupção relativa a qualquer dêles estende-se aos demais."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "126º",
                                                                                                                                                                             "rotulo":    "Art. 126º.",
                                                                                                                                                                             "linha":    1214,
                                                                                                                                                                             "caput":    "A prescrição da execução da pena privativa de liberdade ou da medida de segurança que a substitui (art. 113) regula-se pelo tempo fixado na sentença e verifica-se nos mesmos prazos estabelecidos no art. 125, os quais se aumentam de um têrço, se o condenado é criminoso habitual ou por tendência.",
                                                                                                                                                                             "rubrica":    "Prescrição da execução da pena ou da medida de segurança que a substitui",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1216,
                                                                                                                                                                                                                            "texto":    "Começa a correr a prescrição:",
                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "letra":    "a",
                                                                                                                                                                                                                                                                    "rotulo":    "a)",
                                                                                                                                                                                                                                                                    "linha":    1218,
                                                                                                                                                                                                                                                                    "texto":    "do dia em que passa em julgado a sentença condenatória ou a que revoga a suspensão condicional da pena ou o livramento condicional;",
                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                            "letra":    "b",
                                                                                                                                                                                                                                                                                                            "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                            "linha":    1220,
                                                                                                                                                                                                                                                                                                            "texto":    "do dia em que se interrompe a execução, salvo quando o tempo da interrupção deva computar-se na pena."
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1222,
                                                                                                                                                                                                                            "texto":    "No caso de evadir-se o condenado ou de revogar-se o livramento ou desinternação condicionais, a prescrição se regula pelo restante tempo da execução."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1224,
                                                                                                                                                                                                                            "texto":    "O curso da prescrição da execução da pena suspende-se enquanto o condenado está prêso por outro motivo, e interrompe-se pelo início ou continuação do cumprimento da pena, ou pela reincidência."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "128º",
                                                                                                                                                                             "rotulo":    "Art. 128º.",
                                                                                                                                                                             "linha":    1232,
                                                                                                                                                                             "caput":    "Interrompida a prescrição, salvo o caso do § 3º, segunda parte, do art. 126, todo o prazo começa a correr, novamente, do dia da interrupção.",
                                                                                                                                                                             "rubrica":    "Disposições comuns a ambas as espécies de prescrição"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "129º",
                                                                                                                                                                             "rotulo":    "Art. 129º.",
                                                                                                                                                                             "linha":    1236,
                                                                                                                                                                             "caput":    "São reduzidos de metade os prazos da prescrição, quando o criminoso era, ao tempo do crime, menor de vinte e um anos ou maior de setenta.",
                                                                                                                                                                             "rubrica":    "Redução"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "130º",
                                                                                                                                                                             "rotulo":    "Art. 130º.",
                                                                                                                                                                             "linha":    1240,
                                                                                                                                                                             "caput":    "É imprescritível a execução das penas acessórias.",
                                                                                                                                                                             "rubrica":    "Imprescritibilidade das penas acessórias"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "131º",
                                                                                                                                                                             "rotulo":    "Art. 131º.",
                                                                                                                                                                             "linha":    1244,
                                                                                                                                                                             "caput":    "A prescrição começa a correr, no crime de insubmissão, do dia em que o insubmisso atinge a idade de trinta anos.",
                                                                                                                                                                             "rubrica":    "Prescrição no caso de insubmissão"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "132º",
                                                                                                                                                                             "rotulo":    "Art. 132º.",
                                                                                                                                                                             "linha":    1248,
                                                                                                                                                                             "caput":    "No crime de deserção, embora decorrido o prazo da prescrição, esta só extingue a punibilidade quando o desertor atinge a idade de quarenta e cinco anos, e, se oficial, a de sessenta.",
                                                                                                                                                                             "rubrica":    "Prescrição no caso de deserção"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "133º",
                                                                                                                                                                             "rotulo":    "Art. 133º.",
                                                                                                                                                                             "linha":    1252,
                                                                                                                                                                             "caput":    "A prescrição, embora não alegada, deve ser declarada de ofício.",
                                                                                                                                                                             "rubrica":    "Declaração de ofício"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "134º",
                                                                                                                                                                             "rotulo":    "Art. 134º.",
                                                                                                                                                                             "linha":    1256,
                                                                                                                                                                             "caput":    "A reabilitação alcança quaisquer penas impostas por sentença definitiva.",
                                                                                                                                                                             "rubrica":    "Reabilitação",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1258,
                                                                                                                                                                                                                            "texto":    "A reabilitação poderá ser requerida decorridos cinco anos do dia em que fôr extinta, de qualquer modo, a pena principal ou terminar a execução desta ou da medida de segurança aplicada em substituição (art. 113), ou do dia em que terminar o prazo da suspensão condicional da pena ou do livramento condicional, desde que o condenado:",
                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "letra":    "a",
                                                                                                                                                                                                                                                                    "rotulo":    "a)",
                                                                                                                                                                                                                                                                    "linha":    1260,
                                                                                                                                                                                                                                                                    "texto":    "tenha tido domicílio no País, no prazo acima referido;",
                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                            "letra":    "b",
                                                                                                                                                                                                                                                                                                            "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                            "linha":    1262,
                                                                                                                                                                                                                                                                                                            "texto":    "tenha dado, durante êsse tempo, demonstração efetiva e constante de bom comportamento público e privado;",
                                                                                                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                                                                                                    "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                    "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                    "linha":    1264,
                                                                                                                                                                                                                                                                                                                                                    "texto":    "tenha ressarcido o dano causado pelo crime ou demonstre absoluta impossibilidade de o fazer até o dia do pedido, ou exiba documento que comprove a renúncia da vítima ou novação da dívida."
                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1266,
                                                                                                                                                                                                                            "texto":    "A reabilitação não pode ser concedida:",
                                                                                                                                                                                                                            "alineas":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "letra":    "a",
                                                                                                                                                                                                                                                                    "rotulo":    "a)",
                                                                                                                                                                                                                                                                    "linha":    1268,
                                                                                                                                                                                                                                                                    "texto":    "em favor dos que foram reconhecidos perigosos, salvo prova cabal em contrário;",
                                                                                                                                                                                                                                                                    "alineas":    [
                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                            "letra":    "b",
                                                                                                                                                                                                                                                                                                            "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                            "linha":    1270,
                                                                                                                                                                                                                                                                                                            "texto":    "em relação aos atingidos pelas penas acessórias do art. 98, inciso VII, se o crime fôr de natureza sexual em detrimento de filho, tutelado ou curatelado."
                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                            ]
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1274,
                                                                                                                                                                                                                            "texto":    "Negada a reabilitação, não pode ser novamente requerida senão após o decurso de dois anos.",
                                                                                                                                                                                                                            "rubrica":    "Prazo para renovação do pedido"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "4",
                                                                                                                                                                                                                            "rotulo":    "§ 4",
                                                                                                                                                                                                                            "linha":    1276,
                                                                                                                                                                                                                            "texto":    "Os prazos para o pedido de reabilitação serão contados em dôbro no caso de criminoso habitual ou por tendência."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "5",
                                                                                                                                                                                                                            "rotulo":    "§ 5",
                                                                                                                                                                                                                            "linha":    1280,
                                                                                                                                                                                                                            "texto":    "A reabilitação será revogada de ofício, ou a requerimento do Ministério Público, se a pessoa reabilitada fôr condenada, por decisão definitiva, ao cumprimento de pena privativa da liberdade.",
                                                                                                                                                                                                                            "rubrica":    "Revogação"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "135º",
                                                                                                                                                                             "rotulo":    "Art. 135º.",
                                                                                                                                                                             "linha":    1284,
                                                                                                                                                                             "caput":    "Declarada a reabilitação, serão cancelados, mediante averbação, os antecedentes criminais.",
                                                                                                                                                                             "rubrica":    "Cancelamento do registro de condenações penais",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1288,
                                                                                                                                                                                                                            "texto":    "Concedida a reabilitação, o registro oficial de condenações penais não pode ser comunicado senão à autoridade policial ou judiciária, ou ao representante do Ministério Público, para instrução de processo penal que venha a ser instaurado contra o reabilitado.",
                                                                                                                                                                                                                            "rubrica":    "Sigilo sôbre antecedentes criminais"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DA EXTINÇÃO DA PUNIBILIDADE",
                                                                                                                                     "linhaTitulo":    1115
                                                                                                                             }
                                                                                                                     ],
                                                                                            "artigos":    [

                                                                                                                    ]
                                                                                    }
                                                                            ],
                                                 "artigos":    [

                                                                         ]
                                         },
                                         {
                                                 "tipo":    "parte",
                                                 "rotulo":    "PARTE ESPECIAL",
                                                 "linha":    1290,
                                                 "divisoes":    [
                                                                                    {
                                                                                            "tipo":    "livro",
                                                                                            "rotulo":    "LIVRO I",
                                                                                            "linha":    1291,
                                                                                            "divisoes":    [
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO I",
                                                                                                                                     "linha":    1294,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "136º",
                                                                                                                                                                             "rotulo":    "Art. 136º.",
                                                                                                                                                                             "linha":    1299,
                                                                                                                                                                             "caput":    "Praticar o militar ato de hostilidade contra país estrangeiro, expondo o Brasil a perigo de guerra:",
                                                                                                                                                                             "pena":    "reclusão, de oito a quinze anos.",
                                                                                                                                                                             "rubrica":    "Hostilidade contra país estrangeiro",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1305,
                                                                                                                                                                                                                            "texto":    "Se resulta ruptura de relações diplomáticas, represália ou retorsão:",
                                                                                                                                                                                                                            "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1309,
                                                                                                                                                                                                                            "texto":    "Se resulta guerra:",
                                                                                                                                                                                                                            "rubrica":    "Pena - reclusão, de dez a vinte e quatro anos."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "137º",
                                                                                                                                                                             "rotulo":    "Art. 137º.",
                                                                                                                                                                             "linha":    1315,
                                                                                                                                                                             "caput":    "Provocar o militar, diretamente, país estrangeiro a declarar guerra ou mover hostilidade contra o Brasil ou a intervir em questão que respeite à soberania nacional:",
                                                                                                                                                                             "pena":    "reclusão, de doze a trinta anos.",
                                                                                                                                                                             "rubrica":    "Provocação a país estrangeiro"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "138º",
                                                                                                                                                                             "rotulo":    "Art. 138º.",
                                                                                                                                                                             "linha":    1321,
                                                                                                                                                                             "caput":    "Praticar o militar, indevidamente, no território nacional, ato de jurisdição de país estrangeiro, ou favorecer a prática de ato dessa natureza:",
                                                                                                                                                                             "pena":    "reclusão, de cinco a quinze anos.",
                                                                                                                                                                             "rubrica":    "Ato de jurisdição indevida"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "139º",
                                                                                                                                                                             "rotulo":    "Art. 139º.",
                                                                                                                                                                             "linha":    1327,
                                                                                                                                                                             "caput":    "Violar o militar território estrangeiro, com o fim de praticar ato de jurisdição em nome do Brasil:",
                                                                                                                                                                             "pena":    "reclusão, de dois a seis anos.",
                                                                                                                                                                             "rubrica":    "Violação de território estrangeiro"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "140º",
                                                                                                                                                                             "rotulo":    "Art. 140º.",
                                                                                                                                                                             "linha":    1333,
                                                                                                                                                                             "caput":    "Entrar ou tentar entrar o militar em entendimento com país estrangeiro, para empenhar o Brasil à neutralidade ou à guerra:",
                                                                                                                                                                             "pena":    "reclusão, de seis a doze anos.",
                                                                                                                                                                             "rubrica":    "Entendimento para empenhar o Brasil à neutralidade ou à guerra"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "141º",
                                                                                                                                                                             "rotulo":    "Art. 141º.",
                                                                                                                                                                             "linha":    1339,
                                                                                                                                                                             "caput":    "Entrar em entendimento com país estrangeiro, ou organização nêle existente, para gerar conflito ou divergência de caráter internacional entre o Brasil e qualquer outro país, ou para lhes perturbar as relações diplomáticas:",
                                                                                                                                                                             "pena":    "reclusão, de quatro a oito anos.",
                                                                                                                                                                             "rubrica":    "Entendimento para gerar conflito ou divergência com o Brasil",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1345,
                                                                                                                                                                                                                            "texto":    "Se resulta ruptura de relações diplomáticas:",
                                                                                                                                                                                                                            "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1349,
                                                                                                                                                                                                                            "texto":    "Se resulta guerra:",
                                                                                                                                                                                                                            "rubrica":    "Pena - reclusão, de seis a dezoito anos."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "142º",
                                                                                                                                                                             "rotulo":    "Art. 142º.",
                                                                                                                                                                             "linha":    1355,
                                                                                                                                                                             "caput":    "Tentar:",
                                                                                                                                                                             "rubrica":    "Tentativa contra a soberania do Brasil",
                                                                                                                                                                             "incisos":    [
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "I",
                                                                                                                                                                                                                     "rotulo":    "I",
                                                                                                                                                                                                                     "linha":    1357,
                                                                                                                                                                                                                     "texto":    "submeter o território nacional, ou parte dêle, à soberania de país estrangeiro;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "II",
                                                                                                                                                                                                                     "rotulo":    "II",
                                                                                                                                                                                                                     "linha":    1359,
                                                                                                                                                                                                                     "texto":    "desmembrar, por meio de movimento armado ou tumultos planejados, o território nacional, desde que o fato atente contra a segurança externa do Brasil ou a sua soberania;"
                                                                                                                                                                                                             },
                                                                                                                                                                                                             {
                                                                                                                                                                                                                     "numero":    "III",
                                                                                                                                                                                                                     "rotulo":    "III",
                                                                                                                                                                                                                     "linha":    1361,
                                                                                                                                                                                                                     "texto":    "internacionalizar, por qualquer meio, região ou parte do território nacional:"
                                                                                                                                                                                                             }
                                                                                                                                                                                                     ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "143º",
                                                                                                                                                                             "rotulo":    "Art. 143º.",
                                                                                                                                                                             "linha":    1367,
                                                                                                                                                                             "caput":    "Conseguir, para o fim de espionagem militar, notícia, informação ou documento, cujo sigilo seja de interêsse da segurança externa do Brasil:",
                                                                                                                                                                             "pena":    "reclusão, de quatro a doze anos.",
                                                                                                                                                                             "rubrica":    "Consecução de notícia, informação ou documento para fim de espionagem",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1371,
                                                                                                                                                                                                                            "texto":    "A pena é de reclusão de dez a vinte anos:",
                                                                                                                                                                                                                            "incisos":    [
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "I",
                                                                                                                                                                                                                                                                    "rotulo":    "I",
                                                                                                                                                                                                                                                                    "linha":    1373,
                                                                                                                                                                                                                                                                    "texto":    "se o fato compromete a preparação ou eficiência bélica do Brasil, ou o agente transmite ou fornece, por qualquer meio, mesmo sem remuneração, a notícia, informação ou documento, a autoridade ou pessoa estrangeira;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "II",
                                                                                                                                                                                                                                                                    "rotulo":    "II",
                                                                                                                                                                                                                                                                    "linha":    1375,
                                                                                                                                                                                                                                                                    "texto":    "se o agente, em detrimento da segurança externa do Brasil, promove ou mantém no território nacional atividade ou serviço destinado à espionagem;"
                                                                                                                                                                                                                                                            },
                                                                                                                                                                                                                                                            {
                                                                                                                                                                                                                                                                    "numero":    "III",
                                                                                                                                                                                                                                                                    "rotulo":    "III",
                                                                                                                                                                                                                                                                    "linha":    1377,
                                                                                                                                                                                                                                                                    "texto":    "se o agente se utiliza, ou contribui para que outrem se utilize, de meio de comunicação, para dar indicação que ponha ou possa pôr em perigo a segurança externa do Brasil."
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1381,
                                                                                                                                                                                                                            "texto":    "Contribuir culposamente para a execução do crime:",
                                                                                                                                                                                                                            "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "144º",
                                                                                                                                                                             "rotulo":    "Art. 144º.",
                                                                                                                                                                             "linha":    1387,
                                                                                                                                                                             "caput":    "Revelar notícia, informação ou documento, cujo sigilo seja de interêsse da segurança externa do Brasil:",
                                                                                                                                                                             "pena":    "reclusão, de três a oito anos.",
                                                                                                                                                                             "rubrica":    "Revelação de notícia, informação ou documento",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1393,
                                                                                                                                                                                                                            "texto":    "Se o fato é cometido com o fim de espionagem militar:",
                                                                                                                                                                                                                            "rubrica":    "Fim da espionagem militar"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1399,
                                                                                                                                                                                                                            "texto":    "Se o fato compromete a preparação ou a eficiência bélica do país:",
                                                                                                                                                                                                                            "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "3",
                                                                                                                                                                                                                            "rotulo":    "§ 3",
                                                                                                                                                                                                                            "linha":    1405,
                                                                                                                                                                                                                            "texto":    "Se a revelação é culposa:",
                                                                                                                                                                                                                            "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "145º",
                                                                                                                                                                             "rotulo":    "Art. 145º.",
                                                                                                                                                                             "linha":    1411,
                                                                                                                                                                             "caput":    "Suprimir, subtrair, deturpar, alterar, desviar, ainda que temporàriamente, objeto ou documento concernente à segurança externa do Brasil:",
                                                                                                                                                                             "pena":    "reclusão, de três a oito anos.",
                                                                                                                                                                             "rubrica":    "Turbação de objeto ou documento",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    1417,
                                                                                                                                                                                                                            "texto":    "Se o fato compromete a segurança ou a eficiência bélica do país:",
                                                                                                                                                                                                                            "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    1423,
                                                                                                                                                                                                                            "texto":    "Contribuir culposamente para o fato:",
                                                                                                                                                                                                                            "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "146º",
                                                                                                                                                                             "rotulo":    "Art. 146º.",
                                                                                                                                                                             "linha":    1429,
                                                                                                                                                                             "caput":    "Penetrar, sem licença, ou introduzir-se clandestinamente ou sob falso pretexto, em lugar sujeito à administração militar, ou centro industrial a serviço de construção ou fabricação sob fiscalização militar, para colhêr informação destinada a país estrangeiro ou agente seu:",
                                                                                                                                                                             "pena":    "reclusão, de três a oito anos.",
                                                                                                                                                                             "rubrica":    "Penetração com o fim de espionagem",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    1433,
                                                                                                                                                                                                                            "texto":    "Entrar, em local referido no artigo, sem licença de autoridade competente, munido de máquina fotográfica ou qualquer outro meio hábil para a prática de espionagem:"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "147º",
                                                                                                                                                                             "rotulo":    "Art. 147º.",
                                                                                                                                                                             "linha":    1439,
                                                                                                                                                                             "caput":    "Fazer desenho ou levantar plano ou planta de fortificação, quartel, fábrica, arsenal, hangar ou aeródromo, ou de navio, aeronave ou engenho de guerra motomecanizado, utilizados ou em construção sob administração ou fiscalização militar, ou fotografá-los ou filmá-los:",
                                                                                                                                                                             "pena":    "reclusão, até quatro anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                             "rubrica":    "Desenho ou levantamento de plano ou planta de local militar ou de engenho de guerra"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "148º",
                                                                                                                                                                             "rotulo":    "Art. 148º.",
                                                                                                                                                                             "linha":    1445,
                                                                                                                                                                             "caput":    "Sobrevoar local declarado interdito:",
                                                                                                                                                                             "pena":    "reclusão, até três anos.",
                                                                                                                                                                             "rubrica":    "Sobrevôo em local interdito"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA A SEGURANÇA EXTERNA DO PAÍS",
                                                                                                                                     "linhaTitulo":    1295
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO II",
                                                                                                                                     "linha":    1449,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    1452,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "149º",
                                                                                                                                                                                                                        "rotulo":    "Art. 149º.",
                                                                                                                                                                                                                        "linha":    1458,
                                                                                                                                                                                                                        "caput":    "Reunirem-se militares:",
                                                                                                                                                                                                                        "rubrica":    "Motim",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    1460,
                                                                                                                                                                                                                                                                "texto":    "agindo contra a ordem recebida de superior, ou negando-se a cumpri-la;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    1462,
                                                                                                                                                                                                                                                                "texto":    "recusando obediência a superior, quando estejam agindo sem ordem ou praticando violência;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    1464,
                                                                                                                                                                                                                                                                "texto":    "assentindo em recusa conjunta de obediência, ou em resistência ou violência, em comum, contra superior;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    1466,
                                                                                                                                                                                                                                                                "texto":    "ocupando quartel, fortaleza, arsenal, fábrica ou estabelecimento militar, ou dependência de qualquer dêles, hangar, aeródromo ou aeronave, navio ou viatura militar, ou utilizando-se de qualquer daqueles locais ou meios de transporte, para ação militar, ou prática de violência, em desobediência a ordem superior ou em detrimento da ordem ou da disciplina militar:"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1472,
                                                                                                                                                                                                                                                                     "texto":    "Se os agentes estavam armados:",
                                                                                                                                                                                                                                                                     "rubrica":    "Revolta"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "150º",
                                                                                                                                                                                                                        "rotulo":    "Art. 150º.",
                                                                                                                                                                                                                        "linha":    1479,
                                                                                                                                                                                                                        "caput":    "Reunirem-se dois ou mais militares, com armamento ou material bélico de propriedade militar, praticando violência à pessoa ou à coisa pública ou particular em lugar sujeito ou não à administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de quatro a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Organização de grupo para a prática de violência"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "151º",
                                                                                                                                                                                                                        "rotulo":    "Art. 151º.",
                                                                                                                                                                                                                        "linha":    1486,
                                                                                                                                                                                                                        "caput":    "Deixar o militar de levar ao conhecimento do superior o motim ou a revolta de cuja preparação teve notícia ou, se presenciar o ato criminoso, não usar de todos os meios ao seu alcance para impedi-lo:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de lealdade militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "152º",
                                                                                                                                                                                                                        "rotulo":    "Art. 152º.",
                                                                                                                                                                                                                        "linha":    1493,
                                                                                                                                                                                                                        "caput":    "Concertarem-se militares para a prática do crime previsto no art. 149 deste Código:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Conspiração",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1499,
                                                                                                                                                                                                                                                                     "texto":    "É isento de pena aquêle que, antes da execução do crime e quando era ainda possível evitar-lhe as conseqüências, denuncia o ajuste de que participou.",
                                                                                                                                                                                                                                                                     "rubrica":    "Isenção de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "153º",
                                                                                                                                                                                                                        "rotulo":    "Art. 153º.",
                                                                                                                                                                                                                        "linha":    1503,
                                                                                                                                                                                                                        "caput":    "As penas dos arts. 149 e 150 são aplicáveis sem prejuízo das correspondentes à violência.",
                                                                                                                                                                                                                        "rubrica":    "Cumulação de penas"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO MOTIM E DA REVOLTA",
                                                                                                                                                                                "linhaTitulo":    1453
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    1505,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "154º",
                                                                                                                                                                                                                        "rotulo":    "Art. 154º.",
                                                                                                                                                                                                                        "linha":    1510,
                                                                                                                                                                                                                        "caput":    "Aliciar militar para a prática de qualquer dos crimes previstos no Capítulo I deste Título:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Aliciação para motim ou revolta"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "155º",
                                                                                                                                                                                                                        "rotulo":    "Art. 155º.",
                                                                                                                                                                                                                        "linha":    1516,
                                                                                                                                                                                                                        "caput":    "Incitar à desobediência, à indisciplina ou à prática de crime militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Incitamento",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1521,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem introduz, afixa ou distribui, em lugar sujeito à administração militar, material impresso, manuscrito ou produzido por meio eletrônico, fotocopiado ou gravado que contenha incitamento à prática dos atos previstos no caput deste artigo."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "156º",
                                                                                                                                                                                                                        "rotulo":    "Art. 156º.",
                                                                                                                                                                                                                        "linha":    1525,
                                                                                                                                                                                                                        "caput":    "Fazer apologia de fato que a lei militar considera crime, ou do autor do mesmo, em lugar sujeito à administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Apologia de fato criminoso ou do seu autor"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA ALICIAÇÃO E DO INCITAMENTO",
                                                                                                                                                                                "linhaTitulo":    1506
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    1529,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "157º",
                                                                                                                                                                                                                        "rotulo":    "Art. 157º.",
                                                                                                                                                                                                                        "linha":    1534,
                                                                                                                                                                                                                        "caput":    "Praticar violência contra superior:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Violência contra superior",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1540,
                                                                                                                                                                                                                                                                     "texto":    "Se o superior é comandante da unidade a que pertence o agente, ou oficial general:",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1544,
                                                                                                                                                                                                                                                                     "texto":    "Se a violência é praticada com arma, a pena é aumentada de um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de três a nove anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    1546,
                                                                                                                                                                                                                                                                     "texto":    "Se da violência resulta lesão corporal, aplica-se, além da pena da violência, a do crime contra a pessoa."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    1548,
                                                                                                                                                                                                                                                                     "texto":    "Se da violência resulta morte:"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "5",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 5",
                                                                                                                                                                                                                                                                     "linha":    1552,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada da sexta parte, se o crime ocorre em serviço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de doze a trinta anos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "158º",
                                                                                                                                                                                                                        "rotulo":    "Art. 158º.",
                                                                                                                                                                                                                        "linha":    1556,
                                                                                                                                                                                                                        "caput":    "Praticar violência contra oficial de dia, de serviço, ou de quarto, ou contra sentinela, vigia ou plantão:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Violência contra militar de serviço",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1562,
                                                                                                                                                                                                                                                                     "texto":    "Se a violência é praticada com arma, a pena é aumentada de um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1564,
                                                                                                                                                                                                                                                                     "texto":    "Se da violência resulta lesão corporal, aplica-se, além da pena da violência, a do crime contra a pessoa."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    1566,
                                                                                                                                                                                                                                                                     "texto":    "Se da violência resulta morte:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "159º",
                                                                                                                                                                                                                        "rotulo":    "Art. 159º.",
                                                                                                                                                                                                                        "linha":    1572,
                                                                                                                                                                                                                        "caput":    "Quando da violência resulta morte ou lesão corporal e as circunstâncias evidenciam que o agente não quis o resultado nem assumiu o risco de produzi-lo, a pena do crime contra a pessoa é diminuída de metade.",
                                                                                                                                                                                                                        "rubrica":    "Ausência de dôlo no resultado"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA VIOLÊNCIA CONTRA SUPERIOR OU MILITAR DE SERVIÇO",
                                                                                                                                                                                "linhaTitulo":    1530
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    1574,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "160º",
                                                                                                                                                                                                                        "rotulo":    "Art. 160º.",
                                                                                                                                                                                                                        "linha":    1579,
                                                                                                                                                                                                                        "caput":    "Desrespeitar superior diante de outro militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Desrespeito a superior",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1585,
                                                                                                                                                                                                                                                                     "texto":    "Se o fato é praticado contra o comandante da unidade a que pertence o agente, oficial-general, oficial de dia, de serviço ou de quarto, a pena é aumentada da metade.",
                                                                                                                                                                                                                                                                     "rubrica":    "Desrespeito a comandante, oficial general ou oficial de serviço"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "161º",
                                                                                                                                                                                                                        "rotulo":    "Art. 161º.",
                                                                                                                                                                                                                        "linha":    1589,
                                                                                                                                                                                                                        "caput":    "Praticar o militar diante da tropa, ou em lugar sujeito à administração militar, ato que se traduza em ultraje a símbolo nacional:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Desrespeito a símbolo nacional"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "162º",
                                                                                                                                                                                                                        "rotulo":    "Art. 162º.",
                                                                                                                                                                                                                        "linha":    1595,
                                                                                                                                                                                                                        "caput":    "Despojar-se de uniforme, condecoração militar, insígnia ou distintivo, por menosprêzo ou vilipêndio:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Despojamento desprezível",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1599,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada da metade, se o fato é praticado diante da tropa, ou em público."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO DESRESPEITO A SUPERIOR E A SÍMBOLO NACIONAL OU A FARDA",
                                                                                                                                                                                "linhaTitulo":    1575
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO V",
                                                                                                                                                                                "linha":    1601,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "163º",
                                                                                                                                                                                                                        "rotulo":    "Art. 163º.",
                                                                                                                                                                                                                        "linha":    1605,
                                                                                                                                                                                                                        "caput":    "Recusar obedecer a ordem do superior sôbre assunto ou matéria de serviço, ou relativamente a dever impôsto em lei, regulamento ou instrução:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a dois anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Recusa de obediência"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "164º",
                                                                                                                                                                                                                        "rotulo":    "Art. 164º.",
                                                                                                                                                                                                                        "linha":    1611,
                                                                                                                                                                                                                        "caput":    "Opor-se às ordens da sentinela:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Oposição a ordem de sentinela"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "165º",
                                                                                                                                                                                                                        "rotulo":    "Art. 165º.",
                                                                                                                                                                                                                        "linha":    1617,
                                                                                                                                                                                                                        "caput":    "Promover a reunião de militares, ou nela tomar parte, para discussão de ato de superior ou assunto atinente à disciplina militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano a quem promove a reunião; de dois a seis meses a quem dela participa, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Reunião ilícita"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "166º",
                                                                                                                                                                                                                        "rotulo":    "Art. 166º.",
                                                                                                                                                                                                                        "linha":    1623,
                                                                                                                                                                                                                        "caput":    "Publicar o militar ou assemelhado, sem licença, ato ou documento oficial, ou criticar públicamente ato de seu superior ou assunto atinente à disciplina militar, ou a qualquer resolução do Govêrno:",
                                                                                                                                                                                                                        "pena":    "detenção, de dois meses a um ano, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Publicação ou crítica indevida"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA INSUBORDINAÇÃO",
                                                                                                                                                                                "linhaTitulo":    1602
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VI",
                                                                                                                                                                                "linha":    1627,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "167º",
                                                                                                                                                                                                                        "rotulo":    "Art. 167º.",
                                                                                                                                                                                                                        "linha":    1632,
                                                                                                                                                                                                                        "caput":    "Assumir o militar, sem ordem ou autorização, salvo se em grave emergência, qualquer comando, ou a direção de estabelecimento militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a quatro anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Assunção de comando sem ordem ou autorização"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "168º",
                                                                                                                                                                                                                        "rotulo":    "Art. 168º.",
                                                                                                                                                                                                                        "linha":    1638,
                                                                                                                                                                                                                        "caput":    "Conservar comando ou função legitimamente assumida, depois de receber ordem de seu superior para deixá-los ou transmiti-los a outrem:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a três anos.",
                                                                                                                                                                                                                        "rubrica":    "Conservação ilegal de comando"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "169º",
                                                                                                                                                                                                                        "rotulo":    "Art. 169º.",
                                                                                                                                                                                                                        "linha":    1644,
                                                                                                                                                                                                                        "caput":    "Determinar o comandante, sem ordem superior e fora dos casos em que essa se dispensa, movimento de tropa ou ação militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Operação militar sem ordem superior",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1650,
                                                                                                                                                                                                                                                                     "texto":    "Se o movimento da tropa ou ação militar é em território estrangeiro ou contra fôrça, navio ou aeronave de país estrangeiro:",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "170º",
                                                                                                                                                                                                                        "rotulo":    "Art. 170º.",
                                                                                                                                                                                                                        "linha":    1656,
                                                                                                                                                                                                                        "caput":    "Ordenar, arbitràriamente, o comandante de fôrça, navio, aeronave ou engenho de guerra motomecanizado a entrada de comandados seus em águas ou território estrangeiro, ou sobrevoá-los:",
                                                                                                                                                                                                                        "pena":    "detenção, de 1 (um) a 2 (dois) anos.",
                                                                                                                                                                                                                        "rubrica":    "Ordem arbitrária de invasão"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "171º",
                                                                                                                                                                                                                        "rotulo":    "Art. 171º.",
                                                                                                                                                                                                                        "linha":    1664,
                                                                                                                                                                                                                        "caput":    "Usar o militar, indevidamente, uniforme, distintivo ou insígnia de posto ou de graduação superior:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Uso indevido por militar de uniforme, distintivo ou insígnia"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "172º",
                                                                                                                                                                                                                        "rotulo":    "Art. 172º.",
                                                                                                                                                                                                                        "linha":    1670,
                                                                                                                                                                                                                        "caput":    "Usar, indevidamente, uniforme, distintivo ou insígnia militar a que não tenha direito:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Uso indevido de uniforme, distintivo ou insígnia militar por qualquer pessoa"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "173º",
                                                                                                                                                                                                                        "rotulo":    "Art. 173º.",
                                                                                                                                                                                                                        "linha":    1676,
                                                                                                                                                                                                                        "caput":    "Abusar do direito de requisição militar, excedendo os podêres conferidos ou recusando cumprir dever impôsto em lei:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Abuso de requisição militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "174º",
                                                                                                                                                                                                                        "rotulo":    "Art. 174º.",
                                                                                                                                                                                                                        "linha":    1682,
                                                                                                                                                                                                                        "caput":    "Exceder a faculdade de punir o subordinado, fazendo-o com rigor não permitido, ou ofendendo-o por palavra, ato ou escrito: A",
                                                                                                                                                                                                                        "pena":    "detenção, de 1 (um) a 2 (dois) anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Rigor excessivo"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "175º",
                                                                                                                                                                                                                        "rotulo":    "Art. 175º.",
                                                                                                                                                                                                                        "linha":    1693,
                                                                                                                                                                                                                        "caput":    "Praticar violência contra inferior hierárquico:",
                                                                                                                                                                                                                        "pena":    "detenção, de 3 (três) meses a 2 (dois) anos.",
                                                                                                                                                                                                                        "rubrica":    "Violência contra inferior hierárquico",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1699,
                                                                                                                                                                                                                                                                     "texto":    "Se da violência resulta lesão corporal ou morte é também aplicada a pena do crime contra a pessoa, atendendo-se, quando fôr o caso, ao disposto no art. 159.",
                                                                                                                                                                                                                                                                     "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "176º",
                                                                                                                                                                                                                        "rotulo":    "Art. 176º.",
                                                                                                                                                                                                                        "linha":    1706,
                                                                                                                                                                                                                        "caput":    "Ofender inferior hierárquico, mediante ato de violência que, por natureza ou pelo meio empregado, seja considerado aviltante:",
                                                                                                                                                                                                                        "pena":    "detenção, de 1 (um) a 2 (dois) anos.",
                                                                                                                                                                                                                        "rubrica":    "Ofensa aviltante a inferior hierárquico",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1710,
                                                                                                                                                                                                                                                                     "texto":    "Aplica-se o disposto no parágrafo único do artigo anterior."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA USURPAÇÃO E DO EXCESSO OU ABUSO DE AUTORIDADE",
                                                                                                                                                                                "linhaTitulo":    1628
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VII",
                                                                                                                                                                                "linha":    1712,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "177º",
                                                                                                                                                                                                                        "rotulo":    "Art. 177º.",
                                                                                                                                                                                                                        "linha":    1716,
                                                                                                                                                                                                                        "caput":    "Opor-se à execução de ato legal, mediante ameaça ou violência ao executor, ou a quem esteja prestando auxílio:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Resistência mediante ameaça ou violência",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1722,
                                                                                                                                                                                                                                                                     "texto":    "Se o ato não se executa em razão da resistência:",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1726,
                                                                                                                                                                                                                                                                     "texto":    "-A. Se da resistência resulta morte:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão de dois a quatro anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1734,
                                                                                                                                                                                                                                                                     "texto":    "As penas previstas no caput e no § 1º deste artigo são aplicáveis sem prejuízo das correspondentes à violência.",
                                                                                                                                                                                                                                                                     "rubrica":    "Cumulação de penas"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA RESISTÊNCIA",
                                                                                                                                                                                "linhaTitulo":    1713
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VIII",
                                                                                                                                                                                "linha":    1736,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "178º",
                                                                                                                                                                                                                        "rotulo":    "Art. 178º.",
                                                                                                                                                                                                                        "linha":    1741,
                                                                                                                                                                                                                        "caput":    "Promover ou facilitar a fuga de pessoa legalmente prêsa ou submetida a medida de segurança detentiva:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Fuga de prêso ou internado",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1747,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é praticado a mão armada ou por mais de uma pessoa, ou mediante arrombamento:",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1751,
                                                                                                                                                                                                                                                                     "texto":    "Se há emprêgo de violência contra pessoa, aplica-se também a pena correspondente à violência.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de dois a seis anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    1753,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é praticado por pessoa sob cuja guarda, custódia ou condução está o prêso ou internado:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "179º",
                                                                                                                                                                                                                        "rotulo":    "Art. 179º.",
                                                                                                                                                                                                                        "linha":    1759,
                                                                                                                                                                                                                        "caput":    "Deixar, por culpa, fugir pessoa legalmente prêsa, confiada à sua guarda ou condução:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "180º",
                                                                                                                                                                                                                        "rotulo":    "Art. 180º.",
                                                                                                                                                                                                                        "linha":    1765,
                                                                                                                                                                                                                        "caput":    "Evadir-se, ou tentar evadir-se o prêso ou internado, usando de violência contra a pessoa:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a dois anos, além da correspondente à violência.",
                                                                                                                                                                                                                        "rubrica":    "Evasão de prêso ou internado",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1769,
                                                                                                                                                                                                                                                                     "texto":    "Se a evasão ou a tentativa ocorre mediante arrombamento da prisão militar:"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1775,
                                                                                                                                                                                                                                                                     "texto":    "Se ao fato sucede deserção, aplicam-se cumulativamente as penas correspondentes.",
                                                                                                                                                                                                                                                                     "rubrica":    "Cumulação de penas"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "181º",
                                                                                                                                                                                                                        "rotulo":    "Art. 181º.",
                                                                                                                                                                                                                        "linha":    1779,
                                                                                                                                                                                                                        "caput":    "Arrebatar prêso ou internado, a fim de maltratá-lo, do poder de quem o tenha sob guarda ou custódia militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até quatro anos, além da correspondente à violência.",
                                                                                                                                                                                                                        "rubrica":    "Arrebatamento de prêso ou internado"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "182º",
                                                                                                                                                                                                                        "rotulo":    "Art. 182º.",
                                                                                                                                                                                                                        "linha":    1785,
                                                                                                                                                                                                                        "caput":    "Amotinarem-se presos, ou internados, perturbando a disciplina do recinto de prisão militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até três anos, aos cabeças; aos demais, detenção de um a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Amotinamento",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1791,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem participa do amotinamento ou, sendo oficial e estando presente, não usa os meios ao seu alcance para debelar o amotinamento ou evitar-lhe as conseqüências.",
                                                                                                                                                                                                                                                                     "rubrica":    "Responsabilidade de participe ou de oficial"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA FUGA, EVASÃO, ARREBATAMENTO E AMOTINAMENTO DE PRESOS",
                                                                                                                                                                                "linhaTitulo":    1737
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA A AUTORIDADE OU DISCIPLINA MILITAR",
                                                                                                                                     "linhaTitulo":    1450
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO III",
                                                                                                                                     "linha":    1793,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    1796,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "183º",
                                                                                                                                                                                                                        "rotulo":    "Art. 183º.",
                                                                                                                                                                                                                        "linha":    1800,
                                                                                                                                                                                                                        "caput":    "Deixar de apresentar-se o convocado à incorporação, dentro do prazo que lhe foi marcado, ou, apresentando-se, ausentar-se antes do ato oficial de incorporação:",
                                                                                                                                                                                                                        "pena":    "impedimento, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Insubmissão",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1806,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem, dispensado temporàriamente da incorporação, deixa de se apresentar, decorrido o prazo de licenciamento.",
                                                                                                                                                                                                                                                                     "rubrica":    "Caso assimilado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1810,
                                                                                                                                                                                                                                                                     "texto":    "A pena é diminuída de um têrço:",
                                                                                                                                                                                                                                                                     "rubrica":    "Diminuição da pena",
                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "letra":    "a",
                                                                                                                                                                                                                                                                                                             "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                             "linha":    1812,
                                                                                                                                                                                                                                                                                                             "texto":    "pela ignorância ou a errada compreensão dos atos da convocação militar, quando escusáveis;",
                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                     "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                     "linha":    1814,
                                                                                                                                                                                                                                                                                                                                                     "texto":    "pela apresentação voluntária dentro do prazo de um ano, contado do último dia marcado para a apresentação."
                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "184º",
                                                                                                                                                                                                                        "rotulo":    "Art. 184º.",
                                                                                                                                                                                                                        "linha":    1818,
                                                                                                                                                                                                                        "caput":    "Criar ou simular incapacidade física, que inabilite o convocado para o serviço militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Criação ou simulação de incapacidade física"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "185º",
                                                                                                                                                                                                                        "rotulo":    "Art. 185º.",
                                                                                                                                                                                                                        "linha":    1824,
                                                                                                                                                                                                                        "caput":    "Substituir-se o convocado por outrem na apresentação ou na inspeção de saúde.",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Substituição de convocado",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1828,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem substitui o convocado."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "186º",
                                                                                                                                                                                                                        "rotulo":    "Art. 186º.",
                                                                                                                                                                                                                        "linha":    1832,
                                                                                                                                                                                                                        "caput":    "Dar asilo a convocado, ou tomá-lo a seu serviço, ou proporcionar-lhe ou facilitar-lhe transporte ou meio que obste ou dificulte a incorporação, sabendo ou tendo razão para saber que cometeu qualquer dos crimes previstos neste capítulo:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Favorecimento a convocado",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1838,
                                                                                                                                                                                                                                                                     "texto":    "Se o favorecedor é ascendente, descendente, cônjuge ou irmão do criminoso, fica isento de pena.",
                                                                                                                                                                                                                                                                     "rubrica":    "Isenção de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA INSUBMISSÃO",
                                                                                                                                                                                "linhaTitulo":    1797
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    1840,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "187º",
                                                                                                                                                                                                                        "rotulo":    "Art. 187º.",
                                                                                                                                                                                                                        "linha":    1844,
                                                                                                                                                                                                                        "caput":    "Ausentar-se o militar, sem licença, da unidade em que serve, ou do lugar em que deve permanecer, por mais de oito dias:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos; se oficial, a pena é agravada.",
                                                                                                                                                                                                                        "rubrica":    "Deserção"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "188º",
                                                                                                                                                                                                                        "rotulo":    "Art. 188º.",
                                                                                                                                                                                                                        "linha":    1850,
                                                                                                                                                                                                                        "caput":    "Na mesma pena incorre o militar que:",
                                                                                                                                                                                                                        "rubrica":    "Casos assimilados",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    1852,
                                                                                                                                                                                                                                                                "texto":    "não se apresenta no lugar designado, dentro de oito dias, findo o prazo de trânsito ou férias;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    1854,
                                                                                                                                                                                                                                                                "texto":    "deixa de se apresentar a autoridade competente, dentro do prazo de oito dias, contados daquele em que termina ou é cassada a licença ou agregação ou em que é declarado o estado de sítio ou de guerra;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    1856,
                                                                                                                                                                                                                                                                "texto":    "tendo cumprido a pena, deixa de se apresentar, dentro do prazo de oito dias;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    1858,
                                                                                                                                                                                                                                                                "texto":    "consegue exclusão do serviço ativo ou situação de inatividade, criando ou simulando incapacidade."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "189º",
                                                                                                                                                                                                                        "rotulo":    "Art. 189º.",
                                                                                                                                                                                                                        "linha":    1860,
                                                                                                                                                                                                                        "caput":    "Nos crimes dos arts. 187 e 188, ns. I, II e III:",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    1864,
                                                                                                                                                                                                                                                                "texto":    "se o agente se apresenta voluntàriamente dentro em oito dias após a consumação do crime, a pena é diminuída de metade; e de um têrço, se de mais de oito dias e até sessenta;",
                                                                                                                                                                                                                                                                "rubrica":    "Atenuante especial"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    1868,
                                                                                                                                                                                                                                                                "texto":    "se a deserção ocorre em unidade estacionada em fronteira ou país estrangeiro, a pena é agravada de um têrço.",
                                                                                                                                                                                                                                                                "rubrica":    "Agravante especial"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "190º",
                                                                                                                                                                                                                        "rotulo":    "Art. 190º.",
                                                                                                                                                                                                                        "linha":    1873,
                                                                                                                                                                                                                        "caput":    "Deixar o militar de apresentar-se no momento da partida do navio ou aeronave, de que é tripulante, ou do deslocamento da unidade ou força em que serve:",
                                                                                                                                                                                                                        "pena":    "detenção, até três meses, se após a partida ou deslocamento se apresentar, dentro de vinte e quatro horas, à autoridade militar do lugar, ou, na falta desta, à autoridade policial, para ser comunicada a apresentação ao comando militar competente.",
                                                                                                                                                                                                                        "rubrica":    "Deserção especial",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1878,
                                                                                                                                                                                                                                                                     "texto":    "Se a apresentação se der dentro de prazo superior a vinte e quatro horas e não excedente a cinco dias:"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1884,
                                                                                                                                                                                                                                                                     "texto":    "Se superior a cinco dias e não excedente a oito dias:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - detenção, de dois a oito meses."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1888,
                                                                                                                                                                                                                                                                     "texto":    "-A. Se superior a oito dias: (Parágrafo incluído pela Lei nº 9.764, de 18.12.1998)",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - detenção, de três meses a um ano."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    1896,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de um terço, se se tratar de sargento, subtenente ou suboficial, e de metade, se oficial. (Redação dada pela Lei nº 9.764, de 18.12.1998)",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "191º",
                                                                                                                                                                                                                        "rotulo":    "Art. 191º.",
                                                                                                                                                                                                                        "linha":    1900,
                                                                                                                                                                                                                        "caput":    "Concertarem-se militares para a prática da deserção:",
                                                                                                                                                                                                                        "rubrica":    "Concêrto para deserção",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    1902,
                                                                                                                                                                                                                                                                "texto":    "se a deserção não chega a consumar-se:"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    1908,
                                                                                                                                                                                                                                                                "texto":    "se consumada a deserção:",
                                                                                                                                                                                                                                                                "rubrica":    "Modalidade complexa"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "192º",
                                                                                                                                                                                                                        "rotulo":    "Art. 192º.",
                                                                                                                                                                                                                        "linha":    1914,
                                                                                                                                                                                                                        "caput":    "Evadir-se o militar do poder da escolta, ou de recinto de detenção ou de prisão, ou fugir em seguida à prática de crime para evitar prisão, permanecendo ausente por mais de oito dias:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Deserção por evasão ou fuga"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "193º",
                                                                                                                                                                                                                        "rotulo":    "Art. 193º.",
                                                                                                                                                                                                                        "linha":    1920,
                                                                                                                                                                                                                        "caput":    "Dar asilo a desertor, ou tomá-lo a seu serviço, ou proporcionar-lhe ou facilitar-lhe transporte ou meio de ocultação, sabendo ou tendo razão para saber que cometeu qualquer dos crimes previstos neste capítulo:",
                                                                                                                                                                                                                        "pena":    "detenção, de quatro meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Favorecimento a desertor",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1926,
                                                                                                                                                                                                                                                                     "texto":    "Se o favorecedor é ascendente, descendente, cônjuge ou irmão do criminoso, fica isento de pena.",
                                                                                                                                                                                                                                                                     "rubrica":    "Isenção de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "194º",
                                                                                                                                                                                                                        "rotulo":    "Art. 194º.",
                                                                                                                                                                                                                        "linha":    1930,
                                                                                                                                                                                                                        "caput":    "Deixar o oficial de proceder contra desertor, sabendo, ou devendo saber encontrar-se entre os seus comandados:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de oficial"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA DESERÇÃO",
                                                                                                                                                                                "linhaTitulo":    1841
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    1934,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "195º",
                                                                                                                                                                                                                        "rotulo":    "Art. 195º.",
                                                                                                                                                                                                                        "linha":    1939,
                                                                                                                                                                                                                        "caput":    "Abandonar, sem ordem superior, o pôsto ou lugar de serviço que lhe tenha sido designado, ou o serviço que lhe cumpria, antes de terminá-lo:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Abandono de pôsto"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "196º",
                                                                                                                                                                                                                        "rotulo":    "Art. 196º.",
                                                                                                                                                                                                                        "linha":    1945,
                                                                                                                                                                                                                        "caput":    "Deixar o militar de desempenhar a missão que lhe foi confiada:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Descumprimento de missão",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    1949,
                                                                                                                                                                                                                                                                     "texto":    "Se é oficial o agente, a pena é aumentada de um têrço."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    1951,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente exercia função de comando, a pena é aumentada de metade."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    1955,
                                                                                                                                                                                                                                                                     "texto":    "Se a abstenção é culposa:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "197º",
                                                                                                                                                                                                                        "rotulo":    "Art. 197º.",
                                                                                                                                                                                                                        "linha":    1961,
                                                                                                                                                                                                                        "caput":    "Deixar o oficial de restituir, por ocasião da passagem de função, ou quando lhe é exigido, objeto, plano, carta, cifra, código ou documento que lhe haja sido confiado:",
                                                                                                                                                                                                                        "pena":    "detenção, até 6 (seis) meses, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Retenção indevida",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1966,
                                                                                                                                                                                                                                                                     "texto":    "Se o objeto, plano, carta, cifra, código, ou documento envolve ou constitui segrêdo relativo à segurança nacional:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "198º",
                                                                                                                                                                                                                        "rotulo":    "Art. 198º.",
                                                                                                                                                                                                                        "linha":    1973,
                                                                                                                                                                                                                        "caput":    "Deixar o comandante de manter a fôrça sob seu comando em estado de eficiência:",
                                                                                                                                                                                                                        "pena":    "detenção, de 3 (três) meses a 1 (um) ano.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de eficiência da força"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "199º",
                                                                                                                                                                                                                        "rotulo":    "Art. 199º.",
                                                                                                                                                                                                                        "linha":    1980,
                                                                                                                                                                                                                        "caput":    "Deixar o comandante de empregar todos os meios ao seu alcance para evitar perda, destruição ou inutilização de instalações militares, navio, aeronave ou engenho de guerra motomecanizado em perigo:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de providências para evitar danos",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1986,
                                                                                                                                                                                                                                                                     "texto":    "Se a abstenção é culposa:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "200º",
                                                                                                                                                                                                                        "rotulo":    "Art. 200º.",
                                                                                                                                                                                                                        "linha":    1992,
                                                                                                                                                                                                                        "caput":    "Deixar o comandante, em ocasião de incêndio, naufrágio, encalhe, colisão, ou outro perigo semelhante, de tomar tôdas as providências adequadas para salvar os seus comandados e minorar as conseqüências do sinistro, não sendo o último a sair de bordo ou a deixar a aeronave ou o quartel ou sede militar sob seu comando:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de providências para salvar comandados",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    1998,
                                                                                                                                                                                                                                                                     "texto":    "Se a abstenção é culposa:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "201º",
                                                                                                                                                                                                                        "rotulo":    "Art. 201º.",
                                                                                                                                                                                                                        "linha":    2004,
                                                                                                                                                                                                                        "caput":    "Deixar o comandante de socorrer, sem justa causa, navio de guerra ou mercante, nacional ou estrangeiro, ou aeronave, em perigo, ou náufragos que hajam pedido socorro:",
                                                                                                                                                                                                                        "pena":    "detenção, de 1 (um) a 2 (dois) anos.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de socorro"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "202º",
                                                                                                                                                                                                                        "rotulo":    "Art. 202º.",
                                                                                                                                                                                                                        "linha":    2011,
                                                                                                                                                                                                                        "caput":    "Embriagar-se o militar, quando em serviço, ou apresentar-se embriagado para prestá-lo:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Embriaguez em serviço"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "203º",
                                                                                                                                                                                                                        "rotulo":    "Art. 203º.",
                                                                                                                                                                                                                        "linha":    2017,
                                                                                                                                                                                                                        "caput":    "Dormir o militar, quando em serviço, como oficial de quarto ou de ronda, ou em situação equivalente, ou, não sendo oficial, em serviço de sentinela, vigia, plantão às máquinas, ao leme, de ronda ou em qualquer serviço de natureza semelhante:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Dormir em serviço"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO ABANDONO DE PÔSTO E DE OUTROS CRIMES EM SERVIÇO",
                                                                                                                                                                                "linhaTitulo":    1935
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    2021,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "204º",
                                                                                                                                                                                                                        "rotulo":    "Art. 204º.",
                                                                                                                                                                                                                        "linha":    2025,
                                                                                                                                                                                                                        "caput":    "Comerciar o oficial da ativa, ou tomar parte na administração ou gerência de sociedade comercial, ou dela ser sócio ou participar, exceto como acionista ou cotista em sociedade anônima, ou por cotas de responsabilidade limitada:",
                                                                                                                                                                                                                        "pena":    "detenção, de 1 (um) a 2 (dois) anos.",
                                                                                                                                                                                                                        "rubrica":    "Exercício de comércio por oficial"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO EXERCÍCIO DE COMÉRCIO",
                                                                                                                                                                                "linhaTitulo":    2022
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA O SERVIÇO MILITAR E O DEVER MILITAR",
                                                                                                                                     "linhaTitulo":    1794
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO IV",
                                                                                                                                     "linha":    2030,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    2032,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "205º",
                                                                                                                                                                                                                        "rotulo":    "Art. 205º.",
                                                                                                                                                                                                                        "linha":    2036,
                                                                                                                                                                                                                        "caput":    "Matar alguém:",
                                                                                                                                                                                                                        "pena":    "reclusão, de seis a vinte anos.",
                                                                                                                                                                                                                        "rubrica":    "Homicídio simples",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2042,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente comete o crime impelido por motivo de relevante valor social ou moral, ou sob o domínio de violenta emoção, logo em seguida a injusta provocação da vítima, o juiz pode reduzir a pena, de um sexto a um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Minoração facultativa da pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2046,
                                                                                                                                                                                                                                                                     "texto":    "Se o homicídio é cometido:",
                                                                                                                                                                                                                                                                     "rubrica":    "Homicídio qualificado",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2048,
                                                                                                                                                                                                                                                                                                             "texto":    "por motivo fútil;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2050,
                                                                                                                                                                                                                                                                                                             "texto":    "mediante paga ou promessa de recompensa, por cupidez, para excitar ou saciar desejos sexuais, ou por outro motivo torpe;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2052,
                                                                                                                                                                                                                                                                                                             "texto":    "com emprêgo de veneno, asfixia, tortura, fogo, explosivo, ou qualquer outro meio dissimulado ou cruel, ou de que possa resultar perigo comum;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IV",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                             "linha":    2054,
                                                                                                                                                                                                                                                                                                             "texto":    "à traição, de emboscada, com surprêsa ou mediante outro recurso insidioso, que dificultou ou tornou impossível a defesa da vítima;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "V",
                                                                                                                                                                                                                                                                                                             "rotulo":    "V",
                                                                                                                                                                                                                                                                                                             "linha":    2056,
                                                                                                                                                                                                                                                                                                             "texto":    "para assegurar a execução, a ocultação, a impunidade ou vantagem de outro crime;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "VI",
                                                                                                                                                                                                                                                                                                             "rotulo":    "VI",
                                                                                                                                                                                                                                                                                                             "linha":    2058,
                                                                                                                                                                                                                                                                                                             "texto":    "prevalecendo-se o agente da situação de serviço:"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "VII",
                                                                                                                                                                                                                                                                                                             "rotulo":    "VII",
                                                                                                                                                                                                                                                                                                             "linha":    2060,
                                                                                                                                                                                                                                                                                                             "texto":    "contra autoridade ou agente descrito nos arts. 142 e 144 da Constituição Federal, integrantes do sistema prisional e da Força Nacional de Segurança Pública, no exercício da função ou em decorrência dela, ou contra seu cônjuge, companheiro ou parente consanguíneo até o terceiro grau, em razão dessa condição:"
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "206º",
                                                                                                                                                                                                                        "rotulo":    "Art. 206º.",
                                                                                                                                                                                                                        "linha":    2066,
                                                                                                                                                                                                                        "caput":    "Se o homicídio é culposo:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Homicídio culposo",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2073,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de 1/3 (um terço):",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2075,
                                                                                                                                                                                                                                                                                                             "texto":    "se o crime resulta da inobservância de regra técnica de profissão, arte ou ofício;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2077,
                                                                                                                                                                                                                                                                                                             "texto":    "se o agente deixa de prestar imediato socorro à vítima, não procura diminuir as consequências do seu ato ou foge para evitar prisão em flagrante."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2081,
                                                                                                                                                                                                                                                                     "texto":    "Se, em conseqüência de uma só ação ou omissão culposa, ocorre morte de mais de uma pessoa ou também lesões corporais em outras pessoas, a pena é aumentada de um sexto até metade.",
                                                                                                                                                                                                                                                                     "rubrica":    "Multiplicidade de vítimas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2083,
                                                                                                                                                                                                                                                                     "texto":    "O juízo poderá deixar de aplicar a pena se as consequências da infração atingirem o próprio agente de forma tão grave que a sanção penal se torne desnecessária."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "207º",
                                                                                                                                                                                                                        "rotulo":    "Art. 207º.",
                                                                                                                                                                                                                        "linha":    2087,
                                                                                                                                                                                                                        "caput":    "Instigar ou induzir alguém a suicidar-se, ou prestar-lhe auxílio para que o faça, vindo o suicídio consumar-se:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Provocação direta ou auxílio a suicídio",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2095,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é praticado por motivo egoístico, ou a vítima é menor ou tem diminuída, por qualquer motivo, a resistência moral, a pena é duplicada.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2100,
                                                                                                                                                                                                                                                                     "texto":    "Infligir, desumana e reiteradamente, maus-tratos a alguém, sob sua autoridade ou dependência, levando-o, em razão disso, à prática de suicídio:",
                                                                                                                                                                                                                                                                     "rubrica":    "Provocação indireta ao suicídio"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2106,
                                                                                                                                                                                                                                                                     "texto":    "Se o suicídio é apenas tentado, e da tentativa resulta lesão grave, a pena é reduzida de um a dois terços.",
                                                                                                                                                                                                                                                                     "rubrica":    "Redução de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO HOMICÍDIO",
                                                                                                                                                                                "linhaTitulo":    2033
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    2108,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "208º",
                                                                                                                                                                                                                        "rotulo":    "Art. 208º.",
                                                                                                                                                                                                                        "linha":    2112,
                                                                                                                                                                                                                        "caput":    "Matar membros de um grupo nacional, étnico, religioso ou pertencente a determinada raça, com o fim de destruição total ou parcial dêsse grupo:",
                                                                                                                                                                                                                        "pena":    "reclusão, de quinze a trinta anos.",
                                                                                                                                                                                                                        "rubrica":    "Genocídio",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2118,
                                                                                                                                                                                                                                                                     "texto":    "Será punido com reclusão, de quatro a quinze anos, quem, com o mesmo fim:",
                                                                                                                                                                                                                                                                     "rubrica":    "Casos assimilados",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2120,
                                                                                                                                                                                                                                                                                                             "texto":    "inflige lesões graves a membros do grupo;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2122,
                                                                                                                                                                                                                                                                                                             "texto":    "submete o grupo a condições de existência, físicas ou morais, capazes de ocasionar a eliminação de todos os seus membros ou parte dêles;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2124,
                                                                                                                                                                                                                                                                                                             "texto":    "força o grupo à sua dispersão;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IV",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                             "linha":    2126,
                                                                                                                                                                                                                                                                                                             "texto":    "impõe medidas destinadas a impedir os nascimentos no seio do grupo;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "V",
                                                                                                                                                                                                                                                                                                             "rotulo":    "V",
                                                                                                                                                                                                                                                                                                             "linha":    2128,
                                                                                                                                                                                                                                                                                                             "texto":    "efetua coativamente a transferência de crianças do grupo para outro grupo."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO GENOCÍDIO",
                                                                                                                                                                                "linhaTitulo":    2109
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    2130,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "209º",
                                                                                                                                                                                                                        "rotulo":    "Art. 209º.",
                                                                                                                                                                                                                        "linha":    2134,
                                                                                                                                                                                                                        "caput":    "Ofender a integridade corporal ou a saúde de outrem:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Lesão leve",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2141,
                                                                                                                                                                                                                                                                     "texto":    "Se se produz, dolosamente, aceleração de parto, perigo de vida, debilidade permanente de membro, sentido ou função, ou incapacidade para as ocupações habituais, por mais de 30 (trinta) dias:",
                                                                                                                                                                                                                                                                     "rubrica":    "Lesão grave"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2146,
                                                                                                                                                                                                                                                                     "texto":    "Se se produz, dolosamente, enfermidade incurável, perda ou inutilização de membro, sentido ou função, incapacidade permanente para o trabalho, deformidade duradoura ou aborto:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, até cinco anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2154,
                                                                                                                                                                                                                                                                     "texto":    "Se os resultados previstos nos §§ 1º e 2º deste artigo forem causados culposamente:",
                                                                                                                                                                                                                                                                     "rubrica":    "Lesão qualificada pelo resultado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2158,
                                                                                                                                                                                                                                                                     "texto":    "-A. Se da lesão resultar morte e as circunstâncias evidenciarem que o agente não quis o resultado nem assumiu o risco de produzi-lo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena – detenção, de 1 (um) a 4 (quatro) anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    2164,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente comete o crime impelido por motivo de relevante valor moral ou social ou sob o domínio de violenta emoção, logo em seguida a injusta provocação da vítima, o juiz pode reduzir a pena, de um sexto a um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Minoração facultativa da pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "5",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 5",
                                                                                                                                                                                                                                                                     "linha":    2166,
                                                                                                                                                                                                                                                                     "texto":    "No caso de lesões leves, se estas são recíprocas, não se sabendo qual dos contendores atacou primeiro, ou quando ocorre qualquer das hipóteses do parágrafo anterior, o juiz pode diminuir a pena de um a dois terços."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "6",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 6",
                                                                                                                                                                                                                                                                     "linha":    2170,
                                                                                                                                                                                                                                                                     "texto":    "No caso de lesões levíssimas, o juiz pode considerar a infração como disciplinar.",
                                                                                                                                                                                                                                                                     "rubrica":    "Lesão levíssima"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "210º",
                                                                                                                                                                                                                        "rotulo":    "Art. 210º.",
                                                                                                                                                                                                                        "linha":    2174,
                                                                                                                                                                                                                        "caput":    "Se a lesão é culposa:",
                                                                                                                                                                                                                        "pena":    "detenção, de dois meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Lesão culposa",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2181,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de 1/3 (um terço) se o crime resulta da inobservância de regra técnica de profissão, arte ou ofício, ou se o agente deixa de prestar imediato socorro à vítima, não procura diminuir as consequências do seu ato ou foge para evitar prisão em flagrante.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2183,
                                                                                                                                                                                                                                                                     "texto":    "Se, em conseqüência de uma só ação ou omissão culposa, ocorrem lesões em várias pessoas, a pena é aumentada de um sexto até metade."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2185,
                                                                                                                                                                                                                                                                     "texto":    "O juiz poderá deixar de aplicar a pena se as consequências da infração atingirem o próprio agente de forma tão grave que a sanção penal se torne desnecessária."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "211º",
                                                                                                                                                                                                                        "rotulo":    "Art. 211º.",
                                                                                                                                                                                                                        "linha":    2189,
                                                                                                                                                                                                                        "caput":    "Participar de rixa, salvo para separar os contendores:",
                                                                                                                                                                                                                        "pena":    "detenção, até dois meses.",
                                                                                                                                                                                                                        "rubrica":    "Participação em rixa",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2193,
                                                                                                                                                                                                                                                                     "texto":    "Se ocorre morte ou lesão grave, aplica-se, pelo fato de participação na rixa, a pena de detenção, de seis meses a dois anos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA LESÃO CORPORAL E DA RIXA",
                                                                                                                                                                                "linhaTitulo":    2131
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    2195,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "212º",
                                                                                                                                                                                                                        "rotulo":    "Art. 212º.",
                                                                                                                                                                                                                        "linha":    2199,
                                                                                                                                                                                                                        "caput":    "Abandonar o militar pessoa que está sob seu cuidado, guarda, vigilância ou autoridade e, por qualquer motivo, incapaz de defender-se dos riscos resultantes do abandono:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a três anos.",
                                                                                                                                                                                                                        "rubrica":    "Abandono de pessoa",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2205,
                                                                                                                                                                                                                                                                     "texto":    "Se do abandono resulta lesão grave:",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas pelo resultado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2209,
                                                                                                                                                                                                                                                                     "texto":    "Se resulta morte:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, até cinco anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2215,
                                                                                                                                                                                                                                                                     "texto":    "As penas cominadas neste artigo são aumentadas de 1/3 (um terço):",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2217,
                                                                                                                                                                                                                                                                                                             "texto":    "se o abandono ocorre em lugar ermo;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2219,
                                                                                                                                                                                                                                                                                                             "texto":    "se o agente é ascendente ou descendente, cônjuge, irmão, tutor ou curador da vítima;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2221,
                                                                                                                                                                                                                                                                                                             "texto":    "se a vítima é maior de 60 (sessenta) anos, menor de 14 (quatorze) anos ou pessoa com deficiência."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "213º",
                                                                                                                                                                                                                        "rotulo":    "Art. 213º.",
                                                                                                                                                                                                                        "linha":    2225,
                                                                                                                                                                                                                        "caput":    "Expor a perigo a vida ou saúde, em lugar sujeito à administração militar ou no exercício de função militar, de pessoa sob sua autoridade, guarda ou vigilância, para o fim de educação, instrução, tratamento ou custódia, quer privando-a de alimentação ou cuidados indispensáveis, quer sujeitando-a a trabalhos excessivos ou inadequados, quer abusando de meios de correção ou disciplina:",
                                                                                                                                                                                                                        "pena":    "detenção, de dois meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Maus tratos",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2231,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta lesão grave:",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas pelo resultado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2235,
                                                                                                                                                                                                                                                                     "texto":    "Se resulta morte:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, até quatro anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2239,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de 1/3 (um terço) se o crime é praticado contra pessoa menor de 14 (quatorze) anos, maior de 60 (sessenta) anos ou com deficiência.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de dois a dez anos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA PERICLITAÇÃO DA VIDA OU DA SAÚDE",
                                                                                                                                                                                "linhaTitulo":    2196
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO V",
                                                                                                                                                                                "linha":    2241,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "214º",
                                                                                                                                                                                                                        "rotulo":    "Art. 214º.",
                                                                                                                                                                                                                        "linha":    2245,
                                                                                                                                                                                                                        "caput":    "Caluniar alguém, imputando-lhe falsamente fato definido como crime:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Calúnia",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2249,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem, sabendo falsa a imputação, a propala ou divulga."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2253,
                                                                                                                                                                                                                                                                     "texto":    "A prova da verdade do fato imputado exclui o crime, mas não é admitida:",
                                                                                                                                                                                                                                                                     "rubrica":    "Exceção da verdade",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2255,
                                                                                                                                                                                                                                                                                                             "texto":    "se, constituindo o fato imputado crime de ação privada, o ofendido não foi condenado por sentença irrecorrível;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2257,
                                                                                                                                                                                                                                                                                                             "texto":    "se o fato é imputado a qualquer das pessoas indicadas no nº I do art. 218;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2259,
                                                                                                                                                                                                                                                                                                             "texto":    "se do crime imputado, embora de ação pública, o ofendido foi absolvido por sentença irrecorrível."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "215º",
                                                                                                                                                                                                                        "rotulo":    "Art. 215º.",
                                                                                                                                                                                                                        "linha":    2263,
                                                                                                                                                                                                                        "caput":    "Difamar alguém, imputando-lhe fato ofensivo à sua reputação:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Difamação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2267,
                                                                                                                                                                                                                                                                     "texto":    "A exceção da verdade sòmente se admite se a ofensa é relativa ao exercício da função pública, militar ou civil, do ofendido."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "216º",
                                                                                                                                                                                                                        "rotulo":    "Art. 216º.",
                                                                                                                                                                                                                        "linha":    2271,
                                                                                                                                                                                                                        "caput":    "Injuriar alguém, ofendendo-lhe a dignidade ou o decôro:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Injúria",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2275,
                                                                                                                                                                                                                                                                     "texto":    "O juízo pode deixar de aplicar a pena:",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2277,
                                                                                                                                                                                                                                                                                                             "texto":    "quando o ofendido, de forma reprovável, provocou diretamente a injúria;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2279,
                                                                                                                                                                                                                                                                                                             "texto":    "no caso de retorsão imediata, que consista em outra injúria."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2283,
                                                                                                                                                                                                                                                                     "texto":    "Se a injúria consiste na utilização de elementos referentes a raça, a cor, a etnia, a religião, a origem, a orientação sexual ou a condição de pessoa idosa ou com deficiência:",
                                                                                                                                                                                                                                                                     "rubrica":    "Injúria qualificada"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "217º",
                                                                                                                                                                                                                        "rotulo":    "Art. 217º.",
                                                                                                                                                                                                                        "linha":    2289,
                                                                                                                                                                                                                        "caput":    "Se a injúria consiste em violência, ou outro ato que atinja a pessoa, e, por sua natureza ou pelo meio empregado, se considera aviltante:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano, além da pena correspondente à violência.",
                                                                                                                                                                                                                        "rubrica":    "Injúria real"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "218º",
                                                                                                                                                                                                                        "rotulo":    "Art. 218º.",
                                                                                                                                                                                                                        "linha":    2295,
                                                                                                                                                                                                                        "caput":    "As penas cominadas nos antecedentes artigos dêste capítulo aumentam-se de um têrço, se qualquer dos crimes é cometido:",
                                                                                                                                                                                                                        "rubrica":    "Disposições comuns",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    2297,
                                                                                                                                                                                                                                                                "texto":    "contra o Presidente da República ou chefe de govêrno estrangeiro;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    2299,
                                                                                                                                                                                                                                                                "texto":    "contra superior;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    2302,
                                                                                                                                                                                                                                                                "texto":    "contra militar ou servidor público, em razão das suas funções;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    2305,
                                                                                                                                                                                                                                                                "texto":    "na presença de 2 (duas) ou mais pessoas ou de inferior hierárquico do ofendido, ou por meio que facilite a divulgação da calúnia, da difamação ou da injúria."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2307,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é cometido mediante paga ou promessa de recompensa, aplica-se a pena em dôbro, se o fato não constitui crime mais grave."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "219º",
                                                                                                                                                                                                                        "rotulo":    "Art. 219º.",
                                                                                                                                                                                                                        "linha":    2311,
                                                                                                                                                                                                                        "caput":    "Propalar fatos, que sabe inverídicos, capazes de ofender a dignidade ou abalar o crédito das fôrças armadas ou a confiança que estas merecem do público:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Ofensa às fôrças armadas",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2315,
                                                                                                                                                                                                                                                                     "texto":    "A pena será aumentada de um têrço, se o crime é cometido pela imprensa, rádio ou televisão."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "220º",
                                                                                                                                                                                                                        "rotulo":    "Art. 220º.",
                                                                                                                                                                                                                        "linha":    2319,
                                                                                                                                                                                                                        "caput":    "Não constitui ofensa punível, salvo quando inequívoca a intenção de injuriar, difamar ou caluniar:",
                                                                                                                                                                                                                        "rubrica":    "Exclusão de pena",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    2321,
                                                                                                                                                                                                                                                                "texto":    "a irrogada em juízo, na discussão da causa, por uma das partes ou seu procurador contra a outra parte ou seu procurador;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    2323,
                                                                                                                                                                                                                                                                "texto":    "a opinião desfavorável da crítica literária, artística ou científica;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    2325,
                                                                                                                                                                                                                                                                "texto":    "a apreciação crítica às instituições militares, salvo quando inequívoca a intenção de ofender;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    2327,
                                                                                                                                                                                                                                                                "texto":    "conceito desfavorável em apreciação ou informação prestada no cumprimento do dever de ofício."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2329,
                                                                                                                                                                                                                                                                     "texto":    "Nos casos dos ns. I e IV, responde pela ofensa quem lhe dá publicidade."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "221º",
                                                                                                                                                                                                                        "rotulo":    "Art. 221º.",
                                                                                                                                                                                                                        "linha":    2333,
                                                                                                                                                                                                                        "caput":    "Se a ofensa é irrogada de forma imprecisa ou equívoca, quem se julga atingido pode pedir explicações em juízo. Se o interpelado se recusa a dá-las ou, a critério do juiz, não as dá satisfatórias, responde pela ofensa.",
                                                                                                                                                                                                                        "rubrica":    "Equivocidade da ofensa"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES CONTRA A HONRA",
                                                                                                                                                                                "linhaTitulo":    2242
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VI",
                                                                                                                                                                                "linha":    2335,
                                                                                                                                                                                "divisoes":    [
                                                                                                                                                                                                                 {
                                                                                                                                                                                                                         "tipo":    "secao",
                                                                                                                                                                                                                         "rotulo":    "Seção I - Dos crimes contra a liberdade",
                                                                                                                                                                                                                         "linha":    2337,
                                                                                                                                                                                                                         "divisoes":    [

                                                                                                                                                                                                                                                    ],
                                                                                                                                                                                                                         "artigos":    [
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "222º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 222º.",
                                                                                                                                                                                                                                                                 "linha":    2341,
                                                                                                                                                                                                                                                                 "caput":    "Constranger alguém, mediante violência ou grave ameaça, ou depois de lhe haver reduzido, por qualquer outro meio, a capacidade de resistência, a não fazer o que a lei permite, ou a fazer ou a tolerar que se faça, o que ela não manda:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, de 3 (três) meses a 1 (um) ano.",
                                                                                                                                                                                                                                                                 "rubrica":    "Constrangimento ilegal",
                                                                                                                                                                                                                                                                 "paragrafos":    [
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "1",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                                                                "linha":    2348,
                                                                                                                                                                                                                                                                                                                "texto":    "A pena aplica-se em dôbro, quando, para a execução do crime, se reúnem mais de três pessoas, ou há emprêgo de arma, ou quando o constrangimento é exercido com abuso de autoridade, para obter de alguém confissão de autoria de crime ou declaração como testemunha.",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "2",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                                                                "linha":    2350,
                                                                                                                                                                                                                                                                                                                "texto":    "Além da pena cominada, aplica-se a correspondente à violência."
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "3",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                                                                "linha":    2354,
                                                                                                                                                                                                                                                                                                                "texto":    "Não constitui crime:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Exclusão de crime",
                                                                                                                                                                                                                                                                                                                "incisos":    [
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "I",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "I",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2356,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "Salvo o caso de transplante de órgãos, a intervenção médica ou cirúrgica, sem o consentimento do paciente ou de seu representante legal, se justificada para conjurar iminente perigo de vida ou de grave dano ao corpo ou à saúde;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "II",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "II",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2358,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "a coação exercida para impedir suicídio."
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                         },
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "223º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 223º.",
                                                                                                                                                                                                                                                                 "linha":    2362,
                                                                                                                                                                                                                                                                 "caput":    "Ameaçar alguém, por palavra, escrito ou gesto, ou qualquer outro meio simbólico, de lhe causar mal injusto e grave:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, até seis meses, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                                                                 "rubrica":    "Ameaça",
                                                                                                                                                                                                                                                                 "paragrafos":    [
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "único",
                                                                                                                                                                                                                                                                                                                "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                                                                "linha":    2366,
                                                                                                                                                                                                                                                                                                                "texto":    "Se a ameaça é motivada por fato referente a serviço de natureza militar, a pena é aumentada de um têrço."
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                         },
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "224º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 224º.",
                                                                                                                                                                                                                                                                 "linha":    2370,
                                                                                                                                                                                                                                                                 "caput":    "Desafiar outro militar para duelo ou aceitar-lhe o desafio, embora o duelo não se realize: Seqüestro ou cárcere privado",
                                                                                                                                                                                                                                                                 "pena":    "detenção, até três meses, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                                                                 "rubrica":    "Desafio para duelo"
                                                                                                                                                                                                                                                         },
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "225º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 225º.",
                                                                                                                                                                                                                                                                 "linha":    2376,
                                                                                                                                                                                                                                                                 "caput":    "Privar alguém de sua liberdade, mediante seqüestro ou cárcere privado:",
                                                                                                                                                                                                                                                                 "pena":    "reclusão, até três anos.",
                                                                                                                                                                                                                                                                 "paragrafos":    [
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "1",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                                                                "linha":    2383,
                                                                                                                                                                                                                                                                                                                "texto":    "A pena é de reclusão, de 2 (dois) a 5 (cinco) anos:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Aumento de pena",
                                                                                                                                                                                                                                                                                                                "incisos":    [
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "I",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "I",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2386,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "se a vítima é ascendente, descendente, cônjuge, companheira do agente, maior de 60 (sessenta) anos, menor de 18 (dezoito) anos ou pessoa com deficiência;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "II",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "II",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2388,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "se o crime é praticado mediante internação da vítima em casa de saúde ou hospital;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "III",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "III",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2390,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "se a privação de liberdade dura mais de quinze dias."
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "IV",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2392,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "se o crime é praticado com fins libidinosos."
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "2",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                                                                "linha":    2396,
                                                                                                                                                                                                                                                                                                                "texto":    "Se resulta à vítima, em razão de maus tratos ou da natureza da detenção, grave sofrimento físico ou moral:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Formas qualificadas pelo resultado"
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "3",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                                                                "linha":    2400,
                                                                                                                                                                                                                                                                                                                "texto":    "Se, pela razão do parágrafo anterior, resulta morte:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Pena - reclusão, de dois a oito anos."
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                         }
                                                                                                                                                                                                                                                 ]
                                                                                                                                                                                                                 },
                                                                                                                                                                                                                 {
                                                                                                                                                                                                                         "tipo":    "secao",
                                                                                                                                                                                                                         "rotulo":    "Seção II - Do crime contra a inviolabilidade do domicílio",
                                                                                                                                                                                                                         "linha":    2404,
                                                                                                                                                                                                                         "divisoes":    [

                                                                                                                                                                                                                                                    ],
                                                                                                                                                                                                                         "artigos":    [
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "226º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 226º.",
                                                                                                                                                                                                                                                                 "linha":    2407,
                                                                                                                                                                                                                                                                 "caput":    "Entrar ou permanecer, clandestina ou astuciosamente, ou contra a vontade expressa ou tácita de quem de direito, em casa alheia ou em suas dependências:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, até três meses.",
                                                                                                                                                                                                                                                                 "rubrica":    "Violação de domicílio",
                                                                                                                                                                                                                                                                 "paragrafos":    [
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "1",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                                                                "linha":    2413,
                                                                                                                                                                                                                                                                                                                "texto":    "Se o crime é cometido durante o repouso noturno, ou com emprêgo de violência ou de arma, ou mediante arrombamento, ou por duas ou mais pessoas:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "2",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                                                                "linha":    2421,
                                                                                                                                                                                                                                                                                                                "texto":    "A pena é aumentada de 1/3 (um terço) se o fato é cometido por militar em serviço ou por servidor público, fora dos casos legais, ou com inobservância das formalidades prescritas em lei ou com abuso de poder.",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "3",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                                                                "linha":    2425,
                                                                                                                                                                                                                                                                                                                "texto":    "Não constitui crime a entrada ou permanência em casa alheia ou em suas dependências:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Exclusão de crime",
                                                                                                                                                                                                                                                                                                                "incisos":    [
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "I",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "I",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2427,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "durante o dia, com observância das formalidades legais, para efetuar prisão ou outra diligência em cumprimento de lei ou regulamento militar;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "II",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "II",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2429,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "a qualquer hora do dia ou da noite para acudir vítima de desastre ou quando alguma infração penal está sendo ali praticada ou na iminência de o ser."
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "4",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                                                                "linha":    2433,
                                                                                                                                                                                                                                                                                                                "texto":    "O termo \"casa\" compreende:",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Compreensão do têrmo \"casa\"",
                                                                                                                                                                                                                                                                                                                "incisos":    [
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "I",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "I",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2435,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "qualquer compartimento habitado;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "II",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "II",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2437,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "aposento ocupado de habitação coletiva;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "III",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "III",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2439,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "compartimento não aberto ao público, onde alguém exerce profissão ou atividade."
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "5",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 5",
                                                                                                                                                                                                                                                                                                                "linha":    2441,
                                                                                                                                                                                                                                                                                                                "texto":    "Não se compreende no têrmo \"casa\":",
                                                                                                                                                                                                                                                                                                                "incisos":    [
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "I",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "I",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2443,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "hotel, hospedaria, ou qualquer outra habitação coletiva, enquanto aberta, salvo a restrição do nº II do parágrafo anterior;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "II",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "II",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2445,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "taverna, boate, casa de jôgo e outras do mesmo gênero."
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                         }
                                                                                                                                                                                                                                                 ]
                                                                                                                                                                                                                 },
                                                                                                                                                                                                                 {
                                                                                                                                                                                                                         "tipo":    "secao",
                                                                                                                                                                                                                         "rotulo":    "Seção III - Dos crimes contra a inviolabilidade de correspondência ou comunicação",
                                                                                                                                                                                                                         "linha":    2447,
                                                                                                                                                                                                                         "divisoes":    [

                                                                                                                                                                                                                                                    ],
                                                                                                                                                                                                                         "artigos":    [
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "227º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 227º.",
                                                                                                                                                                                                                                                                 "linha":    2450,
                                                                                                                                                                                                                                                                 "caput":    "Devassar indevidamente o conteúdo de correspondência privada dirigida a outrem:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                                                                 "rubrica":    "Violação de correspondência",
                                                                                                                                                                                                                                                                 "paragrafos":    [
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "1",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                                                                "linha":    2454,
                                                                                                                                                                                                                                                                                                                "texto":    "Nas mesmas penas incorre:",
                                                                                                                                                                                                                                                                                                                "incisos":    [
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "I",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "I",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2456,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "quem se apossa de correspondência alheia, fechada ou aberta, e, no todo ou em parte, a sonega ou destrói;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "II",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "II",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2458,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "quem indevidamente divulga, transmite a outrem ou utiliza, abusivamente, comunicação telegráfica ou radioelétrica dirigida a terceiro, ou conversação telefônica entre outras pessoas;"
                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                        "numero":    "III",
                                                                                                                                                                                                                                                                                                                                                        "rotulo":    "III",
                                                                                                                                                                                                                                                                                                                                                        "linha":    2460,
                                                                                                                                                                                                                                                                                                                                                        "texto":    "quem impede a comunicação ou a conversação referida no número anterior."
                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "2",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                                                                "linha":    2464,
                                                                                                                                                                                                                                                                                                                "texto":    "A pena aumenta-se de metade, se há dano para outrem.",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "3",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                                                                "linha":    2466,
                                                                                                                                                                                                                                                                                                                "texto":    "Se o agente comete o crime com abuso de função, em serviço postal, telegráfico, radioelétrico ou telefônico:"
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "4",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                                                                "linha":    2472,
                                                                                                                                                                                                                                                                                                                "texto":    "Salvo o disposto no parágrafo anterior, qualquer dos crimes previstos neste artigo só é considerado militar no caso do art. 9º, nº II, letra a .",
                                                                                                                                                                                                                                                                                                                "rubrica":    "Natureza militar do crime"
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                         }
                                                                                                                                                                                                                                                 ]
                                                                                                                                                                                                                 },
                                                                                                                                                                                                                 {
                                                                                                                                                                                                                         "tipo":    "secao",
                                                                                                                                                                                                                         "rotulo":    "Seção IV - Dos crimes contra a inviolabilidade dos segredos de caráter particular",
                                                                                                                                                                                                                         "linha":    2474,
                                                                                                                                                                                                                         "divisoes":    [

                                                                                                                                                                                                                                                    ],
                                                                                                                                                                                                                         "artigos":    [
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "228º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 228º.",
                                                                                                                                                                                                                                                                 "linha":    2477,
                                                                                                                                                                                                                                                                 "caput":    "Divulgar, sem justa causa, conteúdo de documento particular sigiloso ou de correspondência confidencial, de que é detentor ou destinatário, desde que da divulgação possa resultar dano a outrem:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                                                                 "rubrica":    "Divulgação de segrêdo"
                                                                                                                                                                                                                                                         },
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "229º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 229º.",
                                                                                                                                                                                                                                                                 "linha":    2483,
                                                                                                                                                                                                                                                                 "caput":    "Violar, mediante processo técnico o direito ao recato pessoal ou o direito ao resguardo das palavras que não forem pronunciadas públicamente:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, até um ano.",
                                                                                                                                                                                                                                                                 "rubrica":    "Violação de recato",
                                                                                                                                                                                                                                                                 "paragrafos":    [
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "1",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                                                                "linha":    2487,
                                                                                                                                                                                                                                                                                                                "texto":    "Na mesma pena incorre quem divulga os fatos captados."
                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                "numero":    "2",
                                                                                                                                                                                                                                                                                                                "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                                                                "linha":    2489,
                                                                                                                                                                                                                                                                                                                "texto":    "Considera-se processo técnico, para os fins deste artigo, qualquer meio que registre informações, dados, imagens ou outros similares, não consentidos pela vítima."
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                         },
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "230º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 230º.",
                                                                                                                                                                                                                                                                 "linha":    2493,
                                                                                                                                                                                                                                                                 "caput":    "Revelar, sem justa causa, segrêdo de que tem ciência, em razão de função ou profissão, exercida em local sob administração militar, desde que da revelação possa resultar dano a outrem:",
                                                                                                                                                                                                                                                                 "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                                                                 "rubrica":    "Violação de segrêdo profissional"
                                                                                                                                                                                                                                                         },
                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                 "numero":    "231º",
                                                                                                                                                                                                                                                                 "rotulo":    "Art. 231º.",
                                                                                                                                                                                                                                                                 "linha":    2499,
                                                                                                                                                                                                                                                                 "caput":    "Os crimes previstos nos arts. 228 e 229 sòmente são considerados militares no caso do art. 9º, nº II, letra a .",
                                                                                                                                                                                                                                                                 "rubrica":    "Natureza militar do crime"
                                                                                                                                                                                                                                                         }
                                                                                                                                                                                                                                                 ]
                                                                                                                                                                                                                 }
                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [

                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES CONTRA A LIBERDADE",
                                                                                                                                                                                "linhaTitulo":    2336
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VII",
                                                                                                                                                                                "linha":    2501,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "232º",
                                                                                                                                                                                                                        "rotulo":    "Art. 232º.",
                                                                                                                                                                                                                        "linha":    2508,
                                                                                                                                                                                                                        "caput":    "Constranger alguém, mediante violência ou grave ameaça, a ter conjunção carnal ou a praticar ou permitir que com ele se pratique outro ato libidinoso:",
                                                                                                                                                                                                                        "pena":    "reclusão, de 6 (seis) a 10 (dez) anos.",
                                                                                                                                                                                                                        "rubrica":    "Estupro",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2512,
                                                                                                                                                                                                                                                                     "texto":    "Se da conduta resulta lesão de natureza grave, ou se a vítima é menor de 18 (dezoito) e maior de 14 (quatorze) anos:"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2516,
                                                                                                                                                                                                                                                                     "texto":    "Se da conduta resulta morte:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena – reclusão, de 8 (oito) a 12 (doze) anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2520,
                                                                                                                                                                                                                                                                     "texto":    "Se a vítima é menor de 14 (quatorze) anos ou, por enfermidade ou deficiência mental, não tem o necessário discernimento para a prática do ato ou, por qualquer outra causa, não pode oferecer resistência:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena – reclusão, de 12 (doze) a 30 (trinta) anos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "234º",
                                                                                                                                                                                                                        "rotulo":    "Art. 234º.",
                                                                                                                                                                                                                        "linha":    2535,
                                                                                                                                                                                                                        "caput":    "Induzir alguém menor de 14 (quatorze) anos a satisfazer a lascívia de outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, de 2 (dois) a 5 (cinco) anos.",
                                                                                                                                                                                                                        "rubrica":    "Corrupção de menores"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "235º",
                                                                                                                                                                                                                        "rotulo":    "Art. 235º.",
                                                                                                                                                                                                                        "linha":    2543,
                                                                                                                                                                                                                        "caput":    "Praticar, ou permitir o militar que com ele se pratique, ato libidinoso em lugar sujeito à administração militar ou no exercício de função militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Ato de libidinagem"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "236º",
                                                                                                                                                                                                                        "rotulo":    "Art. 236º.",
                                                                                                                                                                                                                        "linha":    2549,
                                                                                                                                                                                                                        "caput":    "Presume-se a violência, se a vítima:",
                                                                                                                                                                                                                        "rubrica":    "Presunção de violência",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    2551,
                                                                                                                                                                                                                                                                "texto":    "não é maior de quatorze anos, salvo fundada suposição contrária do agente;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    2553,
                                                                                                                                                                                                                                                                "texto":    "é doente ou deficiente mental, e o agente conhecia esta circunstância;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    2555,
                                                                                                                                                                                                                                                                "texto":    "não pode, por qualquer outra causa, oferecer resistência."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "237º",
                                                                                                                                                                                                                        "rotulo":    "Art. 237º.",
                                                                                                                                                                                                                        "linha":    2559,
                                                                                                                                                                                                                        "caput":    "Nos crimes previstos neste capítulo, a pena é agravada, se o fato é praticado:",
                                                                                                                                                                                                                        "rubrica":    "Aumento de pena",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    2561,
                                                                                                                                                                                                                                                                "texto":    "com o concurso de duas ou mais pessoas;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    2563,
                                                                                                                                                                                                                                                                "texto":    "por oficial, ou por militar em serviço."
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES SEXUAIS",
                                                                                                                                                                                "linhaTitulo":    2502
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VIII",
                                                                                                                                                                                "linha":    2565,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "238º",
                                                                                                                                                                                                                        "rotulo":    "Art. 238º.",
                                                                                                                                                                                                                        "linha":    2569,
                                                                                                                                                                                                                        "caput":    "Praticar ato obsceno em lugar sujeito à administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Ato obsceno",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2573,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada, se o fato é praticado por militar em serviço ou por oficial."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "239º",
                                                                                                                                                                                                                        "rotulo":    "Art. 239º.",
                                                                                                                                                                                                                        "linha":    2577,
                                                                                                                                                                                                                        "caput":    "Produzir, distribuir, vender, expor à venda, exibir, adquirir ou ter em depósito para o fim de venda, distribuição ou exibição, livros, jornais, revistas, escritos, pinturas, gravuras, estampas, imagens, desenhos ou qualquer outro objeto de caráter obsceno, em lugar sujeito à administração militar, ou durante o período de exercício ou manobras:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Escrito ou objeto obsceno",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2581,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem distribui, vende, oferece à venda ou exibe a militares em serviço objeto de caráter obsceno."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO ULTRAJE PÚBLICO AO PUDOR",
                                                                                                                                                                                "linhaTitulo":    2566
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA A PESSOA",
                                                                                                                                     "linhaTitulo":    2031
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO V",
                                                                                                                                     "linha":    2583,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    2585,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "240º",
                                                                                                                                                                                                                        "rotulo":    "Art. 240º.",
                                                                                                                                                                                                                        "linha":    2589,
                                                                                                                                                                                                                        "caput":    "Subtrair, para si ou para outrem, coisa alheia móvel:",
                                                                                                                                                                                                                        "pena":    "reclusão, até seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Furto simples",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2595,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente é primário e é de pequeno valor a coisa furtada, o juiz pode substituir a pena de reclusão pela de detenção, diminuí-la de um a dois terços, ou considerar a infração como disciplinar. Entende-se pequeno o valor que não exceda a um décimo da quantia mensal do mais alto salário mínimo do país.",
                                                                                                                                                                                                                                                                     "rubrica":    "Furto atenuado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2597,
                                                                                                                                                                                                                                                                     "texto":    "A atenuação do parágrafo anterior é igualmente aplicável no caso em que o criminoso, sendo primário, restitui a coisa ao seu dono ou repara o dano causado, antes de instaurada a ação penal."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2601,
                                                                                                                                                                                                                                                                     "texto":    "Equipara-se à coisa móvel a energia elétrica ou qualquer outra que tenha valor econômico. 4º Se o furto é praticado durante a noite:",
                                                                                                                                                                                                                                                                     "rubrica":    "Energia de valor econômico"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "5",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 5",
                                                                                                                                                                                                                                                                     "linha":    2610,
                                                                                                                                                                                                                                                                     "texto":    "Se a coisa furtada pertence à Fazenda Pública:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena reclusão, de dois a oito anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "6",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 6",
                                                                                                                                                                                                                                                                     "linha":    2614,
                                                                                                                                                                                                                                                                     "texto":    "Se o furto é praticado:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de dois a seis anos.",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2616,
                                                                                                                                                                                                                                                                                                             "texto":    "com destruição ou rompimento de obstáculo à subtração da coisa;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2618,
                                                                                                                                                                                                                                                                                                             "texto":    "com abuso de confiança ou mediante fraude, escalada ou destreza;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2620,
                                                                                                                                                                                                                                                                                                             "texto":    "com emprêgo de chave falsa;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IV",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                             "linha":    2622,
                                                                                                                                                                                                                                                                                                             "texto":    "mediante concurso de duas ou mais pessoas:"
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "6",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 6",
                                                                                                                                                                                                                                                                     "linha":    2626,
                                                                                                                                                                                                                                                                     "texto":    "-A. Na mesma pena do § 6º deste artigo incorre quem subtrai arma, munição, explosivo ou outro material de uso restrito militar ou que contenha sinal indicativo de pertencer a instituição militar.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de três a dez anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "7",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 7",
                                                                                                                                                                                                                                                                     "linha":    2629,
                                                                                                                                                                                                                                                                     "texto":    "Aos casos previstos nos §§ 4º e 5º são aplicáveis as atenuações a que se referem os §§ 1º e 2º, e aos casos previstos nos §§ 6º e 6º-A é aplicável a atenuação referida no § 2º deste artigo."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "241º",
                                                                                                                                                                                                                        "rotulo":    "Art. 241º.",
                                                                                                                                                                                                                        "linha":    2633,
                                                                                                                                                                                                                        "caput":    "Se a coisa é subtraída para o fim de uso momentâneo e, a seguir, vem a ser imediatamente restituída ou reposta no lugar onde se achava:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Furto de uso",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2640,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de metade se a coisa usada é veículo motorizado, embarcação, aeronave ou arma, e de 1/3 (um terço) se é animal de sela ou de tiro.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO FURTO",
                                                                                                                                                                                "linhaTitulo":    2586
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    2642,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "242º",
                                                                                                                                                                                                                        "rotulo":    "Art. 242º.",
                                                                                                                                                                                                                        "linha":    2646,
                                                                                                                                                                                                                        "caput":    "Subtrair coisa alheia móvel, para si ou para outrem, mediante emprêgo ou ameaça de emprêgo de violência contra pessoa, ou depois de havê-la, por qualquer modo, reduzido à impossibilidade de resistência:",
                                                                                                                                                                                                                        "pena":    "reclusão, de quatro a quinze anos.",
                                                                                                                                                                                                                        "rubrica":    "Roubo simples",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2650,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem, em seguida à subtração da coisa, emprega ou ameaça empregar violência contra pessoa, a fim de assegurar a impunidade do crime ou a detenção da coisa para si ou para outrem."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2654,
                                                                                                                                                                                                                                                                     "texto":    "A pena aumenta-se de um têrço até metade:",
                                                                                                                                                                                                                                                                     "rubrica":    "Roubo qualificado",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2656,
                                                                                                                                                                                                                                                                                                             "texto":    "se a violência ou ameaça é exercida com emprêgo de arma;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2658,
                                                                                                                                                                                                                                                                                                             "texto":    "se há concurso de duas ou mais pessoas;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2660,
                                                                                                                                                                                                                                                                                                             "texto":    "se a vítima está em serviço de transporte de valôres, e o agente conhece tal circunstância;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IV",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                             "linha":    2662,
                                                                                                                                                                                                                                                                                                             "texto":    "se a vítima está em serviço de natureza militar;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "V",
                                                                                                                                                                                                                                                                                                             "rotulo":    "V",
                                                                                                                                                                                                                                                                                                             "linha":    2664,
                                                                                                                                                                                                                                                                                                             "texto":    "se é dolosamente causada lesão grave;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "VI",
                                                                                                                                                                                                                                                                                                             "rotulo":    "VI",
                                                                                                                                                                                                                                                                                                             "linha":    2666,
                                                                                                                                                                                                                                                                                                             "texto":    "se resulta morte e as circunstâncias evidenciam que o agente não quis êsse resultado, nem assumiu o risco de produzi-lo."
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "VII",
                                                                                                                                                                                                                                                                                                             "rotulo":    "VII",
                                                                                                                                                                                                                                                                                                             "linha":    2668,
                                                                                                                                                                                                                                                                                                             "texto":    "se a subtração é de veículo automotor que venha a ser transportado para outra unidade da Federação ou para o exterior;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "VIII",
                                                                                                                                                                                                                                                                                                             "rotulo":    "VIII",
                                                                                                                                                                                                                                                                                                             "linha":    2670,
                                                                                                                                                                                                                                                                                                             "texto":    "se o agente mantém a vítima em seu poder, restringindo sua liberdade;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IX",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IX",
                                                                                                                                                                                                                                                                                                             "linha":    2672,
                                                                                                                                                                                                                                                                                                             "texto":    "se a coisa subtraída é arma, munição, explosivo ou outro material de uso restrito militar ou que contenha sinal indicativo de pertencer a instituição militar."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2676,
                                                                                                                                                                                                                                                                     "texto":    "Se, para praticar o roubo, ou assegurar a impunidade do crime, ou a detenção da coisa, o agente ocasiona dolosamente a morte de alguém, a pena será de reclusão, de quinze a trinta anos, sendo irrelevante se a lesão patrimonial deixa de consumar-se. Se há mais de uma vítima dessa violência à pessoa, aplica-se o disposto no art. 79.",
                                                                                                                                                                                                                                                                     "rubrica":    "Latrocínio"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "243º",
                                                                                                                                                                                                                        "rotulo":    "Art. 243º.",
                                                                                                                                                                                                                        "linha":    2680,
                                                                                                                                                                                                                        "caput":    "Obter para si ou para outrem indevida vantagem econômica, constrangendo alguém, mediante violência ou grave ameaça:",
                                                                                                                                                                                                                        "rubrica":    "Extorsão simples",
                                                                                                                                                                                                                        "alineas":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "letra":    "a",
                                                                                                                                                                                                                                                                "rotulo":    "a)",
                                                                                                                                                                                                                                                                "linha":    2682,
                                                                                                                                                                                                                                                                "texto":    "a praticar ou tolerar que se pratique ato lesivo do seu patrimônio, ou de terceiro;",
                                                                                                                                                                                                                                                                "alineas":    [
                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                        "letra":    "b",
                                                                                                                                                                                                                                                                                                        "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                        "linha":    2684,
                                                                                                                                                                                                                                                                                                        "texto":    "a omitir ato de interêsse do seu patrimônio, ou de terceiro:"
                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                        ]
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2690,
                                                                                                                                                                                                                                                                     "texto":    "Aplica-se à extorsão o disposto no § 2º do art. 242.",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2692,
                                                                                                                                                                                                                                                                     "texto":    "Aplica-se à extorsão, praticada mediante violência, o disposto no § 3º do art. 242."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "244º",
                                                                                                                                                                                                                        "rotulo":    "Art. 244º.",
                                                                                                                                                                                                                        "linha":    2696,
                                                                                                                                                                                                                        "caput":    "Extorquir ou tentar extorquir para si ou para outrem, mediante seqüestro de pessoa, indevida vantagem econômica:",
                                                                                                                                                                                                                        "pena":    "reclusão, de seis a quinze anos.",
                                                                                                                                                                                                                        "rubrica":    "Extorsão mediante seqüestro",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2702,
                                                                                                                                                                                                                                                                     "texto":    "Se o seqüestro dura mais de vinte e quatro horas, ou se o seqüestrado é menor de dezesseis ou maior de sessenta anos, ou se o crime é cometido por mais de duas pessoas, a pena é de reclusão de oito a vinte anos.",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2704,
                                                                                                                                                                                                                                                                     "texto":    "Se à pessoa seqüestrada, em razão de maus tratos ou da natureza do seqüestro, resulta grave sofrimento físico ou moral, a pena de reclusão é aumentada de um têrço."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2706,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente vem a empregar violência contra a pessoa seqüestrada, aplicam-se, correspondentemente, as disposições do art. 242, § 2º, ns. V e VI ,e § 3º."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    2708,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é cometido em concurso, o concorrente que o denunciar à autoridade, facilitando a libertação do sequestrado, terá sua pena reduzida de 1/3 (um terço) a 2/3 (dois terços)."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "245º",
                                                                                                                                                                                                                        "rotulo":    "Art. 245º.",
                                                                                                                                                                                                                        "linha":    2712,
                                                                                                                                                                                                                        "caput":    "Obter ou tentar obter de alguém, para si ou para outrem, indevida vantagem econômica, mediante a ameaça de revelar fato, cuja divulgação pode lesar a sua reputação ou de pessoa que lhe seja particularmente cara:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a dez anos.",
                                                                                                                                                                                                                        "rubrica":    "Chantagem",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2716,
                                                                                                                                                                                                                                                                     "texto":    "Se a ameaça é de divulgação pela imprensa, radiodifusão ou televisão, a pena é agravada."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "246º",
                                                                                                                                                                                                                        "rotulo":    "Art. 246º.",
                                                                                                                                                                                                                        "linha":    2720,
                                                                                                                                                                                                                        "caput":    "Obter de alguém, como garantia de dívida, abusando de sua premente necessidade, documento que pode dar causa a procedimento penal contra o devedor ou contra terceiro:",
                                                                                                                                                                                                                        "pena":    "reclusão, até três anos.",
                                                                                                                                                                                                                        "rubrica":    "Extorsão indireta"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "247º",
                                                                                                                                                                                                                        "rotulo":    "Art. 247º.",
                                                                                                                                                                                                                        "linha":    2726,
                                                                                                                                                                                                                        "caput":    "Nos crimes previstos neste capítulo, a pena é agravada, se a violência é contra superior, ou militar de serviço.",
                                                                                                                                                                                                                        "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO ROUBO E DA EXTORSÃO",
                                                                                                                                                                                "linhaTitulo":    2643
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    2728,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "248º",
                                                                                                                                                                                                                        "rotulo":    "Art. 248º.",
                                                                                                                                                                                                                        "linha":    2732,
                                                                                                                                                                                                                        "caput":    "Apropriar-se de coisa alheia móvel, de que tem a posse ou detenção:",
                                                                                                                                                                                                                        "pena":    "reclusão, até seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Apropriação indébita simples",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2738,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada, se o valor da coisa excede vinte vêzes o maior salário mínimo, ou se o agente recebeu a coisa:",
                                                                                                                                                                                                                                                                     "rubrica":    "Agravação de pena",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2740,
                                                                                                                                                                                                                                                                                                             "texto":    "em depósito necessário;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2742,
                                                                                                                                                                                                                                                                                                             "texto":    "em razão de ofício, emprêgo ou profissão."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "249º",
                                                                                                                                                                                                                        "rotulo":    "Art. 249º.",
                                                                                                                                                                                                                        "linha":    2746,
                                                                                                                                                                                                                        "caput":    "Apropriar-se alguém de coisa alheia vinda ao seu poder por êrro, caso fortuito ou fôrça da natureza:",
                                                                                                                                                                                                                        "pena":    "detenção, até um ano.",
                                                                                                                                                                                                                        "rubrica":    "Apropriação de coisa havida acidentalmente",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2752,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem acha coisa alheia perdida e dela se apropria, total ou parcialmente, deixando de restituí-la ao dono ou legítimo possuidor, ou de entregá-la à autoridade competente, dentro do prazo de quinze dias.",
                                                                                                                                                                                                                                                                     "rubrica":    "Apropriação de coisa achada"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "250º",
                                                                                                                                                                                                                        "rotulo":    "Art. 250º.",
                                                                                                                                                                                                                        "linha":    2754,
                                                                                                                                                                                                                        "caput":    "Nos crimes previstos neste capítulo, aplica-se o disposto nos §§ 1º e 2º do art. 240."
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA APROPRIAÇÃO INDÉBITA",
                                                                                                                                                                                "linhaTitulo":    2729
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    2756,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "251º",
                                                                                                                                                                                                                        "rotulo":    "Art. 251º.",
                                                                                                                                                                                                                        "linha":    2760,
                                                                                                                                                                                                                        "caput":    "Obter, para si ou para outrem, vantagem ilícita, em prejuízo alheio, induzindo ou mantendo alguém em êrro, mediante artifício, ardil ou qualquer outro meio fraudulento:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a sete anos.",
                                                                                                                                                                                                                        "rubrica":    "Estelionato",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2764,
                                                                                                                                                                                                                                                                     "texto":    "Nas mesmas penas incorre quem:",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2768,
                                                                                                                                                                                                                                                                                                             "texto":    "vende, permuta, dá em pagamento, em locação ou em garantia, coisa alheia como própria;",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Disposição de coisa alheia como própria"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2772,
                                                                                                                                                                                                                                                                                                             "texto":    "vende, permuta, dá em pagamento ou em garantia coisa própria inalienável, gravada de ônus ou litigiosa, ou imóvel que prometeu vender a terceiro, mediante pagamento em prestações, silenciando sôbre qualquer dessas circunstâncias;",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Alienação ou oneração fraudulenta de coisa própria"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    2776,
                                                                                                                                                                                                                                                                                                             "texto":    "defrauda, mediante alienação não consentida pelo credor ou por outro modo, a garantia pignoratícia, quando tem a posse do objeto empenhado;",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Defraudação de penhor"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IV",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                             "linha":    2780,
                                                                                                                                                                                                                                                                                                             "texto":    "defrauda substância, qualidade ou quantidade de coisa que entrega a adquirente;",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Fraude na entrega de coisa"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "V",
                                                                                                                                                                                                                                                                                                             "rotulo":    "V",
                                                                                                                                                                                                                                                                                                             "linha":    2784,
                                                                                                                                                                                                                                                                                                             "texto":    "defrauda de qualquer modo o pagamento de cheque que emitiu a favor de alguém.",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Fraude no pagamento de cheque"
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2786,
                                                                                                                                                                                                                                                                     "texto":    "Os crimes previstos nos ns. I a V do parágrafo anterior são considerados militares sòmente nos casos do art. 9º, nº II, letras a e e ."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    2790,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada, se o crime é cometido em detrimento da administração militar.",
                                                                                                                                                                                                                                                                     "rubrica":    "Agravação de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "252º",
                                                                                                                                                                                                                        "rotulo":    "Art. 252º.",
                                                                                                                                                                                                                        "linha":    2794,
                                                                                                                                                                                                                        "caput":    "Abusar, em proveito próprio ou alheio, no exercício de função, em unidade, repartição ou estabelecimento militar, da necessidade, paixão ou inexperiência, ou da doença ou deficiência mental de outrem, induzindo-o à prática de ato que produza efeito jurídico, em prejuízo próprio ou de terceiro, ou em detrimento da administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Abuso de pessoa"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "253º",
                                                                                                                                                                                                                        "rotulo":    "Art. 253º.",
                                                                                                                                                                                                                        "linha":    2798,
                                                                                                                                                                                                                        "caput":    "Nos crimes previstos neste capítulo, aplica-se o disposto nos §§ 1º e 2º do art. 240."
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO ESTELIONATO E OUTRAS FRAUDES",
                                                                                                                                                                                "linhaTitulo":    2757
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO V",
                                                                                                                                                                                "linha":    2800,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "254º",
                                                                                                                                                                                                                        "rotulo":    "Art. 254º.",
                                                                                                                                                                                                                        "linha":    2804,
                                                                                                                                                                                                                        "caput":    "Adquirir, receber ou ocultar em proveito próprio ou alheio, coisa proveniente de crime, ou influir para que terceiro, de boa-fé, a adquira, receba ou oculte:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Receptação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2809,
                                                                                                                                                                                                                                                                     "texto":    "São aplicáveis os §§ 1º e 2º do art. 240."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2813,
                                                                                                                                                                                                                                                                     "texto":    "Se a coisa é arma, munição, explosivo ou outro material militar de uso restrito ou que contenha sinal indicativo de pertencer a instituição militar:",
                                                                                                                                                                                                                                                                     "rubrica":    "Receptação qualificada"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "255º",
                                                                                                                                                                                                                        "rotulo":    "Art. 255º.",
                                                                                                                                                                                                                        "linha":    2819,
                                                                                                                                                                                                                        "caput":    "Adquirir ou receber coisa que, por sua natureza ou pela manifesta desproporção entre o valor e o preço, ou pela condição de quem a oferece, deve presumir-se obtida por meio criminoso:",
                                                                                                                                                                                                                        "pena":    "detenção, até um ano.",
                                                                                                                                                                                                                        "rubrica":    "Receptação culposa",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2823,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente é primário e o valor da coisa não é superior a um décimo do salário mínimo, o juiz pode deixar de aplicar a pena."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "256º",
                                                                                                                                                                                                                        "rotulo":    "Art. 256º.",
                                                                                                                                                                                                                        "linha":    2827,
                                                                                                                                                                                                                        "caput":    "A receptação é punível ainda que desconhecido ou isento de pena o autor do crime de que proveio a coisa.",
                                                                                                                                                                                                                        "rubrica":    "Punibilidade da receptação"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA RECEPTAÇÃO",
                                                                                                                                                                                "linhaTitulo":    2801
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VI",
                                                                                                                                                                                "linha":    2829,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "257º",
                                                                                                                                                                                                                        "rotulo":    "Art. 257º.",
                                                                                                                                                                                                                        "linha":    2833,
                                                                                                                                                                                                                        "caput":    "Suprimir ou deslocar tapume, marco ou qualquer outro sinal indicativo de linha divisória, para apropriar-se, no todo ou em parte, de coisa imóvel sob administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Alteração de limites",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2837,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem:",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2841,
                                                                                                                                                                                                                                                                                                             "texto":    "desvia ou represa, em proveito próprio ou de outrem, águas sob administração militar;",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Usurpação de águas"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2845,
                                                                                                                                                                                                                                                                                                             "texto":    "invade, com violência à pessoa ou à coisa, ou com grave ameaça, ou mediante concurso de duas ou mais pessoas, terreno ou edifício sob administração militar.",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Invasão de propriedade"
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2849,
                                                                                                                                                                                                                                                                     "texto":    "Quando há emprêgo de violência, fica ressalvada a pena a esta correspondente.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena correspondente à violência"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "258º",
                                                                                                                                                                                                                        "rotulo":    "Art. 258º.",
                                                                                                                                                                                                                        "linha":    2853,
                                                                                                                                                                                                                        "caput":    "Apor, suprimir ou alterar, indevidamente, em gado ou rebanho alheio, sob guarda ou administração militar, marca ou sinal indicativo de propriedade:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a três anos.",
                                                                                                                                                                                                                        "rubrica":    "Aposição, supressão ou alteração de marca"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA USURPAÇÃO",
                                                                                                                                                                                "linhaTitulo":    2830
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VII",
                                                                                                                                                                                "linha":    2857,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "259º",
                                                                                                                                                                                                                        "rotulo":    "Art. 259º.",
                                                                                                                                                                                                                        "linha":    2861,
                                                                                                                                                                                                                        "caput":    "Destruir, inutilizar, deteriorar ou fazer desaparecer coisa alheia:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Dano simples",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2865,
                                                                                                                                                                                                                                                                     "texto":    "Se se trata de bem público:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "260º",
                                                                                                                                                                                                                        "rotulo":    "Art. 260º.",
                                                                                                                                                                                                                        "linha":    2871,
                                                                                                                                                                                                                        "caput":    "Nos casos do artigo anterior, se o criminoso é primário e a coisa é de valor não excedente a um décimo do salário mínimo, o juiz pode atenuar a pena, ou considerar a infração como disciplinar.",
                                                                                                                                                                                                                        "rubrica":    "Dano atenuado",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2873,
                                                                                                                                                                                                                                                                     "texto":    "O benefício previsto no artigo é igualmente aplicável, se, dentro das condições nele estabelecidas, o criminoso repara o dano causado antes de instaurada a ação penal."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "261º",
                                                                                                                                                                                                                        "rotulo":    "Art. 261º.",
                                                                                                                                                                                                                        "linha":    2877,
                                                                                                                                                                                                                        "caput":    "Se o dano é cometido:",
                                                                                                                                                                                                                        "rubrica":    "Dano qualificada",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    2879,
                                                                                                                                                                                                                                                                "texto":    "com violência à pessoa ou grave ameaça;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    2881,
                                                                                                                                                                                                                                                                "texto":    "com emprêgo de substância inflamável ou explosiva, se o fato não constitui crime mais grave;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    2883,
                                                                                                                                                                                                                                                                "texto":    "por motivo egoístico ou com prejuízo considerável:"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "262º",
                                                                                                                                                                                                                        "rotulo":    "Art. 262º.",
                                                                                                                                                                                                                        "linha":    2889,
                                                                                                                                                                                                                        "caput":    "Praticar dano em material ou aparelhamento de guerra ou de utilidade militar, ainda que em construção ou fabricação, ou em efeitos recolhidos a depósito, pertencentes ou não às fôrças armadas:",
                                                                                                                                                                                                                        "pena":    "reclusão, até seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Dano em material ou aparelhamento de guerra"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "263º",
                                                                                                                                                                                                                        "rotulo":    "Art. 263º.",
                                                                                                                                                                                                                        "linha":    2895,
                                                                                                                                                                                                                        "caput":    "Causar a perda, destruição, inutilização, encalhe, colisão ou alagamento de navio de guerra ou de navio mercante em serviço militar, ou nêle causar avaria:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a dez anos.",
                                                                                                                                                                                                                        "rubrica":    "Dano em navio de guerra ou mercante em serviço militar",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2899,
                                                                                                                                                                                                                                                                     "texto":    "Se resulta lesão grave, a pena correspondente é aumentada da metade; se resulta a morte, é aplicada em dôbro."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2901,
                                                                                                                                                                                                                                                                     "texto":    "Se, para a prática do dano previsto no artigo, usou o agente de violência contra a pessoa, ser-lhe-á aplicada igualmente a pena a ela correspondente."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "264º",
                                                                                                                                                                                                                        "rotulo":    "Art. 264º.",
                                                                                                                                                                                                                        "linha":    2905,
                                                                                                                                                                                                                        "caput":    "Praticar dano:",
                                                                                                                                                                                                                        "rubrica":    "Dano em aparelhos e instalações de aviação e navais, e em estabelecimentos militares",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    2907,
                                                                                                                                                                                                                                                                "texto":    "em aeronave, hangar, depósito, pista ou instalações de campo de aviação, engenho de guerra motomecanizado, viatura em comboio militar, arsenal, dique, doca, armazém, quartel, alojamento ou em qualquer outra instalação militar;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    2909,
                                                                                                                                                                                                                                                                "texto":    "em estabelecimento militar sob regime industrial, ou centro industrial a serviço de construção ou fabricação militar:"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    2913,
                                                                                                                                                                                                                                                                     "texto":    "Aplica-se o disposto nos parágrafos do artigo anterior.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de dois a dez anos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "265º",
                                                                                                                                                                                                                        "rotulo":    "Art. 265º.",
                                                                                                                                                                                                                        "linha":    2919,
                                                                                                                                                                                                                        "caput":    "Fazer desaparecer, consumir ou extraviar combustível, armamento, munição ou peças de equipamento de navio, de aeronave ou de outros equipamentos militares:",
                                                                                                                                                                                                                        "pena":    "reclusão, até três anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Desaparecimento, consunção ou extravio"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "266º",
                                                                                                                                                                                                                        "rotulo":    "Art. 266º.",
                                                                                                                                                                                                                        "linha":    2927,
                                                                                                                                                                                                                        "caput":    "Se o crime dos arts. 262, 263, 264 e 265 deste Código é culposo, a pena é de detenção de 6 (seis) meses a 2 (dois) anos e, se dele resulta lesão corporal ou morte, aplica-se também a pena cominada ao crime culposo contra a pessoa.",
                                                                                                                                                                                                                        "rubrica":    "Modalidades culposas"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO DANO",
                                                                                                                                                                                "linhaTitulo":    2858
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VIII",
                                                                                                                                                                                "linha":    2929,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "267º",
                                                                                                                                                                                                                        "rotulo":    "Art. 267º.",
                                                                                                                                                                                                                        "linha":    2933,
                                                                                                                                                                                                                        "caput":    "Obter ou estipular, para si ou para outrem, no contrato de mútuo de dinheiro, abusando da premente necessidade, inexperiência ou leviandade do mutuário, juro que excede a taxa fixada em lei, regulamento ou ato oficial:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Usura pecuniária",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2939,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem, em repartição ou local sob administração militar, recebe vencimento ou provento de outrem, ou permite que êstes sejam recebidos, auferindo ou permitindo que outrem aufira proveito cujo valor excede a taxa de três por cento",
                                                                                                                                                                                                                                                                     "rubrica":    "Casos assimilados"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2945,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de 1/3 (um terço) se o crime é cometido por superior, por militar ou por servidor público, em razão da função.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA USURA",
                                                                                                                                                                                "linhaTitulo":    2930
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA O PATRIMÔNIO",
                                                                                                                                     "linhaTitulo":    2584
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO VI",
                                                                                                                                     "linha":    2947,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    2949,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "268º",
                                                                                                                                                                                                                        "rotulo":    "Art. 268º.",
                                                                                                                                                                                                                        "linha":    2953,
                                                                                                                                                                                                                        "caput":    "Causar incêndio em lugar sujeito à administração militar, expondo a perigo a vida, a integridade física ou o patrimônio de outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Incêndio",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2957,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada:",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    2961,
                                                                                                                                                                                                                                                                                                             "texto":    "se o crime é cometido com intuito de obter vantagem pecuniária para si ou para outrem;",
                                                                                                                                                                                                                                                                                                             "rubrica":    "Agravação de pena"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    2963,
                                                                                                                                                                                                                                                                                                             "texto":    "se o incêndio é:",
                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                     "letra":    "a",
                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "a)",
                                                                                                                                                                                                                                                                                                                                                     "linha":    2965,
                                                                                                                                                                                                                                                                                                                                                     "texto":    "em casa habitada ou destinada a habitação;",
                                                                                                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                                                                                                             "letra":    "b",
                                                                                                                                                                                                                                                                                                                                                                                             "rotulo":    "b)",
                                                                                                                                                                                                                                                                                                                                                                                             "linha":    2967,
                                                                                                                                                                                                                                                                                                                                                                                             "texto":    "em edifício público ou qualquer construção destinada a uso público ou a obra de assistência social ou de cultura;",
                                                                                                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                                                                                                     "letra":    "c",
                                                                                                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "c)",
                                                                                                                                                                                                                                                                                                                                                                                                                                     "linha":    2969,
                                                                                                                                                                                                                                                                                                                                                                                                                                     "texto":    "em navio, aeronave, comboio ou veículo de transporte coletivo;",
                                                                                                                                                                                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "letra":    "d",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "rotulo":    "d)",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "linha":    2971,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "texto":    "em estação ferroviária, rodoviária, aeródromo ou construção portuária;",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "letra":    "e",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "rotulo":    "e)",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "linha":    2973,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "texto":    "em estaleiro, fábrica ou oficina;",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "alineas":    [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "@{letra=f; rotulo=f); linha=2975; texto=em depósito de explosivo, combustível ou inflamável;; alineas=System.Object[]}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    2981,
                                                                                                                                                                                                                                                                     "texto":    "Se culposo o incêndio:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "269º",
                                                                                                                                                                                                                        "rotulo":    "Art. 269º.",
                                                                                                                                                                                                                        "linha":    2989,
                                                                                                                                                                                                                        "caput":    "Causar ou tentar causar explosão, em lugar sujeito à administração militar, expondo a perigo a vida, a integridade ou o patrimônio de outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, até quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Explosão",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    2995,
                                                                                                                                                                                                                                                                     "texto":    "Se a substância utilizada é dinamite ou outra de efeitos análogos:",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3001,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada se ocorre qualquer das hipóteses previstas no § 1º, nº I, do artigo anterior, ou é visada ou atingida qualquer das coisas enumeradas no nº II do mesmo parágrafo.",
                                                                                                                                                                                                                                                                     "rubrica":    "Agravação de pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    3003,
                                                                                                                                                                                                                                                                     "texto":    "Se a explosão é causada pelo desencadeamento de energia nuclear:"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    3009,
                                                                                                                                                                                                                                                                     "texto":    "No caso de culpa, se a explosão é causada por dinamite ou substância de efeitos análogos, a pena é detenção, de seis meses a dois anos; se é causada pelo desencadeamento de energia nuclear, detenção de três a dez anos; nos demais casos, detenção de três meses a um ano.",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "270º",
                                                                                                                                                                                                                        "rotulo":    "Art. 270º.",
                                                                                                                                                                                                                        "linha":    3013,
                                                                                                                                                                                                                        "caput":    "Expor a perigo a vida, a integridade física ou o patrimônio de outrem, em lugar sujeito à administração militar, usando de gás tóxico ou asfixiante ou prejudicial de qualquer modo à incolumidade da pessoa ou da coisa:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Emprêgo de gás tóxico ou asfixiante",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3019,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "271º",
                                                                                                                                                                                                                        "rotulo":    "Art. 271º.",
                                                                                                                                                                                                                        "linha":    3025,
                                                                                                                                                                                                                        "caput":    "Expor a perigo a vida ou a integridade física de outrem, em lugar sujeito à administração militar, pelo abuso de radiaçãoionizante ou de substância radioativa:",
                                                                                                                                                                                                                        "pena":    "reclusão, até quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Abuso de radiação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3031,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "272º",
                                                                                                                                                                                                                        "rotulo":    "Art. 272º.",
                                                                                                                                                                                                                        "linha":    3037,
                                                                                                                                                                                                                        "caput":    "Causar inundação, em lugar sujeito à administração militar, expondo a perigo a vida, a integridade física ou o patrimônio de outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Inundação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3043,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "273º",
                                                                                                                                                                                                                        "rotulo":    "Art. 273º.",
                                                                                                                                                                                                                        "linha":    3049,
                                                                                                                                                                                                                        "caput":    "Remover, destruir ou inutilizar obstáculo natural ou obra destinada a impedir inundação, expondo a perigo a vida, a integridade física ou o patrimônio de outrem, em lugar sujeito à administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Perigo de inundação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "274º",
                                                                                                                                                                                                                        "rotulo":    "Art. 274º.",
                                                                                                                                                                                                                        "linha":    3055,
                                                                                                                                                                                                                        "caput":    "Causar desabamento ou desmoronamento, em lugar sujeito à administração militar, expondo a perigo a vida, a integridade física ou o patrimônio de outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Desabamento ou desmoronamento",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3061,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "275º",
                                                                                                                                                                                                                        "rotulo":    "Art. 275º.",
                                                                                                                                                                                                                        "linha":    3067,
                                                                                                                                                                                                                        "caput":    "Subtrair, ocultar ou inutilizar, por ocasião de incêndio, inundação, naufrágio, ou outro desastre ou calamidade, aparelho, material ou qualquer meio destinado a serviço de combate ao perigo, de socorro ou salvamento; ou impedir ou dificultar serviço de tal natureza:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Subtração, ocultação ou inutilização de material de socorro"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "276º",
                                                                                                                                                                                                                        "rotulo":    "Art. 276º.",
                                                                                                                                                                                                                        "linha":    3073,
                                                                                                                                                                                                                        "caput":    "Praticar qualquer dos fatos previstos nos artigos anteriores dêste capítulo, expondo a perigo, embora em lugar não sujeito à administração militar navio, aeronave, material ou engenho de guerra motomecanizado ou não, ainda que em construção ou fabricação, destinados às fôrças armadas, ou instalações especialmente a serviço delas:",
                                                                                                                                                                                                                        "pena":    "reclusão de dois a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Fatos que expõem a perigo aparelhamento militar",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3079,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "277º",
                                                                                                                                                                                                                        "rotulo":    "Art. 277º.",
                                                                                                                                                                                                                        "linha":    3085,
                                                                                                                                                                                                                        "caput":    "Se do crime doloso de perigo comum resulta, além da vontade do agente, lesão grave, a pena é aumentada de metade; se resulta morte, é aplicada em dôbro. No caso de culpa, se do fato resulta lesão corporal, a pena aumenta-se de metade; se resulta morte, aplica-se a pena cominada ao homicídio culposo, aumentada de um têrço.",
                                                                                                                                                                                                                        "rubrica":    "Formas qualificadas pelo resultado"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "278º",
                                                                                                                                                                                                                        "rotulo":    "Art. 278º.",
                                                                                                                                                                                                                        "linha":    3089,
                                                                                                                                                                                                                        "caput":    "Difundir doença ou praga que possa causar dano a floresta, plantação, pastagem ou animais de utilidade econômica ou militar, em lugar sob administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até três anos.",
                                                                                                                                                                                                                        "rubrica":    "Difusão de epizootia ou praga vegetal",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3095,
                                                                                                                                                                                                                                                                     "texto":    "No caso de culpa, a pena é de detenção, até seis meses.",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "279º",
                                                                                                                                                                                                                        "rotulo":    "Art. 279º.",
                                                                                                                                                                                                                        "linha":    3099,
                                                                                                                                                                                                                        "caput":    "Dirigir veículo motorizado, sob administração militar na via pública, encontrando-se em estado de embriaguez, por bebida alcoólica, ou qualquer outro inebriante:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Embriaguez ao volante"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "280º",
                                                                                                                                                                                                                        "rotulo":    "Art. 280º.",
                                                                                                                                                                                                                        "linha":    3105,
                                                                                                                                                                                                                        "caput":    "Violar regra de regulamento de trânsito, dirigindo veículo sob administração militar, expondo a efetivo e grave perigo a incolumidade de outrem:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Perigo resultante de violação de regra de trânsito"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "281º",
                                                                                                                                                                                                                        "rotulo":    "Art. 281º.",
                                                                                                                                                                                                                        "linha":    3111,
                                                                                                                                                                                                                        "caput":    "Causar, na direção de veículo motorizado, sob administração militar, ainda que sem culpa, acidente de trânsito, de que resulte dano pessoal, e, em seguida, afastar-se do local, sem prestar socorro à vítima que dêle necessite:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a um ano, sem prejuízo das cominadas nos arts. 206 e 210.",
                                                                                                                                                                                                                        "rubrica":    "Fuga após acidente de trânsito",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3117,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente se abstém de fugir e, na medida que as circunstâncias o permitam, presta ou providencia para que seja prestado socorro à vítima, fica isento de prisão em flagrante.",
                                                                                                                                                                                                                                                                     "rubrica":    "Isenção de prisão em flagrante"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES DE PERIGO COMUM",
                                                                                                                                                                                "linhaTitulo":    2950
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    3119,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "282º",
                                                                                                                                                                                                                        "rotulo":    "Art. 282º.",
                                                                                                                                                                                                                        "linha":    3124,
                                                                                                                                                                                                                        "caput":    "Impedir ou perturbar serviço de estrada de ferro, sob administração ou requisição militar emanada de ordem legal:",
                                                                                                                                                                                                                        "rubrica":    "Perigo de desastre ferroviário",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    3126,
                                                                                                                                                                                                                                                                "texto":    "danificando ou desarranjando, total ou parcialmente, linha férrea, material rodante ou de tração, obra de arte ou instalação;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    3128,
                                                                                                                                                                                                                                                                "texto":    "colocando obstáculo na linha;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    3130,
                                                                                                                                                                                                                                                                "texto":    "transmitindo falso aviso acêrca do movimento dos veículos, ou interrompendo ou embaraçando o funcionamento dos meios de comunicação;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    3132,
                                                                                                                                                                                                                                                                "texto":    "praticando qualquer outro ato de que possa resultar desastre:"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ],
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3138,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta desastre:",
                                                                                                                                                                                                                                                                     "rubrica":    "Desastre efetivo"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3142,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente quis causar o desastre ou assumiu o risco de produzi-lo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de quatro a doze anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    3148,
                                                                                                                                                                                                                                                                     "texto":    "No caso de culpa, ocorrendo desastre:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    3154,
                                                                                                                                                                                                                                                                     "texto":    "Para os efeitos dêste artigo, entende-se por \"estrada de ferro\" qualquer via de comunicação em que circulem veículos de tração mecânica, em trilhos ou por meio de cabo aéreo.",
                                                                                                                                                                                                                                                                     "rubrica":    "Conceito de \"estrada de ferro\""
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "283º",
                                                                                                                                                                                                                        "rotulo":    "Art. 283º.",
                                                                                                                                                                                                                        "linha":    3158,
                                                                                                                                                                                                                        "caput":    "Expor a perigo aeronave, ou navio próprio ou alheio, sob guarda, proteção ou requisição militar emanada de ordem legal, ou em lugar sujeito à administração militar, bem como praticar qualquer ato tendente a impedir ou dificultar navegação aérea, marítima, fluvial ou lacustre sob administração, guarda ou proteção militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Atentado contra transporte",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3164,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta naufrágio, submersão ou encalhe do navio, ou a queda ou destruição da aeronave:",
                                                                                                                                                                                                                                                                     "rubrica":    "Superveniência de sinistro"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3170,
                                                                                                                                                                                                                                                                     "texto":    "No caso de culpa, se ocorre o sinistro:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "284º",
                                                                                                                                                                                                                        "rotulo":    "Art. 284º.",
                                                                                                                                                                                                                        "linha":    3176,
                                                                                                                                                                                                                        "caput":    "Expor a perigo viatura ou outro meio de transporte militar, ou sob guarda, proteção ou requisição militar emanada de ordem legal, impedir-lhe ou dificultar-lhe o funcionamento:",
                                                                                                                                                                                                                        "pena":    "reclusão, até três anos.",
                                                                                                                                                                                                                        "rubrica":    "Atentado contra viatura ou outro meio de transporte",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3182,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta desastre, a pena é reclusão de dois a cinco anos.",
                                                                                                                                                                                                                                                                     "rubrica":    "Desastre efetivo"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3186,
                                                                                                                                                                                                                                                                     "texto":    "No caso de culpa, se ocorre desastre:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "285º",
                                                                                                                                                                                                                        "rotulo":    "Art. 285º.",
                                                                                                                                                                                                                        "linha":    3192,
                                                                                                                                                                                                                        "caput":    "Se de qualquer dos crimes previstos nos arts. 282 a 284, no caso de desastre ou sinistro, resulta morte de alguém, aplica-se o disposto no art. 277.",
                                                                                                                                                                                                                        "rubrica":    "Formas qualificadas pelo resultado"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "286º",
                                                                                                                                                                                                                        "rotulo":    "Art. 286º.",
                                                                                                                                                                                                                        "linha":    3196,
                                                                                                                                                                                                                        "caput":    "Arremessar projétil contra veículo militar, em movimento, destinado a transporte por terra, por água ou pelo ar:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Arremêsso de projétil",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3202,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta lesão corporal, a pena é de detenção, de seis meses a dois anos; se resulta morte, a pena é a do homicídio culposo, aumentada de um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada pelo resultado"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "287º",
                                                                                                                                                                                                                        "rotulo":    "Art. 287º.",
                                                                                                                                                                                                                        "linha":    3206,
                                                                                                                                                                                                                        "caput":    "Atentar contra a segurança ou o funcionamento de serviço de água, luz, fôrça ou acesso, ou qualquer outro de utilidade, em edifício ou outro lugar sujeito à administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Atentado contra serviço de utilidade militar",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3210,
                                                                                                                                                                                                                                                                     "texto":    "Aumentar-se-á a pena de um têrço até metade, se o dano ocorrer em virtude de subtração de material essencial ao funcionamento do serviço."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "288º",
                                                                                                                                                                                                                        "rotulo":    "Art. 288º.",
                                                                                                                                                                                                                        "linha":    3214,
                                                                                                                                                                                                                        "caput":    "Interromper, perturbar ou dificultar serviço telegráfico, telefônico, telemétrico, de televisão, telepercepção, sinalização, ou outro meio de comunicação militar; ou impedir ou dificultar a sua instalação em lugar sujeito à administração militar, ou desde que para esta seja de interêsse qualquer daqueles serviços ou meios:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a três anos.",
                                                                                                                                                                                                                        "rubrica":    "Interrupção ou perturbação de serviço ou meio de comunicação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "289º",
                                                                                                                                                                                                                        "rotulo":    "Art. 289º.",
                                                                                                                                                                                                                        "linha":    3220,
                                                                                                                                                                                                                        "caput":    "Nos crimes previstos neste capítulo, a pena será agravada, se forem cometidos em ocasião de calamidade pública.",
                                                                                                                                                                                                                        "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES CONTRA OS MEIOS DE TRANSPORTE E DE COMUNICAÇÃO",
                                                                                                                                                                                "linhaTitulo":    3120
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    3222,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "290º",
                                                                                                                                                                                                                        "rotulo":    "Art. 290º.",
                                                                                                                                                                                                                        "linha":    3226,
                                                                                                                                                                                                                        "caput":    "Receber, preparar, produzir, vender, fornecer, ainda que gratuitamente, ter em depósito, transportar, trazer consigo, ainda que para uso próprio, guardar, ministrar ou entregar de qualquer forma a consumo substância entorpecente, ou que determine dependência física ou psíquica, em lugar sujeito à administração militar, sem autorização ou em desacôrdo com determinação legal ou regulamentar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Tráfico, posse ou uso de entorpecente ou substância de efeito similar",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3232,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre, ainda que o fato incriminado ocorra em lugar não sujeito à administração militar:",
                                                                                                                                                                                                                                                                     "rubrica":    "Casos assimilados",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    3234,
                                                                                                                                                                                                                                                                                                             "texto":    "militar que fornece, de qualquer forma, substância entorpecente ou que determine dependência física ou psíquica a outro militar;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    3236,
                                                                                                                                                                                                                                                                                                             "texto":    "militar que, em serviço ou em missão de natureza militar, no país ou no estrangeiro, pratica qualquer dos fatos especificados no artigo;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    3238,
                                                                                                                                                                                                                                                                                                             "texto":    "quem fornece, ministra ou entrega, de qualquer forma, substância entorpecente ou que determine dependência física ou psíquica a militar em serviço, ou em manobras ou exercício."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3242,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente é farmacêutico, médico, dentista ou veterinário:",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    3246,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre o militar que se apresentar para o serviço sob o efeito de substância entorpecente.",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de dois a oito anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    3248,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de metade se as condutas descritas no caput deste artigo são cometidas por militar em serviço."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "5",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 5",
                                                                                                                                                                                                                                                                     "linha":    3250,
                                                                                                                                                                                                                                                                     "texto":    "Tratando-se de tráfico de drogas, a pena será de reclusão de 5 (cinco) a 15 (quinze) anos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "291º",
                                                                                                                                                                                                                        "rotulo":    "Art. 291º.",
                                                                                                                                                                                                                        "linha":    3256,
                                                                                                                                                                                                                        "caput":    "Prescrever o médico ou dentista, ou aviar o farmacêutico receita, ou fornecer substância entorpecente ou que determine dependência física ou psíquica fora dos casos indicados pela terapêutica, ou em dose evidentemente maior que a necessária, ou com infração de preceito legal ou regulamentar, para uso de militar ou para entrega a este, ou para qualquer fim, a qualquer pessoa, em consultório, gabinete, farmácia, laboratório ou lugar sujeitos à administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Receita ilegal",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3262,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre:",
                                                                                                                                                                                                                                                                     "rubrica":    "Casos assimilados",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    3265,
                                                                                                                                                                                                                                                                                                             "texto":    "militar ou o servidor público que, tendo sob sua guarda ou cuidado substância entorpecente ou que determine dependência física ou psíquica, em farmácia, em laboratório, em consultório, em gabinete ou em depósito militar, dela lança mão para uso próprio ou de outrem, ou para destino que não seja lícito ou regular;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    3267,
                                                                                                                                                                                                                                                                                                             "texto":    "quem subtrai substância entorpecente ou que determine dependência física ou psíquica, ou dela se apropria, em lugar sujeito à administração militar, sem prejuízo da pena decorrente da subtração ou apropriação indébita;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    3269,
                                                                                                                                                                                                                                                                                                             "texto":    "quem induz ou instiga militar em serviço ou em manobras ou exercício a usar substância entorpecente ou que determine dependência física ou psíquica;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "IV",
                                                                                                                                                                                                                                                                                                             "rotulo":    "IV",
                                                                                                                                                                                                                                                                                                             "linha":    3271,
                                                                                                                                                                                                                                                                                                             "texto":    "quem contribui, de qualquer forma, para incentivar ou difundir o uso de substância entorpecente ou que determine dependência física ou psíquica, em quartéis, navios, arsenais, estabelecimentos industriais, alojamentos, escolas, colégios ou outros quaisquer estabelecimentos ou lugares sujeitos à administração militar, bem como entre militares que estejam em serviço, ou o desempenhem em missão para a qual tenham recebido ordem superior ou tenham sido legalmente requisitados."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "292º",
                                                                                                                                                                                                                        "rotulo":    "Art. 292º.",
                                                                                                                                                                                                                        "linha":    3275,
                                                                                                                                                                                                                        "caput":    "Causar epidemia, em lugar sujeito à administração militar, mediante propagação de germes patogênicos:",
                                                                                                                                                                                                                        "pena":    "reclusão, de cinco a quinze anos.",
                                                                                                                                                                                                                        "rubrica":    "Epidemia",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3281,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta morte, a pena é aplicada em dôbro.",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3285,
                                                                                                                                                                                                                                                                     "texto":    "No caso de culpa, a pena é de detenção, de um a dois anos, ou, se resulta morte, de dois a quatro anos.",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "293º",
                                                                                                                                                                                                                        "rotulo":    "Art. 293º.",
                                                                                                                                                                                                                        "linha":    3289,
                                                                                                                                                                                                                        "caput":    "Envenenar água potável ou substância alimentícia ou medicinal, expondo a perigo a saúde de militares em manobras ou exercício, ou de indefinido número de pessoas, em lugar sujeito à administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de cinco a quinze anos.",
                                                                                                                                                                                                                        "rubrica":    "Envenenamento com perigo extensivo",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3295,
                                                                                                                                                                                                                                                                     "texto":    "Está sujeito à mesma pena quem em lugar sujeito à administração militar, entrega a consumo, ou tem em depósito, para o fim de ser distribuída, água ou substância envenenada.",
                                                                                                                                                                                                                                                                     "rubrica":    "Caso assimilado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3299,
                                                                                                                                                                                                                                                                     "texto":    "Se resulta a morte de alguém:",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    3305,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo, a pena é de detenção, de seis meses a dois anos; ou, se resulta a morte, de dois a quatro anos.",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "294º",
                                                                                                                                                                                                                        "rotulo":    "Art. 294º.",
                                                                                                                                                                                                                        "linha":    3309,
                                                                                                                                                                                                                        "caput":    "Corromper ou poluir água potável de uso de quartel, fortaleza, unidade, navio, aeronave ou estabelecimento militar, ou de tropa em manobras ou exercício, tornando-a imprópria para consumo ou nociva à saúde:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Corrupção ou poluição de água potável",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3315,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "295º",
                                                                                                                                                                                                                        "rotulo":    "Art. 295º.",
                                                                                                                                                                                                                        "linha":    3321,
                                                                                                                                                                                                                        "caput":    "Fornecer às fôrças armadas substância alimentícia ou medicinal corrompida, adulterada ou falsificada, tornada, assim, nociva à saúde:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Fornecimento de substância nociva",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3327,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "296º",
                                                                                                                                                                                                                        "rotulo":    "Art. 296º.",
                                                                                                                                                                                                                        "linha":    3331,
                                                                                                                                                                                                                        "caput":    "Fornecer às fôrças armadas substância alimentícia ou medicinal alterada, reduzindo, assim, o seu valor nutritivo ou terapêutico:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Pena - detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3337,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "297º",
                                                                                                                                                                                                                        "rotulo":    "Art. 297º.",
                                                                                                                                                                                                                        "linha":    3343,
                                                                                                                                                                                                                        "caput":    "Deixar o médico militar, no exercício da função, de denunciar à autoridade pública doença cuja notificação é compulsória:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de notificação de doença"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES CONTRA A SAÚDE",
                                                                                                                                                                                "linhaTitulo":    3223
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA A INCOLUMIDADE PÚBLICA",
                                                                                                                                     "linhaTitulo":    2948
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO VII",
                                                                                                                                     "linha":    3347,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    3350,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "298º",
                                                                                                                                                                                                                        "rotulo":    "Art. 298º.",
                                                                                                                                                                                                                        "linha":    3354,
                                                                                                                                                                                                                        "caput":    "Desacatar superior, ofendendo-lhe a dignidade ou o decôro, ou procurando deprimir-lhe a autoridade:",
                                                                                                                                                                                                                        "pena":    "reclusão, até quatro anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Desacato a superior",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3360,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada, se o superior é oficial general ou comandante da unidade a que pertence o agente.",
                                                                                                                                                                                                                                                                     "rubrica":    "Agravação de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "299º",
                                                                                                                                                                                                                        "rotulo":    "Art. 299º.",
                                                                                                                                                                                                                        "linha":    3364,
                                                                                                                                                                                                                        "caput":    "Desacatar militar no exercício de função de natureza militar ou em razão dela:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, se o fato não constitui outro crime.",
                                                                                                                                                                                                                        "rubrica":    "Desacato a militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "300º",
                                                                                                                                                                                                                        "rotulo":    "Art. 300º.",
                                                                                                                                                                                                                        "linha":    3372,
                                                                                                                                                                                                                        "caput":    "Desacatar servidor público no exercício de função ou em razão dela, em lugar sujeito à administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, se o fato não constitui outro crime.",
                                                                                                                                                                                                                        "rubrica":    "Desacato a servidor público"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "301º",
                                                                                                                                                                                                                        "rotulo":    "Art. 301º.",
                                                                                                                                                                                                                        "linha":    3378,
                                                                                                                                                                                                                        "caput":    "Desobedecer a ordem legal de autoridade militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Desobediência"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "302º",
                                                                                                                                                                                                                        "rotulo":    "Art. 302º.",
                                                                                                                                                                                                                        "linha":    3384,
                                                                                                                                                                                                                        "caput":    "Penetrar em fortaleza, quartel, estabelecimento militar, navio, aeronave, hangar ou em outro lugar sujeito à administração militar, por onde seja defeso ou não haja passagem regular, ou iludindo a vigilância da sentinela ou de vigia:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Ingresso clandestino"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO DESACATO E DA DESOBEDIÊNCIA",
                                                                                                                                                                                "linhaTitulo":    3351
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    3388,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "303º",
                                                                                                                                                                                                                        "rotulo":    "Art. 303º.",
                                                                                                                                                                                                                        "linha":    3392,
                                                                                                                                                                                                                        "caput":    "Apropriar-se de dinheiro, valor ou qualquer outro bem móvel, público ou particular, de que tem a posse ou detenção, em razão do cargo ou comissão, ou desviá-lo em proveito próprio ou alheio:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a quinze anos.",
                                                                                                                                                                                                                        "rubrica":    "Peculato",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3396,
                                                                                                                                                                                                                                                                     "texto":    "A pena aumenta-se de um terço, se o objeto da apropriação ou desvio é de valor superior a vinte vêzes o salário mínimo."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3402,
                                                                                                                                                                                                                                                                     "texto":    "Aplica-se a mesma pena a quem, embora não tendo a posse ou detenção do dinheiro, valor ou bem, o subtrai, ou contribui para que seja subtraído, em proveito próprio ou alheio, valendo-se da facilidade que lhe proporciona a qualidade de militar ou de servidor público.",
                                                                                                                                                                                                                                                                     "rubrica":    "Peculato-furto"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    3408,
                                                                                                                                                                                                                                                                     "texto":    "Se o servidor público ou o militar contribui culposamente para que outrem subtraia ou desvie o dinheiro, valor ou bem, ou dele se aproprie:",
                                                                                                                                                                                                                                                                     "rubrica":    "Peculato culposo"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    3414,
                                                                                                                                                                                                                                                                     "texto":    "No caso do parágrafo anterior, a reparação do dano, se precede a sentença irrecorrível, extingue a punibilidade; se lhe é posterior, reduz de metade a pena imposta.",
                                                                                                                                                                                                                                                                     "rubrica":    "Extinção ou minoração da pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "304º",
                                                                                                                                                                                                                        "rotulo":    "Art. 304º.",
                                                                                                                                                                                                                        "linha":    3418,
                                                                                                                                                                                                                        "caput":    "Apropriar-se de dinheiro ou qualquer utilidade que, no exercício do cargo ou comissão, recebeu por êrro de outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a sete anos.",
                                                                                                                                                                                                                        "rubrica":    "Peculato mediante aproveitamento do êrro de outrem"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO PECULATO",
                                                                                                                                                                                "linhaTitulo":    3389
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    3422,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "305º",
                                                                                                                                                                                                                        "rotulo":    "Art. 305º.",
                                                                                                                                                                                                                        "linha":    3426,
                                                                                                                                                                                                                        "caput":    "Exigir, para si ou para outrem, direta ou indiretamente, ainda que fora da função ou antes de assumi-la, mas em razão dela, vantagem indevida:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Concussão"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "306º",
                                                                                                                                                                                                                        "rotulo":    "Art. 306º.",
                                                                                                                                                                                                                        "linha":    3432,
                                                                                                                                                                                                                        "caput":    "Exigir impôsto, taxa ou emolumento que sabe indevido, ou, quando devido, empregar na cobrança meio vexatório ou gravoso, que a lei não autoriza:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Excesso de exação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "307º",
                                                                                                                                                                                                                        "rotulo":    "Art. 307º.",
                                                                                                                                                                                                                        "linha":    3438,
                                                                                                                                                                                                                        "caput":    "Desviar, em proveito próprio ou de outrem, o que recebeu indevidamente, em razão do cargo ou função, para recolher aos cofres públicos:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a doze anos.",
                                                                                                                                                                                                                        "rubrica":    "Desvio"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA CONCUSSÃO, EXCESSO DE EXAÇÃO E DESVIO",
                                                                                                                                                                                "linhaTitulo":    3423
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    3442,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "308º",
                                                                                                                                                                                                                        "rotulo":    "Art. 308º.",
                                                                                                                                                                                                                        "linha":    3449,
                                                                                                                                                                                                                        "caput":    "Solicitar ou receber, para si ou para outrem, direta ou indiretamente, ainda que fora da função ou antes de assumi-la, mas em razão dela, vantagem indevida, ou aceitar promessa de tal vantagem:",
                                                                                                                                                                                                                        "pena":    "reclusão, de 2 (dois) a 12 (doze) anos.",
                                                                                                                                                                                                                        "rubrica":    "Corrupção passiva",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3455,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de um terço, se, em conseqüência da vantagem ou promessa, o agente retarda ou deixa de praticar qualquer ato de ofício ou o pratica infringindo dever funcional.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3459,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente pratica, deixa de praticar ou retarda o ato de ofício com infração de dever funcional, cedendo a pedido ou influência de outrem:",
                                                                                                                                                                                                                                                                     "rubrica":    "Diminuição de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "309º",
                                                                                                                                                                                                                        "rotulo":    "Art. 309º.",
                                                                                                                                                                                                                        "linha":    3465,
                                                                                                                                                                                                                        "caput":    "Dar, oferecer ou prometer dinheiro ou vantagem indevida para a prática, omissão ou retardamento de ato funcional:",
                                                                                                                                                                                                                        "pena":    "reclusão, até oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Corrupção ativa",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3471,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de um têrço, se, em razão da vantagem, dádiva ou promessa, é retardado ou omitido o ato, ou praticado com infração de dever funcional.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "310º",
                                                                                                                                                                                                                        "rotulo":    "Art. 310º.",
                                                                                                                                                                                                                        "linha":    3475,
                                                                                                                                                                                                                        "caput":    "Participar, de modo ostensivo ou simulado, diretamente ou por interposta pessoa, em contrato, fornecimento, ou concessão de qualquer serviço concernente à administração militar, sôbre que deva informar ou exercer fiscalização em razão do ofício:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Participação ilícita",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3479,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem adquire para si, direta ou indiretamente, ou por ato simulado, no todo ou em parte, bens ou efeitos em cuja administração, depósito, guarda, fiscalização ou exame, deve intervir em razão de seu emprêgo ou função, ou entra em especulação de lucro ou interêsse, relativamente a êsses bens ou efeitos."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA CORRUPÇÃO",
                                                                                                                                                                                "linhaTitulo":    3443
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO V",
                                                                                                                                                                                "linha":    3481,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "311º",
                                                                                                                                                                                                                        "rotulo":    "Art. 311º.",
                                                                                                                                                                                                                        "linha":    3485,
                                                                                                                                                                                                                        "caput":    "Falsificar, no todo ou em parte, documento público ou particular, ou alterar documento verdadeiro, desde que o fato atente contra a administração ou o serviço militar:",
                                                                                                                                                                                                                        "pena":    "sendo documento público, reclusão, de dois a seis anos; sendo documento particular, reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Falsificação de documento",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3491,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada se o agente é oficial ou exerce função em repartição militar.",
                                                                                                                                                                                                                                                                     "rubrica":    "Agravação da pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3495,
                                                                                                                                                                                                                                                                     "texto":    "Equipara-se a documento, para os efeitos penais, o disco fonográfico ou a fita ou fio de aparelho eletromagnético a que se incorpore declaração destinada à prova de fato jurìdicamente relevante.",
                                                                                                                                                                                                                                                                     "rubrica":    "Documento por equiparação"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "312º",
                                                                                                                                                                                                                        "rotulo":    "Art. 312º.",
                                                                                                                                                                                                                        "linha":    3499,
                                                                                                                                                                                                                        "caput":    "Omitir, em documento público ou particular, declaração que dêle devia constar, ou nêle inserir ou fazer inserir declaração falsa ou diversa da que devia ser escrita, com o fim de prejudicar direito, criar obrigação ou alterar a verdade sôbre fato jurìdicamente relevante, desde que o fato atente contra a administração ou o serviço militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos, se o documento é público; reclusão, até três anos, se o documento é particular.",
                                                                                                                                                                                                                        "rubrica":    "Falsidade ideológica"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "313º",
                                                                                                                                                                                                                        "rotulo":    "Art. 313º.",
                                                                                                                                                                                                                        "linha":    3505,
                                                                                                                                                                                                                        "caput":    "Emitir cheque sem suficiente provisão de fundos em poder do sacado, se a emissão é feita de militar em favor de militar, ou se o fato atenta contra a administração militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                                                                        "rubrica":    "Cheque sem fundos",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3511,
                                                                                                                                                                                                                                                                     "texto":    "Salvo o caso do art. 245, é irrelevante ter sido o cheque emitido para servir como título ou garantia de dívida.",
                                                                                                                                                                                                                                                                     "rubrica":    "Circunstância irrelevante"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3515,
                                                                                                                                                                                                                                                                     "texto":    "Ao crime previsto no artigo aplica-se o disposto nos §§ 1º e 2º do art. 240.",
                                                                                                                                                                                                                                                                     "rubrica":    "Atenuação de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "314º",
                                                                                                                                                                                                                        "rotulo":    "Art. 314º.",
                                                                                                                                                                                                                        "linha":    3519,
                                                                                                                                                                                                                        "caput":    "Atestar ou certificar falsamente, em razão de função, ou profissão, fato ou circunstância que habilite alguém a obter cargo, pôsto ou função, ou isenção de ônus ou de serviço, ou qualquer outra vantagem, desde que o fato atente contra a administração ou serviço militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Certidão ou atestado ideológicamente falso",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3525,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada se o crime é praticado com o fim de lucro ou em prejuízo de terceiro.",
                                                                                                                                                                                                                                                                     "rubrica":    "Agravação de pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "315º",
                                                                                                                                                                                                                        "rotulo":    "Art. 315º.",
                                                                                                                                                                                                                        "linha":    3529,
                                                                                                                                                                                                                        "caput":    "Fazer uso de qualquer dos documentos falsificados ou alterados por outrem, a que se referem os artigos anteriores:",
                                                                                                                                                                                                                        "pena":    "a cominada à falsificação ou à alteração.",
                                                                                                                                                                                                                        "rubrica":    "Uso de documento falso"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "316º",
                                                                                                                                                                                                                        "rotulo":    "Art. 316º.",
                                                                                                                                                                                                                        "linha":    3535,
                                                                                                                                                                                                                        "caput":    "Destruir, suprimir ou ocultar, em benefício próprio ou de outrem, ou em prejuízo alheio, documento verdadeiro, de que não podia dispor, desde que o fato atente contra a administração ou o serviço militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a seis anos, se o documento é público; reclusão, até cinco anos, se o documento é particular.",
                                                                                                                                                                                                                        "rubrica":    "Supressão de documento"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "317º",
                                                                                                                                                                                                                        "rotulo":    "Art. 317º.",
                                                                                                                                                                                                                        "linha":    3541,
                                                                                                                                                                                                                        "caput":    "Usar, como próprio, documento de identidade alheia, ou de qualquer licença ou privilégio em favor de outrem, ou ceder a outrem documento próprio da mesma natureza, para que dêle se utilize, desde que o fato atente contra a administração ou o serviço militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses, se o fato não constitui elemento de crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Uso de documento pessoal alheio"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "318º",
                                                                                                                                                                                                                        "rotulo":    "Art. 318º.",
                                                                                                                                                                                                                        "linha":    3547,
                                                                                                                                                                                                                        "caput":    "Atribuir-se, ou a terceiro, perante a administração militar, falsa identidade, para obter vantagem em proveito próprio ou alheio, ou para causar dano a outrem:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Falsa identidade"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA FALSIDADE",
                                                                                                                                                                                "linhaTitulo":    3482
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VI",
                                                                                                                                                                                "linha":    3551,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "319º",
                                                                                                                                                                                                                        "rotulo":    "Art. 319º.",
                                                                                                                                                                                                                        "linha":    3555,
                                                                                                                                                                                                                        "caput":    "Retardar ou deixar de praticar, indevidamente, ato de ofício, ou praticá-lo contra expressa disposição de lei, para satisfazer interêsse ou sentimento pessoal:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Prevaricação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "320º",
                                                                                                                                                                                                                        "rotulo":    "Art. 320º.",
                                                                                                                                                                                                                        "linha":    3561,
                                                                                                                                                                                                                        "caput":    "Violar, em qualquer negócio de que tenha sido incumbido pela administração militar, seu dever funcional para obter especulativamente vantagem pessoal, para si ou para outrem:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Violação do dever funcional com o fim de lucro"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "321º",
                                                                                                                                                                                                                        "rotulo":    "Art. 321º.",
                                                                                                                                                                                                                        "linha":    3567,
                                                                                                                                                                                                                        "caput":    "Extraviar livro oficial, ou qualquer documento, de que tem a guarda em razão do cargo, sonegá-lo ou inutilizá-lo, total ou parcialmente:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a seis anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Extravio, sonegação ou inutilização de livro ou documento"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "322º",
                                                                                                                                                                                                                        "rotulo":    "Art. 322º.",
                                                                                                                                                                                                                        "linha":    3573,
                                                                                                                                                                                                                        "caput":    "Deixar de responsabilizar subordinado que comete infração no exercício do cargo, ou, quando lhe falte competência, não levar o fato ao conhecimento da autoridade competente:",
                                                                                                                                                                                                                        "pena":    "se o fato foi praticado por indulgência, detenção até seis meses; se por negligência, detenção até três meses.",
                                                                                                                                                                                                                        "rubrica":    "Condescendência criminosa"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "323º",
                                                                                                                                                                                                                        "rotulo":    "Art. 323º.",
                                                                                                                                                                                                                        "linha":    3579,
                                                                                                                                                                                                                        "caput":    "Deixar, no exercício de função, de incluir, por negligência, qualquer nome em relação ou lista para o efeito de alistamento ou de convocação militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Não inclusão de nome em lista"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "324º",
                                                                                                                                                                                                                        "rotulo":    "Art. 324º.",
                                                                                                                                                                                                                        "linha":    3585,
                                                                                                                                                                                                                        "caput":    "Deixar, no exercício de função, de observar lei, regulamento ou instrução, dando causa direta à prática de ato prejudicial à administração militar:",
                                                                                                                                                                                                                        "pena":    "se o fato foi praticado por tolerância, detenção de 1 (um) a 3 (três) anos, e, se por negligência, detenção de 1 (um) a 2 (dois) anos.",
                                                                                                                                                                                                                        "rubrica":    "Inobservância de lei, regulamento ou instrução"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "325º",
                                                                                                                                                                                                                        "rotulo":    "Art. 325º.",
                                                                                                                                                                                                                        "linha":    3592,
                                                                                                                                                                                                                        "caput":    "Devassar indevidamente o conteúdo de correspondência dirigida à administração militar, ou por esta expedida:",
                                                                                                                                                                                                                        "pena":    "detenção, de dois a seis meses, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Violação ou divulgação indevida de correspondência ou comunicação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3597,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem, ainda que não seja servidor público, mas desde que o fato atente contra a administração militar:",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    3599,
                                                                                                                                                                                                                                                                                                             "texto":    "indevidamente se se apossa de correspondência, embora não fechada, e no todo ou em parte a sonega ou destrói;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    3601,
                                                                                                                                                                                                                                                                                                             "texto":    "indevidamente divulga, transmite a outrem, ou abusivamente utiliza comunicação de interêsse militar;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "III",
                                                                                                                                                                                                                                                                                                             "rotulo":    "III",
                                                                                                                                                                                                                                                                                                             "linha":    3603,
                                                                                                                                                                                                                                                                                                             "texto":    "impede a comunicação referida no número anterior."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "326º",
                                                                                                                                                                                                                        "rotulo":    "Art. 326º.",
                                                                                                                                                                                                                        "linha":    3607,
                                                                                                                                                                                                                        "caput":    "Revelar fato de que tem ciência em razão do cargo ou função e que deva permanecer em segrêdo, ou facilitar-lhe a revelação, em prejuízo da administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Violação de sigilo funcional",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3611,
                                                                                                                                                                                                                                                                     "texto":    "Nas mesmas penas incorre quem:",
                                                                                                                                                                                                                                                                     "incisos":    [
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "I",
                                                                                                                                                                                                                                                                                                             "rotulo":    "I",
                                                                                                                                                                                                                                                                                                             "linha":    3613,
                                                                                                                                                                                                                                                                                                             "texto":    "permite ou facilita, mediante atribuição, fornecimento ou empréstimo de senha, ou de qualquer outra forma, o acesso de pessoas não autorizadas a sistemas de informações ou banco de dados da administração militar;"
                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                             "numero":    "II",
                                                                                                                                                                                                                                                                                                             "rotulo":    "II",
                                                                                                                                                                                                                                                                                                             "linha":    3615,
                                                                                                                                                                                                                                                                                                             "texto":    "se utiliza indevidamente do acesso restrito."
                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                             ]
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3617,
                                                                                                                                                                                                                                                                     "texto":    "Se da ação ou omissão resulta dano à administração militar ou a outrem:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "327º",
                                                                                                                                                                                                                        "rotulo":    "Art. 327º.",
                                                                                                                                                                                                                        "linha":    3623,
                                                                                                                                                                                                                        "caput":    "Devassar o sigilo de proposta de concorrência de interêsse da administração militar ou proporcionar a terceiro o ensejo de devassá-lo:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                                                                        "rubrica":    "Violação de sigilo de proposta de concorrência"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "328º",
                                                                                                                                                                                                                        "rotulo":    "Art. 328º.",
                                                                                                                                                                                                                        "linha":    3629,
                                                                                                                                                                                                                        "caput":    "Impedir, perturbar ou fraudar a realização de hasta pública, concorrência ou tomada de preços, de interêsse da administração militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Obstáculo à hasta pública, concorrência ou tomada de preços"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "329º",
                                                                                                                                                                                                                        "rotulo":    "Art. 329º.",
                                                                                                                                                                                                                        "linha":    3635,
                                                                                                                                                                                                                        "caput":    "Entrar no exercício de pôsto ou função militar, ou de cargo ou função em repartição militar, antes de satisfeitas as exigências legais, ou continuar o exercício, sem autorização, depois de saber que foi exonerado, ou afastado, legal e definitivamente, qualquer que seja o ato determinante do afastamento:",
                                                                                                                                                                                                                        "pena":    "detenção, até quatro meses, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Exercício funcional ilegal"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "330º",
                                                                                                                                                                                                                        "rotulo":    "Art. 330º.",
                                                                                                                                                                                                                        "linha":    3641,
                                                                                                                                                                                                                        "caput":    "Abandonar cargo público, em repartição ou estabelecimento militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até dois meses.",
                                                                                                                                                                                                                        "rubrica":    "Abandono de cargo",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3647,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta prejuízo à administração militar:",
                                                                                                                                                                                                                                                                     "rubrica":    "Formas qualificadas"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3651,
                                                                                                                                                                                                                                                                     "texto":    "Se o fato ocorre em lugar compreendido na faixa de fronteira:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - detenção, de três meses a um ano."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "331º",
                                                                                                                                                                                                                        "rotulo":    "Art. 331º.",
                                                                                                                                                                                                                        "linha":    3657,
                                                                                                                                                                                                                        "caput":    "Dar às verbas ou ao dinheiro público aplicação diversa da estabelecida em lei:",
                                                                                                                                                                                                                        "pena":    "detenção, até seis meses.",
                                                                                                                                                                                                                        "rubrica":    "Aplicação ilegal de verba ou dinheiro"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "332º",
                                                                                                                                                                                                                        "rotulo":    "Art. 332º.",
                                                                                                                                                                                                                        "linha":    3665,
                                                                                                                                                                                                                        "caput":    "Abusar da confiança ou da boa-fé de militar ou de servidor público, em serviço ou em razão deste, apresentando-lhe ou remetendo-lhe, para aprovação, recebimento, anuência ou aposição de visto, relação, nota, empenho de despesa, ordem ou folha de pagamento, comunicação, ofício ou qualquer outro documento que sabe, ou deve saber, serem inexatos ou irregulares, desde que o fato atente contra a administração ou o serviço militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Abuso de confiança ou boa-fé",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3671,
                                                                                                                                                                                                                                                                     "texto":    "A pena é agravada, se do fato decorre prejuízo material ou processo penal militar para a pessoa de cuja confiança ou boa-fé se abusou.",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3675,
                                                                                                                                                                                                                                                                     "texto":    "Se a apresentação ou remessa decorre de culpa:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "333º",
                                                                                                                                                                                                                        "rotulo":    "Art. 333º.",
                                                                                                                                                                                                                        "linha":    3681,
                                                                                                                                                                                                                        "caput":    "Praticar violência, em repartição ou estabelecimento militar, no exercício de função ou a pretexto de exercê-la:",
                                                                                                                                                                                                                        "pena":    "detenção, de seis meses a dois anos, além da correspondente à violência.",
                                                                                                                                                                                                                        "rubrica":    "Violência arbitrária"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "334º",
                                                                                                                                                                                                                        "rotulo":    "Art. 334º.",
                                                                                                                                                                                                                        "linha":    3689,
                                                                                                                                                                                                                        "caput":    "Patrocinar, direta ou indiretamente, interesse privado perante a administração militar, valendo-se da qualidade de servidor público ou de militar:",
                                                                                                                                                                                                                        "pena":    "detenção, até três meses.",
                                                                                                                                                                                                                        "rubrica":    "Patrocínio indébito",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3693,
                                                                                                                                                                                                                                                                     "texto":    "Se o interêsse é ilegítimo:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES CONTRA O DEVER FUNCIONAL",
                                                                                                                                                                                "linhaTitulo":    3552
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VII",
                                                                                                                                                                                "linha":    3697,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "335º",
                                                                                                                                                                                                                        "rotulo":    "Art. 335º.",
                                                                                                                                                                                                                        "linha":    3703,
                                                                                                                                                                                                                        "caput":    "Usurpar o exercício de função em repartição ou estabelecimento militar:",
                                                                                                                                                                                                                        "pena":    "detenção, de três meses a dois anos.",
                                                                                                                                                                                                                        "rubrica":    "Usurpação de função",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3707,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato o agente aufere vantagem:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "336º",
                                                                                                                                                                                                                        "rotulo":    "Art. 336º.",
                                                                                                                                                                                                                        "linha":    3716,
                                                                                                                                                                                                                        "caput":    "Solicitar, exigir, cobrar ou obter, para si ou para outrem, vantagem ou promessa de vantagem, a pretexto de influir em ato praticado por militar ou por servidor público de local sujeito à administração militar no exercício da função:",
                                                                                                                                                                                                                        "pena":    "reclusão, de 2 (dois) a 5 (cinco) anos.",
                                                                                                                                                                                                                        "rubrica":    "Tráfico de influência",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3724,
                                                                                                                                                                                                                                                                     "texto":    "A pena é aumentada de metade se o agente alega ou insinua que a vantagem é também destinada ao militar ou ao servidor público.",
                                                                                                                                                                                                                                                                     "rubrica":    "Aumento de Pena"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "337º",
                                                                                                                                                                                                                        "rotulo":    "Art. 337º.",
                                                                                                                                                                                                                        "linha":    3728,
                                                                                                                                                                                                                        "caput":    "Subtrair ou inutilizar, total ou parcialmente, livro oficial, processo ou qualquer documento, desde que o fato atente contra a administração ou o serviço militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a cinco anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Subtração ou inutilização de livro, processo ou documento"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "338º",
                                                                                                                                                                                                                        "rotulo":    "Art. 338º.",
                                                                                                                                                                                                                        "linha":    3734,
                                                                                                                                                                                                                        "caput":    "Rasgar, ou de qualquer forma inutilizar ou conspurcar edital afixado por ordem da autoridade militar; violar ou inutilizar sêlo ou sinal empregado, por determinação legal ou ordem de autoridade militar, para identificar ou cerrar qualquer objeto:",
                                                                                                                                                                                                                        "pena":    "detenção, até um ano.",
                                                                                                                                                                                                                        "rubrica":    "Inutilização de edital ou de sinal oficial"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "339º",
                                                                                                                                                                                                                        "rotulo":    "Art. 339º.",
                                                                                                                                                                                                                        "linha":    3740,
                                                                                                                                                                                                                        "caput":    "Impedir, perturbar ou fraudar em prejuízo da Fazenda Nacional, concorrência, hasta pública ou tomada de preços ou outro qualquer processo administrativo para aquisição ou venda de coisas ou mercadorias de uso das fôrças armadas, seja elevando arbitràriamente os preços, auferindo lucro excedente a um quinto do valor da transação, seja alterando substância, qualidade ou quantidade da coisa ou mercadoria fornecida, seja impedindo a livre concorrência de outros fornecedores, ou por qualquer modo tornando mais onerosa a transação:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a três anos.",
                                                                                                                                                                                                                        "rubrica":    "Impedimento, perturbação ou fraude de concorrência",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    3744,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre o intermediário na transação."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    3746,
                                                                                                                                                                                                                                                                     "texto":    "É aumentada a pena de um terço, se o crime ocorre em período de grave crise econômica."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES PRATICADOS POR PARTICULAR CONTRA A ADMINISTRAÇÃO",
                                                                                                                                                                                "linhaTitulo":    3698
                                                                                                                                                                        }
                                                                                                                                                                ],
                                                                                                                                     "artigos":    [

                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA A ADMINISTRAÇÃO MILITAR",
                                                                                                                                     "linhaTitulo":    3348
                                                                                                                             },
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO VIII",
                                                                                                                                     "linha":    3748,
                                                                                                                                     "divisoes":    [

                                                                                                                                                                ],
                                                                                                                                     "artigos":    [
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "340º",
                                                                                                                                                                             "rotulo":    "Art. 340º.",
                                                                                                                                                                             "linha":    3757,
                                                                                                                                                                             "caput":    "Recusar-se o militar a exercer, sem motivo legal, função que lhe seja atribuída na administração da Justiça Militar:",
                                                                                                                                                                             "pena":    "detenção, de 1 (um) a 2 (dois) anos.",
                                                                                                                                                                             "rubrica":    "Recusa de função na Justiça Militar"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "341º",
                                                                                                                                                                             "rotulo":    "Art. 341º.",
                                                                                                                                                                             "linha":    3763,
                                                                                                                                                                             "caput":    "Desacatar autoridade judiciária militar no exercício da função ou em razão dela:",
                                                                                                                                                                             "pena":    "reclusão, até quatro anos.",
                                                                                                                                                                             "rubrica":    "Desacato"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "342º",
                                                                                                                                                                             "rotulo":    "Art. 342º.",
                                                                                                                                                                             "linha":    3769,
                                                                                                                                                                             "caput":    "Usar de violência ou grave ameaça, com o fim de favorecer interêsse próprio ou alheio, contra autoridade, parte, ou qualquer outra pessoa que funciona, ou é chamada a intervir em inquérito policial, processo administrativo ou judicial militar:",
                                                                                                                                                                             "pena":    "reclusão, até quatro anos, além da pena correspondente à violência.",
                                                                                                                                                                             "rubrica":    "Coação"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "343º",
                                                                                                                                                                             "rotulo":    "Art. 343º.",
                                                                                                                                                                             "linha":    3775,
                                                                                                                                                                             "caput":    "Dar causa à instauração de inquérito policial ou processo judicial militar contra alguém, imputando-lhe crime sujeito à jurisdição militar, de que o sabe inocente:",
                                                                                                                                                                             "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                             "rubrica":    "Denunciação caluniosa",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    3781,
                                                                                                                                                                                                                            "texto":    "A pena é agravada, se o agente se serve do anonimato ou de nome suposto.",
                                                                                                                                                                                                                            "rubrica":    "Agravação de pena"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "344º",
                                                                                                                                                                             "rotulo":    "Art. 344º.",
                                                                                                                                                                             "linha":    3785,
                                                                                                                                                                             "caput":    "Provocar a ação da autoridade, comunicando-lhe a ocorrência de crime sujeito à jurisdição militar, que sabe não se ter verificado: Auto-acusação falsa",
                                                                                                                                                                             "pena":    "detenção, até seis meses.",
                                                                                                                                                                             "rubrica":    "Comunicação falsa de crime"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "345º",
                                                                                                                                                                             "rotulo":    "Art. 345º.",
                                                                                                                                                                             "linha":    3791,
                                                                                                                                                                             "caput":    "Acusar-se, perante a autoridade, de crime sujeito à jurisdição militar, inexistente ou praticado por outrem:",
                                                                                                                                                                             "pena":    "detenção, de três meses a um ano."
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "346º",
                                                                                                                                                                             "rotulo":    "Art. 346º.",
                                                                                                                                                                             "linha":    3797,
                                                                                                                                                                             "caput":    "Fazer afirmação falsa, ou negar ou calar a verdade, como testemunha, perito, tradutor ou intérprete, em inquérito policial, processo administrativo ou judicial, militar:",
                                                                                                                                                                             "pena":    "reclusão, de dois a seis anos.",
                                                                                                                                                                             "rubrica":    "Falso testemunho ou falsa perícia",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    3803,
                                                                                                                                                                                                                            "texto":    "A pena aumenta-se de um têrço, se o crime é praticado mediante subôrno.",
                                                                                                                                                                                                                            "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    3807,
                                                                                                                                                                                                                            "texto":    "O fato deixa de ser punível, se, antes da sentença o agente se retrata ou declara a verdade.",
                                                                                                                                                                                                                            "rubrica":    "Retratação"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "347º",
                                                                                                                                                                             "rotulo":    "Art. 347º.",
                                                                                                                                                                             "linha":    3811,
                                                                                                                                                                             "caput":    "Dar, oferecer ou prometer dinheiro ou qualquer outra vantagem a testemunha, perito, tradutor ou intérprete, para fazer afirmação falsa, negar ou calar a verdade em depoimento, perícia, tradução ou interpretação, em inquérito policial, processo administrativo ou judicial, militar, ainda que a oferta não seja aceita:",
                                                                                                                                                                             "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                             "rubrica":    "Corrupção ativa de testemunha, perito ou intérprete"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "348º",
                                                                                                                                                                             "rotulo":    "Art. 348º.",
                                                                                                                                                                             "linha":    3817,
                                                                                                                                                                             "caput":    "Fazer pela imprensa, rádio ou televisão, antes da intercorrência de decisão definitiva em processo penal militar, comentário tendente a exercer pressão sôbre declaração de testemunha ou laudo de perito:",
                                                                                                                                                                             "pena":    "detenção, até seis meses.",
                                                                                                                                                                             "rubrica":    "Publicidade opressiva"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "349º",
                                                                                                                                                                             "rotulo":    "Art. 349º.",
                                                                                                                                                                             "linha":    3823,
                                                                                                                                                                             "caput":    "Deixar, sem justa causa, de cumprir decisão da Justiça Militar, ou retardar ou fraudar o seu cumprimento:",
                                                                                                                                                                             "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                             "rubrica":    "Desobediência a decisão judicial",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    3827,
                                                                                                                                                                                                                            "texto":    "No caso de transgressão dos arts. 116, 117 e 118, a pena será cumprida sem prejuízo da execução da medida de segurança."
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    3829,
                                                                                                                                                                                                                            "texto":    "Nos casos do art. 118 e seus §§ 1º e 2º, a pena pela desobediência é aplicada ao representante, ou representantes legais, do estabelecimento, sociedade ou associação."
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "350º",
                                                                                                                                                                             "rotulo":    "Art. 350º.",
                                                                                                                                                                             "linha":    3833,
                                                                                                                                                                             "caput":    "Auxiliar a subtrair-se à ação da autoridade autor de crime militar, a que é cominada pena de morte ou reclusão:",
                                                                                                                                                                             "pena":    "detenção, até seis meses.",
                                                                                                                                                                             "rubrica":    "Favorecimento pessoal",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "1",
                                                                                                                                                                                                                            "rotulo":    "§ 1",
                                                                                                                                                                                                                            "linha":    3841,
                                                                                                                                                                                                                            "texto":    "Se ao crime é cominada pena de detenção ou de impedimento:",
                                                                                                                                                                                                                            "rubrica":    "Diminuição de pena"
                                                                                                                                                                                                                    },
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "2",
                                                                                                                                                                                                                            "rotulo":    "§ 2",
                                                                                                                                                                                                                            "linha":    3847,
                                                                                                                                                                                                                            "texto":    "Se quem presta o auxílio é ascendente, descendente, cônjuge ou irmão do criminoso, fica isento da pena.",
                                                                                                                                                                                                                            "rubrica":    "Isenção de pena"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "351º",
                                                                                                                                                                             "rotulo":    "Art. 351º.",
                                                                                                                                                                             "linha":    3851,
                                                                                                                                                                             "caput":    "Prestar a criminoso, fora dos casos de co-autoria ou de receptação, auxílio destinado a tornar seguro o proveito do crime:",
                                                                                                                                                                             "pena":    "detenção, de três meses a um ano.",
                                                                                                                                                                             "rubrica":    "Favorecimento real"
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "352º",
                                                                                                                                                                             "rotulo":    "Art. 352º.",
                                                                                                                                                                             "linha":    3857,
                                                                                                                                                                             "caput":    "Inutilizar, total ou parcialmente, sonegar ou dar descaminho a autos, documento ou objeto de valor probante, que tem sob guarda ou recebe para exame:",
                                                                                                                                                                             "pena":    "detenção, de seis meses a três anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                             "rubrica":    "Inutilização, sonegação ou descaminho de material probante",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    3863,
                                                                                                                                                                                                                            "texto":    "Se a inutilização ou o descaminho resulta de ação ou omissão culposa:",
                                                                                                                                                                                                                            "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "353º",
                                                                                                                                                                             "rotulo":    "Art. 353º.",
                                                                                                                                                                             "linha":    3871,
                                                                                                                                                                             "caput":    "Solicitar ou receber dinheiro ou qualquer outra utilidade, a pretexto de influir em juiz, órgão do Ministério Público, servidor público da Justiça, perito, tradutor, intérprete ou testemunha, na Justiça Militar:",
                                                                                                                                                                             "pena":    "reclusão, até cinco anos.",
                                                                                                                                                                             "rubrica":    "Exploração de prestígio",
                                                                                                                                                                             "paragrafos":    [
                                                                                                                                                                                                                    {
                                                                                                                                                                                                                            "numero":    "único",
                                                                                                                                                                                                                            "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                            "linha":    3877,
                                                                                                                                                                                                                            "texto":    "A pena é aumentada de um têrço, se o agente alega ou insinua que o dinheiro ou utilidade também se destina a qualquer das pessoas referidas no artigo.",
                                                                                                                                                                                                                            "rubrica":    "Aumento de pena"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                            ]
                                                                                                                                                                     },
                                                                                                                                                                     {
                                                                                                                                                                             "numero":    "354º",
                                                                                                                                                                             "rotulo":    "Art. 354º.",
                                                                                                                                                                             "linha":    3881,
                                                                                                                                                                             "caput":    "Exercer função, atividade, direito, autoridade ou múnus, de que foi suspenso ou privado por decisão da Justiça Militar:",
                                                                                                                                                                             "pena":    "detenção, de três meses a dois anos.",
                                                                                                                                                                             "rubrica":    "Desobediência a decisão sôbre perda ou suspensão de atividade ou direito"
                                                                                                                                                                     }
                                                                                                                                                             ],
                                                                                                                                     "titulo":    "DOS CRIMES CONTRA A ADMINISTRAÇÃO DA JUSTIÇA",
                                                                                                                                     "linhaTitulo":    3749
                                                                                                                             }
                                                                                                                     ],
                                                                                            "artigos":    [

                                                                                                                    ],
                                                                                            "titulo":    "DOS CRIMES MILITARES EM TEMPO DE PAZ",
                                                                                            "linhaTitulo":    1292
                                                                                    },
                                                                                    {
                                                                                            "tipo":    "livro",
                                                                                            "rotulo":    "LIVRO II",
                                                                                            "linha":    3885,
                                                                                            "divisoes":    [
                                                                                                                             {
                                                                                                                                     "tipo":    "titulo",
                                                                                                                                     "rotulo":    "TÍTULO I",
                                                                                                                                     "linha":    3888,
                                                                                                                                     "divisoes":    [
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO I",
                                                                                                                                                                                "linha":    3890,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "355º",
                                                                                                                                                                                                                        "rotulo":    "Art. 355º.",
                                                                                                                                                                                                                        "linha":    3894,
                                                                                                                                                                                                                        "caput":    "Tomar o nacional armas contra o Brasil ou Estado aliado, ou prestar serviço nas fôrças armadas de nação em guerra contra o Brasil:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Traição"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "356º",
                                                                                                                                                                                                                        "rotulo":    "Art. 356º.",
                                                                                                                                                                                                                        "linha":    3900,
                                                                                                                                                                                                                        "caput":    "Favorecer ou tentar o nacional favorecer o inimigo, prejudicar ou tentar prejudicar o bom êxito das operações militares, comprometer ou tentar comprometer a eficiência militar:",
                                                                                                                                                                                                                        "rubrica":    "Favor ao inimigo",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    3902,
                                                                                                                                                                                                                                                                "texto":    "empreendendo ou deixando de empreender ação militar;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    3904,
                                                                                                                                                                                                                                                                "texto":    "entregando ao inimigo ou expondo a perigo dessa conseqüência navio, aeronave, fôrça ou posição, engenho de guerra motomecanizado, provisões ou qualquer outro elemento de ação militar;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "III",
                                                                                                                                                                                                                                                                "rotulo":    "III",
                                                                                                                                                                                                                                                                "linha":    3906,
                                                                                                                                                                                                                                                                "texto":    "perdendo, destruindo, inutilizando, deteriorando ou expondo a perigo de perda, destruição, inutilização ou deterioração, navio, aeronave, engenho de guerra motomecanizado, provisões ou qualquer outro elemento de ação militar;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "IV",
                                                                                                                                                                                                                                                                "rotulo":    "IV",
                                                                                                                                                                                                                                                                "linha":    3908,
                                                                                                                                                                                                                                                                "texto":    "sacrificando ou expondo a perigo de sacrifício fôrça militar;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "V",
                                                                                                                                                                                                                                                                "rotulo":    "V",
                                                                                                                                                                                                                                                                "linha":    3910,
                                                                                                                                                                                                                                                                "texto":    "abandonando posição ou deixando de cumprir missão ou ordem:"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "357º",
                                                                                                                                                                                                                        "rotulo":    "Art. 357º.",
                                                                                                                                                                                                                        "linha":    3916,
                                                                                                                                                                                                                        "caput":    "Praticar o nacional o crime definido no art. 142:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Tentativa contra a soberania do Brasil"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "358º",
                                                                                                                                                                                                                        "rotulo":    "Art. 358º.",
                                                                                                                                                                                                                        "linha":    3922,
                                                                                                                                                                                                                        "caput":    "Entrar o nacional em conluio, usar de violência ou ameaça, provocar tumulto ou desordem com o fim de obrigar o comandante a não empreender ou a cessar ação militar, a recuar ou render-se:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Coação a comandante"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "359º",
                                                                                                                                                                                                                        "rotulo":    "Art. 359º.",
                                                                                                                                                                                                                        "linha":    3928,
                                                                                                                                                                                                                        "caput":    "Prestar o nacional ao inimigo informação ou auxílio que lhe possa facilitar a ação militar:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Informação ou auxílio ao inimigo"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "360º",
                                                                                                                                                                                                                        "rotulo":    "Art. 360º.",
                                                                                                                                                                                                                        "linha":    3934,
                                                                                                                                                                                                                        "caput":    "Aliciar o nacional algum militar a passar-se para o inimigo ou prestar-lhe auxílio para êsse fim:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Aliciação de militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "361º",
                                                                                                                                                                                                                        "rotulo":    "Art. 361º.",
                                                                                                                                                                                                                        "linha":    3940,
                                                                                                                                                                                                                        "caput":    "Provocar o nacional, em presença do inimigo, a debandada de tropa, ou guarnição, impedir a reunião de uma ou outra ou causar alarme, com o fim de nelas produzir confusão, desalento ou desordem:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Ato prejudicial à eficiência da tropa"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA TRAIÇÃO",
                                                                                                                                                                                "linhaTitulo":    3891
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO II",
                                                                                                                                                                                "linha":    3944,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "362º",
                                                                                                                                                                                                                        "rotulo":    "Art. 362º.",
                                                                                                                                                                                                                        "linha":    3948,
                                                                                                                                                                                                                        "caput":    "Praticar o estrangeiro os crimes previstos nos arts. 356, ns. I, primeira parte, II, III e IV, 357 a 361:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de dez anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Traição imprópria"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA TRAIÇÃO IMPRÓPRIA",
                                                                                                                                                                                "linhaTitulo":    3945
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO III",
                                                                                                                                                                                "linha":    3952,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "363º",
                                                                                                                                                                                                                        "rotulo":    "Art. 363º.",
                                                                                                                                                                                                                        "linha":    3956,
                                                                                                                                                                                                                        "caput":    "Subtrair-se ou tentar subtrair-se o militar, por temor, em presença do inimigo, ao cumprimento do dever militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Cobardia"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "364º",
                                                                                                                                                                                                                        "rotulo":    "Art. 364º.",
                                                                                                                                                                                                                        "linha":    3962,
                                                                                                                                                                                                                        "caput":    "Provocar o militar, por temor, em presença do inimigo, a debandada de tropa ou guarnição; impedir a reunião de uma ou outra, ou causar alarme com o fim de nelas produzir confusão, desalento ou desordem:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Cobardia qualificada"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "365º",
                                                                                                                                                                                                                        "rotulo":    "Art. 365º.",
                                                                                                                                                                                                                        "linha":    3968,
                                                                                                                                                                                                                        "caput":    "Fugir o militar, ou incitar à fuga, em presença do inimigo:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Fuga em presença do inimigo"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA COBARDIA",
                                                                                                                                                                                "linhaTitulo":    3953
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IV",
                                                                                                                                                                                "linha":    3972,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "366º",
                                                                                                                                                                                                                        "rotulo":    "Art. 366º.",
                                                                                                                                                                                                                        "linha":    3976,
                                                                                                                                                                                                                        "caput":    "Praticar qualquer dos crimes previstos nos arts. 143 e seu § 1°, 144 e seus §§ 1º e 2º, e 146, em favor do inimigo ou comprometendo a preparação, a eficiência ou as operações militares:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Espionagem",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    3982,
                                                                                                                                                                                                                                                                     "texto":    "No caso de concurso por culpa, para execução do crime previsto no art. 143, § 2º, ou de revelação culposa (art. 144, § 3º):",
                                                                                                                                                                                                                                                                     "rubrica":    "Caso de concurso"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "367º",
                                                                                                                                                                                                                        "rotulo":    "Art. 367º.",
                                                                                                                                                                                                                        "linha":    3988,
                                                                                                                                                                                                                        "caput":    "Entrar o estrangeiro em território nacional, ou insinuar-se em fôrça ou unidade em operações de guerra, ainda que fora do território nacional, a fim de colhêr documento, notícia ou informação de caráter militar, em benefício do inimigo, ou em prejuízo daquelas operações:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dez a vinte anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Penetração de estrangeiro"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA ESPIONAGEM",
                                                                                                                                                                                "linhaTitulo":    3973
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO V",
                                                                                                                                                                                "linha":    3992,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "368º",
                                                                                                                                                                                                                        "rotulo":    "Art. 368º.",
                                                                                                                                                                                                                        "linha":    3996,
                                                                                                                                                                                                                        "caput":    "Praticar qualquer dos crimes definidos nos arts. 149 e seu parágrafo único, e 152:",
                                                                                                                                                                                                                        "pena":    "aos cabeças, morte, grau máximo; reclusão, de quinze anos, grau mínimo. Aos co-autores, reclusão, de dez a trinta anos.",
                                                                                                                                                                                                                        "rubrica":    "Motim, revolta ou conspiração",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4002,
                                                                                                                                                                                                                                                                     "texto":    "Se o fato é praticado em presença do inimigo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Forma qualificada",
                                                                                                                                                                                                                                                                     "pena":    "aos cabeças, morte, grau máximo; reclusão, de vinte anos, grau mínimo. Aos co-autores, morte, grau máximo; reclusão, de quinze anos, grau mínimo."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "369º",
                                                                                                                                                                                                                        "rotulo":    "Art. 369º.",
                                                                                                                                                                                                                        "linha":    4008,
                                                                                                                                                                                                                        "caput":    "Praticar o crime previsto no artigo 151:",
                                                                                                                                                                                                                        "pena":    "reclusão, de quatro a doze anos.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de lealdade militar"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO MOTIM E DA REVOLTA",
                                                                                                                                                                                "linhaTitulo":    3993
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VI",
                                                                                                                                                                                "linha":    4012,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "370º",
                                                                                                                                                                                                                        "rotulo":    "Art. 370º.",
                                                                                                                                                                                                                        "linha":    4016,
                                                                                                                                                                                                                        "caput":    "Incitar militar à desobediência, à indisciplina ou à prática de crime militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de três a dez anos.",
                                                                                                                                                                                                                        "rubrica":    "Incitamento",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4020,
                                                                                                                                                                                                                                                                     "texto":    "Na mesma pena incorre quem introduz, afixa ou distribui, em lugar sujeito à administração militar, impressos, manuscritos ou material mimeografado, fotocopiado ou gravado, em que se contenha incitamento à prática dos atos previstos no artigo."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "371º",
                                                                                                                                                                                                                        "rotulo":    "Art. 371º.",
                                                                                                                                                                                                                        "linha":    4024,
                                                                                                                                                                                                                        "caput":    "Praticar qualquer dos crimes previstos no art. 370 e seu parágrafo, em presença do inimigo:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de dez anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Incitamento em presença do inimigo"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO INCITAMENTO",
                                                                                                                                                                                "linhaTitulo":    4013
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VII",
                                                                                                                                                                                "linha":    4028,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "372º",
                                                                                                                                                                                                                        "rotulo":    "Art. 372º.",
                                                                                                                                                                                                                        "linha":    4032,
                                                                                                                                                                                                                        "caput":    "Render-se o comandante, sem ter esgotado os recursos extremos de ação militar; ou, em caso de capitulação, não se conduzir de acôrdo com o dever militar:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Rendição ou capitulação"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "373º",
                                                                                                                                                                                                                        "rotulo":    "Art. 373º.",
                                                                                                                                                                                                                        "linha":    4038,
                                                                                                                                                                                                                        "caput":    "Deixar-se o comandante surpreender pelo inimigo.",
                                                                                                                                                                                                                        "pena":    "detenção, de um a três anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Omissão de vigilância",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4044,
                                                                                                                                                                                                                                                                     "texto":    "Se o fato compromete as operações militares:",
                                                                                                                                                                                                                                                                     "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "374º",
                                                                                                                                                                                                                        "rotulo":    "Art. 374º.",
                                                                                                                                                                                                                        "linha":    4050,
                                                                                                                                                                                                                        "caput":    "Deixar, em presença do inimigo, de conduzir-se de acôrdo com o dever militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, até cinco anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Descumprimento do dever militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "375º",
                                                                                                                                                                                                                        "rotulo":    "Art. 375º.",
                                                                                                                                                                                                                        "linha":    4056,
                                                                                                                                                                                                                        "caput":    "Dar causa, por falta de cumprimento de ordem, à ação militar do inimigo:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Falta de cumprimento de ordem",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4062,
                                                                                                                                                                                                                                                                     "texto":    "Se o fato expõe a perigo fôrça, posição ou outros elementos de ação militar:",
                                                                                                                                                                                                                                                                     "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "376º",
                                                                                                                                                                                                                        "rotulo":    "Art. 376º.",
                                                                                                                                                                                                                        "linha":    4068,
                                                                                                                                                                                                                        "caput":    "Dar causa, por culpa, ao abandono ou à entrega ao inimigo de posição, navio, aeronave, engenho de guerra, provisões, ou qualquer outro elemento de ação militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dez a trinta anos.",
                                                                                                                                                                                                                        "rubrica":    "Entrega ou abandono culposo"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "377º",
                                                                                                                                                                                                                        "rotulo":    "Art. 377º.",
                                                                                                                                                                                                                        "linha":    4074,
                                                                                                                                                                                                                        "caput":    "Dar causa, por culpa, ao sacrifício ou captura de fôrça sob o seu comando:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dez a trinta anos.",
                                                                                                                                                                                                                        "rubrica":    "Captura ou sacrifício culposo"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "378º",
                                                                                                                                                                                                                        "rotulo":    "Art. 378º.",
                                                                                                                                                                                                                        "linha":    4080,
                                                                                                                                                                                                                        "caput":    "Separar o comandante, em caso de capitulação, a sorte própria da dos oficiais e praças:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Separação reprovável"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "379º",
                                                                                                                                                                                                                        "rotulo":    "Art. 379º.",
                                                                                                                                                                                                                        "linha":    4086,
                                                                                                                                                                                                                        "caput":    "Abandonar comboio, cuja escolta lhe tenha sido confiada:",
                                                                                                                                                                                                                        "pena":    "reclusão, de dois a oito anos.",
                                                                                                                                                                                                                        "rubrica":    "Abandono de comboio",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "1",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 1",
                                                                                                                                                                                                                                                                     "linha":    4092,
                                                                                                                                                                                                                                                                     "texto":    "Se do fato resulta avaria grave, ou perda total ou parcial do comboio:",
                                                                                                                                                                                                                                                                     "rubrica":    "Resultado mais grave"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "2",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 2",
                                                                                                                                                                                                                                                                     "linha":    4098,
                                                                                                                                                                                                                                                                     "texto":    "Separar-se, por culpa, do comboio ou da escolta:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    4104,
                                                                                                                                                                                                                                                                     "texto":    "Nas mesmas penas incorre quem, de igual forma, abandona material de guerra, cuja guarda lhe tenha sido confiada.",
                                                                                                                                                                                                                                                                     "rubrica":    "Caso assimilado"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "380º",
                                                                                                                                                                                                                        "rotulo":    "Art. 380º.",
                                                                                                                                                                                                                        "linha":    4108,
                                                                                                                                                                                                                        "caput":    "Permanecer o oficial, por culpa, separado do comando superior:",
                                                                                                                                                                                                                        "pena":    "reclusão, até quatro anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Separação culposa de comando"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "381º",
                                                                                                                                                                                                                        "rotulo":    "Art. 381º.",
                                                                                                                                                                                                                        "linha":    4114,
                                                                                                                                                                                                                        "caput":    "Deixar, por culpa, evadir-se prisioneiro:",
                                                                                                                                                                                                                        "pena":    "reclusão, até quatro anos.",
                                                                                                                                                                                                                        "rubrica":    "Tolerância culposa"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "382º",
                                                                                                                                                                                                                        "rotulo":    "Art. 382º.",
                                                                                                                                                                                                                        "linha":    4120,
                                                                                                                                                                                                                        "caput":    "Entrar o militar, sem autorização, em entendimento com outro militar ou emissário de país inimigo, ou servir, para êsse fim, de intermediário:",
                                                                                                                                                                                                                        "pena":    "reclusão, até três anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Entendimento com o inimigo"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA INOBSERVÂNCIA DO DEVER MILITAR",
                                                                                                                                                                                "linhaTitulo":    4029
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO VIII",
                                                                                                                                                                                "linha":    4124,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "383º",
                                                                                                                                                                                                                        "rotulo":    "Art. 383º.",
                                                                                                                                                                                                                        "linha":    4128,
                                                                                                                                                                                                                        "caput":    "Praticar ou tentar praticar qualquer dos crimes definidos nos arts. 262, 263, §§ 1º e 2º, e 264, em benefício do inimigo, ou comprometendo ou podendo comprometer a preparação, a eficiência ou as operações militares:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Dano especial",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4134,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "384º",
                                                                                                                                                                                                                        "rotulo":    "Art. 384º.",
                                                                                                                                                                                                                        "linha":    4140,
                                                                                                                                                                                                                        "caput":    "Danificar serviço de abastecimento de água, luz ou fôrça, estrada, meio de transporte, instalação telegráfica ou outro meio de comunicação, depósito de combustível, inflamáveis, matérias-primas necessárias à produção, depósito de víveres ou forragens, mina, fábrica, usina ou qualquer estabelecimento de produção de artigo necessário à defesa nacional ou ao bem-estar da população e, bem assim, rebanho, lavoura ou plantação, se o fato compromete ou pode comprometer a preparação, a eficiência ou as operações militares, ou de qualquer forma atenta contra a segurança externa do país:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Dano em bens de interêsse militar"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "385º",
                                                                                                                                                                                                                        "rotulo":    "Art. 385º.",
                                                                                                                                                                                                                        "linha":    4146,
                                                                                                                                                                                                                        "caput":    "Envenenar ou corromper água potável, víveres ou forragens, ou causar epidemia mediante a propagação de germes patogênicos, se o fato compromete ou pode comprometer a preparação, a eficiência ou as operações militares, ou de qualquer forma atenta contra a segurança externa do país:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Envenenamento, corrupção ou epidemia",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4152,
                                                                                                                                                                                                                                                                     "texto":    "Se o crime é culposo:",
                                                                                                                                                                                                                                                                     "rubrica":    "Modalidade culposa"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO DANO",
                                                                                                                                                                                "linhaTitulo":    4125
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO IX",
                                                                                                                                                                                "linha":    4156,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "386º",
                                                                                                                                                                                                                        "rotulo":    "Art. 386º.",
                                                                                                                                                                                                                        "linha":    4161,
                                                                                                                                                                                                                        "caput":    "Praticar crime de perigo comum definido nos arts. 268 a 276 e 278, na modalidade dolosa:",
                                                                                                                                                                                                                        "rubrica":    "Crimes de perigo comum",
                                                                                                                                                                                                                        "incisos":    [
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "I",
                                                                                                                                                                                                                                                                "rotulo":    "I",
                                                                                                                                                                                                                                                                "linha":    4163,
                                                                                                                                                                                                                                                                "texto":    "se o fato compromete ou pode comprometer a preparação, a eficiência ou as operações militares;"
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                "numero":    "II",
                                                                                                                                                                                                                                                                "rotulo":    "II",
                                                                                                                                                                                                                                                                "linha":    4165,
                                                                                                                                                                                                                                                                "texto":    "se o fato é praticado em zona de efetivas operações militares e dêle resulta morte:"
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DOS CRIMES CONTRA A INCOLUMIDADE PÚBLICA",
                                                                                                                                                                                "linhaTitulo":    4157
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO X",
                                                                                                                                                                                "linha":    4169,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "387º",
                                                                                                                                                                                                                        "rotulo":    "Art. 387º.",
                                                                                                                                                                                                                        "linha":    4173,
                                                                                                                                                                                                                        "caput":    "Praticar, em presença do inimigo, qualquer dos crimes definidos nos arts. 163 e 164:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de dez anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Recusa de obediência ou oposição"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "388º",
                                                                                                                                                                                                                        "rotulo":    "Art. 388º.",
                                                                                                                                                                                                                        "linha":    4179,
                                                                                                                                                                                                                        "caput":    "Exercer coação contra oficial general ou comandante da unidade, mesmo que não seja superior, com o fim de impedir-lhe o cumprimento do dever militar:",
                                                                                                                                                                                                                        "pena":    "reclusão, de cinco a quinze anos, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Coação contra oficial general ou comandante"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "389º",
                                                                                                                                                                                                                        "rotulo":    "Art. 389º.",
                                                                                                                                                                                                                        "linha":    4185,
                                                                                                                                                                                                                        "caput":    "Praticar qualquer dos crimes definidos nos arts. 157 e 158, a que esteja cominada, no máximo, reclusão, de trinta anos:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Violência contra superior ou militar de serviço",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4189,
                                                                                                                                                                                                                                                                     "texto":    "Se ao crime não é cominada, no máximo, reclusão de trinta anos, mas é praticado com arma e em presença do inimigo:"
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA INSUBORDINAÇÃO E DA VIOLÊNCIA",
                                                                                                                                                                                "linhaTitulo":    4170
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO XI",
                                                                                                                                                                                "linha":    4193,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "390º",
                                                                                                                                                                                                                        "rotulo":    "Art. 390º.",
                                                                                                                                                                                                                        "linha":    4197,
                                                                                                                                                                                                                        "caput":    "Praticar, em presença do inimigo, crime de abandono de pôsto, definido no art. 195:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Abandono de pôsto"
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DO ABANDONO DE PÔSTO",
                                                                                                                                                                                "linhaTitulo":    4194
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO XII",
                                                                                                                                                                                "linha":    4201,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "391º",
                                                                                                                                                                                                                        "rotulo":    "Art. 391º.",
                                                                                                                                                                                                                        "linha":    4205,
                                                                                                                                                                                                                        "caput":    "Praticar crime de deserção definido no Capítulo II, do Título III, do Livro I, da Parte Especial:",
                                                                                                                                                                                                                        "pena":    "a cominada ao mesmo crime, com aumento da metade, se o fato não constitui crime mais grave.",
                                                                                                                                                                                                                        "rubrica":    "Deserção",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4209,
                                                                                                                                                                                                                                                                     "texto":    "Os prazos para a consumação do crime são reduzidos de metade."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "392º",
                                                                                                                                                                                                                        "rotulo":    "Art. 392º.",
                                                                                                                                                                                                                        "linha":    4213,
                                                                                                                                                                                                                        "caput":    "Desertar em presença do inimigo:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Deserção em presença do inimigo"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "393º",
                                                                                                                                                                                                                        "rotulo":    "Art. 393º.",
                                                                                                                                                                                                                        "linha":    4219,
                                                                                                                                                                                                                        "caput":    "Deixar o convocado, no caso de mobilização total ou parcial, de apresentar-se, dentro do prazo marcado, no centro de mobilização ou ponto de concentração:",
                                                                                                                                                                                                                        "pena":    "detenção, de um a seis anos.",
                                                                                                                                                                                                                        "rubrica":    "Falta de apresentação",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4223,
                                                                                                                                                                                                                                                                     "texto":    "Se o agente é oficial da reserva, aplica-se a pena com aumento de um têrço."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
                                                                                                                                                                                                        ],
                                                                                                                                                                                "titulo":    "DA DESERÇÃO E DA FALTA DE APRESENTAÇÃO",
                                                                                                                                                                                "linhaTitulo":    4202
                                                                                                                                                                        },
                                                                                                                                                                        {
                                                                                                                                                                                "tipo":    "capitulo",
                                                                                                                                                                                "rotulo":    "CAPÍTULO XIII",
                                                                                                                                                                                "linha":    4225,
                                                                                                                                                                                "divisoes":    [

                                                                                                                                                                                                         ],
                                                                                                                                                                                "artigos":    [
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "394º",
                                                                                                                                                                                                                        "rotulo":    "Art. 394º.",
                                                                                                                                                                                                                        "linha":    4231,
                                                                                                                                                                                                                        "caput":    "Promover ou facilitar a libertação de prisioneiro de guerra sob guarda ou custódia de fôrça nacional ou aliada:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de quinze anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Libertação de prisioneiro"
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
                                                                                                                                                                                                                        "numero":    "395º",
                                                                                                                                                                                                                        "rotulo":    "Art. 395º.",
                                                                                                                                                                                                                        "linha":    4237,
                                                                                                                                                                                                                        "caput":    "Evadir-se prisioneiro de guerra e voltar a tomar armas contra o Brasil ou Estado aliado:",
                                                                                                                                                                                                                        "pena":    "morte, grau máximo; reclusão, de vinte anos, grau mínimo.",
                                                                                                                                                                                                                        "rubrica":    "Evasão de prisioneiro",
                                                                                                                                                                                                                        "paragrafos":    [
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "único",
                                                                                                                                                                                                                                                                     "rotulo":    "Parágrafo único",
                                                                                                                                                                                                                                                                     "linha":    4241,
                                                                                                                                                                                                                                                                     "texto":    "Na aplicação dêste artigo, serão considerados os tratados e as convenções internacionais, aceitos pelo Brasil relativamente ao tratamento dos prisioneiros de guerra."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                },
                                                                                                                                                                                                                {
