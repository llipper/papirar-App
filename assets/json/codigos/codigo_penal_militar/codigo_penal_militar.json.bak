                                                                                                                                                                                                                                                                     "linha":    4320,
                                                                                                                                                                                                                                                                     "texto":    "No caso do § 2º do art. 209:",
                                                                                                                                                                                                                                                                     "rubrica":    "Pena - reclusão, de quatro a dez anos."
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "3",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 3",
                                                                                                                                                                                                                                                                     "linha":    4326,
                                                                                                                                                                                                                                                                     "texto":    "No caso do § 3º do art. 209:",
                                                                                                                                                                                                                                                                     "rubrica":    "Lesões qualificadas pelo resultado"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "4",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 4",
                                                                                                                                                                                                                                                                     "linha":    4332,
                                                                                                                                                                                                                                                                     "texto":    "No caso do § 4º do art. 209, o juiz pode reduzir a pena de um sexto a um têrço.",
                                                                                                                                                                                                                                                                     "rubrica":    "Minoração facultativa da pena"
                                                                                                                                                                                                                                                             },
                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                     "numero":    "5",
                                                                                                                                                                                                                                                                     "rotulo":    "§ 5",
                                                                                                                                                                                                                                                                     "linha":    4334,
                                                                                                                                                                                                                                                                     "texto":    "No caso do § 5º do art. 209, o juiz pode diminuir a pena de um têrço."
                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                }
