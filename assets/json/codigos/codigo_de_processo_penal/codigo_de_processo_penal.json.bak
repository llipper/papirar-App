{
        "id": "Codigo_de_Processo_Penal",
        "titulo": "Código de Processo Penal",
        "apelido": "Código de Processo Penal.",
        "sigla": "CPP",
        "fonte": "Codigo_de_Processo_Penal.txt",
        "fonteHtmlLocal": "codigos/Codigo_de_Processo_Penal/del3689.htm",
        "fonteOficial": "https://www.planalto.gov.br/ccivil_03/decreto-lei/del3689.htm",
        "ementa": "Código de Processo Penal.",
        "preambulo": [
                {
                        "texto": "DECRETO-LEI Nº 3.689, DE 3 DE OUTUBRO DE 1941.",
                        "linha": 1
                },
                {
                        "texto": "Código de Processo Penal.",
                        "linha": 3
                },
                {
                        "texto": "O PRESIDENTE DA REPÚBLICA, usando da atribuição que Ihe confere o art. 180 da Constituição, decreta a seguinte Lei:",
                        "linha": 5
                }
        ],
        "divisoes": [
                {
                        "tipo": "livro",
                        "rotulo": "LIVRO I",
                        "linha": 7,
                        "divisoes": [
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO I",
                                        "linha": 11,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "1º",
                                                        "rotulo": "Art. 1º.",
                                                        "linha": 15,
                                                        "caput": "O processo penal reger-se-á, em todo o território brasileiro, por este Código, ressalvados:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 17,
                                                                        "texto": "os tratados, as convenções e regras de direito internacional;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 19,
                                                                        "texto": "as prerrogativas constitucionais do Presidente da República, dos ministros de Estado, nos crimes conexos com os do Presidente da República, e dos ministros do Supremo Tribunal Federal, nos crimes de responsabilidade (Constituição, arts. 86, 89, § 2º, e 100);"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 21,
                                                                        "texto": "os processos da competência da Justiça Militar;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 23,
                                                                        "texto": "os processos da competência do tribunal especial (Constituição, art. 122, no 17);"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 25,
                                                                        "texto": "os processos por crimes de imprensa."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 27,
                                                                        "texto": "Aplicar-se-á, entretanto, este Código aos processos referidos nos nos. IV e V, quando as leis especiais que os regulam não dispuserem de modo diverso."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "2º",
                                                        "rotulo": "Art. 2º.",
                                                        "linha": 29,
                                                        "caput": "A lei processual penal aplicar-se-á desde logo, sem prejuízo da validade dos atos realizados sob a vigência da lei anterior."
                                                },
                                                {
                                                        "numero": "3º",
                                                        "rotulo": "Art. 3º.",
                                                        "linha": 31,
                                                        "caput": "A lei processual penal admitirá interpretação extensiva e aplicação analógica, bem como o suplemento dos princípios gerais de direito. Juiz das Garantias"
                                                },
                                                {
                                                        "numero": "3º-A",
                                                        "rotulo": "Art. 3º-A.",
                                                        "linha": 37,
                                                        "caput": "O processo penal terá estrutura acusatória, vedadas a iniciativa do juiz na fase de investigação e a substituição da atuação probatória do órgão de acusação."
                                                },
                                                {
                                                        "numero": "3º-B",
                                                        "rotulo": "Art. 3º-B.",
                                                        "linha": 39,
                                                        "caput": "O juiz das garantias é responsável pelo controle da legalidade da investigação criminal e pela salvaguarda dos direitos individuais cuja franquia tenha sido reservada à autorização prévia do Poder Judiciário, competindo-lhe especialmente:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 41,
                                                                        "texto": "receber a comunicação imediata da prisão, nos termos do inciso LXII do caput do art. 5º da Constituição Federal;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 43,
                                                                        "texto": "receber o auto da prisão em flagrante para o controle da legalidade da prisão, observado o disposto no art. 310 deste Código;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 45,
                                                                        "texto": "zelar pela observância dos direitos do preso, podendo determinar que este seja conduzido à sua presença, a qualquer tempo;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 47,
                                                                        "texto": "ser informado sobre a instauração de qualquer investigação criminal;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 49,
                                                                        "texto": "decidir sobre o requerimento de prisão provisória ou outra medida cautelar, observado o disposto no § 1º deste artigo;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 51,
                                                                        "texto": "prorrogar a prisão provisória ou outra medida cautelar, bem como substituí-las ou revogá-las, assegurado, no primeiro caso, o exercício do contraditório em audiência pública e oral, na forma do disposto neste Código ou em legislação especial pertinente;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 53,
                                                                        "texto": "decidir sobre o requerimento de produção antecipada de provas consideradas urgentes e não repetíveis, assegurados o contraditório e a ampla defesa em audiência pública e oral;"
                                                                },
                                                                {
                                                                        "numero": "VIII",
                                                                        "rotulo": "VIII",
                                                                        "linha": 55,
                                                                        "texto": "prorrogar o prazo de duração do inquérito, estando o investigado preso, em vista das razões apresentadas pela autoridade policial e observado o disposto no § 2º deste artigo;"
                                                                },
                                                                {
                                                                        "numero": "IX",
                                                                        "rotulo": "IX",
                                                                        "linha": 57,
                                                                        "texto": "determinar o trancamento do inquérito policial quando não houver fundamento razoável para sua instauração ou prosseguimento;"
                                                                },
                                                                {
                                                                        "numero": "X",
                                                                        "rotulo": "X",
                                                                        "linha": 59,
                                                                        "texto": "requisitar documentos, laudos e informações ao delegado de polícia sobre o andamento da investigação;"
                                                                },
                                                                {
                                                                        "numero": "XI",
                                                                        "rotulo": "XI",
                                                                        "linha": 61,
                                                                        "texto": "decidir sobre os requerimentos de:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 63,
                                                                                        "texto": "interceptação telefônica, do fluxo de comunicações em sistemas de informática e telemática ou de outras formas de comunicação;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 65,
                                                                                        "texto": "afastamento dos sigilos fiscal, bancário, de dados e telefônico;"
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 67,
                                                                                        "texto": "busca e apreensão domiciliar;"
                                                                                },
                                                                                {
                                                                                        "letra": "d",
                                                                                        "rotulo": "d)",
                                                                                        "linha": 69,
                                                                                        "texto": "acesso a informações sigilosas;"
                                                                                },
                                                                                {
                                                                                        "letra": "e",
                                                                                        "rotulo": "e)",
                                                                                        "linha": 71,
                                                                                        "texto": "outros meios de obtenção da prova que restrinjam direitos fundamentais do investigado;"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "XII",
                                                                        "rotulo": "XII",
                                                                        "linha": 73,
                                                                        "texto": "julgar o habeas corpus impetrado antes do oferecimento da denúncia; XIII - determinar a instauração de incidente de insanidade mental; XIV - decidir sobre o recebimento da denúncia ou queixa, nos termos do art. 399 deste Código; XV - assegurar prontamente, quando se fizer necessário, o direito outorgado ao investigado e ao seu defensor de acesso a todos os elementos informativos e provas produzidos no âmbito da investigação criminal, salvo no que concerne, estritamente, às diligências em andamento; XVI - deferir pedido de admissão de assistente técnico para acompanhar a produção da perícia; XVII - decidir sobre a homologação de acordo de não persecução penal ou os de colaboração premiada, quando formalizados durante a investigação; XVIII - outras matérias inerentes às atribuições definidas no caput deste artigo."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 89,
                                                                        "texto": "O preso em flagrante ou por força de mandado de prisão provisória será encaminhado à presença do juiz competente para celebração da audiência de custódia no prazo de 24 (vinte e quatro) horas, momento em que se realizará, por videoconferência, audiência com a presença do Ministério Público e da Defensoria Pública ou de advogado constituído, na forma estabelecida no art. 310 deste Código."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 91,
                                                                        "texto": "Se o investigado estiver preso, o juiz das garantias poderá, mediante representação da autoridade policial e ouvido o Ministério Público, prorrogar, uma única vez, a duração do inquérito por até 15 (quinze) dias, após o que, se ainda assim a investigação não for concluída, a prisão será imediatamente relaxada."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "3º-C",
                                                        "rotulo": "Art. 3º-C.",
                                                        "linha": 93,
                                                        "caput": "A competência do juiz das garantias abrange todas as infrações penais, exceto as de menor potencial ofensivo, e cessa com o recebimento da denúncia ou queixa na forma do art. 399 deste Código.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 95,
                                                                        "texto": "Recebida a denúncia ou queixa, as questões pendentes serão decididas pelo juiz da instrução e julgamento."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 97,
                                                                        "texto": "As decisões proferidas pelo juiz das garantias não vinculam o juiz da instrução e julgamento, que, após o recebimento da denúncia ou queixa, deverá reexaminar a necessidade das medidas cautelares em curso, no prazo máximo de 10 (dez) dias."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 99,
                                                                        "texto": "Os autos que compõem as matérias de competência do juiz das garantias ficarão acautelados na secretaria desse juízo, à disposição do Ministério Público e da defesa, e não serão apensados aos autos do processo enviados ao juiz da instrução e julgamento, ressalvados os documentos relativos às provas irrepetíveis, medidas de obtenção de provas ou de antecipação de provas, que deverão ser remetidos para apensamento em apartado."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 101,
                                                                        "texto": "Fica assegurado às partes o amplo acesso aos autos acautelados na secretaria do juízo das garantias."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "3º-D",
                                                        "rotulo": "Art. 3º-D.",
                                                        "linha": 103,
                                                        "caput": "O juiz que, na fase de investigação, praticar qualquer ato incluído nas competências dos arts. 4º e 5º deste Código ficará impedido de funcionar no processo.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 105,
                                                                        "texto": "Nas comarcas em que funcionar apenas um juiz, os tribunais criarão um sistema de rodízio de magistrados, a fim de atender às disposições deste Capítulo."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "3º-E",
                                                        "rotulo": "Art. 3º-E.",
                                                        "linha": 107,
                                                        "caput": "O juiz das garantias será designado conforme as normas de organização judiciária da União, dos Estados e do Distrito Federal, observando critérios objetivos a serem periodicamente divulgados pelo respectivo tribunal."
                                                },
                                                {
                                                        "numero": "3º-F",
                                                        "rotulo": "Art. 3º-F.",
                                                        "linha": 109,
                                                        "caput": "O juiz das garantias deverá assegurar o cumprimento das regras para o tratamento dos presos, impedindo o acordo ou ajuste de qualquer autoridade com órgãos da imprensa para explorar a imagem da pessoa submetida à prisão, sob pena de responsabilidade civil, administrativa e penal.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 111,
                                                                        "texto": "Por meio de regulamento, as autoridades deverão disciplinar, em 180 (cento e oitenta) dias, o modo pelo qual as informações sobre a realização da prisão e a identidade do preso serão, de modo padronizado e respeitada a programação normativa aludida no caput deste artigo, transmitidas à imprensa, assegurados a efetividade da persecução penal, o direito à informação e a dignidade da pessoa submetida à prisão."
                                                                }
                                                        ]
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO II",
                                        "linha": 113,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "4º",
                                                        "rotulo": "Art. 4º.",
                                                        "linha": 118,
                                                        "caput": "A polícia judiciária será exercida pelas autoridades policiais no território de suas respectivas circunscrições e terá por fim a apuração das infrações penais e da sua autoria.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 120,
                                                                        "texto": "A competência definida neste artigo não excluirá a de autoridades administrativas, a quem por lei seja cometida a mesma função."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "5º",
                                                        "rotulo": "Art. 5º.",
                                                        "linha": 122,
                                                        "caput": "Nos crimes de ação pública o inquérito policial será iniciado:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 124,
                                                                        "texto": "de ofício;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 126,
                                                                        "texto": "mediante requisição da autoridade judiciária ou do Ministério Público, ou a requerimento do ofendido ou de quem tiver qualidade para representá-lo."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 128,
                                                                        "texto": "O requerimento a que se refere o no II conterá sempre que possível:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 130,
                                                                                        "texto": "a narração do fato, com todas as circunstâncias;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 132,
                                                                                        "texto": "a individualização do indiciado ou seus sinais característicos e as razões de convicção ou de presunção de ser ele o autor da infração, ou os motivos de impossibilidade de o fazer;"
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 134,
                                                                                        "texto": "a nomeação das testemunhas, com indicação de sua profissão e residência."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 136,
                                                                        "texto": "Do despacho que indeferir o requerimento de abertura de inquérito caberá recurso para o chefe de Polícia."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 138,
                                                                        "texto": "Qualquer pessoa do povo que tiver conhecimento da existência de infração penal em que caiba ação pública poderá, verbalmente ou por escrito, comunicá-la à autoridade policial, e esta, verificada a procedência das informações, mandará instaurar inquérito."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 140,
                                                                        "texto": "O inquérito, nos crimes em que a ação pública depender de representação, não poderá sem ela ser iniciado."
                                                                },
                                                                {
                                                                        "numero": "5",
                                                                        "rotulo": "§ 5",
                                                                        "linha": 142,
                                                                        "texto": "Nos crimes de ação privada, a autoridade policial somente poderá proceder a inquérito a requerimento de quem tenha qualidade para intentá-la."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "6º",
                                                        "rotulo": "Art. 6º.",
                                                        "linha": 144,
                                                        "caput": "Logo que tiver conhecimento da prática da infração penal, a autoridade policial deverá:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 147,
                                                                        "texto": "dirigir-se ao local, providenciando para que não se alterem o estado e conservação das coisas, até a chegada dos peritos criminais;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 150,
                                                                        "texto": "apreender os objetos que tiverem relação com o fato, após liberados pelos peritos criminais;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 152,
                                                                        "texto": "colher todas as provas que servirem para o esclarecimento do fato e suas circunstâncias;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 154,
                                                                        "texto": "ouvir o ofendido;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 156,
                                                                        "texto": "ouvir o indiciado, com observância, no que for aplicável, do disposto no Capítulo III do Título Vll, deste Livro, devendo o respectivo termo ser assinado por duas testemunhas que Ihe tenham ouvido a leitura;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 158,
                                                                        "texto": "proceder a reconhecimento de pessoas e coisas e a acareações;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 160,
                                                                        "texto": "determinar, se for caso, que se proceda a exame de corpo de delito e a quaisquer outras perícias;"
                                                                },
                                                                {
                                                                        "numero": "VIII",
                                                                        "rotulo": "VIII",
                                                                        "linha": 162,
                                                                        "texto": "ordenar a identificação do indiciado pelo processo datiloscópico, se possível, e fazer juntar aos autos sua folha de antecedentes;"
                                                                },
                                                                {
                                                                        "numero": "IX",
                                                                        "rotulo": "IX",
                                                                        "linha": 164,
                                                                        "texto": "averiguar a vida pregressa do indiciado, sob o ponto de vista individual, familiar e social, sua condição econômica, sua atitude e estado de ânimo antes e depois do crime e durante ele, e quaisquer outros elementos que contribuírem para a apreciação do seu temperamento e caráter."
                                                                },
                                                                {
                                                                        "numero": "X",
                                                                        "rotulo": "X",
                                                                        "linha": 166,
                                                                        "texto": "colher informações sobre a existência de filhos, respectivas idades e se possuem alguma deficiência e o nome e o contato de eventual responsável pelos cuidados dos filhos, indicado pela pessoa presa."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "7º",
                                                        "rotulo": "Art. 7º.",
                                                        "linha": 168,
                                                        "caput": "Para verificar a possibilidade de haver a infração sido praticada de determinado modo, a autoridade policial poderá proceder à reprodução simulada dos fatos, desde que esta não contrarie a moralidade ou a ordem pública."
                                                },
                                                {
                                                        "numero": "8º",
                                                        "rotulo": "Art. 8º.",
                                                        "linha": 170,
                                                        "caput": "Havendo prisão em flagrante, será observado o disposto no Capítulo II do Título IX deste Livro."
                                                },
                                                {
                                                        "numero": "9º",
                                                        "rotulo": "Art. 9º.",
                                                        "linha": 172,
                                                        "caput": "Todas as peças do inquérito policial serão, num só processado, reduzidas a escrito ou datilografadas e, neste caso, rubricadas pela autoridade."
                                                },
                                                {
                                                        "numero": "10º",
                                                        "rotulo": "Art. 10º.",
                                                        "linha": 174,
                                                        "caput": "O inquérito deverá terminar no prazo de 10 dias, se o indiciado tiver sido preso em flagrante, ou estiver preso preventivamente, contado o prazo, nesta hipótese, a partir do dia em que se executar a ordem de prisão, ou no prazo de 30 dias, quando estiver solto, mediante fiança ou sem ela.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 176,
                                                                        "texto": "A autoridade fará minucioso relatório do que tiver sido apurado e enviará os autos ao juiz competente."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 178,
                                                                        "texto": "No relatório poderá a autoridade indicar testemunhas que não tiverem sido inquiridas, mencionando o lugar onde possam ser encontradas."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 180,
                                                                        "texto": "Quando o fato for de difícil elucidação, e o indiciado estiver solto, a autoridade poderá requerer ao juiz a devolução dos autos, para ulteriores diligências, que serão realizadas no prazo marcado pelo juiz."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "11º",
                                                        "rotulo": "Art. 11º.",
                                                        "linha": 182,
                                                        "caput": "Os instrumentos do crime, bem como os objetos que interessarem à prova, acompanharão os autos do inquérito."
                                                },
                                                {
                                                        "numero": "12º",
                                                        "rotulo": "Art. 12º.",
                                                        "linha": 184,
                                                        "caput": "O inquérito policial acompanhará a denúncia ou queixa, sempre que servir de base a uma ou outra."
                                                },
                                                {
                                                        "numero": "13º",
                                                        "rotulo": "Art. 13º.",
                                                        "linha": 186,
                                                        "caput": "Incumbirá ainda à autoridade policial:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 188,
                                                                        "texto": "fornecer às autoridades judiciárias as informações necessárias à instrução e julgamento dos processos;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 190,
                                                                        "texto": "realizar as diligências requisitadas pelo juiz ou pelo Ministério Público;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 192,
                                                                        "texto": "cumprir os mandados de prisão expedidos pelas autoridades judiciárias;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 194,
                                                                        "texto": "representar acerca da prisão preventiva."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "13º-A",
                                                        "rotulo": "Art. 13º-A.",
                                                        "linha": 196,
                                                        "caput": "Nos crimes previstos nos arts. 148, 149 e 149-A, no § 3º do art. 158 e no art. 159 do Decreto-Lei no 2.848, de 7 de dezembro de 1940 (Código Penal), e no art. 239 da Lei no 8.069, de 13 de julho de 1990 (Estatuto da Criança e do Adolescente), o membro do Ministério Público ou o delegado de polícia poderá requisitar, de quaisquer órgãos do poder público ou de empresas da iniciativa privada, dados e informações cadastrais da vítima ou de suspeitos.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 198,
                                                                        "texto": "A requisição, que será atendida no prazo de 24 (vinte e quatro) horas, conterá:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 200,
                                                                                        "texto": "nome da autoridade requisitante;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 202,
                                                                                        "texto": "número do inquérito policial; e"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 204,
                                                                                        "texto": "a identificação da unidade de polícia judiciária responsável pela investigação."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "13º-B",
                                                        "rotulo": "Art. 13º-B.",
                                                        "linha": 206,
                                                        "caput": "Se necessário à prevenção e à repressão dos crimes relacionados ao tráfico de pessoas, o membro do Ministério Público ou o delegado de polícia poderão requisitar, mediante autorização judicial, às empresas prestadoras de serviço de telecomunicações e/ou telemática que disponibilizem imediatamente os meios técnicos adequados – como sinais, informações e outros – que permitam a localização da vítima ou dos suspeitos do delito em curso.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 208,
                                                                        "texto": "Para os efeitos deste artigo, sinal significa posicionamento da estação de cobertura, setorização e intensidade de radiofrequência."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 210,
                                                                        "texto": "Na hipótese de que trata o caput, o sinal:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 212,
                                                                                        "texto": "não permitirá acesso ao conteúdo da comunicação de qualquer natureza, que dependerá de autorização judicial, conforme disposto em lei;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 214,
                                                                                        "texto": "deverá ser fornecido pela prestadora de telefonia móvel celular por período não superior a 30 (trinta) dias, renovável por uma única vez, por igual período;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 216,
                                                                                        "texto": "para períodos superiores àquele de que trata o inciso II, será necessária a apresentação de ordem judicial."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 218,
                                                                        "texto": "Na hipótese prevista neste artigo, o inquérito policial deverá ser instaurado no prazo máximo de 72 (setenta e duas) horas, contado do registro da respectiva ocorrência policial."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 220,
                                                                        "texto": "Não havendo manifestação judicial no prazo de 12 (doze) horas, a autoridade competente requisitará às empresas prestadoras de serviço de telecomunicações e/ou telemática que disponibilizem imediatamente os meios técnicos adequados – como sinais, informações e outros – que permitam a localização da vítima ou dos suspeitos do delito em curso, com imediata comunicação ao juiz."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "14º",
                                                        "rotulo": "Art. 14º.",
                                                        "linha": 222,
                                                        "caput": "O ofendido, ou seu representante legal, e o indiciado poderão requerer qualquer diligência, que será realizada, ou não, a juízo da autoridade."
                                                },
                                                {
                                                        "numero": "14º-A",
                                                        "rotulo": "Art. 14º-A.",
                                                        "linha": 224,
                                                        "caput": "Nos casos em que servidores vinculados às instituições dispostas no art. 144 da Constituição Federal figurarem como investigados em inquéritos policiais, inquéritos policiais militares e demais procedimentos extrajudiciais, cujo objeto for a investigação de fatos relacionados ao uso da força letal praticados no exercício profissional, de forma consumada ou tentada, incluindo as situações dispostas no art. 23 do Decreto-Lei nº 2.848, de 7 de dezembro de 1940 (Código Penal), o indiciado poderá constituir defensor.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 226,
                                                                        "texto": "Para os casos previstos no caput deste artigo, o investigado deverá ser citado da instauração do procedimento investigatório, podendo constituir defensor no prazo de até 48 (quarenta e oito) horas a contar do recebimento da citação."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 228,
                                                                        "texto": "Esgotado o prazo disposto no § 1º deste artigo com ausência de nomeação de defensor pelo investigado, a autoridade responsável pela investigação deverá intimar a instituição a que estava vinculado o investigado à época da ocorrência dos fatos, para que essa, no prazo de 48 (quarenta e oito) horas, indique defensor para a representação do investigado."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 233,
                                                                        "texto": "Havendo necessidade de indicação de defensor nos termos do § 2º deste artigo, a defesa caberá preferencialmente à Defensoria Pública, e, nos locais em que ela não estiver instalada, a União ou a Unidade da Federação correspondente à respectiva competência territorial do procedimento instaurado deverá disponibilizar profissional para acompanhamento e realização de todos os atos relacionados à defesa administrativa do investigado."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 235,
                                                                        "texto": "A indicação do profissional a que se refere o § 3º deste artigo deverá ser precedida de manifestação de que não existe defensor público lotado na área territorial onde tramita o inquérito e com atribuição para nele atuar, hipótese em que poderá ser indicado profissional que não integre os quadros próprios da Administração."
                                                                },
                                                                {
                                                                        "numero": "5",
                                                                        "rotulo": "§ 5",
                                                                        "linha": 237,
                                                                        "texto": "Na hipótese de não atuação da Defensoria Pública, os custos com o patrocínio dos interesses dos investigados nos procedimentos de que trata este artigo correrão por conta do orçamento próprio da instituição a que este esteja vinculado à época da ocorrência dos fatos investigados."
                                                                },
                                                                {
                                                                        "numero": "6",
                                                                        "rotulo": "§ 6",
                                                                        "linha": 239,
                                                                        "texto": "As disposições constantes deste artigo se aplicam aos servidores militares vinculados às instituições dispostas no art. 142 da Constituição Federal, desde que os fatos investigados digam respeito a missões para a Garantia da Lei e da Ordem."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "15º",
                                                        "rotulo": "Art. 15º.",
                                                        "linha": 241,
                                                        "caput": "Se o indiciado for menor, ser-lhe-á nomeado curador pela autoridade policial."
                                                },
                                                {
                                                        "numero": "16º",
                                                        "rotulo": "Art. 16º.",
                                                        "linha": 243,
                                                        "caput": "O Ministério Público não poderá requerer a devolução do inquérito à autoridade policial, senão para novas diligências, imprescindíveis ao oferecimento da denúncia."
                                                },
                                                {
                                                        "numero": "17º",
                                                        "rotulo": "Art. 17º.",
                                                        "linha": 245,
                                                        "caput": "A autoridade policial não poderá mandar arquivar autos de inquérito."
                                                },
                                                {
                                                        "numero": "18º",
                                                        "rotulo": "Art. 18º.",
                                                        "linha": 247,
                                                        "caput": "Depois de ordenado o arquivamento do inquérito pela autoridade judiciária, por falta de base para a denúncia, a autoridade policial poderá proceder a novas pesquisas, se de outras provas tiver notícia."
                                                },
                                                {
                                                        "numero": "19º",
                                                        "rotulo": "Art. 19º.",
                                                        "linha": 249,
                                                        "caput": "Nos crimes em que não couber ação pública, os autos do inquérito serão remetidos ao juízo competente, onde aguardarão a iniciativa do ofendido ou de seu representante legal, ou serão entregues ao requerente, se o pedir, mediante traslado."
                                                },
                                                {
                                                        "numero": "20º",
                                                        "rotulo": "Art. 20º.",
                                                        "linha": 251,
                                                        "caput": "A autoridade assegurará no inquérito o sigilo necessário à elucidação do fato ou exigido pelo interesse da sociedade.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 254,
                                                                        "texto": "Nos atestados de antecedentes que lhe forem solicitados, a autoridade policial não poderá mencionar quaisquer anotações referentes a instauração de inquérito contra os requerentes."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "21º",
                                                        "rotulo": "Art. 21º.",
                                                        "linha": 256,
                                                        "caput": "A incomunicabilidade do indiciado dependerá sempre de despacho nos autos e somente será permitida quando o interesse da sociedade ou a conveniência da investigação o exigir.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 259,
                                                                        "texto": "A incomunicabilidade, que não excederá de três dias, será decretada por despacho fundamentado do Juiz, a requerimento da autoridade policial, ou do órgão do Ministério Público, respeitado, em qualquer hipótese, o disposto no artigo 89, inciso III, do Estatuto da Ordem dos Advogados do Brasil (Lei n. 4.215, de 27 de abril de 1963)"
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "22º",
                                                        "rotulo": "Art. 22º.",
                                                        "linha": 261,
                                                        "caput": "No Distrito Federal e nas comarcas em que houver mais de uma circunscrição policial, a autoridade com exercício em uma delas poderá, nos inquéritos a que esteja procedendo, ordenar diligências em circunscrição de outra, independentemente de precatórias ou requisições, e bem assim providenciará, até que compareça a autoridade competente, sobre qualquer fato que ocorra em sua presença, noutra circunscrição."
                                                },
                                                {
                                                        "numero": "23º",
                                                        "rotulo": "Art. 23º.",
                                                        "linha": 263,
                                                        "caput": "Ao fazer a remessa dos autos do inquérito ao juiz competente, a autoridade policial oficiará ao Instituto de Identificação e Estatística, ou repartição congênere, mencionando o juízo a que tiverem sido distribuídos, e os dados relativos à infração penal e à pessoa do indiciado."
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO III",
                                        "linha": 265,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "24º",
                                                        "rotulo": "Art. 24º.",
                                                        "linha": 269,
                                                        "caput": "Nos crimes de ação pública, esta será promovida por denúncia do Ministério Público, mas dependerá, quando a lei o exigir, de requisição do Ministro da Justiça, ou de representação do ofendido ou de quem tiver qualidade para representá-lo.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 272,
                                                                        "texto": "No caso de morte do ofendido ou quando declarado ausente por decisão judicial, o direito de representação passará ao cônjuge, ascendente, descendente ou irmão."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 274,
                                                                        "texto": "Seja qual for o crime, quando praticado em detrimento do patrimônio ou interesse da União, Estado e Município, a ação penal será pública."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "25º",
                                                        "rotulo": "Art. 25º.",
                                                        "linha": 276,
                                                        "caput": "A representação será irretratável, depois de oferecida a denúncia."
                                                },
                                                {
                                                        "numero": "26º",
                                                        "rotulo": "Art. 26º.",
                                                        "linha": 278,
                                                        "caput": "A ação penal, nas contravenções, será iniciada com o auto de prisão em flagrante ou por meio de portaria expedida pela autoridade judiciária ou policial."
                                                },
                                                {
                                                        "numero": "27º",
                                                        "rotulo": "Art. 27º.",
                                                        "linha": 280,
                                                        "caput": "Qualquer pessoa do povo poderá provocar a iniciativa do Ministério Público, nos casos em que caiba a ação pública, fornecendo-lhe, por escrito, informações sobre o fato e a autoria e indicando o tempo, o lugar e os elementos de convicção."
                                                },
                                                {
                                                        "numero": "28º",
                                                        "rotulo": "Art. 28º.",
                                                        "linha": 282,
                                                        "caput": "Ordenado o arquivamento do inquérito policial ou de quaisquer elementos informativos da mesma natureza, o órgão do Ministério Público comunicará à vítima, ao investigado e à autoridade policial e encaminhará os autos para a instância de revisão ministerial para fins de homologação, na forma da lei.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 284,
                                                                        "texto": "Se a vítima, ou seu representante legal, não concordar com o arquivamento do inquérito policial, poderá, no prazo de 30 (trinta) dias do recebimento da comunicação, submeter a matéria à revisão da instância competente do órgão ministerial, conforme dispuser a respectiva lei orgânica."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 286,
                                                                        "texto": "Nas ações penais relativas a crimes praticados em detrimento da União, Estados e Municípios, a revisão do arquivamento do inquérito policial poderá ser provocada pela chefia do órgão a quem couber a sua representação judicial."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "28º-A",
                                                        "rotulo": "Art. 28º-A.",
                                                        "linha": 288,
                                                        "caput": "Não sendo caso de arquivamento e tendo o investigado confessado formal e circunstancialmente a prática de infração penal sem violência ou grave ameaça e com pena mínima inferior a 4 (quatro) anos, o Ministério Público poderá propor acordo de não persecução penal, desde que necessário e suficiente para reprovação e prevenção do crime, mediante as seguintes condições ajustadas cumulativa e alternativamente:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 290,
                                                                        "texto": "reparar o dano ou restituir a coisa à vítima, exceto na impossibilidade de fazê-lo;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 292,
                                                                        "texto": "renunciar voluntariamente a bens e direitos indicados pelo Ministério Público como instrumentos, produto ou proveito do crime;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 294,
                                                                        "texto": "prestar serviço à comunidade ou a entidades públicas por período correspondente à pena mínima cominada ao delito diminuída de um a dois terços, em local a ser indicado pelo juízo da execução, na forma do art. 46 do Decreto-Lei nº 2.848, de 7 de dezembro de 1940 (Código Penal);"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 296,
                                                                        "texto": "pagar prestação pecuniária, a ser estipulada nos termos do art. 45 do Decreto-Lei nº 2.848, de 7 de dezembro de 1940 (Código Penal), a entidade pública ou de interesse social, a ser indicada pelo juízo da execução, que tenha, preferencialmente, como função proteger bens jurídicos iguais ou semelhantes aos aparentemente lesados pelo delito; ou"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 298,
                                                                        "texto": "cumprir, por prazo determinado, outra condição indicada pelo Ministério Público, desde que proporcional e compatível com a infração penal imputada."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 300,
                                                                        "texto": "Para aferição da pena mínima cominada ao delito a que se refere o caput deste artigo, serão consideradas as causas de aumento e diminuição aplicáveis ao caso concreto."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 302,
                                                                        "texto": "O disposto no caput deste artigo não se aplica nas seguintes hipóteses:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 304,
                                                                                        "texto": "se for cabível transação penal de competência dos Juizados Especiais Criminais, nos termos da lei;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 306,
                                                                                        "texto": "se o investigado for reincidente ou se houver elementos probatórios que indiquem conduta criminal habitual, reiterada ou profissional, exceto se insignificantes as infrações penais pretéritas;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 308,
                                                                                        "texto": "ter sido o agente beneficiado nos 5 (cinco) anos anteriores ao cometimento da infração, em acordo de não persecução penal, transação penal ou suspensão condicional do processo; e"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 310,
                                                                                        "texto": "nos crimes praticados no âmbito de violência doméstica ou familiar, ou praticados contra a mulher por razões da condição de sexo feminino, em favor do agressor."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 312,
                                                                        "texto": "O acordo de não persecução penal será formalizado por escrito e será firmado pelo membro do Ministério Público, pelo investigado e por seu defensor."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 314,
                                                                        "texto": "Para a homologação do acordo de não persecução penal, será realizada audiência na qual o juiz deverá verificar a sua voluntariedade, por meio da oitiva do investigado na presença do seu defensor, e sua legalidade."
                                                                },
                                                                {
                                                                        "numero": "5",
                                                                        "rotulo": "§ 5",
                                                                        "linha": 316,
                                                                        "texto": "Se o juiz considerar inadequadas, insuficientes ou abusivas as condições dispostas no acordo de não persecução penal, devolverá os autos ao Ministério Público para que seja reformulada a proposta de acordo, com concordância do investigado e seu defensor."
                                                                },
                                                                {
                                                                        "numero": "6",
                                                                        "rotulo": "§ 6",
                                                                        "linha": 318,
                                                                        "texto": "Homologado judicialmente o acordo de não persecução penal, o juiz devolverá os autos ao Ministério Público para que inicie sua execução perante o juízo de execução penal."
                                                                },
                                                                {
                                                                        "numero": "7",
                                                                        "rotulo": "§ 7",
                                                                        "linha": 320,
                                                                        "texto": "O juiz poderá recusar homologação à proposta que não atender aos requisitos legais ou quando não for realizada a adequação a que se refere o § 5º deste artigo."
                                                                },
                                                                {
                                                                        "numero": "8",
                                                                        "rotulo": "§ 8",
                                                                        "linha": 322,
                                                                        "texto": "Recusada a homologação, o juiz devolverá os autos ao Ministério Público para a análise da necessidade de complementação das investigações ou o oferecimento da denúncia."
                                                                },
                                                                {
                                                                        "numero": "9",
                                                                        "rotulo": "§ 9",
                                                                        "linha": 324,
                                                                        "texto": "A vítima será intimada da homologação do acordo de não persecução penal e de seu descumprimento."
                                                                },
                                                                {
                                                                        "numero": "10",
                                                                        "rotulo": "§ 10",
                                                                        "linha": 326,
                                                                        "texto": "Descumpridas quaisquer das condições estipuladas no acordo de não persecução penal, o Ministério Público deverá comunicar ao juízo, para fins de sua rescisão e posterior oferecimento de denúncia."
                                                                },
                                                                {
                                                                        "numero": "11",
                                                                        "rotulo": "§ 11",
                                                                        "linha": 328,
                                                                        "texto": "O descumprimento do acordo de não persecução penal pelo investigado também poderá ser utilizado pelo Ministério Público como justificativa para o eventual não oferecimento de suspensão condicional do processo."
                                                                },
                                                                {
                                                                        "numero": "12",
                                                                        "rotulo": "§ 12",
                                                                        "linha": 330,
                                                                        "texto": "A celebração e o cumprimento do acordo de não persecução penal não constarão de certidão de antecedentes criminais, exceto para os fins previstos no inciso III do § 2º deste artigo."
                                                                },
                                                                {
                                                                        "numero": "13",
                                                                        "rotulo": "§ 13",
                                                                        "linha": 332,
                                                                        "texto": "Cumprido integralmente o acordo de não persecução penal, o juízo competente decretará a extinção de punibilidade."
                                                                },
                                                                {
                                                                        "numero": "14",
                                                                        "rotulo": "§ 14",
                                                                        "linha": 334,
                                                                        "texto": "No caso de recusa, por parte do Ministério Público, em propor o acordo de não persecução penal, o investigado poderá requerer a remessa dos autos a órgão superior, na forma do art. 28 deste Código."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "29º",
                                                        "rotulo": "Art. 29º.",
                                                        "linha": 336,
                                                        "caput": "Será admitida ação privada nos crimes de ação pública, se esta não for intentada no prazo legal, cabendo ao Ministério Público aditar a queixa, repudiá-la e oferecer denúncia substitutiva, intervir em todos os termos do processo, fornecer elementos de prova, interpor recurso e, a todo tempo, no caso de negligência do querelante, retomar a ação como parte principal."
                                                },
                                                {
                                                        "numero": "30º",
                                                        "rotulo": "Art. 30º.",
                                                        "linha": 338,
                                                        "caput": "Ao ofendido ou a quem tenha qualidade para representá-lo caberá intentar a ação privada."
                                                },
                                                {
                                                        "numero": "31º",
                                                        "rotulo": "Art. 31º.",
                                                        "linha": 340,
                                                        "caput": "No caso de morte do ofendido ou quando declarado ausente por decisão judicial, o direito de oferecer queixa ou prosseguir na ação passará ao cônjuge, ascendente, descendente ou irmão."
                                                },
                                                {
                                                        "numero": "32º",
                                                        "rotulo": "Art. 32º.",
                                                        "linha": 342,
                                                        "caput": "Nos crimes de ação privada, o juiz, a requerimento da parte que comprovar a sua pobreza, nomeará advogado para promover a ação penal.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 344,
                                                                        "texto": "Considerar-se-á pobre a pessoa que não puder prover às despesas do processo, sem privar-se dos recursos indispensáveis ao próprio sustento ou da família."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 346,
                                                                        "texto": "Será prova suficiente de pobreza o atestado da autoridade policial em cuja circunscrição residir o ofendido."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "33º",
                                                        "rotulo": "Art. 33º.",
                                                        "linha": 348,
                                                        "caput": "Se o ofendido for menor de 18 anos, ou mentalmente enfermo, ou retardado mental, e não tiver representante legal, ou colidirem os interesses deste com os daquele, o direito de queixa poderá ser exercido por curador especial, nomeado, de ofício ou a requerimento do Ministério Público, pelo juiz competente para o processo penal."
                                                },
                                                {
                                                        "numero": "34º",
                                                        "rotulo": "Art. 34º.",
                                                        "linha": 350,
                                                        "caput": "Se o ofendido for menor de 21 e maior de 18 anos, o direito de queixa poderá ser exercido por ele ou por seu representante legal."
                                                },
                                                {
                                                        "numero": "35º",
                                                        "rotulo": "Art. 35º.",
                                                        "linha": 353,
                                                        "caput": ""
                                                },
                                                {
                                                        "numero": "36º",
                                                        "rotulo": "Art. 36º.",
                                                        "linha": 356,
                                                        "caput": "Se comparecer mais de uma pessoa com direito de queixa, terá preferência o cônjuge, e, em seguida, o parente mais próximo na ordem de enumeração constante do art. 31, podendo, entretanto, qualquer delas prosseguir na ação, caso o querelante desista da instância ou a abandone."
                                                },
                                                {
                                                        "numero": "37º",
                                                        "rotulo": "Art. 37º.",
                                                        "linha": 358,
                                                        "caput": "As fundações, associações ou sociedades legalmente constituídas poderão exercer a ação penal, devendo ser representadas por quem os respectivos contratos ou estatutos designarem ou, no silêncio destes, pelos seus diretores ou sócios-gerentes."
                                                },
                                                {
                                                        "numero": "38º",
                                                        "rotulo": "Art. 38º.",
                                                        "linha": 360,
                                                        "caput": "Salvo disposição em contrário, o ofendido, ou seu representante legal, decairá no direito de queixa ou de representação, se não o exercer dentro do prazo de seis meses, contado do dia em que vier a saber quem é o autor do crime, ou, no caso do art. 29, do dia em que se esgotar o prazo para o oferecimento da denúncia.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 362,
                                                                        "texto": "Verificar-se-á a decadência do direito de queixa ou representação, dentro do mesmo prazo, nos casos dos arts. 24, parágrafo único, e 31."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "39º",
                                                        "rotulo": "Art. 39º.",
                                                        "linha": 364,
                                                        "caput": "O direito de representação poderá ser exercido, pessoalmente ou por procurador com poderes especiais, mediante declaração, escrita ou oral, feita ao juiz, ao órgão do Ministério Público, ou à autoridade policial.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 366,
                                                                        "texto": "A representação feita oralmente ou por escrito, sem assinatura devidamente autenticada do ofendido, de seu representante legal ou procurador, será reduzida a termo, perante o juiz ou autoridade policial, presente o órgão do Ministério Público, quando a este houver sido dirigida."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 368,
                                                                        "texto": "A representação conterá todas as informações que possam servir à apuração do fato e da autoria."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 370,
                                                                        "texto": "Oferecida ou reduzida a termo a representação, a autoridade policial procederá a inquérito, ou, não sendo competente, remetê-lo-á à autoridade que o for."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 372,
                                                                        "texto": "A representação, quando feita ao juiz ou perante este reduzida a termo, será remetida à autoridade policial para que esta proceda a inquérito."
                                                                },
                                                                {
                                                                        "numero": "5",
                                                                        "rotulo": "§ 5",
                                                                        "linha": 374,
                                                                        "texto": "O órgão do Ministério Público dispensará o inquérito, se com a representação forem oferecidos elementos que o habilitem a promover a ação penal, e, neste caso, oferecerá a denúncia no prazo de quinze dias."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "40º",
                                                        "rotulo": "Art. 40º.",
                                                        "linha": 376,
                                                        "caput": "Quando, em autos ou papéis de que conhecerem, os juízes ou tribunais verificarem a existência de crime de ação pública, remeterão ao Ministério Público as cópias e os documentos necessários ao oferecimento da denúncia."
                                                },
                                                {
                                                        "numero": "41º",
                                                        "rotulo": "Art. 41º.",
                                                        "linha": 378,
                                                        "caput": "A denúncia ou queixa conterá a exposição do fato criminoso, com todas as suas circunstâncias, a qualificação do acusado ou esclarecimentos pelos quais se possa identificá-lo, a classificação do crime e, quando necessário, o rol das testemunhas."
                                                },
                                                {
                                                        "numero": "42º",
                                                        "rotulo": "Art. 42º.",
                                                        "linha": 380,
                                                        "caput": "O Ministério Público não poderá desistir da ação penal."
                                                },
                                                {
                                                        "numero": "43º",
                                                        "rotulo": "Art. 43º.",
                                                        "linha": 382,
                                                        "caput": ""
                                                },
                                                {
                                                        "numero": "44º",
                                                        "rotulo": "Art. 44º.",
                                                        "linha": 388,
                                                        "caput": "A queixa poderá ser dada por procurador com poderes especiais, devendo constar do instrumento do mandato o nome do querelante e a menção do fato criminoso, salvo quando tais esclarecimentos dependerem de diligências que devem ser previamente requeridas no juízo criminal."
                                                },
                                                {
                                                        "numero": "45º",
                                                        "rotulo": "Art. 45º.",
                                                        "linha": 390,
                                                        "caput": "A queixa, ainda quando a ação penal for privativa do ofendido, poderá ser aditada pelo Ministério Público, a quem caberá intervir em todos os termos subseqüentes do processo."
                                                },
                                                {
                                                        "numero": "46º",
                                                        "rotulo": "Art. 46º.",
                                                        "linha": 392,
                                                        "caput": "O prazo para oferecimento da denúncia, estando o réu preso, será de 5 dias, contado da data em que o órgão do Ministério Público receber os autos do inquérito policial, e de 15 dias, se o réu estiver solto ou afiançado. No último caso, se houver devolução do inquérito à autoridade policial (art. 16), contar-se-á o prazo da data em que o órgão do Ministério Público receber novamente os autos.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 394,
                                                                        "texto": "Quando o Ministério Público dispensar o inquérito policial, o prazo para o oferecimento da denúncia contar-se-á da data em que tiver recebido as peças de informações ou a representação"
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 396,
                                                                        "texto": "O prazo para o aditamento da queixa será de 3 dias, contado da data em que o órgão do Ministério Público receber os autos, e, se este não se pronunciar dentro do tríduo, entender-se-á que não tem o que aditar, prosseguindo-se nos demais termos do processo."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "47º",
                                                        "rotulo": "Art. 47º.",
                                                        "linha": 398,
                                                        "caput": "Se o Ministério Público julgar necessários maiores esclarecimentos e documentos complementares ou novos elementos de convicção, deverá requisitá-los, diretamente, de quaisquer autoridades ou funcionários que devam ou possam fornecê-los."
                                                },
                                                {
                                                        "numero": "48º",
                                                        "rotulo": "Art. 48º.",
                                                        "linha": 400,
                                                        "caput": "A queixa contra qualquer dos autores do crime obrigará ao processo de todos, e o Ministério Público velará pela sua indivisibilidade."
                                                },
                                                {
                                                        "numero": "49º",
                                                        "rotulo": "Art. 49º.",
                                                        "linha": 402,
                                                        "caput": "A renúncia ao exercício do direito de queixa, em relação a um dos autores do crime, a todos se estenderá."
                                                },
                                                {
                                                        "numero": "50º",
                                                        "rotulo": "Art. 50º.",
                                                        "linha": 404,
                                                        "caput": "A renúncia expressa constará de declaração assinada pelo ofendido, por seu representante legal ou procurador com poderes especiais.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 406,
                                                                        "texto": "A renúncia do representante legal do menor que houver completado 18 (dezoito) anos não privará este do direito de queixa, nem a renúncia do último excluirá o direito do primeiro."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "51º",
                                                        "rotulo": "Art. 51º.",
                                                        "linha": 408,
                                                        "caput": "O perdão concedido a um dos querelados aproveitará a todos, sem que produza, todavia, efeito em relação ao que o recusar."
                                                },
                                                {
                                                        "numero": "52º",
                                                        "rotulo": "Art. 52º.",
                                                        "linha": 410,
                                                        "caput": "Se o querelante for menor de 21 e maior de 18 anos, o direito de perdão poderá ser exercido por ele ou por seu representante legal, mas o perdão concedido por um, havendo oposição do outro, não produzirá efeito."
                                                },
                                                {
                                                        "numero": "53º",
                                                        "rotulo": "Art. 53º.",
                                                        "linha": 412,
                                                        "caput": "Se o querelado for mentalmente enfermo ou retardado mental e não tiver representante legal, ou colidirem os interesses deste com os do querelado, a aceitação do perdão caberá ao curador que o juiz Ihe nomear."
                                                },
                                                {
                                                        "numero": "54º",
                                                        "rotulo": "Art. 54º.",
                                                        "linha": 414,
                                                        "caput": "Se o querelado for menor de 21 anos, observar-se-á, quanto à aceitação do perdão, o disposto no art. 52."
                                                },
                                                {
                                                        "numero": "55º",
                                                        "rotulo": "Art. 55º.",
                                                        "linha": 416,
                                                        "caput": "O perdão poderá ser aceito por procurador com poderes especiais."
                                                },
                                                {
                                                        "numero": "56º",
                                                        "rotulo": "Art. 56º.",
                                                        "linha": 418,
                                                        "caput": "Aplicar-se-á ao perdão extraprocessual expresso o disposto no art. 50."
                                                },
                                                {
                                                        "numero": "57º",
                                                        "rotulo": "Art. 57º.",
                                                        "linha": 420,
                                                        "caput": "A renúncia tácita e o perdão tácito admitirão todos os meios de prova."
                                                },
                                                {
                                                        "numero": "58º",
                                                        "rotulo": "Art. 58º.",
                                                        "linha": 422,
                                                        "caput": "Concedido o perdão, mediante declaração expressa nos autos, o querelado será intimado a dizer, dentro de três dias, se o aceita, devendo, ao mesmo tempo, ser cientificado de que o seu silêncio importará aceitação.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 424,
                                                                        "texto": "Aceito o perdão, o juiz julgará extinta a punibilidade."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "59º",
                                                        "rotulo": "Art. 59º.",
                                                        "linha": 426,
                                                        "caput": "A aceitação do perdão fora do processo constará de declaração assinada pelo querelado, por seu representante legal ou procurador com poderes especiais."
                                                },
                                                {
                                                        "numero": "60º",
                                                        "rotulo": "Art. 60º.",
                                                        "linha": 428,
                                                        "caput": "Nos casos em que somente se procede mediante queixa, considerar-se-á perempta a ação penal:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 430,
                                                                        "texto": "quando, iniciada esta, o querelante deixar de promover o andamento do processo durante 30 dias seguidos;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 432,
                                                                        "texto": "quando, falecendo o querelante, ou sobrevindo sua incapacidade, não comparecer em juízo, para prosseguir no processo, dentro do prazo de 60 (sessenta) dias, qualquer das pessoas a quem couber fazê-lo, ressalvado o disposto no art. 36;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 434,
                                                                        "texto": "quando o querelante deixar de comparecer, sem motivo justificado, a qualquer ato do processo a que deva estar presente, ou deixar de formular o pedido de condenação nas alegações finais;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 436,
                                                                        "texto": "quando, sendo o querelante pessoa jurídica, esta se extinguir sem deixar sucessor."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "61º",
                                                        "rotulo": "Art. 61º.",
                                                        "linha": 438,
                                                        "caput": "Em qualquer fase do processo, o juiz, se reconhecer extinta a punibilidade, deverá declará-lo de ofício.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 440,
                                                                        "texto": "No caso de requerimento do Ministério Público, do querelante ou do réu, o juiz mandará autuá-lo em apartado, ouvirá a parte contrária e, se o julgar conveniente, concederá o prazo de cinco dias para a prova, proferindo a decisão dentro de cinco dias ou reservando-se para apreciar a matéria na sentença final."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "62º",
                                                        "rotulo": "Art. 62º.",
                                                        "linha": 442,
                                                        "caput": "No caso de morte do acusado, o juiz somente à vista da certidão de óbito, e depois de ouvido o Ministério Público, declarará extinta a punibilidade."
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO IV",
                                        "linha": 444,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "63º",
                                                        "rotulo": "Art. 63º.",
                                                        "linha": 448,
                                                        "caput": "Transitada em julgado a sentença condenatória, poderão promover-lhe a execução, no juízo cível, para o efeito da reparação do dano, o ofendido, seu representante legal ou seus herdeiros.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 450,
                                                                        "texto": "Transitada em julgado a sentença condenatória, a execução poderá ser efetuada pelo valor fixado nos termos do inciso iv do caputdo art. 387 deste Código sem prejuízo da liquidação para a apuração do dano efetivamente sofrido. ."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "64º",
                                                        "rotulo": "Art. 64º.",
                                                        "linha": 452,
                                                        "caput": "Sem prejuízo do disposto no artigo anterior, a ação para ressarcimento do dano poderá ser proposta no juízo cível, contra o autor do crime e, se for caso, contra o responsável civil.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 454,
                                                                        "texto": "Intentada a ação penal, o juiz da ação civil poderá suspender o curso desta, até o julgamento definitivo daquela."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "65º",
                                                        "rotulo": "Art. 65º.",
                                                        "linha": 456,
                                                        "caput": "Faz coisa julgada no cível a sentença penal que reconhecer ter sido o ato praticado em estado de necessidade, em legítima defesa, em estrito cumprimento de dever legal ou no exercício regular de direito."
                                                },
                                                {
                                                        "numero": "66º",
                                                        "rotulo": "Art. 66º.",
                                                        "linha": 458,
                                                        "caput": "Não obstante a sentença absolutória no juízo criminal, a ação civil poderá ser proposta quando não tiver sido, categoricamente, reconhecida a inexistência material do fato."
                                                },
                                                {
                                                        "numero": "67º",
                                                        "rotulo": "Art. 67º.",
                                                        "linha": 460,
                                                        "caput": "Não impedirão igualmente a propositura da ação civil:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 462,
                                                                        "texto": "despacho de arquivamento do inquérito ou das peças de informação;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 464,
                                                                        "texto": "a decisão que julgar extinta a punibilidade;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 466,
                                                                        "texto": "a sentença absolutória que decidir que o fato imputado não constitui crime."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "68º",
                                                        "rotulo": "Art. 68º.",
                                                        "linha": 468,
                                                        "caput": "Quando o titular do direito à reparação do dano for pobre (art. 32, §§ 1o e 2o), a execução da sentença condenatória (art. 63) ou a ação civil (art. 64) será promovida, a seu requerimento, pelo Ministério Público."
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO V",
                                        "linha": 470,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 490,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "70º",
                                                                        "rotulo": "Art. 70º.",
                                                                        "linha": 494,
                                                                        "caput": "A competência será, de regra, determinada pelo lugar em que se consumar a infração, ou, no caso de tentativa, pelo lugar em que for praticado o último ato de execução.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 496,
                                                                                        "texto": "Se, iniciada a execução no território nacional, a infração se consumar fora dele, a competência será determinada pelo lugar em que tiver sido praticado, no Brasil, o último ato de execução."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 498,
                                                                                        "texto": "Quando o último ato de execução for praticado fora do território nacional, será competente o juiz do lugar em que o crime, embora parcialmente, tenha produzido ou devia produzir seu resultado."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 500,
                                                                                        "texto": "Quando incerto o limite territorial entre duas ou mais jurisdições, ou quando incerta a jurisdição por ter sido a infração consumada ou tentada nas divisas de duas ou mais jurisdições, a competência firmar-se-á pela prevenção."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 502,
                                                                                        "texto": "Nos crimes previstos no art. 171 do Decreto-Lei nº 2.848, de 7 de dezembro de 1940 (Código Penal), quando praticados mediante depósito, mediante emissão de cheques sem suficiente provisão de fundos em poder do sacado ou com o pagamento frustrado ou mediante transferência de valores, a competência será definida pelo local do domicílio da vítima, e, em caso de pluralidade de vítimas, a competência firmar-se-á pela prevenção."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "71º",
                                                                        "rotulo": "Art. 71º.",
                                                                        "linha": 504,
                                                                        "caput": "Tratando-se de infração continuada ou permanente, praticada em território de duas ou mais jurisdições, a competência firmar-se-á pela prevenção."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 506,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "72º",
                                                                        "rotulo": "Art. 72º.",
                                                                        "linha": 510,
                                                                        "caput": "Não sendo conhecido o lugar da infração, a competência regular-se-á pelo domicílio ou residência do réu.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 512,
                                                                                        "texto": "Se o réu tiver mais de uma residência, a competência firmar-se-á pela prevenção."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 514,
                                                                                        "texto": "Se o réu não tiver residência certa ou for ignorado o seu paradeiro, será competente o juiz que primeiro tomar conhecimento do fato."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "73º",
                                                                        "rotulo": "Art. 73º.",
                                                                        "linha": 516,
                                                                        "caput": "Nos casos de exclusiva ação privada, o querelante poderá preferir o foro de domicílio ou da residência do réu, ainda quando conhecido o lugar da infração."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 518,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "74º",
                                                                        "rotulo": "Art. 74º.",
                                                                        "linha": 522,
                                                                        "caput": "A competência pela natureza da infração será regulada pelas leis de organização judiciária, salvo a competência privativa do Tribunal do Júri.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 525,
                                                                                        "texto": "Compete ao Tribunal do Júri o julgamento dos crimes previstos nos arts. 121, §§ 1º e 2º, 122, parágrafo único, 123, 124, 125, 126 e 127 do Código Penal, consumados ou tentados."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 527,
                                                                                        "texto": "Se, iniciado o processo perante um juiz, houver desclassificação para infração da competência de outro, a este será remetido o processo, salvo se mais graduada for a jurisdição do primeiro, que, em tal caso, terá sua competência prorrogada."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 529,
                                                                                        "texto": "Se o juiz da pronúncia desclassificar a infração para outra atribuída à competência de juiz singular, observar-se-á o disposto no art. 410; mas, se a desclassificação for feita pelo próprio Tribunal do Júri, a seu presidente caberá proferir a sentença (art. 492, § 2o)."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IV",
                                                        "linha": 531,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "75º",
                                                                        "rotulo": "Art. 75º.",
                                                                        "linha": 535,
                                                                        "caput": "A precedência da distribuição fixará a competência quando, na mesma circunscrição judiciária, houver mais de um juiz igualmente competente.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 537,
                                                                                        "texto": "A distribuição realizada para o efeito da concessão de fiança ou da decretação de prisão preventiva ou de qualquer diligência anterior à denúncia ou queixa prevenirá a da ação penal."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 539,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "76º",
                                                                        "rotulo": "Art. 76º.",
                                                                        "linha": 543,
                                                                        "caput": "A competência será determinada pela conexão:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 545,
                                                                                        "texto": "se, ocorrendo duas ou mais infrações, houverem sido praticadas, ao mesmo tempo, por várias pessoas reunidas, ou por várias pessoas em concurso, embora diverso o tempo e o lugar, ou por várias pessoas, umas contra as outras;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 547,
                                                                                        "texto": "se, no mesmo caso, houverem sido umas praticadas para facilitar ou ocultar as outras, ou para conseguir impunidade ou vantagem em relação a qualquer delas;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 549,
                                                                                        "texto": "quando a prova de uma infração ou de qualquer de suas circunstâncias elementares influir na prova de outra infração."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "77º",
                                                                        "rotulo": "Art. 77º.",
                                                                        "linha": 551,
                                                                        "caput": "A competência será determinada pela continência quando:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 553,
                                                                                        "texto": "duas ou mais pessoas forem acusadas pela mesma infração;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 555,
                                                                                        "texto": "no caso de infração cometida nas condições previstas nos arts. 51, § 1o, 53, segunda parte, e 54 do Código Penal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "78º",
                                                                        "rotulo": "Art. 78º.",
                                                                        "linha": 565,
                                                                        "caput": "Na determinação da competência por conexão ou continência, serão observadas as seguintes regras:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 567,
                                                                                        "texto": "no concurso entre a competência do júri e a de outro órgão da jurisdição comum, prevalecerá a competência do júri, salvo os casos de homicídios cometidos por membros de organizações criminosas ultraviolentas, grupo paramilitar ou milícia privada, ou sua tentativa, na forma do art. 2º da lei que institui o marco legal do combate ao crime organizado no Brasil; Il - no concurso de jurisdições da mesma categoria:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 571,
                                                                                                        "texto": "preponderará a do lugar da infração, à qual for cominada a pena mais grave;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 573,
                                                                                                        "texto": "prevalecerá a do lugar em que houver ocorrido o maior número de infrações, se as respectivas penas forem de igual gravidade;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 575,
                                                                                                        "texto": "firmar-se-á a competência pela prevenção, nos outros casos;"
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 577,
                                                                                        "texto": "no concurso de jurisdições de diversas categorias, predominará a de maior graduação;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 579,
                                                                                        "texto": "no concurso entre a jurisdição comum e a especial, prevalecerá esta."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "79º",
                                                                        "rotulo": "Art. 79º.",
                                                                        "linha": 581,
                                                                        "caput": "A conexão e a continência importarão unidade de processo e julgamento, salvo:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 583,
                                                                                        "texto": "no concurso entre a jurisdição comum e a militar;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 585,
                                                                                        "texto": "no concurso entre a jurisdição comum e a do juízo de menores."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 587,
                                                                                        "texto": "Cessará, em qualquer caso, a unidade do processo, se, em relação a algum co-réu, sobrevier o caso previsto no art. 152."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 589,
                                                                                        "texto": "A unidade do processo não importará a do julgamento, se houver co-réu foragido que não possa ser julgado à revelia, ou ocorrer a hipótese do art. 461."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "80º",
                                                                        "rotulo": "Art. 80º.",
                                                                        "linha": 591,
                                                                        "caput": "Será facultativa a separação dos processos quando as infrações tiverem sido praticadas em circunstâncias de tempo ou de lugar diferentes, ou, quando pelo excessivo número de acusados e para não Ihes prolongar a prisão provisória, ou por outro motivo relevante, o juiz reputar conveniente a separação."
                                                                },
                                                                {
                                                                        "numero": "81º",
                                                                        "rotulo": "Art. 81º.",
                                                                        "linha": 593,
                                                                        "caput": "Verificada a reunião dos processos por conexão ou continência, ainda que no processo da sua competência própria venha o juiz ou tribunal a proferir sentença absolutória ou que desclassifique a infração para outra que não se inclua na sua competência, continuará competente em relação aos demais processos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 595,
                                                                                        "texto": "Reconhecida inicialmente ao júri a competência por conexão ou continência, o juiz, se vier a desclassificar a infração ou impronunciar ou absolver o acusado, de maneira que exclua a competência do júri, remeterá o processo ao juízo competente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "82º",
                                                                        "rotulo": "Art. 82º.",
                                                                        "linha": 597,
                                                                        "caput": "Se, não obstante a conexão ou continência, forem instaurados processos diferentes, a autoridade de jurisdição prevalente deverá avocar os processos que corram perante os outros juízes, salvo se já estiverem com sentença definitiva. Neste caso, a unidade dos processos só se dará, ulteriormente, para o efeito de soma ou de unificação das penas."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 599,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "83º",
                                                                        "rotulo": "Art. 83º.",
                                                                        "linha": 603,
                                                                        "caput": "Verificar-se-á a competência por prevenção toda vez que, concorrendo dois ou mais juízes igualmente competentes ou com jurisdição cumulativa, um deles tiver antecedido aos outros na prática de algum ato do processo ou de medida a este relativa, ainda que anterior ao oferecimento da denúncia ou da queixa (arts. 70, § 3o, 71, 72, § 2o, e 78, II, c)."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VII",
                                                        "linha": 605,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "84º",
                                                                        "rotulo": "Art. 84º.",
                                                                        "linha": 610,
                                                                        "caput": "A competência pela prerrogativa de função é do Supremo Tribunal Federal, do Superior Tribunal de Justiça, dos Tribunais Regionais Federais e Tribunais de Justiça dos Estados e do Distrito Federal, relativamente às pessoas que devam responder perante eles por crimes comuns e de responsabilidade."
                                                                },
                                                                {
                                                                        "numero": "85º",
                                                                        "rotulo": "Art. 85º.",
                                                                        "linha": 616,
                                                                        "caput": "Nos processos por crime contra a honra, em que forem querelantes as pessoas que a Constituição sujeita à jurisdição do Supremo Tribunal Federal e dos Tribunais de Apelação, àquele ou a estes caberá o julgamento, quando oposta e admitida a exceção da verdade."
                                                                },
                                                                {
                                                                        "numero": "86º",
                                                                        "rotulo": "Art. 86º.",
                                                                        "linha": 618,
                                                                        "caput": "Ao Supremo Tribunal Federal competirá, privativamente, processar e julgar:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 620,
                                                                                        "texto": "os seus ministros, nos crimes comuns;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 622,
                                                                                        "texto": "os ministros de Estado, salvo nos crimes conexos com os do Presidente da República;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 624,
                                                                                        "texto": "procurador-geral da República, os desembargadores dos Tribunais de Apelação, os ministros do Tribunal de Contas e os embaixadores e ministros diplomáticos, nos crimes comuns e de responsabilidade."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "87º",
                                                                        "rotulo": "Art. 87º.",
                                                                        "linha": 626,
                                                                        "caput": "Competirá, originariamente, aos Tribunais de Apelação o julgamento dos governadores ou interventores nos Estados ou Territórios, e prefeito do Distrito Federal, seus respectivos secretários e chefes de Polícia, juízes de instância inferior e órgãos do Ministério Público."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VIII",
                                                        "linha": 628,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "88º",
                                                                        "rotulo": "Art. 88º.",
                                                                        "linha": 632,
                                                                        "caput": "No processo por crimes praticados fora do território brasileiro, será competente o juízo da Capital do Estado onde houver por último residido o acusado. Se este nunca tiver residido no Brasil, será competente o juízo da Capital da República."
                                                                },
                                                                {
                                                                        "numero": "89º",
                                                                        "rotulo": "Art. 89º.",
                                                                        "linha": 634,
                                                                        "caput": "Os crimes cometidos em qualquer embarcação nas águas territoriais da República, ou nos rios e lagos fronteiriços, bem como a bordo de embarcações nacionais, em alto-mar, serão processados e julgados pela justiça do primeiro porto brasileiro em que tocar a embarcação, após o crime, ou, quando se afastar do País, pela do último em que houver tocado."
                                                                },
                                                                {
                                                                        "numero": "90º",
                                                                        "rotulo": "Art. 90º.",
                                                                        "linha": 636,
                                                                        "caput": "Os crimes praticados a bordo de aeronave nacional, dentro do espaço aéreo correspondente ao território brasileiro, ou ao alto-mar, ou a bordo de aeronave estrangeira, dentro do espaço aéreo correspondente ao território nacional, serão processados e julgados pela justiça da comarca em cujo território se verificar o pouso após o crime, ou pela da comarca de onde houver partido a aeronave."
                                                                },
                                                                {
                                                                        "numero": "91º",
                                                                        "rotulo": "Art. 91º.",
                                                                        "linha": 639,
                                                                        "caput": "Quando incerta e não se determinar de acordo com as normas estabelecidas nos arts. 89 e 90, a competência se firmará pela prevenção."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": [
                                                {
                                                        "numero": "69º",
                                                        "rotulo": "Art. 69º.",
                                                        "linha": 474,
                                                        "caput": "Determinará a competência jurisdicional:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 476,
                                                                        "texto": "lugar da infração:"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 478,
                                                                        "texto": "domicílio ou residência do réu;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 480,
                                                                        "texto": "a natureza da infração;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 482,
                                                                        "texto": "a distribuição;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 484,
                                                                        "texto": "a conexão ou continência;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 486,
                                                                        "texto": "a prevenção;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 488,
                                                                        "texto": "a prerrogativa de função."
                                                                }
                                                        ]
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO VI",
                                        "linha": 641,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 645,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "92º",
                                                                        "rotulo": "Art. 92º.",
                                                                        "linha": 649,
                                                                        "caput": "Se a decisão sobre a existência da infração depender da solução de controvérsia, que o juiz repute séria e fundada, sobre o estado civil das pessoas, o curso da ação penal ficará suspenso até que no juízo cível seja a controvérsia dirimida por sentença passada em julgado, sem prejuízo, entretanto, da inquirição das testemunhas e de outras provas de natureza urgente.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 651,
                                                                                        "texto": "Se for o crime de ação pública, o Ministério Público, quando necessário, promoverá a ação civil ou prosseguirá na que tiver sido iniciada, com a citação dos interessados."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "93º",
                                                                        "rotulo": "Art. 93º.",
                                                                        "linha": 653,
                                                                        "caput": "Se o reconhecimento da existência da infração penal depender de decisão sobre questão diversa da prevista no artigo anterior, da competência do juízo cível, e se neste houver sido proposta ação para resolvê-la, o juiz criminal poderá, desde que essa questão seja de difícil solução e não verse sobre direito cuja prova a lei civil limite, suspender o curso do processo, após a inquirição das testemunhas e realização das outras provas de natureza urgente.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 655,
                                                                                        "texto": "O juiz marcará o prazo da suspensão, que poderá ser razoavelmente prorrogado, se a demora não for imputável à parte. Expirado o prazo, sem que o juiz cível tenha proferido decisão, o juiz criminal fará prosseguir o processo, retomando sua competência para resolver, de fato e de direito, toda a matéria da acusação ou da defesa."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 657,
                                                                                        "texto": "Do despacho que denegar a suspensão não caberá recurso."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 659,
                                                                                        "texto": "Suspenso o processo, e tratando-se de crime de ação pública, incumbirá ao Ministério Público intervir imediatamente na causa cível, para o fim de promover-lhe o rápido andamento."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "94º",
                                                                        "rotulo": "Art. 94º.",
                                                                        "linha": 661,
                                                                        "caput": "A suspensão do curso da ação penal, nos casos dos artigos anteriores, será decretada pelo juiz, de ofício ou a requerimento das partes."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 663,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "95º",
                                                                        "rotulo": "Art. 95º.",
                                                                        "linha": 667,
                                                                        "caput": "Poderão ser opostas as exceções de:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 669,
                                                                                        "texto": "suspeição;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 671,
                                                                                        "texto": "incompetência de juízo;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 673,
                                                                                        "texto": "litispendência;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 675,
                                                                                        "texto": "ilegitimidade de parte;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 677,
                                                                                        "texto": "coisa julgada."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "96º",
                                                                        "rotulo": "Art. 96º.",
                                                                        "linha": 679,
                                                                        "caput": "A argüição de suspeição precederá a qualquer outra, salvo quando fundada em motivo superveniente."
                                                                },
                                                                {
                                                                        "numero": "97º",
                                                                        "rotulo": "Art. 97º.",
                                                                        "linha": 681,
                                                                        "caput": "O juiz que espontaneamente afirmar suspeição deverá fazê-lo por escrito, declarando o motivo legal, e remeterá imediatamente o processo ao seu substituto, intimadas as partes."
                                                                },
                                                                {
                                                                        "numero": "98º",
                                                                        "rotulo": "Art. 98º.",
                                                                        "linha": 683,
                                                                        "caput": "Quando qualquer das partes pretender recusar o juiz, deverá fazê-lo em petição assinada por ela própria ou por procurador com poderes especiais, aduzindo as suas razões acompanhadas de prova documental ou do rol de testemunhas."
                                                                },
                                                                {
                                                                        "numero": "99º",
                                                                        "rotulo": "Art. 99º.",
                                                                        "linha": 685,
                                                                        "caput": "Se reconhecer a suspeição, o juiz sustará a marcha do processo, mandará juntar aos autos a petição do recusante com os documentos que a instruam, e por despacho se declarará suspeito, ordenando a remessa dos autos ao substituto."
                                                                },
                                                                {
                                                                        "numero": "100º",
                                                                        "rotulo": "Art. 100º.",
                                                                        "linha": 687,
                                                                        "caput": "Não aceitando a suspeição, o juiz mandará autuar em apartado a petição, dará sua resposta dentro em três dias, podendo instruí-la e oferecer testemunhas, e, em seguida, determinará sejam os autos da exceção remetidos, dentro em 24 vinte e quatro horas, ao juiz ou tribunal a quem competir o julgamento.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 689,
                                                                                        "texto": "Reconhecida, preliminarmente, a relevância da argüição, o juiz ou tribunal, com citação das partes, marcará dia e hora para a inquirição das testemunhas, seguindo-se o julgamento, independentemente de mais alegações."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 691,
                                                                                        "texto": "Se a suspeição for de manifesta improcedência, o juiz ou relator a rejeitará liminarmente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "101º",
                                                                        "rotulo": "Art. 101º.",
                                                                        "linha": 693,
                                                                        "caput": "Julgada procedente a suspeição, ficarão nulos os atos do processo principal, pagando o juiz as custas, no caso de erro inescusável; rejeitada, evidenciando-se a malícia do excipiente, a este será imposta a multa de duzentos mil-réis a dois contos de réis."
                                                                },
                                                                {
                                                                        "numero": "102º",
                                                                        "rotulo": "Art. 102º.",
                                                                        "linha": 695,
                                                                        "caput": "Quando a parte contrária reconhecer a procedência da argüição, poderá ser sustado, a seu requerimento, o processo principal, até que se julgue o incidente da suspeição."
                                                                },
                                                                {
                                                                        "numero": "103º",
                                                                        "rotulo": "Art. 103º.",
                                                                        "linha": 697,
                                                                        "caput": "No Supremo Tribunal Federal e nos Tribunais de Apelação, o juiz que se julgar suspeito deverá declará-lo nos autos e, se for revisor, passar o feito ao seu substituto na ordem da precedência, ou, se for relator, apresentar os autos em mesa para nova distribuição.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 699,
                                                                                        "texto": "Se não for relator nem revisor, o juiz que houver de dar-se por suspeito, deverá fazê-lo verbalmente, na sessão de julgamento, registrando-se na ata a declaração."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 701,
                                                                                        "texto": "Se o presidente do tribunal se der por suspeito, competirá ao seu substituto designar dia para o julgamento e presidi-lo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 703,
                                                                                        "texto": "Observar-se-á, quanto à argüição de suspeição pela parte, o disposto nos arts. 98 a 101, no que Ihe for aplicável, atendido, se o juiz a reconhecer, o que estabelece este artigo."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 705,
                                                                                        "texto": "A suspeição, não sendo reconhecida, será julgada pelo tribunal pleno, funcionando como relator o presidente."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 707,
                                                                                        "texto": "Se o recusado for o presidente do tribunal, o relator será o vice-presidente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "104º",
                                                                        "rotulo": "Art. 104º.",
                                                                        "linha": 709,
                                                                        "caput": "Se for argüida a suspeição do órgão do Ministério Público, o juiz, depois de ouvi-lo, decidirá, sem recurso, podendo antes admitir a produção de provas no prazo de três dias."
                                                                },
                                                                {
                                                                        "numero": "105º",
                                                                        "rotulo": "Art. 105º.",
                                                                        "linha": 711,
                                                                        "caput": "As partes poderão também argüir de suspeitos os peritos, os intérpretes e os serventuários ou funcionários de justiça, decidindo o juiz de plano e sem recurso, à vista da matéria alegada e prova imediata."
                                                                },
                                                                {
                                                                        "numero": "106º",
                                                                        "rotulo": "Art. 106º.",
                                                                        "linha": 713,
                                                                        "caput": "A suspeição dos jurados deverá ser argüida oralmente, decidindo de plano do presidente do Tribunal do Júri, que a rejeitará se, negada pelo recusado, não for imediatamente comprovada, o que tudo constará da ata."
                                                                },
                                                                {
                                                                        "numero": "107º",
                                                                        "rotulo": "Art. 107º.",
                                                                        "linha": 715,
                                                                        "caput": "Não se poderá opor suspeição às autoridades policiais nos atos do inquérito, mas deverão elas declarar-se suspeitas, quando ocorrer motivo legal."
                                                                },
                                                                {
                                                                        "numero": "108º",
                                                                        "rotulo": "Art. 108º.",
                                                                        "linha": 717,
                                                                        "caput": "A exceção de incompetência do juízo poderá ser oposta, verbalmente ou por escrito, no prazo de defesa.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 719,
                                                                                        "texto": "Se, ouvido o Ministério Público, for aceita a declinatória, o feito será remetido ao juízo competente, onde, ratificados os atos anteriores, o processo prosseguirá."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 721,
                                                                                        "texto": "Recusada a incompetência, o juiz continuará no feito, fazendo tomar por termo a declinatória, se formulada verbalmente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "109º",
                                                                        "rotulo": "Art. 109º.",
                                                                        "linha": 723,
                                                                        "caput": "Se em qualquer fase do processo o juiz reconhecer motivo que o torne incompetente, declará-lo-á nos autos, haja ou não alegação da parte, prosseguindo-se na forma do artigo anterior."
                                                                },
                                                                {
                                                                        "numero": "110º",
                                                                        "rotulo": "Art. 110º.",
                                                                        "linha": 725,
                                                                        "caput": "Nas exceções de litispendência, ilegitimidade de parte e coisa julgada, será observado, no que Ihes for aplicável, o disposto sobre a exceção de incompetência do juízo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 727,
                                                                                        "texto": "Se a parte houver de opor mais de uma dessas exceções, deverá fazê-lo numa só petição ou articulado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 729,
                                                                                        "texto": "A exceção de coisa julgada somente poderá ser oposta em relação ao fato principal, que tiver sido objeto da sentença."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "111º",
                                                                        "rotulo": "Art. 111º.",
                                                                        "linha": 731,
                                                                        "caput": "As exceções serão processadas em autos apartados e não suspenderão, em regra, o andamento da ação penal."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 733,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "112º",
                                                                        "rotulo": "Art. 112º.",
                                                                        "linha": 737,
                                                                        "caput": "O juiz, o órgão do Ministério Público, os serventuários ou funcionários de justiça e os peritos ou intérpretes abster-se-ão de servir no processo, quando houver incompatibilidade ou impedimento legal, que declararão nos autos. Se não se der a abstenção, a incompatibilidade ou impedimento poderá ser argüido pelas partes, seguindo-se o processo estabelecido para a exceção de suspeição."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IV",
                                                        "linha": 739,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "113º",
                                                                        "rotulo": "Art. 113º.",
                                                                        "linha": 743,
                                                                        "caput": "As questões atinentes à competência resolver-se-ão não só pela exceção própria, como também pelo conflito positivo ou negativo de jurisdição."
                                                                },
                                                                {
                                                                        "numero": "114º",
                                                                        "rotulo": "Art. 114º.",
                                                                        "linha": 745,
                                                                        "caput": "Haverá conflito de jurisdição:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 747,
                                                                                        "texto": "quando duas ou mais autoridades judiciárias se considerarem competentes, ou incompetentes, para conhecer do mesmo fato criminoso;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 749,
                                                                                        "texto": "quando entre elas surgir controvérsia sobre unidade de juízo, junção ou separação de processos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "115º",
                                                                        "rotulo": "Art. 115º.",
                                                                        "linha": 751,
                                                                        "caput": "O conflito poderá ser suscitado:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 753,
                                                                                        "texto": "pela parte interessada;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 755,
                                                                                        "texto": "pelos órgãos do Ministério Público junto a qualquer dos juízos em dissídio;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 757,
                                                                                        "texto": "por qualquer dos juízes ou tribunais em causa."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "116º",
                                                                        "rotulo": "Art. 116º.",
                                                                        "linha": 759,
                                                                        "caput": "Os juízes e tribunais, sob a forma de representação, e a parte interessada, sob a de requerimento, darão parte escrita e circunstanciada do conflito, perante o tribunal competente, expondo os fundamentos e juntando os documentos comprobatórios.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 761,
                                                                                        "texto": "Quando negativo o conflito, os juízes e tribunais poderão suscitá-lo nos próprios autos do processo."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 763,
                                                                                        "texto": "Distribuído o feito, se o conflito for positivo, o relator poderá determinar imediatamente que se suspenda o andamento do processo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 765,
                                                                                        "texto": "Expedida ou não a ordem de suspensão, o relator requisitará informações às autoridades em conflito, remetendo-lhes cópia do requerimento ou representação."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 767,
                                                                                        "texto": "As informações serão prestadas no prazo marcado pelo relator."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 769,
                                                                                        "texto": "Recebidas as informações, e depois de ouvido o procurador-geral, o conflito será decidido na primeira sessão, salvo se a instrução do feito depender de diligência."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 771,
                                                                                        "texto": "Proferida a decisão, as cópias necessárias serão remetidas, para a sua execução, às autoridades contra as quais tiver sido levantado o conflito ou que o houverem suscitado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "117º",
                                                                        "rotulo": "Art. 117º.",
                                                                        "linha": 773,
                                                                        "caput": "O Supremo Tribunal Federal, mediante avocatória, restabelecerá a sua jurisdição, sempre que exercida por qualquer dos juízes ou tribunais inferiores."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 775,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "118º",
                                                                        "rotulo": "Art. 118º.",
                                                                        "linha": 779,
                                                                        "caput": "Antes de transitar em julgado a sentença final, as coisas apreendidas não poderão ser restituídas enquanto interessarem ao processo."
                                                                },
                                                                {
                                                                        "numero": "119º",
                                                                        "rotulo": "Art. 119º.",
                                                                        "linha": 781,
                                                                        "caput": "As coisas a que se referem os arts. 74 e 100 do Código Penal não poderão ser restituídas, mesmo depois de transitar em julgado a sentença final, salvo se pertencerem ao lesado ou a terceiro de boa-fé."
                                                                },
                                                                {
                                                                        "numero": "120º",
                                                                        "rotulo": "Art. 120º.",
                                                                        "linha": 783,
                                                                        "caput": "A restituição, quando cabível, poderá ser ordenada pela autoridade policial ou juiz, mediante termo nos autos, desde que não exista dúvida quanto ao direito do reclamante.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 785,
                                                                                        "texto": "Se duvidoso esse direito, o pedido de restituição autuar-se-á em apartado, assinando-se ao requerente o prazo de 5 (cinco) dias para a prova. Em tal caso, só o juiz criminal poderá decidir o incidente."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 787,
                                                                                        "texto": "O incidente autuar-se-á também em apartado e só a autoridade judicial o resolverá, se as coisas forem apreendidas em poder de terceiro de boa-fé, que será intimado para alegar e provar o seu direito, em prazo igual e sucessivo ao do reclamante, tendo um e outro dois dias para arrazoar."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 789,
                                                                                        "texto": "Sobre o pedido de restituição será sempre ouvido o Ministério Público."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 791,
                                                                                        "texto": "Em caso de dúvida sobre quem seja o verdadeiro dono, o juiz remeterá as partes para o juízo cível, ordenando o depósito das coisas em mãos de depositário ou do próprio terceiro que as detinha, se for pessoa idônea."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 793,
                                                                                        "texto": "Tratando-se de coisas facilmente deterioráveis, serão avaliadas e levadas a leilão público, depositando-se o dinheiro apurado, ou entregues ao terceiro que as detinha, se este for pessoa idônea e assinar termo de responsabilidade."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "121º",
                                                                        "rotulo": "Art. 121º.",
                                                                        "linha": 795,
                                                                        "caput": "No caso de apreensão de coisa adquirida com os proventos da infração, aplica-se o disposto no art. 133 e seu parágrafo."
                                                                },
                                                                {
                                                                        "numero": "122º",
                                                                        "rotulo": "Art. 122º.",
                                                                        "linha": 799,
                                                                        "caput": "Sem prejuízo do disposto no art. 120, as coisas apreendidas serão alienadas nos termos do disposto no art. 133 deste Código."
                                                                },
                                                                {
                                                                        "numero": "123º",
                                                                        "rotulo": "Art. 123º.",
                                                                        "linha": 801,
                                                                        "caput": "Fora dos casos previstos nos artigos anteriores, se dentro no prazo de 90 dias, a contar da data em que transitar em julgado a sentença final, condenatória ou absolutória, os objetos apreendidos não forem reclamados ou não pertencerem ao réu, serão vendidos em leilão, depositando-se o saldo à disposição do juízo de ausentes."
                                                                },
                                                                {
                                                                        "numero": "124º",
                                                                        "rotulo": "Art. 124º.",
                                                                        "linha": 803,
                                                                        "caput": "Os instrumentos do crime, cuja perda em favor da União for decretada, e as coisas confiscadas, de acordo com o disposto no art. 100 do Código Penal, serão inutilizados ou recolhidos a museu criminal, se houver interesse na sua conservação."
                                                                },
                                                                {
                                                                        "numero": "124º-A",
                                                                        "rotulo": "Art. 124º-A.",
                                                                        "linha": 805,
                                                                        "caput": "Na hipótese de decretação de perdimento de obras de arte ou de outros bens de relevante valor cultural ou artístico, se o crime não tiver vítima determinada, poderá haver destinação dos bens a museus públicos."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 807,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "125º",
                                                                        "rotulo": "Art. 125º.",
                                                                        "linha": 811,
                                                                        "caput": "Caberá o seqüestro dos bens imóveis, adquiridos pelo indiciado com os proventos da infração, ainda que já tenham sido transferidos a terceiro."
                                                                },
                                                                {
                                                                        "numero": "126º",
                                                                        "rotulo": "Art. 126º.",
                                                                        "linha": 813,
                                                                        "caput": "Para a decretação do seqüestro, bastará a existência de indícios veementes da proveniência ilícita dos bens."
                                                                },
                                                                {
                                                                        "numero": "127º",
                                                                        "rotulo": "Art. 127º.",
                                                                        "linha": 815,
                                                                        "caput": "O juiz, de ofício, a requerimento do Ministério Público ou do ofendido, ou mediante representação da autoridade policial, poderá ordenar o seqüestro, em qualquer fase do processo ou ainda antes de oferecida a denúncia ou queixa."
                                                                },
                                                                {
                                                                        "numero": "128º",
                                                                        "rotulo": "Art. 128º.",
                                                                        "linha": 817,
                                                                        "caput": "Realizado o seqüestro, o juiz ordenará a sua inscrição no Registro de Imóveis."
                                                                },
                                                                {
                                                                        "numero": "129º",
                                                                        "rotulo": "Art. 129º.",
                                                                        "linha": 819,
                                                                        "caput": "O seqüestro autuar-se-á em apartado e admitirá embargos de terceiro."
                                                                },
                                                                {
                                                                        "numero": "130º",
                                                                        "rotulo": "Art. 130º.",
                                                                        "linha": 821,
                                                                        "caput": "O seqüestro poderá ainda ser embargado:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 823,
                                                                                        "texto": "pelo acusado, sob o fundamento de não terem os bens sido adquiridos com os proventos da infração;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 825,
                                                                                        "texto": "pelo terceiro, a quem houverem os bens sido transferidos a título oneroso, sob o fundamento de tê-los adquirido de boa-fé."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 827,
                                                                                        "texto": "Não poderá ser pronunciada decisão nesses embargos antes de passar em julgado a sentença condenatória."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "131º",
                                                                        "rotulo": "Art. 131º.",
                                                                        "linha": 829,
                                                                        "caput": "O seqüestro será levantado:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 831,
                                                                                        "texto": "se a ação penal não for intentada no prazo de sessenta dias, contado da data em que ficar concluída a diligência;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 833,
                                                                                        "texto": "se o terceiro, a quem tiverem sido transferidos os bens, prestar caução que assegure a aplicação do disposto no art. 74, II, b, segunda parte, do Código Penal;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 835,
                                                                                        "texto": "se for julgada extinta a punibilidade ou absolvido o réu, por sentença transitada em julgado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "132º",
                                                                        "rotulo": "Art. 132º.",
                                                                        "linha": 837,
                                                                        "caput": "Proceder-se-á ao seqüestro dos bens móveis se, verificadas as condições previstas no art. 126, não for cabível a medida regulada no Capítulo Xl do Título Vll deste Livro."
                                                                },
                                                                {
                                                                        "numero": "133º",
                                                                        "rotulo": "Art. 133º.",
                                                                        "linha": 841,
                                                                        "caput": "Transitada em julgado a sentença condenatória, o juiz, de ofício ou a requerimento do interessado ou do Ministério Público, determinará a avaliação e a venda dos bens em leilão público cujo perdimento tenha sido decretado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 843,
                                                                                        "texto": "Do dinheiro apurado, será recolhido aos cofres públicos o que não couber ao lesado ou a terceiro de boa-fé."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 845,
                                                                                        "texto": "O valor apurado deverá ser recolhido ao Fundo Penitenciário Nacional, exceto se houver previsão diversa em lei especial."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "133º-A",
                                                                        "rotulo": "Art. 133º-A.",
                                                                        "linha": 847,
                                                                        "caput": "O juiz poderá autorizar, constatado o interesse público, a utilização de bem sequestrado, apreendido ou sujeito a qualquer medida assecuratória pelos órgãos de segurança pública previstos no art. 144 da Constituição Federal, do sistema prisional, do sistema socioeducativo, da Força Nacional de Segurança Pública e do Instituto Geral de Perícia, para o desempenho de suas atividades.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 849,
                                                                                        "texto": "O órgão de segurança pública participante das ações de investigação ou repressão da infração penal que ensejou a constrição do bem terá prioridade na sua utilização."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 851,
                                                                                        "texto": "Fora das hipóteses anteriores, demonstrado o interesse público, o juiz poderá autorizar o uso do bem pelos demais órgãos públicos."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 853,
                                                                                        "texto": "Se o bem a que se refere o caput deste artigo for veículo, embarcação ou aeronave, o juiz ordenará à autoridade de trânsito ou ao órgão de registro e controle a expedição de certificado provisório de registro e licenciamento em favor do órgão público beneficiário, o qual estará isento do pagamento de multas, encargos e tributos anteriores à disponibilização do bem para a sua utilização, que deverão ser cobrados de seu responsável."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 855,
                                                                                        "texto": "Transitada em julgado a sentença penal condenatória com a decretação de perdimento dos bens, ressalvado o direito do lesado ou terceiro de boa-fé, o juiz poderá determinar a transferência definitiva da propriedade ao órgão público beneficiário ao qual foi custodiado o bem."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "134º",
                                                                        "rotulo": "Art. 134º.",
                                                                        "linha": 857,
                                                                        "caput": "A hipoteca legal sobre os imóveis do indiciado poderá ser requerida pelo ofendido em qualquer fase do processo, desde que haja certeza da infração e indícios suficientes da autoria."
                                                                },
                                                                {
                                                                        "numero": "135º",
                                                                        "rotulo": "Art. 135º.",
                                                                        "linha": 859,
                                                                        "caput": "Pedida a especialização mediante requerimento, em que a parte estimará o valor da responsabilidade civil, e designará e estimará o imóvel ou imóveis que terão de ficar especialmente hipotecados, o juiz mandará logo proceder ao arbitramento do valor da responsabilidade e à avaliação do imóvel ou imóveis.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 861,
                                                                                        "texto": "A petição será instruída com as provas ou indicação das provas em que se fundar a estimação da responsabilidade, com a relação dos imóveis que o responsável possuir, se outros tiver, além dos indicados no requerimento, e com os documentos comprobatórios do domínio."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 863,
                                                                                        "texto": "O arbitramento do valor da responsabilidade e a avaliação dos imóveis designados far-se-ão por perito nomeado pelo juiz, onde não houver avaliador judicial, sendo-lhe facultada a consulta dos autos do processo respectivo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 865,
                                                                                        "texto": "O juiz, ouvidas as partes no prazo de dois dias, que correrá em cartório, poderá corrigir o arbitramento do valor da responsabilidade, se Ihe parecer excessivo ou deficiente."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 867,
                                                                                        "texto": "O juiz autorizará somente a inscrição da hipoteca do imóvel ou imóveis necessários à garantia da responsabilidade."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 869,
                                                                                        "texto": "O valor da responsabilidade será liquidado definitivamente após a condenação, podendo ser requerido novo arbitramento se qualquer das partes não se conformar com o arbitramento anterior à sentença condenatória."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 871,
                                                                                        "texto": "Se o réu oferecer caução suficiente, em dinheiro ou em títulos de dívida pública, pelo valor de sua cotação em Bolsa, o juiz poderá deixar de mandar proceder à inscrição da hipoteca legal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "136º",
                                                                        "rotulo": "Art. 136º.",
                                                                        "linha": 874,
                                                                        "caput": "O arresto do imóvel poderá ser decretado de início, revogando-se, porém, se no prazo de 15 (quinze) dias não for promovido o processo de inscrição da hipoteca legal."
                                                                },
                                                                {
                                                                        "numero": "137º",
                                                                        "rotulo": "Art. 137º.",
                                                                        "linha": 877,
                                                                        "caput": "Se o responsável não possuir bens imóveis ou os possuir de valor insuficiente, poderão ser arrestados bens móveis suscetíveis de penhora, nos termos em que é facultada a hipoteca legal dos imóveis. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 879,
                                                                                        "texto": "Se esses bens forem coisas fungíveis e facilmente deterioráveis, proceder-se-á na forma do § 5o do art. 120."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 881,
                                                                                        "texto": "Das rendas dos bens móveis poderão ser fornecidos recursos arbitrados pelo juiz, para a manutenção do indiciado e de sua família."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "138º",
                                                                        "rotulo": "Art. 138º.",
                                                                        "linha": 884,
                                                                        "caput": "O processo de especialização da hipoteca e do arresto correrão em auto apartado. ."
                                                                },
                                                                {
                                                                        "numero": "139º",
                                                                        "rotulo": "Art. 139º.",
                                                                        "linha": 887,
                                                                        "caput": "O depósito e a administração dos bens arrestados ficarão sujeitos ao regime do processo civil. ."
                                                                },
                                                                {
                                                                        "numero": "140º",
                                                                        "rotulo": "Art. 140º.",
                                                                        "linha": 889,
                                                                        "caput": "As garantias do ressarcimento do dano alcançarão também as despesas processuais e as penas pecuniárias, tendo preferência sobre estas a reparação do dano ao ofendido."
                                                                },
                                                                {
                                                                        "numero": "141º",
                                                                        "rotulo": "Art. 141º.",
                                                                        "linha": 892,
                                                                        "caput": "O arresto será levantado ou cancelada a hipoteca, se, por sentença irrecorrível, o réu for absolvido ou julgada extinta a punibilidade. ."
                                                                },
                                                                {
                                                                        "numero": "142º",
                                                                        "rotulo": "Art. 142º.",
                                                                        "linha": 894,
                                                                        "caput": "Caberá ao Ministério Público promover as medidas estabelecidas nos arts. 134 e 137, se houver interesse da Fazenda Pública, ou se o ofendido for pobre e o requerer."
                                                                },
                                                                {
                                                                        "numero": "143º",
                                                                        "rotulo": "Art. 143º.",
                                                                        "linha": 897,
                                                                        "caput": "Passando em julgado a sentença condenatória, serão os autos de hipoteca ou arresto remetidos ao juiz do cível (art. 63). ."
                                                                },
                                                                {
                                                                        "numero": "144º",
                                                                        "rotulo": "Art. 144º.",
                                                                        "linha": 899,
                                                                        "caput": "Os interessados ou, nos casos do art. 142, o Ministério Público poderão requerer no juízo cível, contra o responsável civil, as medidas previstas nos arts. 134, 136 e 137."
                                                                },
                                                                {
                                                                        "numero": "144º-A",
                                                                        "rotulo": "Art. 144º-A.",
                                                                        "linha": 901,
                                                                        "caput": "O juiz determinará a alienação antecipada para preservação do valor dos bens sempre que estiverem sujeitos a qualquer grau de deterioração ou depreciação, ou quando houver dificuldade para sua manutenção.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 903,
                                                                                        "texto": "O leilão far-se-á preferencialmente por meio eletrônico."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 905,
                                                                                        "texto": "Os bens deverão ser vendidos pelo valor fixado na avaliação judicial ou por valor maior. Não alcançado o valor estipulado pela administração judicial, será realizado novo leilão, em até 10 (dez) dias contados da realização do primeiro, podendo os bens ser alienados por valor não inferior a 80% (oitenta por cento) do estipulado na avaliação judicial."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 907,
                                                                                        "texto": "O produto da alienação ficará depositado em conta vinculada ao juízo até a decisão final do processo, procedendo-se à sua conversão em renda para a União, Estado ou Distrito Federal, no caso de condenação, ou, no caso de absolvição, à sua devolução ao acusado."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 909,
                                                                                        "texto": "Quando a indisponibilidade recair sobre dinheiro, inclusive moeda estrangeira, títulos, valores mobiliários ou cheques emitidos como ordem de pagamento, o juízo determinará a conversão do numerário apreendido em moeda nacional corrente e o depósito das correspondentes quantias em conta judicial."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 911,
                                                                                        "texto": "No caso da alienação de veículos, embarcações ou aeronaves, o juiz ordenará à autoridade de trânsito ou ao equivalente órgão de registro e controle a expedição de certificado de registro e licenciamento em favor do arrematante, ficando este livre do pagamento de multas, encargos e tributos anteriores, sem prejuízo de execução fiscal em relação ao antigo proprietário."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 913,
                                                                                        "texto": "O valor dos títulos da dívida pública, das ações das sociedades e dos títulos de crédito negociáveis em bolsa será o da cotação oficial do dia, provada por certidão ou publicação no órgão oficial."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 915,
                                                                                        "texto": "(VETADO)."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VII",
                                                        "linha": 917,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "145º",
                                                                        "rotulo": "Art. 145º.",
                                                                        "linha": 921,
                                                                        "caput": "Argüida, por escrito, a falsidade de documento constante dos autos, o juiz observará o seguinte processo:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 923,
                                                                                        "texto": "mandará autuar em apartado a impugnação, e em seguida ouvirá a parte contrária, que, no prazo de 48 horas, oferecerá resposta;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 925,
                                                                                        "texto": "assinará o prazo de três dias, sucessivamente, a cada uma das partes, para prova de suas alegações;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 927,
                                                                                        "texto": "conclusos os autos, poderá ordenar as diligências que entender necessárias;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 929,
                                                                                        "texto": "se reconhecida a falsidade por decisão irrecorrível, mandará desentranhar o documento e remetê-lo, com os autos do processo incidente, ao Ministério Público."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "146º",
                                                                        "rotulo": "Art. 146º.",
                                                                        "linha": 931,
                                                                        "caput": "A argüição de falsidade, feita por procurador, exige poderes especiais."
                                                                },
                                                                {
                                                                        "numero": "147º",
                                                                        "rotulo": "Art. 147º.",
                                                                        "linha": 933,
                                                                        "caput": "O juiz poderá, de ofício, proceder à verificação da falsidade."
                                                                },
                                                                {
                                                                        "numero": "148º",
                                                                        "rotulo": "Art. 148º.",
                                                                        "linha": 935,
                                                                        "caput": "Qualquer que seja a decisão, não fará coisa julgada em prejuízo de ulterior processo penal ou civil."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VIII",
                                                        "linha": 937,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "149º",
                                                                        "rotulo": "Art. 149º.",
                                                                        "linha": 941,
                                                                        "caput": "Quando houver dúvida sobre a integridade mental do acusado, o juiz ordenará, de ofício ou a requerimento do Ministério Público, do defensor, do curador, do ascendente, descendente, irmão ou cônjuge do acusado, seja este submetido a exame médico-legal.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 943,
                                                                                        "texto": "O exame poderá ser ordenado ainda na fase do inquérito, mediante representação da autoridade policial ao juiz competente."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 945,
                                                                                        "texto": "O juiz nomeará curador ao acusado, quando determinar o exame, ficando suspenso o processo, se já iniciada a ação penal, salvo quanto às diligências que possam ser prejudicadas pelo adiamento."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "150º",
                                                                        "rotulo": "Art. 150º.",
                                                                        "linha": 947,
                                                                        "caput": "Para o efeito do exame, o acusado, se estiver preso, será internado em manicômio judiciário, onde houver, ou, se estiver solto, e o requererem os peritos, em estabelecimento adequado que o juiz designar.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 949,
                                                                                        "texto": "O exame não durará mais de quarenta e cinco dias, salvo se os peritos demonstrarem a necessidade de maior prazo."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 951,
                                                                                        "texto": "Se não houver prejuízo para a marcha do processo, o juiz poderá autorizar sejam os autos entregues aos peritos, para facilitar o exame."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "151º",
                                                                        "rotulo": "Art. 151º.",
                                                                        "linha": 953,
                                                                        "caput": "Se os peritos concluírem que o acusado era, ao tempo da infração, irresponsável nos termos do art. 22 do Código Penal, o processo prosseguirá, com a presença do curador."
                                                                },
                                                                {
                                                                        "numero": "152º",
                                                                        "rotulo": "Art. 152º.",
                                                                        "linha": 955,
                                                                        "caput": "Se se verificar que a doença mental sobreveio à infração o processo continuará suspenso até que o acusado se restabeleça, observado o § 2o do art. 149.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 957,
                                                                                        "texto": "O juiz poderá, nesse caso, ordenar a internação do acusado em manicômio judiciário ou em outro estabelecimento adequado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 959,
                                                                                        "texto": "O processo retomará o seu curso, desde que se restabeleça o acusado, ficando-lhe assegurada a faculdade de reinquirir as testemunhas que houverem prestado depoimento sem a sua presença."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "153º",
                                                                        "rotulo": "Art. 153º.",
                                                                        "linha": 961,
                                                                        "caput": "O incidente da insanidade mental processar-se-á em auto apartado, que só depois da apresentação do laudo, será apenso ao processo principal."
                                                                },
                                                                {
                                                                        "numero": "154º",
                                                                        "rotulo": "Art. 154º.",
                                                                        "linha": 963,
                                                                        "caput": "Se a insanidade mental sobrevier no curso da execução da pena, observar-se-á o disposto no art. 682."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO VII",
                                        "linha": 965,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 969,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "155º",
                                                                        "rotulo": "Art. 155º.",
                                                                        "linha": 974,
                                                                        "caput": "O juiz formará sua convicção pela livre apreciação da prova produzida em contraditório judicial, não podendo fundamentar sua decisão exclusivamente nos elementos informativos colhidos na investigação, ressalvadas as provas cautelares, não repetíveis e antecipadas.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 976,
                                                                                        "texto": "Somente quanto ao estado das pessoas serão observadas as restrições estabelecidas na lei civil."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "156º",
                                                                        "rotulo": "Art. 156º.",
                                                                        "linha": 979,
                                                                        "caput": "A prova da alegação incumbirá a quem a fizer, sendo, porém, facultado ao juiz de ofício:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 981,
                                                                                        "texto": "ordenar, mesmo antes de iniciada a ação penal, a produção antecipada de provas consideradas urgentes e relevantes, observando a necessidade, adequação e proporcionalidade da medida;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 983,
                                                                                        "texto": "determinar, no curso da instrução, ou antes de proferir sentença, a realização de diligências para dirimir dúvida sobre ponto relevante."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "157º",
                                                                        "rotulo": "Art. 157º.",
                                                                        "linha": 986,
                                                                        "caput": "São inadmissíveis, devendo ser desentranhadas do processo, as provas ilícitas, assim entendidas as obtidas em violação a normas constitucionais ou legais.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 988,
                                                                                        "texto": "São também inadmissíveis as provas derivadas das ilícitas, salvo quando não evidenciado o nexo de causalidade entre umas e outras, ou quando as derivadas puderem ser obtidas por uma fonte independente das primeiras."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 990,
                                                                                        "texto": "Considera-se fonte independente aquela que por si só, seguindo os trâmites típicos e de praxe, próprios da investigação ou instrução criminal, seria capaz de conduzir ao fato objeto da prova."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 992,
                                                                                        "texto": "Preclusa a decisão de desentranhamento da prova declarada inadmissível, esta será inutilizada por decisão judicial, facultado às partes acompanhar o incidente."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 994,
                                                                                        "texto": "(VETADO)"
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 996,
                                                                                        "texto": "O juiz que conhecer do conteúdo da prova declarada inadmissível não poderá proferir a sentença ou acórdão. (Vide ADI 6.300)"
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 998,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "158º",
                                                                        "rotulo": "Art. 158º.",
                                                                        "linha": 1005,
                                                                        "caput": "Quando a infração deixar vestígios, será indispensável o exame de corpo de delito, direto ou indireto, não podendo supri-lo a confissão do acusado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1007,
                                                                                        "texto": "Dar-se-á prioridade à realização do exame de corpo de delito quando se tratar de crime que envolva:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 1009,
                                                                                                        "texto": "violência doméstica e familiar contra mulher;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 1011,
                                                                                                        "texto": "violência contra criança, adolescente, idoso ou pessoa com deficiência."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "158º-A",
                                                                        "rotulo": "Art. 158º-A.",
                                                                        "linha": 1013,
                                                                        "caput": "Considera-se cadeia de custódia o conjunto de todos os procedimentos utilizados para manter e documentar a história cronológica do vestígio coletado em locais ou em vítimas de crimes, para rastrear sua posse e manuseio a partir de seu reconhecimento até o descarte.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1015,
                                                                                        "texto": "O início da cadeia de custódia dá-se com a preservação do local de crime ou com procedimentos policiais ou periciais nos quais seja detectada a existência de vestígio."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1017,
                                                                                        "texto": "O agente público que reconhecer um elemento como de potencial interesse para a produção da prova pericial fica responsável por sua preservação."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1019,
                                                                                        "texto": "Vestígio é todo objeto ou material bruto, visível ou latente, constatado ou recolhido, que se relaciona à infração penal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "158º-B",
                                                                        "rotulo": "Art. 158º-B.",
                                                                        "linha": 1021,
                                                                        "caput": "A cadeia de custódia compreende o rastreamento do vestígio nas seguintes etapas:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1023,
                                                                                        "texto": "reconhecimento: ato de distinguir um elemento como de potencial interesse para a produção da prova pericial;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1025,
                                                                                        "texto": "isolamento: ato de evitar que se altere o estado das coisas, devendo isolar e preservar o ambiente imediato, mediato e relacionado aos vestígios e local de crime;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1027,
                                                                                        "texto": "fixação: descrição detalhada do vestígio conforme se encontra no local de crime ou no corpo de delito, e a sua posição na área de exames, podendo ser ilustrada por fotografias, filmagens ou croqui, sendo indispensável a sua descrição no laudo pericial produzido pelo perito responsável pelo atendimento;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1029,
                                                                                        "texto": "coleta: ato de recolher o vestígio que será submetido à análise pericial, respeitando suas características e natureza;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 1031,
                                                                                        "texto": "acondicionamento: procedimento por meio do qual cada vestígio coletado é embalado de forma individualizada, de acordo com suas características físicas, químicas e biológicas, para posterior análise, com anotação da data, hora e nome de quem realizou a coleta e o acondicionamento;"
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 1033,
                                                                                        "texto": "transporte: ato de transferir o vestígio de um local para o outro, utilizando as condições adequadas (embalagens, veículos, temperatura, entre outras), de modo a garantir a manutenção de suas características originais, bem como o controle de sua posse;"
                                                                                },
                                                                                {
                                                                                        "numero": "VII",
                                                                                        "rotulo": "VII",
                                                                                        "linha": 1035,
                                                                                        "texto": "recebimento: ato formal de transferência da posse do vestígio, que deve ser documentado com, no mínimo, informações referentes ao número de procedimento e unidade de polícia judiciária relacionada, local de origem, nome de quem transportou o vestígio, código de rastreamento, natureza do exame, tipo do vestígio, protocolo, assinatura e identificação de quem o recebeu;"
                                                                                },
                                                                                {
                                                                                        "numero": "VIII",
                                                                                        "rotulo": "VIII",
                                                                                        "linha": 1037,
                                                                                        "texto": "processamento: exame pericial em si, manipulação do vestígio de acordo com a metodologia adequada às suas características biológicas, físicas e químicas, a fim de se obter o resultado desejado, que deverá ser formalizado em laudo produzido por perito;"
                                                                                },
                                                                                {
                                                                                        "numero": "IX",
                                                                                        "rotulo": "IX",
                                                                                        "linha": 1039,
                                                                                        "texto": "armazenamento: procedimento referente à guarda, em condições adequadas, do material a ser processado, guardado para realização de contraperícia, descartado ou transportado, com vinculação ao número do laudo correspondente;"
                                                                                },
                                                                                {
                                                                                        "numero": "X",
                                                                                        "rotulo": "X",
                                                                                        "linha": 1041,
                                                                                        "texto": "descarte: procedimento referente à liberação do vestígio, respeitando a legislação vigente e, quando pertinente, mediante autorização judicial."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "158º-C",
                                                                        "rotulo": "Art. 158º-C.",
                                                                        "linha": 1043,
                                                                        "caput": "A coleta dos vestígios deverá ser realizada preferencialmente por perito oficial, que dará o encaminhamento necessário para a central de custódia, mesmo quando for necessária a realização de exames complementares.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1045,
                                                                                        "texto": "Todos vestígios coletados no decurso do inquérito ou processo devem ser tratados como descrito nesta Lei, ficando órgão central de perícia oficial de natureza criminal responsável por detalhar a forma do seu cumprimento."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1047,
                                                                                        "texto": "É proibida a entrada em locais isolados bem como a remoção de quaisquer vestígios de locais de crime antes da liberação por parte do perito responsável, sendo tipificada como fraude processual a sua realização."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "158º-D",
                                                                        "rotulo": "Art. 158º-D.",
                                                                        "linha": 1049,
                                                                        "caput": "O recipiente para acondicionamento do vestígio será determinado pela natureza do material.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1051,
                                                                                        "texto": "Todos os recipientes deverão ser selados com lacres, com numeração individualizada, de forma a garantir a inviolabilidade e a idoneidade do vestígio durante o transporte."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1053,
                                                                                        "texto": "O recipiente deverá individualizar o vestígio, preservar suas características, impedir contaminação e vazamento, ter grau de resistência adequado e espaço para registro de informações sobre seu conteúdo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1055,
                                                                                        "texto": "O recipiente só poderá ser aberto pelo perito que vai proceder à análise e, motivadamente, por pessoa autorizada."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1057,
                                                                                        "texto": "Após cada rompimento de lacre, deve se fazer constar na ficha de acompanhamento de vestígio o nome e a matrícula do responsável, a data, o local, a finalidade, bem como as informações referentes ao novo lacre utilizado."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1059,
                                                                                        "texto": "O lacre rompido deverá ser acondicionado no interior do novo recipiente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "158º-E",
                                                                        "rotulo": "Art. 158º-E.",
                                                                        "linha": 1061,
                                                                        "caput": "Todos os Institutos de Criminalística deverão ter uma central de custódia destinada à guarda e controle dos vestígios, e sua gestão deve ser vinculada diretamente ao órgão central de perícia oficial de natureza criminal.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1063,
                                                                                        "texto": "Toda central de custódia deve possuir os serviços de protocolo, com local para conferência, recepção, devolução de materiais e documentos, possibilitando a seleção, a classificação e a distribuição de materiais, devendo ser um espaço seguro e apresentar condições ambientais que não interfiram nas características do vestígio."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1065,
                                                                                        "texto": "Na central de custódia, a entrada e a saída de vestígio deverão ser protocoladas, consignando-se informações sobre a ocorrência no inquérito que a eles se relacionam."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1067,
                                                                                        "texto": "Todas as pessoas que tiverem acesso ao vestígio armazenado deverão ser identificadas e deverão ser registradas a data e a hora do acesso."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1069,
                                                                                        "texto": "Por ocasião da tramitação do vestígio armazenado, todas as ações deverão ser registradas, consignando-se a identificação do responsável pela tramitação, a destinação, a data e horário da ação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "158º-F",
                                                                        "rotulo": "Art. 158º-F.",
                                                                        "linha": 1071,
                                                                        "caput": "Após a realização da perícia, o material deverá ser devolvido à central de custódia, devendo nela permanecer.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1073,
                                                                                        "texto": "Caso a central de custódia não possua espaço ou condições de armazenar determinado material, deverá a autoridade policial ou judiciária determinar as condições de depósito do referido material em local diverso, mediante requerimento do diretor do órgão central de perícia oficial de natureza criminal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "159º",
                                                                        "rotulo": "Art. 159º.",
                                                                        "linha": 1080,
                                                                        "caput": "O exame de corpo de delito e outras perícias serão realizados por perito oficial, portador de diploma de curso superior.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1082,
                                                                                        "texto": "Na falta de perito oficial, o exame será realizado por 2 (duas) pessoas idôneas, portadoras de diploma de curso superior preferencialmente na área específica, dentre as que tiverem habilitação técnica relacionada com a natureza do exame."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1084,
                                                                                        "texto": "Os peritos não oficiais prestarão o compromisso de bem e fielmente desempenhar o encargo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1086,
                                                                                        "texto": "Serão facultadas ao Ministério Público, ao assistente de acusação, ao ofendido, ao querelante e ao acusado a formulação de quesitos e indicação de assistente técnico."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1088,
                                                                                        "texto": "O assistente técnico atuará a partir de sua admissão pelo juiz e após a conclusão dos exames e elaboração do laudo pelos peritos oficiais, sendo as partes intimadas desta decisão."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1090,
                                                                                        "texto": "Durante o curso do processo judicial, é permitido às partes, quanto à perícia:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 1092,
                                                                                                        "texto": "requerer a oitiva dos peritos para esclarecerem a prova ou para responderem a quesitos, desde que o mandado de intimação e os quesitos ou questões a serem esclarecidas sejam encaminhados com antecedência mínima de 10 (dez) dias, podendo apresentar as respostas em laudo complementar;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 1094,
                                                                                                        "texto": "indicar assistentes técnicos que poderão apresentar pareceres em prazo a ser fixado pelo juiz ou ser inquiridos em audiência."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1096,
                                                                                        "texto": "Havendo requerimento das partes, o material probatório que serviu de base à perícia será disponibilizado no ambiente do órgão oficial, que manterá sempre sua guarda, e na presença de perito oficial, para exame pelos assistentes, salvo se for impossível a sua conservação."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 1098,
                                                                                        "texto": "Tratando-se de perícia complexa que abranja mais de uma área de conhecimento especializado, poder-se-á designar a atuação de mais de um perito oficial, e a parte indicar mais de um assistente técnico."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "160º",
                                                                        "rotulo": "Art. 160º.",
                                                                        "linha": 1102,
                                                                        "caput": "Os peritos elaborarão o laudo pericial, onde descreverão minuciosamente o que examinarem, e responderão aos quesitos formulados.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1104,
                                                                                        "texto": "O laudo pericial será elaborado no prazo máximo de 10 dias, podendo este prazo ser prorrogado, em casos excepcionais, a requerimento dos peritos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "161º",
                                                                        "rotulo": "Art. 161º.",
                                                                        "linha": 1106,
                                                                        "caput": "O exame de corpo de delito poderá ser feito em qualquer dia e a qualquer hora."
                                                                },
                                                                {
                                                                        "numero": "162º",
                                                                        "rotulo": "Art. 162º.",
                                                                        "linha": 1108,
                                                                        "caput": "A autópsia será feita pelo menos seis horas depois do óbito, salvo se os peritos, pela evidência dos sinais de morte, julgarem que possa ser feita antes daquele prazo, o que declararão no auto.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1110,
                                                                                        "texto": "Nos casos de morte violenta, bastará o simples exame externo do cadáver, quando não houver infração penal que apurar, ou quando as lesões externas permitirem precisar a causa da morte e não houver necessidade de exame interno para a verificação de alguma circunstância relevante."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "163º",
                                                                        "rotulo": "Art. 163º.",
                                                                        "linha": 1112,
                                                                        "caput": "Em caso de exumação para exame cadavérico, a autoridade providenciará para que, em dia e hora previamente marcados, se realize a diligência, da qual se lavrará auto circunstanciado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1114,
                                                                                        "texto": "O administrador de cemitério público ou particular indicará o lugar da sepultura, sob pena de desobediência. No caso de recusa ou de falta de quem indique a sepultura, ou de encontrar-se o cadáver em lugar não destinado a inumações, a autoridade procederá às pesquisas necessárias, o que tudo constará do auto."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "164º",
                                                                        "rotulo": "Art. 164º.",
                                                                        "linha": 1117,
                                                                        "caput": "Os cadáveres serão sempre fotografados na posição em que forem encontrados, bem como, na medida do possível, todas as lesões externas e vestígios deixados no local do crime."
                                                                },
                                                                {
                                                                        "numero": "165º",
                                                                        "rotulo": "Art. 165º.",
                                                                        "linha": 1119,
                                                                        "caput": "Para representar as lesões encontradas no cadáver, os peritos, quando possível, juntarão ao laudo do exame provas fotográficas, esquemas ou desenhos, devidamente rubricados."
                                                                },
                                                                {
                                                                        "numero": "166º",
                                                                        "rotulo": "Art. 166º.",
                                                                        "linha": 1121,
                                                                        "caput": "Havendo dúvida sobre a identidade do cadáver exumado, proceder-se-á ao reconhecimento pelo Instituto de Identificação e Estatística ou repartição congênere ou pela inquirição de testemunhas, lavrando-se auto de reconhecimento e de identidade, no qual se descreverá o cadáver, com todos os sinais e indicações.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1123,
                                                                                        "texto": "Em qualquer caso, serão arrecadados e autenticados todos os objetos encontrados, que possam ser úteis para a identificação do cadáver."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "167º",
                                                                        "rotulo": "Art. 167º.",
                                                                        "linha": 1125,
                                                                        "caput": "Não sendo possível o exame de corpo de delito, por haverem desaparecido os vestígios, a prova testemunhal poderá suprir-lhe a falta."
                                                                },
                                                                {
                                                                        "numero": "168º",
                                                                        "rotulo": "Art. 168º.",
                                                                        "linha": 1127,
                                                                        "caput": "Em caso de lesões corporais, se o primeiro exame pericial tiver sido incompleto, proceder-se-á a exame complementar por determinação da autoridade policial ou judiciária, de ofício, ou a requerimento do Ministério Público, do ofendido ou do acusado, ou de seu defensor.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1129,
                                                                                        "texto": "No exame complementar, os peritos terão presente o auto de corpo de delito, a fim de suprir-lhe a deficiência ou retificá-lo."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1131,
                                                                                        "texto": "Se o exame tiver por fim precisar a classificação do delito no art. 129, § 1o, I, do Código Penal, deverá ser feito logo que decorra o prazo de 30 dias, contado da data do crime."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1133,
                                                                                        "texto": "A falta de exame complementar poderá ser suprida pela prova testemunhal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "169º",
                                                                        "rotulo": "Art. 169º.",
                                                                        "linha": 1135,
                                                                        "caput": "Para o efeito de exame do local onde houver sido praticada a infração, a autoridade providenciará imediatamente para que não se altere o estado das coisas até a chegada dos peritos, que poderão instruir seus laudos com fotografias, desenhos ou esquemas elucidativos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1137,
                                                                                        "texto": "Os peritos registrarão, no laudo, as alterações do estado das coisas e discutirão, no relatório, as conseqüências dessas alterações na dinâmica dos fatos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "170º",
                                                                        "rotulo": "Art. 170º.",
                                                                        "linha": 1139,
                                                                        "caput": "Nas perícias de laboratório, os peritos guardarão material suficiente para a eventualidade de nova perícia. Sempre que conveniente, os laudos serão ilustrados com provas fotográficas, ou microfotográficas, desenhos ou esquemas."
                                                                },
                                                                {
                                                                        "numero": "171º",
                                                                        "rotulo": "Art. 171º.",
                                                                        "linha": 1141,
                                                                        "caput": "Nos crimes cometidos com destruição ou rompimento de obstáculo a subtração da coisa, ou por meio de escalada, os peritos, além de descrever os vestígios, indicarão com que instrumentos, por que meios e em que época presumem ter sido o fato praticado."
                                                                },
                                                                {
                                                                        "numero": "172º",
                                                                        "rotulo": "Art. 172º.",
                                                                        "linha": 1143,
                                                                        "caput": "Proceder-se-á, quando necessário, à avaliação de coisas destruídas, deterioradas ou que constituam produto do crime.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1145,
                                                                                        "texto": "Se impossível a avaliação direta, os peritos procederão à avaliação por meio dos elementos existentes nos autos e dos que resultarem de diligências."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "173º",
                                                                        "rotulo": "Art. 173º.",
                                                                        "linha": 1147,
                                                                        "caput": "No caso de incêndio, os peritos verificarão a causa e o lugar em que houver começado, o perigo que dele tiver resultado para a vida ou para o patrimônio alheio, a extensão do dano e o seu valor e as demais circunstâncias que interessarem à elucidação do fato."
                                                                },
                                                                {
                                                                        "numero": "174º",
                                                                        "rotulo": "Art. 174º.",
                                                                        "linha": 1149,
                                                                        "caput": "No exame para o reconhecimento de escritos, por comparação de letra, observar-se-á o seguinte:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1151,
                                                                                        "texto": "a pessoa a quem se atribua ou se possa atribuir o escrito será intimada para o ato, se for encontrada;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1153,
                                                                                        "texto": "para a comparação, poderão servir quaisquer documentos que a dita pessoa reconhecer ou já tiverem sido judicialmente reconhecidos como de seu punho, ou sobre cuja autenticidade não houver dúvida;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1155,
                                                                                        "texto": "a autoridade, quando necessário, requisitará, para o exame, os documentos que existirem em arquivos ou estabelecimentos públicos, ou nestes realizará a diligência, se daí não puderem ser retirados;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1157,
                                                                                        "texto": "quando não houver escritos para a comparação ou forem insuficientes os exibidos, a autoridade mandará que a pessoa escreva o que Ihe for ditado. Se estiver ausente a pessoa, mas em lugar certo, esta última diligência poderá ser feita por precatória, em que se consignarão as palavras que a pessoa será intimada a escrever."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "175º",
                                                                        "rotulo": "Art. 175º.",
                                                                        "linha": 1159,
                                                                        "caput": "Serão sujeitos a exame os instrumentos empregados para a prática da infração, a fim de se Ihes verificar a natureza e a eficiência."
                                                                },
                                                                {
                                                                        "numero": "176º",
                                                                        "rotulo": "Art. 176º.",
                                                                        "linha": 1161,
                                                                        "caput": "A autoridade e as partes poderão formular quesitos até o ato da diligência."
                                                                },
                                                                {
                                                                        "numero": "177º",
                                                                        "rotulo": "Art. 177º.",
                                                                        "linha": 1163,
                                                                        "caput": "No exame por precatória, a nomeação dos peritos far-se-á no juízo deprecado. Havendo, porém, no caso de ação privada, acordo das partes, essa nomeação poderá ser feita pelo juiz deprecante.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1165,
                                                                                        "texto": "Os quesitos do juiz e das partes serão transcritos na precatória."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "178º",
                                                                        "rotulo": "Art. 178º.",
                                                                        "linha": 1167,
                                                                        "caput": "No caso do art. 159, o exame será requisitado pela autoridade ao diretor da repartição, juntando-se ao processo o laudo assinado pelos peritos."
                                                                },
                                                                {
                                                                        "numero": "179º",
                                                                        "rotulo": "Art. 179º.",
                                                                        "linha": 1169,
                                                                        "caput": "No caso do § 1o do art. 159, o escrivão lavrará o auto respectivo, que será assinado pelos peritos e, se presente ao exame, também pela autoridade.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1171,
                                                                                        "texto": "No caso do art. 160, parágrafo único, o laudo, que poderá ser datilografado, será subscrito e rubricado em suas folhas por todos os peritos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "180º",
                                                                        "rotulo": "Art. 180º.",
                                                                        "linha": 1173,
                                                                        "caput": "Se houver divergência entre os peritos, serão consignadas no auto do exame as declarações e respostas de um e de outro, ou cada um redigirá separadamente o seu laudo, e a autoridade nomeará um terceiro; se este divergir de ambos, a autoridade poderá mandar proceder a novo exame por outros peritos."
                                                                },
                                                                {
                                                                        "numero": "181º",
                                                                        "rotulo": "Art. 181º.",
                                                                        "linha": 1176,
                                                                        "caput": "No caso de inobservância de formalidades, ou no caso de omissões, obscuridades ou contradições, a autoridade judiciária mandará suprir a formalidade, complementar ou esclarecer o laudo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1178,
                                                                                        "texto": "A autoridade poderá também ordenar que se proceda a novo exame, por outros peritos, se julgar conveniente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "182º",
                                                                        "rotulo": "Art. 182º.",
                                                                        "linha": 1180,
                                                                        "caput": "O juiz não ficará adstrito ao laudo, podendo aceitá-lo ou rejeitá-lo, no todo ou em parte."
                                                                },
                                                                {
                                                                        "numero": "183º",
                                                                        "rotulo": "Art. 183º.",
                                                                        "linha": 1182,
                                                                        "caput": "Nos crimes em que não couber ação pública, observar-se-á o disposto no art. 19."
                                                                },
                                                                {
                                                                        "numero": "184º",
                                                                        "rotulo": "Art. 184º.",
                                                                        "linha": 1184,
                                                                        "caput": "Salvo o caso de exame de corpo de delito, o juiz ou a autoridade policial negará a perícia requerida pelas partes, quando não for necessária ao esclarecimento da verdade."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 1186,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "185º",
                                                                        "rotulo": "Art. 185º.",
                                                                        "linha": 1191,
                                                                        "caput": "O acusado que comparecer perante a autoridade judiciária, no curso do processo penal, será qualificado e interrogado na presença de seu defensor, constituído ou nomeado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1194,
                                                                                        "texto": "O interrogatório do réu preso será realizado, em sala própria, no estabelecimento em que estiver recolhido, desde que estejam garantidas a segurança do juiz, do membro do Ministério Público e dos auxiliares bem como a presença do defensor e a publicidade do ato."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1197,
                                                                                        "texto": "Excepcionalmente, o juiz, por decisão fundamentada, de ofício ou a requerimento das partes, poderá realizar o interrogatório do réu preso por sistema de videoconferência ou outro recurso tecnológico de transmissão de sons e imagens em tempo real, desde que a medida seja necessária para atender a uma das seguintes finalidades:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 1199,
                                                                                                        "texto": "prevenir risco à segurança pública, quando exista fundada suspeita de que o preso integre organização criminosa ou de que, por outra razão, possa fugir durante o deslocamento;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 1201,
                                                                                                        "texto": "viabilizar a participação do réu no referido ato processual, quando haja relevante dificuldade para seu comparecimento em juízo, por enfermidade ou outra circunstância pessoal;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 1203,
                                                                                                        "texto": "impedir a influência do réu no ânimo de testemunha ou da vítima, desde que não seja possível colher o depoimento destas por videoconferência, nos termos do art. 217 deste Código;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 1205,
                                                                                                        "texto": "responder à gravíssima questão de ordem pública."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1207,
                                                                                        "texto": "Da decisão que determinar a realização de interrogatório por videoconferência, as partes serão intimadas com 10 (dez) dias de antecedência."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1209,
                                                                                        "texto": "Antes do interrogatório por videoconferência, o preso poderá acompanhar, pelo mesmo sistema tecnológico, a realização de todos os atos da audiência única de instrução e julgamento de que tratam os arts. 400, 411 e 531 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1211,
                                                                                        "texto": "Em qualquer modalidade de interrogatório, o juiz garantirá ao réu o direito de entrevista prévia e reservada com o seu defensor; se realizado por videoconferência, fica também garantido o acesso a canais telefônicos reservados para comunicação entre o defensor que esteja no presídio e o advogado presente na sala de audiência do Fórum, e entre este e o preso."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1213,
                                                                                        "texto": "A sala reservada no estabelecimento prisional para a realização de atos processuais por sistema de videoconferência será fiscalizada pelos corregedores e pelo juiz de cada causa, como também pelo Ministério Público e pela Ordem dos Advogados do Brasil."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 1215,
                                                                                        "texto": "Será requisitada a apresentação do réu preso em juízo nas hipóteses em que o interrogatório não se realizar na forma prevista nos §§ 1o e 2o deste artigo."
                                                                                },
                                                                                {
                                                                                        "numero": "8",
                                                                                        "rotulo": "§ 8",
                                                                                        "linha": 1217,
                                                                                        "texto": "Aplica-se o disposto nos §§ 2o, 3o, 4o e 5o deste artigo, no que couber, à realização de outros atos processuais que dependam da participação de pessoa que esteja presa, como acareação, reconhecimento de pessoas e coisas, e inquirição de testemunha ou tomada de declarações do ofendido."
                                                                                },
                                                                                {
                                                                                        "numero": "9",
                                                                                        "rotulo": "§ 9",
                                                                                        "linha": 1219,
                                                                                        "texto": "Na hipótese do § 8o deste artigo, fica garantido o acompanhamento do ato processual pelo acusado e seu defensor."
                                                                                },
                                                                                {
                                                                                        "numero": "10",
                                                                                        "rotulo": "§ 10",
                                                                                        "linha": 1221,
                                                                                        "texto": "Do interrogatório deverá constar a informação sobre a existência de filhos, respectivas idades e se possuem alguma deficiência e o nome e o contato de eventual responsável pelos cuidados dos filhos, indicado pela pessoa presa"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "186º",
                                                                        "rotulo": "Art. 186º.",
                                                                        "linha": 1224,
                                                                        "caput": "Depois de devidamente qualificado e cientificado do inteiro teor da acusação, o acusado será informado pelo juiz, antes de iniciar o interrogatório, do seu direito de permanecer calado e de não responder perguntas que lhe forem formuladas.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1226,
                                                                                        "texto": "O silêncio, que não importará em confissão, não poderá ser interpretado em prejuízo da defesa."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "187º",
                                                                        "rotulo": "Art. 187º.",
                                                                        "linha": 1229,
                                                                        "caput": "O interrogatório será constituído de duas partes: sobre a pessoa do acusado e sobre os fatos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1231,
                                                                                        "texto": "Na primeira parte o interrogando será perguntado sobre a residência, meios de vida ou profissão, oportunidades sociais, lugar onde exerce a sua atividade, vida pregressa, notadamente se foi preso ou processado alguma vez e, em caso afirmativo, qual o juízo do processo, se houve suspensão condicional ou condenação, qual a pena imposta, se a cumpriu e outros dados familiares e sociais."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1233,
                                                                                        "texto": "Na segunda parte será perguntado sobre:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 1235,
                                                                                                        "texto": "ser verdadeira a acusação que lhe é feita;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 1237,
                                                                                                        "texto": "não sendo verdadeira a acusação, se tem algum motivo particular a que atribuí-la, se conhece a pessoa ou pessoas a quem deva ser imputada a prática do crime, e quais sejam, e se com elas esteve antes da prática da infração ou depois dela;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 1239,
                                                                                                        "texto": "onde estava ao tempo em que foi cometida a infração e se teve notícia desta;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 1241,
                                                                                                        "texto": "as provas já apuradas;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 1243,
                                                                                                        "texto": "se conhece as vítimas e testemunhas já inquiridas ou por inquirir, e desde quando, e se tem o que alegar contra elas;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 1245,
                                                                                                        "texto": "se conhece o instrumento com que foi praticada a infração, ou qualquer objeto que com esta se relacione e tenha sido apreendido;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VII",
                                                                                                        "rotulo": "VII",
                                                                                                        "linha": 1247,
                                                                                                        "texto": "todos os demais fatos e pormenores que conduzam à elucidação dos antecedentes e circunstâncias da infração;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VIII",
                                                                                                        "rotulo": "VIII",
                                                                                                        "linha": 1249,
                                                                                                        "texto": "se tem algo mais a alegar em sua defesa."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "188º",
                                                                        "rotulo": "Art. 188º.",
                                                                        "linha": 1261,
                                                                        "caput": "Após proceder ao interrogatório, o juiz indagará das partes se restou algum fato para ser esclarecido, formulando as perguntas correspondentes se o entender pertinente e relevante."
                                                                },
                                                                {
                                                                        "numero": "189º",
                                                                        "rotulo": "Art. 189º.",
                                                                        "linha": 1264,
                                                                        "caput": "Se o interrogando negar a acusação, no todo ou em parte, poderá prestar esclarecimentos e indicar provas."
                                                                },
                                                                {
                                                                        "numero": "190º",
                                                                        "rotulo": "Art. 190º.",
                                                                        "linha": 1267,
                                                                        "caput": "Se confessar a autoria, será perguntado sobre os motivos e circunstâncias do fato e se outras pessoas concorreram para a infração, e quais sejam."
                                                                },
                                                                {
                                                                        "numero": "191º",
                                                                        "rotulo": "Art. 191º.",
                                                                        "linha": 1270,
                                                                        "caput": "Havendo mais de um acusado, serão interrogados separadamente."
                                                                },
                                                                {
                                                                        "numero": "192º",
                                                                        "rotulo": "Art. 192º.",
                                                                        "linha": 1277,
                                                                        "caput": "O interrogatório do mudo, do surdo ou do surdo-mudo será feito pela forma seguinte:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1279,
                                                                                        "texto": "ao surdo serão apresentadas por escrito as perguntas, que ele responderá oralmente;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1281,
                                                                                        "texto": "ao mudo as perguntas serão feitas oralmente, respondendo-as por escrito;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1283,
                                                                                        "texto": "ao surdo-mudo as perguntas serão formuladas por escrito e do mesmo modo dará as respostas."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1285,
                                                                                        "texto": "Caso o interrogando não saiba ler ou escrever, intervirá no ato, como intérprete e sob compromisso, pessoa habilitada a entendê-lo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "193º",
                                                                        "rotulo": "Art. 193º.",
                                                                        "linha": 1288,
                                                                        "caput": "Quando o interrogando não falar a língua nacional, o interrogatório será feito por meio de intérprete."
                                                                },
                                                                {
                                                                        "numero": "195º",
                                                                        "rotulo": "Art. 195º.",
                                                                        "linha": 1294,
                                                                        "caput": "Se o interrogado não souber escrever, não puder ou não quiser assinar, tal fato será consignado no termo."
                                                                },
                                                                {
                                                                        "numero": "196º",
                                                                        "rotulo": "Art. 196º.",
                                                                        "linha": 1297,
                                                                        "caput": "A todo tempo o juiz poderá proceder a novo interrogatório de ofício ou a pedido fundamentado de qualquer das partes."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IV",
                                                        "linha": 1299,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "197º",
                                                                        "rotulo": "Art. 197º.",
                                                                        "linha": 1303,
                                                                        "caput": "O valor da confissão se aferirá pelos critérios adotados para os outros elementos de prova, e para a sua apreciação o juiz deverá confrontá-la com as demais provas do processo, verificando se entre ela e estas existe compatibilidade ou concordância."
                                                                },
                                                                {
                                                                        "numero": "198º",
                                                                        "rotulo": "Art. 198º.",
                                                                        "linha": 1305,
                                                                        "caput": "O silêncio do acusado não importará confissão, mas poderá constituir elemento para a formação do convencimento do juiz."
                                                                },
                                                                {
                                                                        "numero": "199º",
                                                                        "rotulo": "Art. 199º.",
                                                                        "linha": 1307,
                                                                        "caput": "A confissão, quando feita fora do interrogatório, será tomada por termo nos autos, observado o disposto no art. 195."
                                                                },
                                                                {
                                                                        "numero": "200º",
                                                                        "rotulo": "Art. 200º.",
                                                                        "linha": 1309,
                                                                        "caput": "A confissão será divisível e retratável, sem prejuízo do livre convencimento do juiz, fundado no exame das provas em conjunto."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 1313,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "201º",
                                                                        "rotulo": "Art. 201º.",
                                                                        "linha": 1318,
                                                                        "caput": "Sempre que possível, o ofendido será qualificado e perguntado sobre as circunstâncias da infração, quem seja ou presuma ser o seu autor, as provas que possa indicar, tomando-se por termo as suas declarações.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1320,
                                                                                        "texto": "Se, intimado para esse fim, deixar de comparecer sem motivo justo, o ofendido poderá ser conduzido à presença da autoridade."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1322,
                                                                                        "texto": "O ofendido será comunicado dos atos processuais relativos ao ingresso e à saída do acusado da prisão, à designação de data para audiência e à sentença e respectivos acórdãos que a mantenham ou modifiquem."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1324,
                                                                                        "texto": "As comunicações ao ofendido deverão ser feitas no endereço por ele indicado, admitindo-se, por opção do ofendido, o uso de meio eletrônico."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1326,
                                                                                        "texto": "Antes do início da audiência e durante a sua realização, será reservado espaço separado para o ofendido."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1328,
                                                                                        "texto": "Se o juiz entender necessário, poderá encaminhar o ofendido para atendimento multidisciplinar, especialmente nas áreas psicossocial, de assistência jurídica e de saúde, a expensas do ofensor ou do Estado."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1330,
                                                                                        "texto": "O juiz tomará as providências necessárias à preservação da intimidade, vida privada, honra e imagem do ofendido, podendo, inclusive, determinar o segredo de justiça em relação aos dados, depoimentos e outras informações constantes dos autos a seu respeito para evitar sua exposição aos meios de comunicação."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 1332,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "202º",
                                                                        "rotulo": "Art. 202º.",
                                                                        "linha": 1336,
                                                                        "caput": "Toda pessoa poderá ser testemunha."
                                                                },
                                                                {
                                                                        "numero": "203º",
                                                                        "rotulo": "Art. 203º.",
                                                                        "linha": 1338,
                                                                        "caput": "A testemunha fará, sob palavra de honra, a promessa de dizer a verdade do que souber e Ihe for perguntado, devendo declarar seu nome, sua idade, seu estado e sua residência, sua profissão, lugar onde exerce sua atividade, se é parente, e em que grau, de alguma das partes, ou quais suas relações com qualquer delas, e relatar o que souber, explicando sempre as razões de sua ciência ou as circunstâncias pelas quais possa avaliar-se de sua credibilidade."
                                                                },
                                                                {
                                                                        "numero": "204º",
                                                                        "rotulo": "Art. 204º.",
                                                                        "linha": 1340,
                                                                        "caput": "O depoimento será prestado oralmente, não sendo permitido à testemunha trazê-lo por escrito.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1342,
                                                                                        "texto": "Não será vedada à testemunha, entretanto, breve consulta a apontamentos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "205º",
                                                                        "rotulo": "Art. 205º.",
                                                                        "linha": 1344,
                                                                        "caput": "Se ocorrer dúvida sobre a identidade da testemunha, o juiz procederá à verificação pelos meios ao seu alcance, podendo, entretanto, tomar-lhe o depoimento desde logo."
                                                                },
                                                                {
                                                                        "numero": "206º",
                                                                        "rotulo": "Art. 206º.",
                                                                        "linha": 1346,
                                                                        "caput": "A testemunha não poderá eximir-se da obrigação de depor. Poderão, entretanto, recusar-se a fazê-lo o ascendente ou descendente, o afim em linha reta, o cônjuge, ainda que desquitado, o irmão e o pai, a mãe, ou o filho adotivo do acusado, salvo quando não for possível, por outro modo, obter-se ou integrar-se a prova do fato e de suas circunstâncias."
                                                                },
                                                                {
                                                                        "numero": "207º",
                                                                        "rotulo": "Art. 207º.",
                                                                        "linha": 1348,
                                                                        "caput": "São proibidas de depor as pessoas que, em razão de função, ministério, ofício ou profissão, devam guardar segredo, salvo se, desobrigadas pela parte interessada, quiserem dar o seu testemunho."
                                                                },
                                                                {
                                                                        "numero": "208º",
                                                                        "rotulo": "Art. 208º.",
                                                                        "linha": 1350,
                                                                        "caput": "Não se deferirá o compromisso a que alude o art. 203 aos doentes e deficientes mentais e aos menores de 14 (quatorze) anos, nem às pessoas a que se refere o art. 206."
                                                                },
                                                                {
                                                                        "numero": "209º",
                                                                        "rotulo": "Art. 209º.",
                                                                        "linha": 1352,
                                                                        "caput": "O juiz, quando julgar necessário, poderá ouvir outras testemunhas, além das indicadas pelas partes.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1354,
                                                                                        "texto": "Se ao juiz parecer conveniente, serão ouvidas as pessoas a que as testemunhas se referirem."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1356,
                                                                                        "texto": "Não será computada como testemunha a pessoa que nada souber que interesse à decisão da causa."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "210º",
                                                                        "rotulo": "Art. 210º.",
                                                                        "linha": 1359,
                                                                        "caput": "As testemunhas serão inquiridas cada uma de per si, de modo que umas não saibam nem ouçam os depoimentos das outras, devendo o juiz adverti-las das penas cominadas ao falso testemunho.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1361,
                                                                                        "texto": "Antes do início da audiência e durante a sua realização, serão reservados espaços separados para a garantia da incomunicabilidade das testemunhas."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "211º",
                                                                        "rotulo": "Art. 211º.",
                                                                        "linha": 1363,
                                                                        "caput": "Se o juiz, ao pronunciar sentença final, reconhecer que alguma testemunha fez afirmação falsa, calou ou negou a verdade, remeterá cópia do depoimento à autoridade policial para a instauração de inquérito.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1365,
                                                                                        "texto": "Tendo o depoimento sido prestado em plenário de julgamento, o juiz, no caso de proferir decisão na audiência (art. 538, § 2o), o tribunal (art. 561), ou o conselho de sentença, após a votação dos quesitos, poderão fazer apresentar imediatamente a testemunha à autoridade policial."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "212º",
                                                                        "rotulo": "Art. 212º.",
                                                                        "linha": 1368,
                                                                        "caput": "As perguntas serão formuladas pelas partes diretamente à testemunha, não admitindo o juiz aquelas que puderem induzir a resposta, não tiverem relação com a causa ou importarem na repetição de outra já respondida.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1370,
                                                                                        "texto": "Sobre os pontos não esclarecidos, o juiz poderá complementar a inquirição."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "213º",
                                                                        "rotulo": "Art. 213º.",
                                                                        "linha": 1372,
                                                                        "caput": "O juiz não permitirá que a testemunha manifeste suas apreciações pessoais, salvo quando inseparáveis da narrativa do fato."
                                                                },
                                                                {
                                                                        "numero": "214º",
                                                                        "rotulo": "Art. 214º.",
                                                                        "linha": 1374,
                                                                        "caput": "Antes de iniciado o depoimento, as partes poderão contraditar a testemunha ou argüir circunstâncias ou defeitos, que a tornem suspeita de parcialidade, ou indigna de fé. O juiz fará consignar a contradita ou argüição e a resposta da testemunha, mas só excluirá a testemunha ou não Ihe deferirá compromisso nos casos previstos nos arts. 207 e 208."
                                                                },
                                                                {
                                                                        "numero": "215º",
                                                                        "rotulo": "Art. 215º.",
                                                                        "linha": 1376,
                                                                        "caput": "Na redação do depoimento, o juiz deverá cingir-se, tanto quanto possível, às expressões usadas pelas testemunhas, reproduzindo fielmente as suas frases."
                                                                },
                                                                {
                                                                        "numero": "216º",
                                                                        "rotulo": "Art. 216º.",
                                                                        "linha": 1378,
                                                                        "caput": "O depoimento da testemunha será reduzido a termo, assinado por ela, pelo juiz e pelas partes. Se a testemunha não souber assinar, ou não puder fazê-lo, pedirá a alguém que o faça por ela, depois de lido na presença de ambos."
                                                                },
                                                                {
                                                                        "numero": "217º",
                                                                        "rotulo": "Art. 217º.",
                                                                        "linha": 1381,
                                                                        "caput": "Se o juiz verificar que a presença do réu poderá causar humilhação, temor, ou sério constrangimento à testemunha ou ao ofendido, de modo que prejudique a verdade do depoimento, fará a inquirição por videoconferência e, somente na impossibilidade dessa forma, determinará a retirada do réu, prosseguindo na inquirição, com a presença do seu defensor.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1383,
                                                                                        "texto": "A adoção de qualquer das medidas previstas no caput deste artigo deverá constar do termo, assim como os motivos que a determinaram."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "218º",
                                                                        "rotulo": "Art. 218º.",
                                                                        "linha": 1385,
                                                                        "caput": "Se, regularmente intimada, a testemunha deixar de comparecer sem motivo justificado, o juiz poderá requisitar à autoridade policial a sua apresentação ou determinar seja conduzida por oficial de justiça, que poderá solicitar o auxílio da força pública."
                                                                },
                                                                {
                                                                        "numero": "219º",
                                                                        "rotulo": "Art. 219º.",
                                                                        "linha": 1388,
                                                                        "caput": "O juiz poderá aplicar à testemunha faltosa a multa prevista no art. 453, sem prejuízo do processo penal por crime de desobediência, e condená-la ao pagamento das custas da diligência."
                                                                },
                                                                {
                                                                        "numero": "220º",
                                                                        "rotulo": "Art. 220º.",
                                                                        "linha": 1390,
                                                                        "caput": "As pessoas impossibilitadas, por enfermidade ou por velhice, de comparecer para depor, serão inquiridas onde estiverem."
                                                                },
                                                                {
                                                                        "numero": "221º",
                                                                        "rotulo": "Art. 221º.",
                                                                        "linha": 1398,
                                                                        "caput": "O Presidente e o Vice-Presidente da República, os senadores e deputados federais, os ministros de Estado, os governadores de Estados e Territórios, os secretários de Estado, os prefeitos do Distrito Federal e dos Municípios, os deputados às Assembléias Legislativas Estaduais, os membros do Poder Judiciário, os ministros e juízes dos Tribunais de Contas da União, dos Estados, do Distrito Federal, bem como os do Tribunal Marítimo serão inquiridos em local, dia e hora previamente ajustados entre eles e o juiz.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1400,
                                                                                        "texto": "O Presidente e o Vice-Presidente da República, os presidentes do Senado Federal, da Câmara dos Deputados e do Supremo Tribunal Federal poderão optar pela prestação de depoimento por escrito, caso em que as perguntas, formuladas pelas partes e deferidas pelo juiz, Ihes serão transmitidas por ofício."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1402,
                                                                                        "texto": "Os militares deverão ser requisitados à autoridade superior."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1404,
                                                                                        "texto": "Aos funcionários públicos aplicar-se-á o disposto no art. 218, devendo, porém, a expedição do mandado ser imediatamente comunicada ao chefe da repartição em que servirem, com indicação do dia e da hora marcados."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "222º",
                                                                        "rotulo": "Art. 222º.",
                                                                        "linha": 1406,
                                                                        "caput": "A testemunha que morar fora da jurisdição do juiz será inquirida pelo juiz do lugar de sua residência, expedindo-se, para esse fim, carta precatória, com prazo razoável, intimadas as partes.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1408,
                                                                                        "texto": "A expedição da precatória não suspenderá a instrução criminal."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1410,
                                                                                        "texto": "Findo o prazo marcado, poderá realizar-se o julgamento, mas, a todo tempo, a precatória, uma vez devolvida, será junta aos autos."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1412,
                                                                                        "texto": "Na hipótese prevista no caput deste artigo, a oitiva de testemunha poderá ser realizada por meio de videoconferência ou outro recurso tecnológico de transmissão de sons e imagens em tempo real, permitida a presença do defensor e podendo ser realizada, inclusive, durante a realização da audiência de instrução e julgamento."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "222º-A",
                                                                        "rotulo": "Art. 222º-A.",
                                                                        "linha": 1414,
                                                                        "caput": "As cartas rogatórias só serão expedidas se demonstrada previamente a sua imprescindibilidade, arcando a parte requerente com os custos de envio.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1416,
                                                                                        "texto": "Aplica-se às cartas rogatórias o disposto nos §§ 1o e 2o do art. 222 deste Código."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "223º",
                                                                        "rotulo": "Art. 223º.",
                                                                        "linha": 1418,
                                                                        "caput": "Quando a testemunha não conhecer a língua nacional, será nomeado intérprete para traduzir as perguntas e respostas.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1420,
                                                                                        "texto": "Tratando-se de mudo, surdo ou surdo-mudo, proceder-se-á na conformidade do art. 192."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "224º",
                                                                        "rotulo": "Art. 224º.",
                                                                        "linha": 1422,
                                                                        "caput": "As testemunhas comunicarão ao juiz, dentro de um ano, qualquer mudança de residência, sujeitando-se, pela simples omissão, às penas do não-comparecimento."
                                                                },
                                                                {
                                                                        "numero": "225º",
                                                                        "rotulo": "Art. 225º.",
                                                                        "linha": 1424,
                                                                        "caput": "Se qualquer testemunha houver de ausentar-se, ou, por enfermidade ou por velhice, inspirar receio de que ao tempo da instrução criminal já não exista, o juiz poderá, de ofício ou a requerimento de qualquer das partes, tomar-lhe antecipadamente o depoimento."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VII",
                                                        "linha": 1426,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "226º",
                                                                        "rotulo": "Art. 226º.",
                                                                        "linha": 1430,
                                                                        "caput": "Quando houver necessidade de fazer-se o reconhecimento de pessoa, proceder-se-á pela seguinte forma:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1432,
                                                                                        "texto": "a pessoa que tiver de fazer o reconhecimento será convidada a descrever a pessoa que deva ser reconhecida; Il - a pessoa, cujo reconhecimento se pretender, será colocada, se possível, ao lado de outras que com ela tiverem qualquer semelhança, convidando-se quem tiver de fazer o reconhecimento a apontá-la;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1436,
                                                                                        "texto": "se houver razão para recear que a pessoa chamada para o reconhecimento, por efeito de intimidação ou outra influência, não diga a verdade em face da pessoa que deve ser reconhecida, a autoridade providenciará para que esta não veja aquela;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1438,
                                                                                        "texto": "do ato de reconhecimento lavrar-se-á auto pormenorizado, subscrito pela autoridade, pela pessoa chamada para proceder ao reconhecimento e por duas testemunhas presenciais."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1440,
                                                                                        "texto": "O disposto no no III deste artigo não terá aplicação na fase da instrução criminal ou em plenário de julgamento."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "227º",
                                                                        "rotulo": "Art. 227º.",
                                                                        "linha": 1442,
                                                                        "caput": "No reconhecimento de objeto, proceder-se-á com as cautelas estabelecidas no artigo anterior, no que for aplicável."
                                                                },
                                                                {
                                                                        "numero": "228º",
                                                                        "rotulo": "Art. 228º.",
                                                                        "linha": 1444,
                                                                        "caput": "Se várias forem as pessoas chamadas a efetuar o reconhecimento de pessoa ou de objeto, cada uma fará a prova em separado, evitando-se qualquer comunicação entre elas."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VIII",
                                                        "linha": 1446,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "229º",
                                                                        "rotulo": "Art. 229º.",
                                                                        "linha": 1450,
                                                                        "caput": "A acareação será admitida entre acusados, entre acusado e testemunha, entre testemunhas, entre acusado ou testemunha e a pessoa ofendida, e entre as pessoas ofendidas, sempre que divergirem, em suas declarações, sobre fatos ou circunstâncias relevantes.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1452,
                                                                                        "texto": "Os acareados serão reperguntados, para que expliquem os pontos de divergências, reduzindo-se a termo o ato de acareação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "230º",
                                                                        "rotulo": "Art. 230º.",
                                                                        "linha": 1454,
                                                                        "caput": "Se ausente alguma testemunha, cujas declarações divirjam das de outra, que esteja presente, a esta se darão a conhecer os pontos da divergência, consignando-se no auto o que explicar ou observar. Se subsistir a discordância, expedir-se-á precatória à autoridade do lugar onde resida a testemunha ausente, transcrevendo-se as declarações desta e as da testemunha presente, nos pontos em que divergirem, bem como o texto do referido auto, a fim de que se complete a diligência, ouvindo-se a testemunha ausente, pela mesma forma estabelecida para a testemunha presente. Esta diligência só se realizará quando não importe demora prejudicial ao processo e o juiz a entenda conveniente."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IX",
                                                        "linha": 1456,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "231º",
                                                                        "rotulo": "Art. 231º.",
                                                                        "linha": 1460,
                                                                        "caput": "Salvo os casos expressos em lei, as partes poderão apresentar documentos em qualquer fase do processo."
                                                                },
                                                                {
                                                                        "numero": "232º",
                                                                        "rotulo": "Art. 232º.",
                                                                        "linha": 1462,
                                                                        "caput": "Consideram-se documentos quaisquer escritos, instrumentos ou papéis, públicos ou particulares.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1464,
                                                                                        "texto": "À fotografia do documento, devidamente autenticada, se dará o mesmo valor do original."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "233º",
                                                                        "rotulo": "Art. 233º.",
                                                                        "linha": 1466,
                                                                        "caput": "As cartas particulares, interceptadas ou obtidas por meios criminosos, não serão admitidas em juízo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1468,
                                                                                        "texto": "As cartas poderão ser exibidas em juízo pelo respectivo destinatário, para a defesa de seu direito, ainda que não haja consentimento do signatário."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "234º",
                                                                        "rotulo": "Art. 234º.",
                                                                        "linha": 1470,
                                                                        "caput": "Se o juiz tiver notícia da existência de documento relativo a ponto relevante da acusação ou da defesa, providenciará, independentemente de requerimento de qualquer das partes, para sua juntada aos autos, se possível."
                                                                },
                                                                {
                                                                        "numero": "235º",
                                                                        "rotulo": "Art. 235º.",
                                                                        "linha": 1472,
                                                                        "caput": "A letra e firma dos documentos particulares serão submetidas a exame pericial, quando contestada a sua autenticidade."
                                                                },
                                                                {
                                                                        "numero": "236º",
                                                                        "rotulo": "Art. 236º.",
                                                                        "linha": 1474,
                                                                        "caput": "Os documentos em língua estrangeira, sem prejuízo de sua juntada imediata, serão, se necessário, traduzidos por tradutor público, ou, na falta, por pessoa idônea nomeada pela autoridade."
                                                                },
                                                                {
                                                                        "numero": "237º",
                                                                        "rotulo": "Art. 237º.",
                                                                        "linha": 1476,
                                                                        "caput": "As públicas-formas só terão valor quando conferidas com o original, em presença da autoridade."
                                                                },
                                                                {
                                                                        "numero": "238º",
                                                                        "rotulo": "Art. 238º.",
                                                                        "linha": 1478,
                                                                        "caput": "Os documentos originais, juntos a processo findo, quando não exista motivo relevante que justifique a sua conservação nos autos, poderão, mediante requerimento, e ouvido o Ministério Público, ser entregues à parte que os produziu, ficando traslado nos autos."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO X",
                                                        "linha": 1480,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "239º",
                                                                        "rotulo": "Art. 239º.",
                                                                        "linha": 1484,
                                                                        "caput": "Considera-se indício a circunstância conhecida e provada, que, tendo relação com o fato, autorize, por indução, concluir-se a existência de outra ou outras circunstâncias."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO XI",
                                                        "linha": 1486,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "240º",
                                                                        "rotulo": "Art. 240º.",
                                                                        "linha": 1490,
                                                                        "caput": "A busca será domiciliar ou pessoal.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1492,
                                                                                        "texto": "Proceder-se-á à busca domiciliar, quando fundadas razões a autorizarem, para:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 1494,
                                                                                                        "texto": "prender criminosos;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 1496,
                                                                                                        "texto": "apreender coisas achadas ou obtidas por meios criminosos;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 1498,
                                                                                                        "texto": "apreender instrumentos de falsificação ou de contrafação e objetos falsificados ou contrafeitos;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "d",
                                                                                                        "rotulo": "d)",
                                                                                                        "linha": 1500,
                                                                                                        "texto": "apreender armas e munições, instrumentos utilizados na prática de crime ou destinados a fim delituoso;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "e",
                                                                                                        "rotulo": "e)",
                                                                                                        "linha": 1502,
                                                                                                        "texto": "descobrir objetos necessários à prova de infração ou à defesa do réu;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "f",
                                                                                                        "rotulo": "f)",
                                                                                                        "linha": 1504,
                                                                                                        "texto": "apreender cartas, abertas ou não, destinadas ao acusado ou em seu poder, quando haja suspeita de que o conhecimento do seu conteúdo possa ser útil à elucidação do fato;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "g",
                                                                                                        "rotulo": "g)",
                                                                                                        "linha": 1506,
                                                                                                        "texto": "apreender pessoas vítimas de crimes;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "h",
                                                                                                        "rotulo": "h)",
                                                                                                        "linha": 1508,
                                                                                                        "texto": "colher qualquer elemento de convicção."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1510,
                                                                                        "texto": "Proceder-se-á à busca pessoal quando houver fundada suspeita de que alguém oculte consigo arma proibida ou objetos mencionados nas letras b a f e letra h do parágrafo anterior."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "241º",
                                                                        "rotulo": "Art. 241º.",
                                                                        "linha": 1512,
                                                                        "caput": "Quando a própria autoridade policial ou judiciária não a realizar pessoalmente, a busca domiciliar deverá ser precedida da expedição de mandado."
                                                                },
                                                                {
                                                                        "numero": "242º",
                                                                        "rotulo": "Art. 242º.",
                                                                        "linha": 1514,
                                                                        "caput": "A busca poderá ser determinada de ofício ou a requerimento de qualquer das partes."
                                                                },
                                                                {
                                                                        "numero": "243º",
                                                                        "rotulo": "Art. 243º.",
                                                                        "linha": 1516,
                                                                        "caput": "O mandado de busca deverá:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1518,
                                                                                        "texto": "indicar, o mais precisamente possível, a casa em que será realizada a diligência e o nome do respectivo proprietário ou morador; ou, no caso de busca pessoal, o nome da pessoa que terá de sofrê-la ou os sinais que a identifiquem;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1520,
                                                                                        "texto": "mencionar o motivo e os fins da diligência;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1522,
                                                                                        "texto": "ser subscrito pelo escrivão e assinado pela autoridade que o fizer expedir."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1524,
                                                                                        "texto": "Se houver ordem de prisão, constará do próprio texto do mandado de busca."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1526,
                                                                                        "texto": "Não será permitida a apreensão de documento em poder do defensor do acusado, salvo quando constituir elemento do corpo de delito."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "244º",
                                                                        "rotulo": "Art. 244º.",
                                                                        "linha": 1528,
                                                                        "caput": "A busca pessoal independerá de mandado, no caso de prisão ou quando houver fundada suspeita de que a pessoa esteja na posse de arma proibida ou de objetos ou papéis que constituam corpo de delito, ou quando a medida for determinada no curso de busca domiciliar."
                                                                },
                                                                {
                                                                        "numero": "245º",
                                                                        "rotulo": "Art. 245º.",
                                                                        "linha": 1530,
                                                                        "caput": "As buscas domiciliares serão executadas de dia, salvo se o morador consentir que se realizem à noite, e, antes de penetrarem na casa, os executores mostrarão e lerão o mandado ao morador, ou a quem o represente, intimando-o, em seguida, a abrir a porta.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1532,
                                                                                        "texto": "Se a própria autoridade der a busca, declarará previamente sua qualidade e o objeto da diligência."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1534,
                                                                                        "texto": "Em caso de desobediência, será arrombada a porta e forçada a entrada."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1536,
                                                                                        "texto": "Recalcitrando o morador, será permitido o emprego de força contra coisas existentes no interior da casa, para o descobrimento do que se procura."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1538,
                                                                                        "texto": "Observar-se-á o disposto nos §§ 2o e 3o, quando ausentes os moradores, devendo, neste caso, ser intimado a assistir à diligência qualquer vizinho, se houver e estiver presente."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1540,
                                                                                        "texto": "Se é determinada a pessoa ou coisa que se vai procurar, o morador será intimado a mostrá-la."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1542,
                                                                                        "texto": "Descoberta a pessoa ou coisa que se procura, será imediatamente apreendida e posta sob custódia da autoridade ou de seus agentes."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 1544,
                                                                                        "texto": "Finda a diligência, os executores lavrarão auto circunstanciado, assinando-o com duas testemunhas presenciais, sem prejuízo do disposto no § 4o."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "246º",
                                                                        "rotulo": "Art. 246º.",
                                                                        "linha": 1546,
                                                                        "caput": "Aplicar-se-á também o disposto no artigo anterior, quando se tiver de proceder a busca em compartimento habitado ou em aposento ocupado de habitação coletiva ou em compartimento não aberto ao público, onde alguém exercer profissão ou atividade."
                                                                },
                                                                {
                                                                        "numero": "247º",
                                                                        "rotulo": "Art. 247º.",
                                                                        "linha": 1548,
                                                                        "caput": "Não sendo encontrada a pessoa ou coisa procurada, os motivos da diligência serão comunicados a quem tiver sofrido a busca, se o requerer."
                                                                },
                                                                {
                                                                        "numero": "248º",
                                                                        "rotulo": "Art. 248º.",
                                                                        "linha": 1550,
                                                                        "caput": "Em casa habitada, a busca será feita de modo que não moleste os moradores mais do que o indispensável para o êxito da diligência."
                                                                },
                                                                {
                                                                        "numero": "249º",
                                                                        "rotulo": "Art. 249º.",
                                                                        "linha": 1552,
                                                                        "caput": "A busca em mulher será feita por outra mulher, se não importar retardamento ou prejuízo da diligência."
                                                                },
                                                                {
                                                                        "numero": "250º",
                                                                        "rotulo": "Art. 250º.",
                                                                        "linha": 1554,
                                                                        "caput": "A autoridade ou seus agentes poderão penetrar no território de jurisdição alheia, ainda que de outro Estado, quando, para o fim de apreensão, forem no seguimento de pessoa ou coisa, devendo apresentar-se à competente autoridade local, antes da diligência ou após, conforme a urgência desta.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1556,
                                                                                        "texto": "Entender-se-á que a autoridade ou seus agentes vão em seguimento da pessoa ou coisa, quando:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 1558,
                                                                                                        "texto": "tendo conhecimento direto de sua remoção ou transporte, a seguirem sem interrupção, embora depois a percam de vista;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 1560,
                                                                                                        "texto": "ainda que não a tenham avistado, mas sabendo, por informações fidedignas ou circunstâncias indiciárias, que está sendo removida ou transportada em determinada direção, forem ao seu encalço."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1562,
                                                                                        "texto": "Se as autoridades locais tiverem fundadas razões para duvidar da legitimidade das pessoas que, nas referidas diligências, entrarem pelos seus distritos, ou da legalidade dos mandados que apresentarem, poderão exigir as provas dessa legitimidade, mas de modo que não se frustre a diligência."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO VIII",
                                        "linha": 1564,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 1570,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "251º",
                                                                        "rotulo": "Art. 251º.",
                                                                        "linha": 1574,
                                                                        "caput": "Ao juiz incumbirá prover à regularidade do processo e manter a ordem no curso dos respectivos atos, podendo, para tal fim, requisitar a força pública."
                                                                },
                                                                {
                                                                        "numero": "252º",
                                                                        "rotulo": "Art. 252º.",
                                                                        "linha": 1576,
                                                                        "caput": "O juiz não poderá exercer jurisdição no processo em que:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1578,
                                                                                        "texto": "tiver funcionado seu cônjuge ou parente, consangüíneo ou afim, em linha reta ou colateral até o terceiro grau, inclusive, como defensor ou advogado, órgão do Ministério Público, autoridade policial, auxiliar da justiça ou perito;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1580,
                                                                                        "texto": "ele próprio houver desempenhado qualquer dessas funções ou servido como testemunha;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1582,
                                                                                        "texto": "tiver funcionado como juiz de outra instância, pronunciando-se, de fato ou de direito, sobre a questão;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1584,
                                                                                        "texto": "ele próprio ou seu cônjuge ou parente, consangüíneo ou afim em linha reta ou colateral até o terceiro grau, inclusive, for parte ou diretamente interessado no feito."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "253º",
                                                                        "rotulo": "Art. 253º.",
                                                                        "linha": 1586,
                                                                        "caput": "Nos juízos coletivos, não poderão servir no mesmo processo os juízes que forem entre si parentes, consangüíneos ou afins, em linha reta ou colateral até o terceiro grau, inclusive."
                                                                },
                                                                {
                                                                        "numero": "254º",
                                                                        "rotulo": "Art. 254º.",
                                                                        "linha": 1588,
                                                                        "caput": "O juiz dar-se-á por suspeito, e, se não o fizer, poderá ser recusado por qualquer das partes:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1590,
                                                                                        "texto": "se for amigo íntimo ou inimigo capital de qualquer deles;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1592,
                                                                                        "texto": "se ele, seu cônjuge, ascendente ou descendente, estiver respondendo a processo por fato análogo, sobre cujo caráter criminoso haja controvérsia;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1594,
                                                                                        "texto": "se ele, seu cônjuge, ou parente, consangüíneo, ou afim, até o terceiro grau, inclusive, sustentar demanda ou responder a processo que tenha de ser julgado por qualquer das partes;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1596,
                                                                                        "texto": "se tiver aconselhado qualquer das partes;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 1598,
                                                                                        "texto": "se for credor ou devedor, tutor ou curador, de qualquer das partes; Vl - se for sócio, acionista ou administrador de sociedade interessada no processo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "255º",
                                                                        "rotulo": "Art. 255º.",
                                                                        "linha": 1602,
                                                                        "caput": "O impedimento ou suspeição decorrente de parentesco por afinidade cessará pela dissolução do casamento que Ihe tiver dado causa, salvo sobrevindo descendentes; mas, ainda que dissolvido o casamento sem descendentes, não funcionará como juiz o sogro, o padrasto, o cunhado, o genro ou enteado de quem for parte no processo."
                                                                },
                                                                {
                                                                        "numero": "256º",
                                                                        "rotulo": "Art. 256º.",
                                                                        "linha": 1604,
                                                                        "caput": "A suspeição não poderá ser declarada nem reconhecida, quando a parte injuriar o juiz ou de propósito der motivo para criá-la."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 1606,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "257º",
                                                                        "rotulo": "Art. 257º.",
                                                                        "linha": 1611,
                                                                        "caput": "Ao Ministério Público cabe: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1613,
                                                                                        "texto": "promover, privativamente, a ação penal pública, na forma estabelecida neste Código; e ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1615,
                                                                                        "texto": "fiscalizar a execução da lei. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "258º",
                                                                        "rotulo": "Art. 258º.",
                                                                        "linha": 1617,
                                                                        "caput": "Os órgãos do Ministério Público não funcionarão nos processos em que o juiz ou qualquer das partes for seu cônjuge, ou parente, consangüíneo ou afim, em linha reta ou colateral, até o terceiro grau, inclusive, e a eles se estendem, no que Ihes for aplicável, as prescrições relativas à suspeição e aos impedimentos dos juízes."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 1619,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "259º",
                                                                        "rotulo": "Art. 259º.",
                                                                        "linha": 1623,
                                                                        "caput": "A impossibilidade de identificação do acusado com o seu verdadeiro nome ou outros qualificativos não retardará a ação penal, quando certa a identidade física. A qualquer tempo, no curso do processo, do julgamento ou da execução da sentença, se for descoberta a sua qualificação, far-se-á a retificação, por termo, nos autos, sem prejuízo da validade dos atos precedentes."
                                                                },
                                                                {
                                                                        "numero": "260º",
                                                                        "rotulo": "Art. 260º.",
                                                                        "linha": 1625,
                                                                        "caput": "Se o acusado não atender à intimação para o interrogatório, reconhecimento ou qualquer outro ato que, sem ele, não possa ser realizado, a autoridade poderá mandar conduzi-lo à sua presença.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1627,
                                                                                        "texto": "O mandado conterá, além da ordem de condução, os requisitos mencionados no art. 352, no que Ihe for aplicável."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "261º",
                                                                        "rotulo": "Art. 261º.",
                                                                        "linha": 1629,
                                                                        "caput": "Nenhum acusado, ainda que ausente ou foragido, será processado ou julgado sem defensor.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1631,
                                                                                        "texto": "A defesa técnica, quando realizada por defensor público ou dativo, será sempre exercida através de manifestação fundamentada."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "262º",
                                                                        "rotulo": "Art. 262º.",
                                                                        "linha": 1633,
                                                                        "caput": "Ao acusado menor dar-se-á curador."
                                                                },
                                                                {
                                                                        "numero": "263º",
                                                                        "rotulo": "Art. 263º.",
                                                                        "linha": 1635,
                                                                        "caput": "Se o acusado não o tiver, ser-lhe-á nomeado defensor pelo juiz, ressalvado o seu direito de, a todo tempo, nomear outro de sua confiança, ou a si mesmo defender-se, caso tenha habilitação.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1637,
                                                                                        "texto": "O acusado, que não for pobre, será obrigado a pagar os honorários do defensor dativo, arbitrados pelo juiz."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "264º",
                                                                        "rotulo": "Art. 264º.",
                                                                        "linha": 1639,
                                                                        "caput": "Salvo motivo relevante, os advogados e solicitadores serão obrigados, sob pena de multa de cem a quinhentos mil-réis, a prestar seu patrocínio aos acusados, quando nomeados pelo Juiz."
                                                                },
                                                                {
                                                                        "numero": "265º",
                                                                        "rotulo": "Art. 265º.",
                                                                        "linha": 1644,
                                                                        "caput": "O defensor não poderá abandonar o processo sem justo motivo, previamente comunicado ao juiz, sob pena de responder por infração disciplinar perante o órgão correicional competente.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1646,
                                                                                        "texto": "A audiência poderá ser adiada se, por motivo justificado, o defensor não puder comparecer. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1648,
                                                                                        "texto": "Incumbe ao defensor provar o impedimento até a abertura da audiência. Não o fazendo, o juiz não determinará o adiamento de ato algum do processo, devendo nomear defensor substituto, ainda que provisoriamente ou só para o efeito do ato. ."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1650,
                                                                                        "texto": "Em caso de abandono do processo pelo defensor, o acusado será intimado para constituir novo defensor, se assim o quiser, e, na hipótese de não ser localizado, deverá ser nomeado defensor público ou advogado dativo para a sua defesa."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "266º",
                                                                        "rotulo": "Art. 266º.",
                                                                        "linha": 1652,
                                                                        "caput": "A constituição de defensor independerá de instrumento de mandato, se o acusado o indicar por ocasião do interrogatório."
                                                                },
                                                                {
                                                                        "numero": "267º",
                                                                        "rotulo": "Art. 267º.",
                                                                        "linha": 1654,
                                                                        "caput": "Nos termos do art. 252, não funcionarão como defensores os parentes do juiz."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IV",
                                                        "linha": 1656,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "268º",
                                                                        "rotulo": "Art. 268º.",
                                                                        "linha": 1660,
                                                                        "caput": "Em todos os termos da ação pública, poderá intervir, como assistente do Ministério Público, o ofendido ou seu representante legal, ou, na falta, qualquer das pessoas mencionadas no Art. 31."
                                                                },
                                                                {
                                                                        "numero": "269º",
                                                                        "rotulo": "Art. 269º.",
                                                                        "linha": 1662,
                                                                        "caput": "O assistente será admitido enquanto não passar em julgado a sentença e receberá a causa no estado em que se achar."
                                                                },
                                                                {
                                                                        "numero": "270º",
                                                                        "rotulo": "Art. 270º.",
                                                                        "linha": 1664,
                                                                        "caput": "O co-réu no mesmo processo não poderá intervir como assistente do Ministério Público."
                                                                },
                                                                {
                                                                        "numero": "271º",
                                                                        "rotulo": "Art. 271º.",
                                                                        "linha": 1666,
                                                                        "caput": "Ao assistente será permitido propor meios de prova, requerer perguntas às testemunhas, aditar o libelo e os articulados, participar do debate oral e arrazoar os recursos interpostos pelo Ministério Público, ou por ele próprio, nos casos dos arts. 584, § 1º, e 598.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1668,
                                                                                        "texto": "O juiz, ouvido o Ministério Público, decidirá acerca da realização das provas propostas pelo assistente."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1670,
                                                                                        "texto": "O processo prosseguirá independentemente de nova intimação do assistente, quando este, intimado, deixar de comparecer a qualquer dos atos da instrução ou do julgamento, sem motivo de força maior devidamente comprovado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "272º",
                                                                        "rotulo": "Art. 272º.",
                                                                        "linha": 1672,
                                                                        "caput": "O Ministério Público será ouvido previamente sobre a admissão do assistente."
                                                                },
                                                                {
                                                                        "numero": "273º",
                                                                        "rotulo": "Art. 273º.",
                                                                        "linha": 1674,
                                                                        "caput": "Do despacho que admitir, ou não, o assistente, não caberá recurso, devendo, entretanto, constar dos autos o pedido e a decisão."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 1676,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "274º",
                                                                        "rotulo": "Art. 274º.",
                                                                        "linha": 1680,
                                                                        "caput": "As prescrições sobre suspeição dos juízes estendem-se aos serventuários e funcionários da justiça, no que Ihes for aplicável."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 1682,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "275º",
                                                                        "rotulo": "Art. 275º.",
                                                                        "linha": 1686,
                                                                        "caput": "O perito, ainda quando não oficial, estará sujeito à disciplina judiciária."
                                                                },
                                                                {
                                                                        "numero": "276º",
                                                                        "rotulo": "Art. 276º.",
                                                                        "linha": 1688,
                                                                        "caput": "As partes não intervirão na nomeação do perito."
                                                                },
                                                                {
                                                                        "numero": "277º",
                                                                        "rotulo": "Art. 277º.",
                                                                        "linha": 1690,
                                                                        "caput": "O perito nomeado pela autoridade será obrigado a aceitar o encargo, sob pena de multa de cem a quinhentos mil-réis, salvo escusa atendível.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1692,
                                                                                        "texto": "Incorrerá na mesma multa o perito que, sem justa causa, provada imediatamente:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 1694,
                                                                                                        "texto": "deixar de acudir à intimação ou ao chamado da autoridade;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 1696,
                                                                                                        "texto": "não comparecer no dia e local designados para o exame;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 1698,
                                                                                                        "texto": "não der o laudo, ou concorrer para que a perícia não seja feita, nos prazos estabelecidos."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "278º",
                                                                        "rotulo": "Art. 278º.",
                                                                        "linha": 1700,
                                                                        "caput": "No caso de não-comparecimento do perito, sem justa causa, a autoridade poderá determinar a sua condução."
                                                                },
                                                                {
                                                                        "numero": "279º",
                                                                        "rotulo": "Art. 279º.",
                                                                        "linha": 1702,
                                                                        "caput": "Não poderão ser peritos:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1704,
                                                                                        "texto": "os que estiverem sujeitos à interdição de direito mencionada nos ns. Ie IV do art. 69 do Código Penal;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1706,
                                                                                        "texto": "os que tiverem prestado depoimento no processo ou opinado anteriormente sobre o objeto da perícia;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1708,
                                                                                        "texto": "os analfabetos e os menores de 21 anos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "280º",
                                                                        "rotulo": "Art. 280º.",
                                                                        "linha": 1710,
                                                                        "caput": "É extensivo aos peritos, no que Ihes for aplicável, o disposto sobre suspeição dos juízes."
                                                                },
                                                                {
                                                                        "numero": "281º",
                                                                        "rotulo": "Art. 281º.",
                                                                        "linha": 1712,
                                                                        "caput": "Os intérpretes são, para todos os efeitos, equiparados aos peritos."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO IX",
                                        "linha": 1714,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 1720,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "282º",
                                                                        "rotulo": "Art. 282º.",
                                                                        "linha": 1725,
                                                                        "caput": "As medidas cautelares previstas neste Título deverão ser aplicadas observando-se a: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1727,
                                                                                        "texto": "necessidade para aplicação da lei penal, para a investigação ou a instrução criminal e, nos casos expressamente previstos, para evitar a prática de infrações penais; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1729,
                                                                                        "texto": "adequação da medida à gravidade do crime, circunstâncias do fato e condições pessoais do indiciado ou acusado. ."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1731,
                                                                                        "texto": "As medidas cautelares poderão ser aplicadas isolada ou cumulativamente. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1738,
                                                                                        "texto": "As medidas cautelares serão decretadas pelo juiz a requerimento das partes ou, quando no curso da investigação criminal, por representação da autoridade policial ou mediante requerimento do Ministério Público."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1740,
                                                                                        "texto": "Ressalvados os casos de urgência ou de perigo de ineficácia da medida, o juiz, ao receber o pedido de medida cautelar, determinará a intimação da parte contrária, para se manifestar no prazo de 5 (cinco) dias, acompanhada de cópia do requerimento e das peças necessárias, permanecendo os autos em juízo, e os casos de urgência ou de perigo deverão ser justificados e fundamentados em decisão que contenha elementos do caso concreto que justifiquem essa medida excepcional."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1742,
                                                                                        "texto": "No caso de descumprimento de qualquer das obrigações impostas, o juiz, mediante requerimento do Ministério Público, de seu assistente ou do querelante, poderá substituir a medida, impor outra em cumulação, ou, em último caso, decretar a prisão preventiva, nos termos do parágrafo único do art. 312 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1744,
                                                                                        "texto": "O juiz poderá, de ofício ou a pedido das partes, revogar a medida cautelar ou substituí-la quando verificar a falta de motivo para que subsista, bem como voltar a decretá-la, se sobrevierem razões que a justifiquem."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1746,
                                                                                        "texto": "A prisão preventiva somente será determinada quando não for cabível a sua substituição por outra medida cautelar, observado o art. 319 deste Código, e o não cabimento da substituição por outra medida cautelar deverá ser justificado de forma fundamentada nos elementos presentes do caso concreto, de forma individualizada."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "283º",
                                                                        "rotulo": "Art. 283º.",
                                                                        "linha": 1750,
                                                                        "caput": "Ninguém poderá ser preso senão em flagrante delito ou por ordem escrita e fundamentada da autoridade judiciária competente, em decorrência de prisão cautelar ou em virtude de condenação criminal transitada em julgado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1752,
                                                                                        "texto": "As medidas cautelares previstas neste Título não se aplicam à infração a que não for isolada, cumulativa ou alternativamente cominada pena privativa de liberdade. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1754,
                                                                                        "texto": "A prisão poderá ser efetuada em qualquer dia e a qualquer hora, respeitadas as restrições relativas à inviolabilidade do domicílio. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "284º",
                                                                        "rotulo": "Art. 284º.",
                                                                        "linha": 1756,
                                                                        "caput": "Não será permitido o emprego de força, salvo a indispensável no caso de resistência ou de tentativa de fuga do preso."
                                                                },
                                                                {
                                                                        "numero": "285º",
                                                                        "rotulo": "Art. 285º.",
                                                                        "linha": 1758,
                                                                        "caput": "A autoridade que ordenar a prisão fará expedir o respectivo mandado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1760,
                                                                                        "texto": "O mandado de prisão:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 1762,
                                                                                                        "texto": "será lavrado pelo escrivão e assinado pela autoridade;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 1764,
                                                                                                        "texto": "designará a pessoa, que tiver de ser presa, por seu nome, alcunha ou sinais característicos;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 1766,
                                                                                                        "texto": "mencionará a infração penal que motivar a prisão;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "d",
                                                                                                        "rotulo": "d)",
                                                                                                        "linha": 1768,
                                                                                                        "texto": "declarará o valor da fiança arbitrada, quando afiançável a infração;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "e",
                                                                                                        "rotulo": "e)",
                                                                                                        "linha": 1770,
                                                                                                        "texto": "será dirigido a quem tiver qualidade para dar-lhe execução."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "286º",
                                                                        "rotulo": "Art. 286º.",
                                                                        "linha": 1772,
                                                                        "caput": "O mandado será passado em duplicata, e o executor entregará ao preso, logo depois da prisão, um dos exemplares com declaração do dia, hora e lugar da diligência. Da entrega deverá o preso passar recibo no outro exemplar; se recusar, não souber ou não puder escrever, o fato será mencionado em declaração, assinada por duas testemunhas."
                                                                },
                                                                {
                                                                        "numero": "287º",
                                                                        "rotulo": "Art. 287º.",
                                                                        "linha": 1775,
                                                                        "caput": "Se a infração for inafiançável, a falta de exibição do mandado não obstará a prisão, e o preso, em tal caso, será imediatamente apresentado ao juiz que tiver expedido o mandado, para a realização de audiência de custódia."
                                                                },
                                                                {
                                                                        "numero": "288º",
                                                                        "rotulo": "Art. 288º.",
                                                                        "linha": 1777,
                                                                        "caput": "Ninguém será recolhido à prisão, sem que seja exibido o mandado ao respectivo diretor ou carcereiro, a quem será entregue cópia assinada pelo executor ou apresentada a guia expedida pela autoridade competente, devendo ser passado recibo da entrega do preso, com declaração de dia e hora.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1779,
                                                                                        "texto": "O recibo poderá ser passado no próprio exemplar do mandado, se este for o documento exibido."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "289º",
                                                                        "rotulo": "Art. 289º.",
                                                                        "linha": 1783,
                                                                        "caput": "Quando o acusado estiver no território nacional, fora da jurisdição do juiz processante, será deprecada a sua prisão, devendo constar da precatória o inteiro teor do mandado. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1785,
                                                                                        "texto": "Havendo urgência, o juiz poderá requisitar a prisão por qualquer meio de comunicação, do qual deverá constar o motivo da prisão, bem como o valor da fiança se arbitrada. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1787,
                                                                                        "texto": "A autoridade a quem se fizer a requisição tomará as precauções necessárias para averiguar a autenticidade da comunicação. ."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1789,
                                                                                        "texto": "O juiz processante deverá providenciar a remoção do preso no prazo máximo de 30 (trinta) dias, contados da efetivação da medida. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "289º-A",
                                                                        "rotulo": "Art. 289º-A.",
                                                                        "linha": 1791,
                                                                        "caput": "O juiz competente providenciará o imediato registro do mandado de prisão em banco de dados mantido pelo Conselho Nacional de Justiça para essa finalidade. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1793,
                                                                                        "texto": "Qualquer agente policial poderá efetuar a prisão determinada no mandado de prisão registrado no Conselho Nacional de Justiça, ainda que fora da competência territorial do juiz que o expediu. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1795,
                                                                                        "texto": "Qualquer agente policial poderá efetuar a prisão decretada, ainda que sem registro no Conselho Nacional de Justiça, adotando as precauções necessárias para averiguar a autenticidade do mandado e comunicando ao juiz que a decretou, devendo este providenciar, em seguida, o registro do mandado na forma do caputdeste artigo. ."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1797,
                                                                                        "texto": "A prisão será imediatamente comunicada ao juiz do local de cumprimento da medida o qual providenciará a certidão extraída do registro do Conselho Nacional de Justiça e informará ao juízo que a decretou. ."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1799,
                                                                                        "texto": "O preso será informado de seus direitos, nos termos do inciso LXIII do art. 5o da Constituição Federal e, caso o autuado não informe o nome de seu advogado, será comunicado à Defensoria Pública. ."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1801,
                                                                                        "texto": "Havendo dúvidas das autoridades locais sobre a legitimidade da pessoa do executor ou sobre a identidade do preso, aplica-se o disposto no § 2o do art. 290 deste Código. ."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1803,
                                                                                        "texto": "O Conselho Nacional de Justiça regulamentará o registro do mandado de prisão a que se refere o caputdeste artigo. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "290º",
                                                                        "rotulo": "Art. 290º.",
                                                                        "linha": 1805,
                                                                        "caput": "Se o réu, sendo perseguido, passar ao território de outro município ou comarca, o executor poderá efetuar-lhe a prisão no lugar onde o alcançar, apresentando-o imediatamente à autoridade local, que, depois de lavrado, se for o caso, o auto de flagrante, providenciará para a remoção do preso.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1807,
                                                                                        "texto": "- Entender-se-á que o executor vai em perseguição do réu, quando:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 1809,
                                                                                                        "texto": "tendo-o avistado, for perseguindo-o sem interrupção, embora depois o tenha perdido de vista;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 1811,
                                                                                                        "texto": "sabendo, por indícios ou informações fidedignas, que o réu tenha passado, há pouco tempo, em tal ou qual direção, pelo lugar em que o procure, for no seu encalço."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1813,
                                                                                        "texto": "Quando as autoridades locais tiverem fundadas razões para duvidar da legitimidade da pessoa do executor ou da legalidade do mandado que apresentar, poderão pôr em custódia o réu, até que fique esclarecida a dúvida."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "291º",
                                                                        "rotulo": "Art. 291º.",
                                                                        "linha": 1815,
                                                                        "caput": "A prisão em virtude de mandado entender-se-á feita desde que o executor, fazendo-se conhecer do réu, Ihe apresente o mandado e o intime a acompanhá-lo."
                                                                },
                                                                {
                                                                        "numero": "292º",
                                                                        "rotulo": "Art. 292º.",
                                                                        "linha": 1817,
                                                                        "caput": "Se houver, ainda que por parte de terceiros, resistência à prisão em flagrante ou à determinada por autoridade competente, o executor e as pessoas que o auxiliarem poderão usar dos meios necessários para defender-se ou para vencer a resistência, do que tudo se lavrará auto subscrito também por duas testemunhas.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1819,
                                                                                        "texto": "É vedado o uso de algemas em mulheres grávidas durante os atos médico-hospitalares preparatórios para a realização do parto e durante o trabalho de parto, bem como em mulheres durante o período de puerpério imediato."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "293º",
                                                                        "rotulo": "Art. 293º.",
                                                                        "linha": 1821,
                                                                        "caput": "Se o executor do mandado verificar, com segurança, que o réu entrou ou se encontra em alguma casa, o morador será intimado a entregá-lo, à vista da ordem de prisão. Se não for obedecido imediatamente, o executor convocará duas testemunhas e, sendo dia, entrará à força na casa, arrombando as portas, se preciso; sendo noite, o executor, depois da intimação ao morador, se não for atendido, fará guardar todas as saídas, tornando a casa incomunicável, e, logo que amanheça, arrombará as portas e efetuará a prisão.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1823,
                                                                                        "texto": "O morador que se recusar a entregar o réu oculto em sua casa será levado à presença da autoridade, para que se proceda contra ele como for de direito."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "294º",
                                                                        "rotulo": "Art. 294º.",
                                                                        "linha": 1825,
                                                                        "caput": "No caso de prisão em flagrante, observar-se-á o disposto no artigo anterior, no que for aplicável."
                                                                },
                                                                {
                                                                        "numero": "295º",
                                                                        "rotulo": "Art. 295º.",
                                                                        "linha": 1827,
                                                                        "caput": "Serão recolhidos a quartéis ou a prisão especial, à disposição da autoridade competente, quando sujeitos a prisão antes de condenação definitiva:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1829,
                                                                                        "texto": "os ministros de Estado;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1832,
                                                                                        "texto": "os governadores ou interventores de Estados ou Territórios, o prefeito do Distrito Federal, seus respectivos secretários, os prefeitos municipais, os vereadores e os chefes de Polícia;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1834,
                                                                                        "texto": "os membros do Parlamento Nacional, do Conselho de Economia Nacional e das Assembléias Legislativas dos Estados;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1836,
                                                                                        "texto": "os cidadãos inscritos no \"Livro de Mérito\";"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 1839,
                                                                                        "texto": "os oficiais das Forças Armadas e os militares dos Estados, do Distrito Federal e dos Territórios;"
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 1841,
                                                                                        "texto": "os magistrados;"
                                                                                },
                                                                                {
                                                                                        "numero": "VII",
                                                                                        "rotulo": "VII",
                                                                                        "linha": 1843,
                                                                                        "texto": "os diplomados por qualquer das faculdades superiores da República;"
                                                                                },
                                                                                {
                                                                                        "numero": "VIII",
                                                                                        "rotulo": "VIII",
                                                                                        "linha": 1845,
                                                                                        "texto": "os ministros de confissão religiosa;"
                                                                                },
                                                                                {
                                                                                        "numero": "IX",
                                                                                        "rotulo": "IX",
                                                                                        "linha": 1847,
                                                                                        "texto": "os ministros do Tribunal de Contas;"
                                                                                },
                                                                                {
                                                                                        "numero": "X",
                                                                                        "rotulo": "X",
                                                                                        "linha": 1849,
                                                                                        "texto": "os cidadãos que já tiverem exercido efetivamente a função de jurado, salvo quando excluídos da lista por motivo de incapacidade para o exercício daquela função;"
                                                                                },
                                                                                {
                                                                                        "numero": "XI",
                                                                                        "rotulo": "XI",
                                                                                        "linha": 1852,
                                                                                        "texto": "os delegados de polícia e os guardas-civis dos Estados e Territórios, ativos e inativos."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1854,
                                                                                        "texto": "A prisão especial, prevista neste Código ou em outras leis, consiste exclusivamente no recolhimento em local distinto da prisão comum."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1856,
                                                                                        "texto": "Não havendo estabelecimento específico para o preso especial, este será recolhido em cela distinta do mesmo estabelecimento."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1858,
                                                                                        "texto": "A cela especial poderá consistir em alojamento coletivo, atendidos os requisitos de salubridade do ambiente, pela concorrência dos fatores de aeração, insolação e condicionamento térmico adequados à existência humana."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1860,
                                                                                        "texto": "O preso especial não será transportado juntamente com o preso comum."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1862,
                                                                                        "texto": "Os demais direitos e deveres do preso especial serão os mesmos do preso comum."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "296º",
                                                                        "rotulo": "Art. 296º.",
                                                                        "linha": 1864,
                                                                        "caput": "Os inferiores e praças de pré, onde for possível, serão recolhidos à prisão, em estabelecimentos militares, de acordo com os respectivos regulamentos."
                                                                },
                                                                {
                                                                        "numero": "297º",
                                                                        "rotulo": "Art. 297º.",
                                                                        "linha": 1866,
                                                                        "caput": "Para o cumprimento de mandado expedido pela autoridade judiciária, a autoridade policial poderá expedir tantos outros quantos necessários às diligências, devendo neles ser fielmente reproduzido o teor do mandado original."
                                                                },
                                                                {
                                                                        "numero": "298º",
                                                                        "rotulo": "Art. 298º.",
                                                                        "linha": 1868,
                                                                        "caput": ""
                                                                },
                                                                {
                                                                        "numero": "299º",
                                                                        "rotulo": "Art. 299º.",
                                                                        "linha": 1871,
                                                                        "caput": "A captura poderá ser requisitada, à vista de mandado judicial, por qualquer meio de comunicação, tomadas pela autoridade, a quem se fizer a requisição, as precauções necessárias para averiguar a autenticidade desta. ."
                                                                },
                                                                {
                                                                        "numero": "300º",
                                                                        "rotulo": "Art. 300º.",
                                                                        "linha": 1874,
                                                                        "caput": "As pessoas presas provisoriamente ficarão separadas das que já estiverem definitivamente condenadas, nos termos da lei de execução penal. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 1876,
                                                                                        "texto": "O militar preso em flagrante delito, após a lavratura dos procedimentos legais, será recolhido a quartel da instituição a que pertencer, onde ficará preso à disposição das autoridades competentes. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "300º-A",
                                                                        "rotulo": "Art. 300º-A.",
                                                                        "linha": 1878,
                                                                        "caput": "O investigado por crimes contra a dignidade sexual, quando preso cautelarmente, e o condenado pelos mesmos crimes deverão ser submetidos obrigatoriamente à identificação do perfil genético, mediante extração de DNA (ácido desoxirribonucleico), por técnica adequada e indolor, por ocasião do ingresso no estabelecimento prisional."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 1880,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "301º",
                                                                        "rotulo": "Art. 301º.",
                                                                        "linha": 1884,
                                                                        "caput": "Qualquer do povo poderá e as autoridades policiais e seus agentes deverão prender quem quer que seja encontrado em flagrante delito."
                                                                },
                                                                {
                                                                        "numero": "302º",
                                                                        "rotulo": "Art. 302º.",
                                                                        "linha": 1886,
                                                                        "caput": "Considera-se em flagrante delito quem:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1888,
                                                                                        "texto": "está cometendo a infração penal;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1890,
                                                                                        "texto": "acaba de cometê-la;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1892,
                                                                                        "texto": "é perseguido, logo após, pela autoridade, pelo ofendido ou por qualquer pessoa, em situação que faça presumir ser autor da infração;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 1894,
                                                                                        "texto": "é encontrado, logo depois, com instrumentos, armas, objetos ou papéis que façam presumir ser ele autor da infração."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "303º",
                                                                        "rotulo": "Art. 303º.",
                                                                        "linha": 1896,
                                                                        "caput": "Nas infrações permanentes, entende-se o agente em flagrante delito enquanto não cessar a permanência."
                                                                },
                                                                {
                                                                        "numero": "304º",
                                                                        "rotulo": "Art. 304º.",
                                                                        "linha": 1899,
                                                                        "caput": "Apresentado o preso à autoridade competente, ouvirá esta o condutor e colherá, desde logo, sua assinatura, entregando a este cópia do termo e recibo de entrega do preso. Em seguida, procederá à oitiva das testemunhas que o acompanharem e ao interrogatório do acusado sobre a imputação que lhe é feita, colhendo, após cada oitiva suas respectivas assinaturas, lavrando, a autoridade, afinal, o auto.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1901,
                                                                                        "texto": "Resultando das respostas fundada a suspeita contra o conduzido, a autoridade mandará recolhê-lo à prisão, exceto no caso de livrar-se solto ou de prestar fiança, e prosseguirá nos atos do inquérito ou processo, se para isso for competente; se não o for, enviará os autos à autoridade que o seja."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1903,
                                                                                        "texto": "A falta de testemunhas da infração não impedirá o auto de prisão em flagrante; mas, nesse caso, com o condutor, deverão assiná-lo pelo menos duas pessoas que hajam testemunhado a apresentação do preso à autoridade."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1906,
                                                                                        "texto": "Quando o acusado se recusar a assinar, não souber ou não puder fazê-lo, o auto de prisão em flagrante será assinado por duas testemunhas, que tenham ouvido sua leitura na presença deste."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1908,
                                                                                        "texto": "Da lavratura do auto de prisão em flagrante deverá constar a informação sobre a existência de filhos, respectivas idades e se possuem alguma deficiência e o nome e o contato de eventual responsável pelos cuidados dos filhos, indicado pela pessoa presa."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "305º",
                                                                        "rotulo": "Art. 305º.",
                                                                        "linha": 1910,
                                                                        "caput": "Na falta ou no impedimento do escrivão, qualquer pessoa designada pela autoridade lavrará o auto, depois de prestado o compromisso legal."
                                                                },
                                                                {
                                                                        "numero": "306º",
                                                                        "rotulo": "Art. 306º.",
                                                                        "linha": 1917,
                                                                        "caput": "A prisão de qualquer pessoa e o local onde se encontre serão comunicados imediatamente ao juiz competente, ao Ministério Público e à família do preso ou à pessoa por ele indicada. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1919,
                                                                                        "texto": "Em até 24 (vinte e quatro) horas após a realização da prisão, será encaminhado ao juiz competente o auto de prisão em flagrante e, caso o autuado não informe o nome de seu advogado, cópia integral para a Defensoria Pública. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1921,
                                                                                        "texto": "No mesmo prazo, será entregue ao preso, mediante recibo, a nota de culpa, assinada pela autoridade, com o motivo da prisão, o nome do condutor e os das testemunhas. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "307º",
                                                                        "rotulo": "Art. 307º.",
                                                                        "linha": 1923,
                                                                        "caput": "Quando o fato for praticado em presença da autoridade, ou contra esta, no exercício de suas funções, constarão do auto a narração deste fato, a voz de prisão, as declarações que fizer o preso e os depoimentos das testemunhas, sendo tudo assinado pela autoridade, pelo preso e pelas testemunhas e remetido imediatamente ao juiz a quem couber tomar conhecimento do fato delituoso, se não o for a autoridade que houver presidido o auto."
                                                                },
                                                                {
                                                                        "numero": "308º",
                                                                        "rotulo": "Art. 308º.",
                                                                        "linha": 1925,
                                                                        "caput": "Não havendo autoridade no lugar em que se tiver efetuado a prisão, o preso será logo apresentado à do lugar mais próximo."
                                                                },
                                                                {
                                                                        "numero": "309º",
                                                                        "rotulo": "Art. 309º.",
                                                                        "linha": 1927,
                                                                        "caput": "Se o réu se livrar solto, deverá ser posto em liberdade, depois de lavrado o auto de prisão em flagrante."
                                                                },
                                                                {
                                                                        "numero": "310º",
                                                                        "rotulo": "Art. 310º.",
                                                                        "linha": 1933,
                                                                        "caput": "Após receber o auto de prisão em flagrante, no prazo máximo de até 24 (vinte e quatro) horas após a realização da prisão, o juiz deverá promover, por meio de videoconferência em tempo real, audiência de custódia com a presença do acusado, seu advogado constituído ou membro da Defensoria Pública e o membro do Ministério Público, e, nessa audiência, o juiz deverá, fundamentadamente:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 1935,
                                                                                        "texto": "relaxar a prisão ilegal; ou ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 1937,
                                                                                        "texto": "converter a prisão em flagrante em preventiva, quando presentes os requisitos constantes do art. 312 deste Código, e se revelarem inadequadas ou insuficientes as medidas cautelares diversas da prisão; ou ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 1939,
                                                                                        "texto": "conceder liberdade provisória, com ou sem fiança. ."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1942,
                                                                                        "texto": "Se o juiz verificar, pelo auto de prisão em flagrante, que o agente praticou o fato em qualquer das condições constantes dos incisos I, II ou III do caput do art. 23 do Decreto-Lei nº 2.848, de 7 de dezembro de 1940 (Código Penal), poderá, fundamentadamente, conceder ao acusado liberdade provisória, mediante termo de comparecimento obrigatório a todos os atos processuais, sob pena de revogação. (Renumerado do parágrafo único pela Lei nº 13.964, de 2019)"
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1944,
                                                                                        "texto": "Se o juiz verificar que o agente é reincidente ou que integra organização criminosa armada ou milícia, ou que porta arma de fogo de uso restrito, deverá denegar a liberdade provisória, com ou sem medidas cautelares."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 1946,
                                                                                        "texto": "A autoridade que deu causa, sem motivação idônea, à não realização da audiência de custódia no prazo estabelecido no caput deste artigo responderá administrativa, civil e penalmente pela omissão."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 1948,
                                                                                        "texto": "Transcorridas 24 (vinte e quatro) horas após o decurso do prazo estabelecido no caput deste artigo, a não realização de audiência de custódia sem motivação idônea ensejará também a ilegalidade da prisão, a ser relaxada pela autoridade competente, sem prejuízo da possibilidade de imediata decretação de prisão preventiva. (Vide ADI 6.300)"
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 1950,
                                                                                        "texto": "São circunstâncias que, sem prejuízo de outras, recomendam a conversão da prisão em flagrante em preventiva:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 1952,
                                                                                                        "texto": "haver provas que indiquem a prática reiterada de infrações penais pelo agente;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 1954,
                                                                                                        "texto": "ter a infração penal sido praticada com violência ou grave ameaça contra a pessoa;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 1956,
                                                                                                        "texto": "ter o agente já sido liberado em prévia audiência de custódia por outra infração penal, salvo se por ela tiver sido absolvido posteriormente;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 1958,
                                                                                                        "texto": "ter o agente praticado a infração penal na pendência de inquérito ou ação penal;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 1960,
                                                                                                        "texto": "ter havido fuga ou haver perigo de fuga; ou"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 1962,
                                                                                                        "texto": "haver perigo de perturbação da tramitação e do decurso do inquérito ou da instrução criminal, bem como perigo para a coleta, a conservação ou a incolumidade da prova."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 1964,
                                                                                        "texto": "A decisão de que trata o caput deste artigo deve ser motivada e fundamentada, sendo obrigatório o exame, pelo juiz, das circunstâncias previstas nos §§ 2º e 5º deste artigo e dos critérios de periculosidade previstos no § 3º do art. 312."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 1966,
                                                                                        "texto": "Antes do início da audiência de custódia, deverá a serventia judicial conferir os processos criminais a que responde o acusado e, constatada pendência de citação em qualquer deles, informar ao juiz, que certificará a ocorrência e procederá a citação pessoal do acusado, comunicando de imediato o juízo competente."
                                                                                },
                                                                                {
                                                                                        "numero": "8",
                                                                                        "rotulo": "§ 8",
                                                                                        "linha": 1968,
                                                                                        "texto": "Na audiência de custódia por videoconferência, serão facultados todos os mecanismos para intervenção da defesa técnica e do Ministério Público, que poderão suscitar questões de ordem."
                                                                                },
                                                                                {
                                                                                        "numero": "9",
                                                                                        "rotulo": "§ 9",
                                                                                        "linha": 1970,
                                                                                        "texto": "Será garantido o direito de entrevista prévia, reservada e inviolável entre o preso e o seu defensor, presencialmente, por videoconferência ou por qualquer outro meio de comunicação."
                                                                                },
                                                                                {
                                                                                        "numero": "10",
                                                                                        "rotulo": "§ 10",
                                                                                        "linha": 1972,
                                                                                        "texto": "Deverá ser assegurada privacidade ao preso na sala em que se realizar a videoconferência, devendo permanecer sozinho durante a realização de sua oitiva, ressalvada a possibilidade de presença física de seu defensor no ambiente."
                                                                                },
                                                                                {
                                                                                        "numero": "11",
                                                                                        "rotulo": "§ 11",
                                                                                        "linha": 1974,
                                                                                        "texto": "No caso de qualquer falha no sistema de comunicações cuja causa seja atribuível ao tribunal, por questões internas ou decorrente dos provedores de serviço que o tribunal tenha contratado, é obrigatória a repetição completa da audiência, sem convalescer qualquer ato incompleto."
                                                                                },
                                                                                {
                                                                                        "numero": "12",
                                                                                        "rotulo": "§ 12",
                                                                                        "linha": 1976,
                                                                                        "texto": "Todos os estabelecimentos prisionais terão salas próprias, com disponibilização de mecanismos de videoconferência estáveis, para a realização das audiências de custódia."
                                                                                },
                                                                                {
                                                                                        "numero": "13",
                                                                                        "rotulo": "§ 13",
                                                                                        "linha": 1978,
                                                                                        "texto": "Em situações excepcionais decorrentes de força maior, poderá a audiência de custódia ser realizada presencialmente, mediante decisão justificada do juiz competente, vedada a hipótese se o ato se revelar demasiadamente custoso ou trouxer excessivo risco à segurança social ou à segurança física do detido."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "310º-A",
                                                                        "rotulo": "Art. 310º-A.",
                                                                        "linha": 1980,
                                                                        "caput": "No caso de prisão em flagrante por crime praticado com violência ou grave ameaça contra a pessoa, por crime contra a dignidade sexual ou por crime praticado por agente em relação ao qual existam elementos probatórios que indiquem integrar organização criminosa que utilize ou tenha à sua disposição armas de fogo ou em relação ao qual seja imputada a prática de crime previsto no art. 1º da Lei nº 8.072, de 25 de julho de 1990 (Lei dos Crimes Hediondos), o Ministério Público ou a autoridade policial deverá requerer ao juiz a coleta de material biológico para obtenção e armazenamento do perfil genético do custodiado, na forma da Lei nº 12.037, de 1º de outubro de 2009.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 1982,
                                                                                        "texto": "A coleta de material biológico para a obtenção do perfil genético deverá ser feita, preferencialmente, na própria audiência de custódia ou no prazo de 10 (dez) dias, contado de sua realização."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 1984,
                                                                                        "texto": "A coleta de material biológico será realizada por agente público treinado e respeitará os procedimentos de cadeia de custódia definidos pela legislação em vigor e complementados pelo órgão de perícia oficial de natureza criminal."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 1986,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "311º",
                                                                        "rotulo": "Art. 311º.",
                                                                        "linha": 1993,
                                                                        "caput": "Em qualquer fase da investigação policial ou do processo penal, caberá a prisão preventiva decretada pelo juiz, a requerimento do Ministério Público, do querelante ou do assistente, ou por representação da autoridade policial."
                                                                },
                                                                {
                                                                        "numero": "312º",
                                                                        "rotulo": "Art. 312º.",
                                                                        "linha": 1999,
                                                                        "caput": "A prisão preventiva poderá ser decretada como garantia da ordem pública, da ordem econômica, por conveniência da instrução criminal ou para assegurar a aplicação da lei penal, quando houver prova da existência do crime e indício suficiente de autoria e de perigo gerado pelo estado de liberdade do imputado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2003,
                                                                                        "texto": "A prisão preventiva também poderá ser decretada em caso de descumprimento de qualquer das obrigações impostas por força de outras medidas cautelares (art. 282, § 4o)."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2005,
                                                                                        "texto": "A decisão que decretar a prisão preventiva deve ser motivada e fundamentada em receio de perigo e existência concreta de fatos novos ou contemporâneos que justifiquem a aplicação da medida adotada."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 2007,
                                                                                        "texto": "Devem ser considerados na aferição da periculosidade do agente, geradora de riscos à ordem pública:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 2009,
                                                                                                        "texto": "modus operandi, inclusive quanto ao uso reiterado de violência ou grave ameaça à pessoa ou quanto à premeditação do agente para a prática delituosa;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 2011,
                                                                                                        "texto": "a participação em organização criminosa;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 2013,
                                                                                                        "texto": "a natureza, a quantidade e a variedade de drogas, armas ou munições apreendidas; ou"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 2015,
                                                                                                        "texto": "fundado receio de reiteração delitiva, inclusive à vista da existência de outros inquéritos e ações penais em curso."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 2017,
                                                                                        "texto": "É incabível a decretação da prisão preventiva com base em alegações de gravidade abstrata do delito, devendo ser concretamente demonstrados a periculosidade do agente e seu risco à ordem pública, à ordem econômica, à regularidade da instrução criminal e à aplicação da lei penal, conforme o caso."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "313º",
                                                                        "rotulo": "Art. 313º.",
                                                                        "linha": 2032,
                                                                        "caput": "Nos termos do art. 312 deste Código, será admitida a decretação da prisão preventiva: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2034,
                                                                                        "texto": "nos crimes dolosos punidos com pena privativa de liberdade máxima superior a 4 (quatro) anos; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2036,
                                                                                        "texto": "se tiver sido condenado por outro crime doloso, em sentença transitada em julgado, ressalvado o disposto no inciso I do caput do art. 64 do Decreto-Lei no 2.848, de 7 de dezembro de 1940 - Código Penal;."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2038,
                                                                                        "texto": "se o crime envolver violência doméstica e familiar contra a mulher, criança, adolescente, idoso, enfermo ou pessoa com deficiência, para garantir a execução das medidas protetivas de urgência; ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2040,
                                                                                        "texto": "."
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2042,
                                                                                        "texto": "se o crime for cometido por integrante de organização criminosa ultraviolenta, grupo paramilitar ou milícia privada, no contexto da atuação ou para a consecução das condutas previstas no art. 2º da lei que institui o marco legal do combate ao crime organizado no Brasil."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2045,
                                                                                        "texto": "Também será admitida a prisão preventiva quando houver dúvida sobre a identidade civil da pessoa ou quando esta não fornecer elementos suficientes para esclarecê-la, devendo o preso ser colocado imediatamente em liberdade após a identificação, salvo se outra hipótese recomendar a manutenção da medida."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2047,
                                                                                        "texto": "Não será admitida a decretação da prisão preventiva com a finalidade de antecipação de cumprimento de pena ou como decorrência imediata de investigação criminal ou da apresentação ou recebimento de denúncia."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "314º",
                                                                        "rotulo": "Art. 314º.",
                                                                        "linha": 2051,
                                                                        "caput": "A prisão preventiva em nenhum caso será decretada se o juiz verificar pelas provas constantes dos autos ter o agente praticado o fato nas condições previstas nos incisos I, II e III do caput do art. 23 do Decreto-Lei no 2.848, de 7 de dezembro de 1940 - Código Penal. ."
                                                                },
                                                                {
                                                                        "numero": "315º",
                                                                        "rotulo": "Art. 315º.",
                                                                        "linha": 2056,
                                                                        "caput": "A decisão que decretar, substituir ou denegar a prisão preventiva será sempre motivada e fundamentada.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2058,
                                                                                        "texto": "Na motivação da decretação da prisão preventiva ou de qualquer outra cautelar, o juiz deverá indicar concretamente a existência de fatos novos ou contemporâneos que justifiquem a aplicação da medida adotada."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2060,
                                                                                        "texto": "Não se considera fundamentada qualquer decisão judicial, seja ela interlocutória, sentença ou acórdão, que:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 2062,
                                                                                                        "texto": "limitar-se à indicação, à reprodução ou à paráfrase de ato normativo, sem explicar sua relação com a causa ou a questão decidida;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 2064,
                                                                                                        "texto": "empregar conceitos jurídicos indeterminados, sem explicar o motivo concreto de sua incidência no caso;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 2066,
                                                                                                        "texto": "invocar motivos que se prestariam a justificar qualquer outra decisão;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 2068,
                                                                                                        "texto": "não enfrentar todos os argumentos deduzidos no processo capazes de, em tese, infirmar a conclusão adotada pelo julgador;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 2070,
                                                                                                        "texto": "limitar-se a invocar precedente ou enunciado de súmula, sem identificar seus fundamentos determinantes nem demonstrar que o caso sob julgamento se ajusta àqueles fundamentos;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 2072,
                                                                                                        "texto": "deixar de seguir enunciado de súmula, jurisprudência ou precedente invocado pela parte, sem demonstrar a existência de distinção no caso em julgamento ou a superação do entendimento."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "316º",
                                                                        "rotulo": "Art. 316º.",
                                                                        "linha": 2076,
                                                                        "caput": "O juiz poderá, de ofício ou a pedido das partes, revogar a prisão preventiva se, no correr da investigação ou do processo, verificar a falta de motivo para que ela subsista, bem como novamente decretá-la, se sobrevierem razões que a justifiquem.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2078,
                                                                                        "texto": "Decretada a prisão preventiva, deverá o órgão emissor da decisão revisar a necessidade de sua manutenção a cada 90 (noventa) dias, mediante decisão fundamentada, de ofício, sob pena de tornar a prisão ilegal."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IV",
                                                        "linha": 2080,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "317º",
                                                                        "rotulo": "Art. 317º.",
                                                                        "linha": 2087,
                                                                        "caput": "A prisão domiciliar consiste no recolhimento do indiciado ou acusado em sua residência, só podendo dela ausentar-se com autorização judicial. ."
                                                                },
                                                                {
                                                                        "numero": "318º",
                                                                        "rotulo": "Art. 318º.",
                                                                        "linha": 2090,
                                                                        "caput": "Poderá o juiz substituir a prisão preventiva pela domiciliar quando o agente for:.",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2092,
                                                                                        "texto": "maior de 80 (oitenta) anos; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2094,
                                                                                        "texto": "extremamente debilitado por motivo de doença grave; ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2096,
                                                                                        "texto": "imprescindível aos cuidados especiais de pessoa menor de 6 (seis) anos de idade ou com deficiência; ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2099,
                                                                                        "texto": "gestante;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2101,
                                                                                        "texto": "mulher com filho de até 12 (doze) anos de idade incompletos;"
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 2103,
                                                                                        "texto": "homem, caso seja o único responsável pelos cuidados do filho de até 12 (doze) anos de idade incompletos."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2105,
                                                                                        "texto": "Para a substituição, o juiz exigirá prova idônea dos requisitos estabelecidos neste artigo. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "318º-A",
                                                                        "rotulo": "Art. 318º-A.",
                                                                        "linha": 2107,
                                                                        "caput": "A prisão preventiva imposta à mulher gestante ou que for mãe ou responsável por crianças ou pessoas com deficiência será substituída por prisão domiciliar, desde que: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2109,
                                                                                        "texto": "não tenha cometido crime com violência ou grave ameaça a pessoa; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2111,
                                                                                        "texto": "não tenha cometido o crime contra seu filho ou dependente. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "318º-B",
                                                                        "rotulo": "Art. 318º-B.",
                                                                        "linha": 2113,
                                                                        "caput": "A substituição de que tratam os arts. 318 e 318-A poderá ser efetuada sem prejuízo da aplicação concomitante das medidas alternativas previstas no art. 319 deste Código. ."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 2115,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "319º",
                                                                        "rotulo": "Art. 319º.",
                                                                        "linha": 2128,
                                                                        "caput": "São medidas cautelares diversas da prisão: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2130,
                                                                                        "texto": "comparecimento periódico em juízo, no prazo e nas condições fixadas pelo juiz, para informar e justificar atividades; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2132,
                                                                                        "texto": "proibição de acesso ou frequência a determinados lugares quando, por circunstâncias relacionadas ao fato, deva o indiciado ou acusado permanecer distante desses locais para evitar o risco de novas infrações; ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2134,
                                                                                        "texto": "proibição de manter contato com pessoa determinada quando, por circunstâncias relacionadas ao fato, deva o indiciado ou acusado dela permanecer distante; ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2136,
                                                                                        "texto": "proibição de ausentar-se da Comarca quando a permanência seja conveniente ou necessária para a investigação ou instrução; ."
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2138,
                                                                                        "texto": "recolhimento domiciliar no período noturno e nos dias de folga quando o investigado ou acusado tenha residência e trabalho fixos; ."
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 2140,
                                                                                        "texto": "suspensão do exercício de função pública ou de atividade de natureza econômica ou financeira quando houver justo receio de sua utilização para a prática de infrações penais; ."
                                                                                },
                                                                                {
                                                                                        "numero": "VII",
                                                                                        "rotulo": "VII",
                                                                                        "linha": 2142,
                                                                                        "texto": "internação provisória do acusado nas hipóteses de crimes praticados com violência ou grave ameaça, quando os peritos concluírem ser inimputável ou semi-imputável (art. 26 do Código Penal) e houver risco de reiteração; ."
                                                                                },
                                                                                {
                                                                                        "numero": "VIII",
                                                                                        "rotulo": "VIII",
                                                                                        "linha": 2144,
                                                                                        "texto": "fiança, nas infrações que a admitem, para assegurar o comparecimento a atos do processo, evitar a obstrução do seu andamento ou em caso de resistência injustificada à ordem judicial; ."
                                                                                },
                                                                                {
                                                                                        "numero": "IX",
                                                                                        "rotulo": "IX",
                                                                                        "linha": 2146,
                                                                                        "texto": "monitoração eletrônica. ."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2148,
                                                                                        "texto": "."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2150,
                                                                                        "texto": "."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 2152,
                                                                                        "texto": "."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 2154,
                                                                                        "texto": "A fiança será aplicada de acordo com as disposições do Capítulo VI deste Título, podendo ser cumulada com outras medidas cautelares. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "320º",
                                                                        "rotulo": "Art. 320º.",
                                                                        "linha": 2157,
                                                                        "caput": "A proibição de ausentar-se do País será comunicada pelo juiz às autoridades encarregadas de fiscalizar as saídas do território nacional, intimando-se o indiciado ou acusado para entregar o passaporte, no prazo de 24 (vinte e quatro) horas. ."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 2159,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "321º",
                                                                        "rotulo": "Art. 321º.",
                                                                        "linha": 2166,
                                                                        "caput": "Ausentes os requisitos que autorizam a decretação da prisão preventiva, o juiz deverá conceder liberdade provisória, impondo, se for o caso, as medidas cautelares previstas no art. 319 deste Código e observados os critérios constantes do art. 282 deste Código. .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2168,
                                                                                        "texto": "."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2170,
                                                                                        "texto": "."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "322º",
                                                                        "rotulo": "Art. 322º.",
                                                                        "linha": 2175,
                                                                        "caput": "A autoridade policial somente poderá conceder fiança nos casos de infração cuja pena privativa de liberdade máxima não seja superior a 4 (quatro) anos. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2177,
                                                                                        "texto": "Nos demais casos, a fiança será requerida ao juiz, que decidirá em 48 (quarenta e oito) horas. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "323º",
                                                                        "rotulo": "Art. 323º.",
                                                                        "linha": 2188,
                                                                        "caput": "Não será concedida fiança: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2190,
                                                                                        "texto": "nos crimes de racismo; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2192,
                                                                                        "texto": "nos crimes de tortura, tráfico ilícito de entorpecentes e drogas afins, terrorismo e nos definidos como crimes hediondos; ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2194,
                                                                                        "texto": "nos crimes cometidos por grupos armados, civis ou militares, contra a ordem constitucional e o Estado Democrático; ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2196,
                                                                                        "texto": "."
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2198,
                                                                                        "texto": "."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "324º",
                                                                        "rotulo": "Art. 324º.",
                                                                        "linha": 2205,
                                                                        "caput": "Não será, igualmente, concedida fiança: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2207,
                                                                                        "texto": "aos que, no mesmo processo, tiverem quebrado fiança anteriormente concedida ou infringido, sem motivo justo, qualquer das obrigações a que se referem os arts. 327 e 328 deste Código; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2209,
                                                                                        "texto": "em caso de prisão civil ou militar; ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2211,
                                                                                        "texto": ". ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2213,
                                                                                        "texto": "quando presentes os motivos que autorizam a decretação da prisão preventiva (art. 312). ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "325º",
                                                                        "rotulo": "Art. 325º.",
                                                                        "linha": 2228,
                                                                        "caput": "O valor da fiança será fixado pela autoridade que a conceder nos seguintes limites: .",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 2230,
                                                                                        "texto": "(revogada); ."
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 2232,
                                                                                        "texto": "(revogada). ."
                                                                                }
                                                                        ],
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2234,
                                                                                        "texto": "de 1 (um) a 100 (cem) salários mínimos, quando se tratar de infração cuja pena privativa de liberdade, no grau máximo, não for superior a 4 (quatro) anos; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2236,
                                                                                        "texto": "de 10 (dez) a 200 (duzentos) salários mínimos, quando o máximo da pena privativa de liberdade cominada for superior a 4 (quatro) anos. ."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2238,
                                                                                        "texto": "Se assim recomendar a situação econômica do preso, a fiança poderá ser: .",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 2240,
                                                                                                        "texto": "dispensada, na forma do art. 350 deste Código; ."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 2242,
                                                                                                        "texto": "reduzida até o máximo de 2/3 (dois terços); ou ."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 2244,
                                                                                                        "texto": "aumentada em até 1.000 (mil) vezes. ."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2246,
                                                                                        "texto": ".",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 2248,
                                                                                                        "texto": "."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 2250,
                                                                                                        "texto": "."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 2252,
                                                                                                        "texto": "."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "326º",
                                                                        "rotulo": "Art. 326º.",
                                                                        "linha": 2254,
                                                                        "caput": "Para determinar o valor da fiança, a autoridade terá em consideração a natureza da infração, as condições pessoais de fortuna e vida pregressa do acusado, as circunstâncias indicativas de sua periculosidade, bem como a importância provável das custas do processo, até final julgamento."
                                                                },
                                                                {
                                                                        "numero": "327º",
                                                                        "rotulo": "Art. 327º.",
                                                                        "linha": 2256,
                                                                        "caput": "A fiança tomada por termo obrigará o afiançado a comparecer perante a autoridade, todas as vezes que for intimado para atos do inquérito e da instrução criminal e para o julgamento. Quando o réu não comparecer, a fiança será havida como quebrada."
                                                                },
                                                                {
                                                                        "numero": "328º",
                                                                        "rotulo": "Art. 328º.",
                                                                        "linha": 2258,
                                                                        "caput": "O réu afiançado não poderá, sob pena de quebramento da fiança, mudar de residência, sem prévia permissão da autoridade processante, ou ausentar-se por mais de 8 (oito) dias de sua residência, sem comunicar àquela autoridade o lugar onde será encontrado."
                                                                },
                                                                {
                                                                        "numero": "329º",
                                                                        "rotulo": "Art. 329º.",
                                                                        "linha": 2260,
                                                                        "caput": "Nos juízos criminais e delegacias de polícia, haverá um livro especial, com termos de abertura e de encerramento, numerado e rubricado em todas as suas folhas pela autoridade, destinado especialmente aos termos de fiança. O termo será lavrado pelo escrivão e assinado pela autoridade e por quem prestar a fiança, e dele extrair-se-á certidão para juntar-se aos autos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2262,
                                                                                        "texto": "O réu e quem prestar a fiança serão pelo escrivão notificados das obrigações e da sanção previstas nos arts. 327 e 328, o que constará dos autos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "330º",
                                                                        "rotulo": "Art. 330º.",
                                                                        "linha": 2264,
                                                                        "caput": "A fiança, que será sempre definitiva, consistirá em depósito de dinheiro, pedras, objetos ou metais preciosos, títulos da dívida pública, federal, estadual ou municipal, ou em hipoteca inscrita em primeiro lugar.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2266,
                                                                                        "texto": "A avaliação de imóvel, ou de pedras, objetos ou metais preciosos será feita imediatamente por perito nomeado pela autoridade."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2268,
                                                                                        "texto": "Quando a fiança consistir em caução de títulos da dívida pública, o valor será determinado pela sua cotação em Bolsa, e, sendo nominativos, exigir-se-á prova de que se acham livres de ônus."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "331º",
                                                                        "rotulo": "Art. 331º.",
                                                                        "linha": 2270,
                                                                        "caput": "O valor em que consistir a fiança será recolhido à repartição arrecadadora federal ou estadual, ou entregue ao depositário público, juntando-se aos autos os respectivos conhecimentos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2272,
                                                                                        "texto": "Nos lugares em que o depósito não se puder fazer de pronto, o valor será entregue ao escrivão ou pessoa abonada, a critério da autoridade, e dentro de três dias dar-se-á ao valor o destino que Ihe assina este artigo, o que tudo constará do termo de fiança."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "332º",
                                                                        "rotulo": "Art. 332º.",
                                                                        "linha": 2274,
                                                                        "caput": "Em caso de prisão em flagrante, será competente para conceder a fiança a autoridade que presidir ao respectivo auto, e, em caso de prisão por mandado, o juiz que o houver expedido, ou a autoridade judiciária ou policial a quem tiver sido requisitada a prisão."
                                                                },
                                                                {
                                                                        "numero": "333º",
                                                                        "rotulo": "Art. 333º.",
                                                                        "linha": 2276,
                                                                        "caput": "Depois de prestada a fiança, que será concedida independentemente de audiência do Ministério Público, este terá vista do processo a fim de requerer o que julgar conveniente."
                                                                },
                                                                {
                                                                        "numero": "334º",
                                                                        "rotulo": "Art. 334º.",
                                                                        "linha": 2279,
                                                                        "caput": "A fiança poderá ser prestada enquanto não transitar em julgado a sentença condenatória. ."
                                                                },
                                                                {
                                                                        "numero": "335º",
                                                                        "rotulo": "Art. 335º.",
                                                                        "linha": 2282,
                                                                        "caput": "Recusando ou retardando a autoridade policial a concessão da fiança, o preso, ou alguém por ele, poderá prestá-la, mediante simples petição, perante o juiz competente, que decidirá em 48 (quarenta e oito) horas. ."
                                                                },
                                                                {
                                                                        "numero": "336º",
                                                                        "rotulo": "Art. 336º.",
                                                                        "linha": 2286,
                                                                        "caput": "O dinheiro ou objetos dados como fiança servirão ao pagamento das custas, da indenização do dano, da prestação pecuniária e da multa, se o réu for condenado. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2288,
                                                                                        "texto": "Este dispositivo terá aplicação ainda no caso da prescrição depois da sentença condenatória (). ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "337º",
                                                                        "rotulo": "Art. 337º.",
                                                                        "linha": 2291,
                                                                        "caput": "Se a fiança for declarada sem efeito ou passar em julgado sentença que houver absolvido o acusado ou declarada extinta a ação penal, o valor que a constituir, atualizado, será restituído sem desconto, salvo o disposto no parágrafo único do art. 336 deste Código. ."
                                                                },
                                                                {
                                                                        "numero": "338º",
                                                                        "rotulo": "Art. 338º.",
                                                                        "linha": 2293,
                                                                        "caput": "A fiança que se reconheça não ser cabível na espécie será cassada em qualquer fase do processo."
                                                                },
                                                                {
                                                                        "numero": "339º",
                                                                        "rotulo": "Art. 339º.",
                                                                        "linha": 2295,
                                                                        "caput": "Será também cassada a fiança quando reconhecida a existência de delito inafiançável, no caso de inovação na classificação do delito."
                                                                },
                                                                {
                                                                        "numero": "340º",
                                                                        "rotulo": "Art. 340º.",
                                                                        "linha": 2297,
                                                                        "caput": "Será exigido o reforço da fiança:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2299,
                                                                                        "texto": "quando a autoridade tomar, por engano, fiança insuficiente;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2301,
                                                                                        "texto": "quando houver depreciação material ou perecimento dos bens hipotecados ou caucionados, ou depreciação dos metais ou pedras preciosas;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2303,
                                                                                        "texto": "quando for inovada a classificação do delito."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2305,
                                                                                        "texto": "A fiança ficará sem efeito e o réu será recolhido à prisão, quando, na conformidade deste artigo, não for reforçada."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "341º",
                                                                        "rotulo": "Art. 341º.",
                                                                        "linha": 2308,
                                                                        "caput": "Julgar-se-á quebrada a fiança quando o acusado: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2310,
                                                                                        "texto": "regularmente intimado para ato do processo, deixar de comparecer, sem motivo justo; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2312,
                                                                                        "texto": "deliberadamente praticar ato de obstrução ao andamento do processo; ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2314,
                                                                                        "texto": "descumprir medida cautelar imposta cumulativamente com a fiança; ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2316,
                                                                                        "texto": "resistir injustificadamente a ordem judicial; ."
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2318,
                                                                                        "texto": "praticar nova infração penal dolosa. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "342º",
                                                                        "rotulo": "Art. 342º.",
                                                                        "linha": 2320,
                                                                        "caput": "Se vier a ser reformado o julgamento em que se declarou quebrada a fiança, esta subsistirá em todos os seus efeitos"
                                                                },
                                                                {
                                                                        "numero": "343º",
                                                                        "rotulo": "Art. 343º.",
                                                                        "linha": 2323,
                                                                        "caput": "O quebramento injustificado da fiança importará na perda de metade do seu valor, cabendo ao juiz decidir sobre a imposição de outras medidas cautelares ou, se for o caso, a decretação da prisão preventiva. ."
                                                                },
                                                                {
                                                                        "numero": "344º",
                                                                        "rotulo": "Art. 344º.",
                                                                        "linha": 2326,
                                                                        "caput": "Entender-se-á perdido, na totalidade, o valor da fiança, se, condenado, o acusado não se apresentar para o início do cumprimento da pena definitivamente imposta. ."
                                                                },
                                                                {
                                                                        "numero": "345º",
                                                                        "rotulo": "Art. 345º.",
                                                                        "linha": 2329,
                                                                        "caput": "No caso de perda da fiança, o seu valor, deduzidas as custas e mais encargos a que o acusado estiver obrigado, será recolhido ao fundo penitenciário, na forma da lei. ."
                                                                },
                                                                {
                                                                        "numero": "346º",
                                                                        "rotulo": "Art. 346º.",
                                                                        "linha": 2332,
                                                                        "caput": "No caso de quebramento de fiança, feitas as deduções previstas no art. 345 deste Código, o valor restante será recolhido ao fundo penitenciário, na forma da lei. ."
                                                                },
                                                                {
                                                                        "numero": "347º",
                                                                        "rotulo": "Art. 347º.",
                                                                        "linha": 2334,
                                                                        "caput": "Não ocorrendo a hipótese do art. 345, o saldo será entregue a quem houver prestado a fiança, depois de deduzidos os encargos a que o réu estiver obrigado."
                                                                },
                                                                {
                                                                        "numero": "348º",
                                                                        "rotulo": "Art. 348º.",
                                                                        "linha": 2336,
                                                                        "caput": "Nos casos em que a fiança tiver sido prestada por meio de hipoteca, a execução será promovida no juízo cível pelo órgão do Ministério Público."
                                                                },
                                                                {
                                                                        "numero": "349º",
                                                                        "rotulo": "Art. 349º.",
                                                                        "linha": 2338,
                                                                        "caput": "Se a fiança consistir em pedras, objetos ou metais preciosos, o juiz determinará a venda por leiloeiro ou corretor."
                                                                },
                                                                {
                                                                        "numero": "350º",
                                                                        "rotulo": "Art. 350º.",
                                                                        "linha": 2342,
                                                                        "caput": "Nos casos em que couber fiança, o juiz, verificando a situação econômica do preso, poderá conceder-lhe liberdade provisória, sujeitando-o às obrigações constantes dos arts. 327 e 328 deste Código e a outras medidas cautelares, se for o caso. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2344,
                                                                                        "texto": "Se o beneficiado descumprir, sem motivo justo, qualquer das obrigações ou medidas impostas, aplicar-se-á o disposto no § 4o do art. 282 deste Código. ."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO IX-A",
                                        "linha": 2346,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "350º-A",
                                                        "rotulo": "Art. 350º-A.",
                                                        "linha": 2351,
                                                        "caput": "Constatada a existência de indícios da prática de crime contra a dignidade sexual, o juiz poderá aplicar, de imediato, ao autor, em conjunto ou separadamente, as seguintes medidas protetivas de urgência, entre outras:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2353,
                                                                        "texto": "suspensão da posse ou restrição do porte de armas, com comunicação ao órgão competente, nos termos da Lei nº 10.826, de 22 de dezembro de 2003 (Estatuto do Desarmamento);"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2355,
                                                                        "texto": "afastamento do lar, domicílio ou local de convivência com a vítima, se aplicável;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2357,
                                                                        "texto": "proibição de determinadas condutas, entre as quais:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 2359,
                                                                                        "texto": "aproximação da vítima, de seus familiares e das testemunhas, fixando o limite mínimo de distância entre esses e o autor;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 2361,
                                                                                        "texto": "contato com a vítima, seus familiares e testemunhas por qualquer meio de comunicação;"
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 2363,
                                                                                        "texto": "frequentação de determinados lugares a fim de preservar a integridade física e psicológica da vítima;"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2365,
                                                                        "texto": "restrição ou suspensão de visitas aos dependentes menores, ouvida a equipe de atendimento multidisciplinar ou serviço similar;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 2367,
                                                                        "texto": "prestação de alimentos provisionais ou provisórios;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 2369,
                                                                        "texto": "comparecimento do autor a programas de recuperação e reeducação;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 2371,
                                                                        "texto": "acompanhamento psicossocial do autor, por meio de atendimento individual e/ou em grupo de apoio."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 2373,
                                                                        "texto": "As medidas referidas neste artigo não impedem a aplicação de outras previstas na legislação em vigor, sempre que a segurança da vítima ou as circunstâncias o exigirem, devendo a providência ser comunicada ao Ministério Público."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 2375,
                                                                        "texto": "Na hipótese de aplicação do inciso I do caput deste artigo, encontrando-se o autor nas condições mencionadas no capute nos incisos do art. 6º da Lei nº 10.826, de 22 de dezembro de 2003 (Estatuto do Desarmamento), o juiz comunicará ao respectivo órgão, corporação ou instituição as medidas protetivas de urgência concedidas e determinará a restrição do porte de armas, ficando o superior imediato do autor responsável pelo cumprimento da determinação judicial, sob pena de incorrer nos crimes de prevaricação ou de desobediência, conforme o caso."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 2377,
                                                                        "texto": "Para garantir a efetividade das medidas protetivas de urgência, poderá o juiz requisitar, a qualquer momento, auxílio da força policial."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 2379,
                                                                        "texto": "Aplica-se às hipóteses previstas neste artigo, no que couber, o disposto na Lei nº 13.105, de 16 de março de 2015 (Código de Processo Civil)."
                                                                },
                                                                {
                                                                        "numero": "5",
                                                                        "rotulo": "§ 5",
                                                                        "linha": 2381,
                                                                        "texto": "Nos casos previstos neste artigo, a medida protetiva de urgência será cumulada com a sujeição do autor a monitoração eletrônica, disponibilizando-se à vítima dispositivo de segurança que alerte sobre sua eventual aproximação."
                                                                },
                                                                {
                                                                        "numero": "6",
                                                                        "rotulo": "§ 6",
                                                                        "linha": 2383,
                                                                        "texto": "O disposto neste artigo aplica-se, ainda, aos crimes cuja vítima esteja em situação de vulnerabilidade, como crianças, adolescentes, pessoas com deficiência ou incapazes, qualquer que seja o crime investigado."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "350º-B",
                                                        "rotulo": "Art. 350º-B.",
                                                        "linha": 2385,
                                                        "caput": "Em qualquer fase da investigação policial ou do processo penal, a pedido da autoridade policial, do Ministério Público ou da vítima, o juiz poderá determinar a proibição do autor de exercer atividades que envolvam contato direto com pessoa em situação de vulnerabilidade, quando houver prova da existência do crime, indício suficiente de autoria e perigo gerado pelo estado de liberdade do imputado."
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO X",
                                        "linha": 2387,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 2391,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "351º",
                                                                        "rotulo": "Art. 351º.",
                                                                        "linha": 2395,
                                                                        "caput": "A citação inicial far-se-á por mandado, quando o réu estiver no território sujeito à jurisdição do juiz que a houver ordenado."
                                                                },
                                                                {
                                                                        "numero": "352º",
                                                                        "rotulo": "Art. 352º.",
                                                                        "linha": 2397,
                                                                        "caput": "O mandado de citação indicará:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2399,
                                                                                        "texto": "nome do juiz;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2401,
                                                                                        "texto": "nome do querelante nas ações iniciadas por queixa;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2403,
                                                                                        "texto": "nome do réu, ou, se for desconhecido, os seus sinais característicos;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2405,
                                                                                        "texto": "a residência do réu, se for conhecida;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2407,
                                                                                        "texto": "fim para que é feita a citação;"
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 2409,
                                                                                        "texto": "juízo e o lugar, o dia e a hora em que o réu deverá comparecer;"
                                                                                },
                                                                                {
                                                                                        "numero": "VII",
                                                                                        "rotulo": "VII",
                                                                                        "linha": 2411,
                                                                                        "texto": "a subscrição do escrivão e a rubrica do juiz."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "353º",
                                                                        "rotulo": "Art. 353º.",
                                                                        "linha": 2413,
                                                                        "caput": "Quando o réu estiver fora do território da jurisdição do juiz processante, será citado mediante precatória."
                                                                },
                                                                {
                                                                        "numero": "354º",
                                                                        "rotulo": "Art. 354º.",
                                                                        "linha": 2415,
                                                                        "caput": "A precatória indicará:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2417,
                                                                                        "texto": "juiz deprecado e o juiz deprecante;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2419,
                                                                                        "texto": "a sede da jurisdição de um e de outro; Ill - o fim para que é feita a citação, com todas as especificações;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2423,
                                                                                        "texto": "juízo do lugar, o dia e a hora em que o réu deverá comparecer."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "355º",
                                                                        "rotulo": "Art. 355º.",
                                                                        "linha": 2425,
                                                                        "caput": "A precatória será devolvida ao juiz deprecante, independentemente de traslado, depois de lançado o \"cumpra-se\" e de feita a citação por mandado do juiz deprecado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2427,
                                                                                        "texto": "Verificado que o réu se encontra em território sujeito à jurisdição de outro juiz, a este remeterá o juiz deprecado os autos para efetivação da diligência, desde que haja tempo para fazer-se a citação."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2429,
                                                                                        "texto": "Certificado pelo oficial de justiça que o réu se oculta para não ser citado, a precatória será imediatamente devolvida, para o fim previsto no art. 362."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "356º",
                                                                        "rotulo": "Art. 356º.",
                                                                        "linha": 2431,
                                                                        "caput": "Se houver urgência, a precatória, que conterá em resumo os requisitos enumerados no art. 354, poderá ser expedida por via telegráfica, depois de reconhecida a firma do juiz, o que a estação expedidora mencionará."
                                                                },
                                                                {
                                                                        "numero": "357º",
                                                                        "rotulo": "Art. 357º.",
                                                                        "linha": 2433,
                                                                        "caput": "São requisitos da citação por mandado:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2435,
                                                                                        "texto": "leitura do mandado ao citando pelo oficial e entrega da contrafé, na qual se mencionarão dia e hora da citação;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2437,
                                                                                        "texto": "declaração do oficial, na certidão, da entrega da contrafé, e sua aceitação ou recusa."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "358º",
                                                                        "rotulo": "Art. 358º.",
                                                                        "linha": 2439,
                                                                        "caput": "A citação do militar far-se-á por intermédio do chefe do respectivo serviço."
                                                                },
                                                                {
                                                                        "numero": "359º",
                                                                        "rotulo": "Art. 359º.",
                                                                        "linha": 2441,
                                                                        "caput": "O dia designado para funcionário público comparecer em juízo, como acusado, será notificado assim a ele como ao chefe de sua repartição."
                                                                },
                                                                {
                                                                        "numero": "360º",
                                                                        "rotulo": "Art. 360º.",
                                                                        "linha": 2444,
                                                                        "caput": "Se o réu estiver preso, será pessoalmente citado."
                                                                },
                                                                {
                                                                        "numero": "361º",
                                                                        "rotulo": "Art. 361º.",
                                                                        "linha": 2446,
                                                                        "caput": "Se o réu não for encontrado, será citado por edital, com o prazo de 15 (quinze) dias."
                                                                },
                                                                {
                                                                        "numero": "362º",
                                                                        "rotulo": "Art. 362º.",
                                                                        "linha": 2449,
                                                                        "caput": "Verificando que o réu se oculta para não ser citado, o oficial de justiça certificará a ocorrência e procederá à citação com hora certa, na forma estabelecida nos arts. 227 a 229 da Lei no 5.869, de 11 de janeiro de 1973 - Código de Processo Civil. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2451,
                                                                                        "texto": "Completada a citação com hora certa, se o acusado não comparecer, ser-lhe-á nomeado defensor dativo. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "363º",
                                                                        "rotulo": "Art. 363º.",
                                                                        "linha": 2456,
                                                                        "caput": "O processo terá completada a sua formação quando realizada a citação do acusado. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2458,
                                                                                        "texto": "Não sendo encontrado o acusado, será procedida a citação por edital. ."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 2460,
                                                                                        "texto": "Comparecendo o acusado citado por edital, em qualquer tempo, o processo observará o disposto nos arts. 394 e seguintes deste Código. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "364º",
                                                                        "rotulo": "Art. 364º.",
                                                                        "linha": 2462,
                                                                        "caput": "No caso do artigo anterior, no I, o prazo será fixado pelo juiz entre 15 (quinze) e 90 (noventa) dias, de acordo com as circunstâncias, e, no caso de no II, o prazo será de trinta dias."
                                                                },
                                                                {
                                                                        "numero": "365º",
                                                                        "rotulo": "Art. 365º.",
                                                                        "linha": 2464,
                                                                        "caput": "O edital de citação indicará:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2466,
                                                                                        "texto": "nome do juiz que a determinar;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2468,
                                                                                        "texto": "nome do réu, ou, se não for conhecido, os seus sinais característicos, bem como sua residência e profissão, se constarem do processo;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2470,
                                                                                        "texto": "fim para que é feita a citação;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2472,
                                                                                        "texto": "juízo e o dia, a hora e o lugar em que o réu deverá comparecer;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 2474,
                                                                                        "texto": "prazo, que será contado do dia da publicação do edital na imprensa, se houver, ou da sua afixação."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2476,
                                                                                        "texto": "O edital será afixado à porta do edifício onde funcionar o juízo e será publicado pela imprensa, onde houver, devendo a afixação ser certificada pelo oficial que a tiver feito e a publicação provada por exemplar do jornal ou certidão do escrivão, da qual conste a página do jornal com a data da publicação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "366º",
                                                                        "rotulo": "Art. 366º.",
                                                                        "linha": 2479,
                                                                        "caput": "Se o acusado, citado por edital, não comparecer, nem constituir advogado, ficarão suspensos o processo e o curso do prazo prescricional, podendo o juiz determinar a produção antecipada das provas consideradas urgentes e, se for o caso, decretar prisão preventiva, nos termos do disposto no art. 312."
                                                                },
                                                                {
                                                                        "numero": "367º",
                                                                        "rotulo": "Art. 367º.",
                                                                        "linha": 2482,
                                                                        "caput": "O processo seguirá sem a presença do acusado que, citado ou intimado pessoalmente para qualquer ato, deixar de comparecer sem motivo justificado, ou, no caso de mudança de residência, não comunicar o novo endereço ao juízo."
                                                                },
                                                                {
                                                                        "numero": "368º",
                                                                        "rotulo": "Art. 368º.",
                                                                        "linha": 2485,
                                                                        "caput": "Estando o acusado no estrangeiro, em lugar sabido, será citado mediante carta rogatória, suspendendo-se o curso do prazo de prescrição até o seu cumprimento."
                                                                },
                                                                {
                                                                        "numero": "369º",
                                                                        "rotulo": "Art. 369º.",
                                                                        "linha": 2488,
                                                                        "caput": "As citações que houverem de ser feitas em legações estrangeiras serão efetuadas mediante carta rogatória."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 2490,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "370º",
                                                                        "rotulo": "Art. 370º.",
                                                                        "linha": 2495,
                                                                        "caput": "Nas intimações dos acusados, das testemunhas e demais pessoas que devam tomar conhecimento de qualquer ato, será observado, no que for aplicável, o disposto no Capítulo anterior.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2497,
                                                                                        "texto": "A intimação do defensor constituído, do advogado do querelante e do assistente far-se-á por publicação no órgão incumbido da publicidade dos atos judiciais da comarca, incluindo, sob pena de nulidade, o nome do acusado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2500,
                                                                                        "texto": "Caso não haja órgão de publicação dos atos judiciais na comarca, a intimação far-se-á diretamente pelo escrivão, por mandado, ou via postal com comprovante de recebimento, ou por qualquer outro meio idôneo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 2502,
                                                                                        "texto": "A intimação pessoal, feita pelo escrivão, dispensará a aplicação a que alude o § 1o."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 2504,
                                                                                        "texto": "A intimação do Ministério Público e do defensor nomeado será pessoal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "371º",
                                                                        "rotulo": "Art. 371º.",
                                                                        "linha": 2506,
                                                                        "caput": "Será admissível a intimação por despacho na petição em que for requerida, observado o disposto no art. 357."
                                                                },
                                                                {
                                                                        "numero": "372º",
                                                                        "rotulo": "Art. 372º.",
                                                                        "linha": 2508,
                                                                        "caput": "Adiada, por qualquer motivo, a instrução criminal, o juiz marcará desde logo, na presença das partes e testemunhas, dia e hora para seu prosseguimento, do que se lavrará termo nos autos."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO XI",
                                        "linha": 2510,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "373º",
                                                        "rotulo": "Art. 373º.",
                                                        "linha": 2516,
                                                        "caput": "A aplicação provisória de interdições de direitos poderá ser determinada pelo juiz, de ofício, ou a requerimento do Ministério Público, do querelante, do assistente, do ofendido, ou de seu representante legal, ainda que este não se tenha constituído como assistente:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2518,
                                                                        "texto": "durante a instrução criminal após a apresentação da defesa ou do prazo concedido para esse fim;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2520,
                                                                        "texto": "na sentença de pronúncia;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2522,
                                                                        "texto": "na decisão confirmatória da pronúncia ou na que, em grau de recurso, pronunciar o réu;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2524,
                                                                        "texto": "na sentença condenatória recorrível."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 2526,
                                                                        "texto": "No caso do no I, havendo requerimento de aplicação da medida, o réu ou seu defensor será ouvido no prazo de 2 (dois) dias."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 2528,
                                                                        "texto": "Decretada a medida, serão feitas as comunicações necessárias para a sua execução, na forma do disposto no Capítulo III do Título II do Livro IV."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "374º",
                                                        "rotulo": "Art. 374º.",
                                                        "linha": 2530,
                                                        "caput": "Não caberá recurso do despacho ou da parte da sentença que decretar ou denegar a aplicação provisória de interdições de direitos, mas estas poderão ser substituídas ou revogadas:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2532,
                                                                        "texto": "se aplicadas no curso da instrução criminal, durante esta ou pelas sentenças a que se referem os ns. II, III e IV do artigo anterior;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2534,
                                                                        "texto": "se aplicadas na sentença de pronúncia, pela decisão que, em grau de recurso, a confirmar, total ou parcialmente, ou pela sentença condenatória recorrível;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2536,
                                                                        "texto": "se aplicadas na decisão a que se refere o no III do artigo anterior, pela sentença condenatória recorrível."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "375º",
                                                        "rotulo": "Art. 375º.",
                                                        "linha": 2538,
                                                        "caput": "O despacho que aplicar, provisoriamente, substituir ou revogar interdição de direito, será fundamentado."
                                                },
                                                {
                                                        "numero": "376º",
                                                        "rotulo": "Art. 376º.",
                                                        "linha": 2540,
                                                        "caput": "A decisão que impronunciar ou absolver o réu fará cessar a aplicação provisória da interdição anteriormente determinada."
                                                },
                                                {
                                                        "numero": "377º",
                                                        "rotulo": "Art. 377º.",
                                                        "linha": 2542,
                                                        "caput": "Transitando em julgado a sentença condenatória, serão executadas somente as interdições nela aplicadas ou que derivarem da imposição da pena principal."
                                                },
                                                {
                                                        "numero": "378º",
                                                        "rotulo": "Art. 378º.",
                                                        "linha": 2544,
                                                        "caput": "A aplicação provisória de medida de segurança obedecerá ao disposto nos artigos anteriores, com as modificações seguintes:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2546,
                                                                        "texto": "juiz poderá aplicar, provisoriamente, a medida de segurança, de ofício, ou a requerimento do Ministério Público;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2548,
                                                                        "texto": "a aplicação poderá ser determinada ainda no curso do inquérito, mediante representação da autoridade policial;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2550,
                                                                        "texto": "a aplicação provisória de medida de segurança, a substituição ou a revogação da anteriormente aplicada poderão ser determinadas, também, na sentença absolutória;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2552,
                                                                        "texto": "decretada a medida, atender-se-á ao disposto no Título V do Livro IV, no que for aplicável."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "379º",
                                                        "rotulo": "Art. 379º.",
                                                        "linha": 2554,
                                                        "caput": "Transitando em julgado a sentença, observar-se-á, quanto à execução das medidas de segurança definitivamente aplicadas, o disposto no Título V do Livro IV."
                                                },
                                                {
                                                        "numero": "380º",
                                                        "rotulo": "Art. 380º.",
                                                        "linha": 2556,
                                                        "caput": "A aplicação provisória de medida de segurança obstará a concessão de fiança, e tornará sem efeito a anteriormente concedida."
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO XII",
                                        "linha": 2558,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "381º",
                                                        "rotulo": "Art. 381º.",
                                                        "linha": 2562,
                                                        "caput": "A sentença conterá:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2564,
                                                                        "texto": "os nomes das partes ou, quando não possível, as indicações necessárias para identificá-las;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2566,
                                                                        "texto": "a exposição sucinta da acusação e da defesa;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2568,
                                                                        "texto": "a indicação dos motivos de fato e de direito em que se fundar a decisão;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2570,
                                                                        "texto": "a indicação dos artigos de lei aplicados;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 2572,
                                                                        "texto": "dispositivo;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 2574,
                                                                        "texto": "a data e a assinatura do juiz."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "382º",
                                                        "rotulo": "Art. 382º.",
                                                        "linha": 2576,
                                                        "caput": "Qualquer das partes poderá, no prazo de 2 (dois) dias, pedir ao juiz que declare a sentença, sempre que nela houver obscuridade, ambigüidade, contradição ou omissão."
                                                },
                                                {
                                                        "numero": "383º",
                                                        "rotulo": "Art. 383º.",
                                                        "linha": 2579,
                                                        "caput": "O juiz, sem modificar a descrição do fato contida na denúncia ou queixa, poderá atribuir-lhe definição jurídica diversa, ainda que, em conseqüência, tenha de aplicar pena mais grave. .",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 2581,
                                                                        "texto": "Se, em conseqüência de definição jurídica diversa, houver possibilidade de proposta de suspensão condicional do processo, o juiz procederá de acordo com o disposto na lei. ."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 2583,
                                                                        "texto": "Tratando-se de infração da competência de outro juízo, a este serão encaminhados os autos. ."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "384º",
                                                        "rotulo": "Art. 384º.",
                                                        "linha": 2587,
                                                        "caput": "Encerrada a instrução probatória, se entender cabível nova definição jurídica do fato, em conseqüência de prova existente nos autos de elemento ou circunstância da infração penal não contida na acusação, o Ministério Público deverá aditar a denúncia ou queixa, no prazo de 5 (cinco) dias, se em virtude desta houver sido instaurado o processo em crime de ação pública, reduzindo-se a termo o aditamento, quando feito oralmente. .",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 2589,
                                                                        "texto": "Não procedendo o órgão do Ministério Público ao aditamento, aplica-se o art. 28 deste Código. ."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 2591,
                                                                        "texto": "Ouvido o defensor do acusado no prazo de 5 (cinco) dias e admitido o aditamento, o juiz, a requerimento de qualquer das partes, designará dia e hora para continuação da audiência, com inquirição de testemunhas, novo interrogatório do acusado, realização de debates e julgamento. ."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 2593,
                                                                        "texto": "Aplicam-se as disposições dos §§ 1o e 2o do art. 383 ao caputdeste artigo. ."
                                                                },
                                                                {
                                                                        "numero": "4",
                                                                        "rotulo": "§ 4",
                                                                        "linha": 2595,
                                                                        "texto": "Havendo aditamento, cada parte poderá arrolar até 3 (três) testemunhas, no prazo de 5 (cinco) dias, ficando o juiz, na sentença, adstrito aos termos do aditamento. ."
                                                                },
                                                                {
                                                                        "numero": "5",
                                                                        "rotulo": "§ 5",
                                                                        "linha": 2597,
                                                                        "texto": "Não recebido o aditamento, o processo prosseguirá. ."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "385º",
                                                        "rotulo": "Art. 385º.",
                                                        "linha": 2599,
                                                        "caput": "Nos crimes de ação pública, o juiz poderá proferir sentença condenatória, ainda que o Ministério Público tenha opinado pela absolvição, bem como reconhecer agravantes, embora nenhuma tenha sido alegada."
                                                },
                                                {
                                                        "numero": "386º",
                                                        "rotulo": "Art. 386º.",
                                                        "linha": 2601,
                                                        "caput": "O juiz absolverá o réu, mencionando a causa na parte dispositiva, desde que reconheça:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2603,
                                                                        "texto": "estar provada a inexistência do fato;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2605,
                                                                        "texto": "não haver prova da existência do fato;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2607,
                                                                        "texto": "não constituir o fato infração penal;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2610,
                                                                        "texto": "estar provado que o réu não concorreu para a infração penal;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 2613,
                                                                        "texto": "não existir prova de ter o réu concorrido para a infração penal;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 2616,
                                                                        "texto": "existirem circunstâncias que excluam o crime ou isentem o réu de pena (arts. 20, 21, 22, 23, 26 e § 1º do art. 28, todos do Código Penal), ou mesmo se houver fundada dúvida sobre sua existência;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 2618,
                                                                        "texto": "não existir prova suficiente para a condenação."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 2620,
                                                                        "texto": "Na sentença absolutória, o juiz:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2622,
                                                                                        "texto": "mandará, se for o caso, pôr o réu em liberdade;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2625,
                                                                                        "texto": "ordenará a cessação das medidas cautelares e provisoriamente aplicadas;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2627,
                                                                                        "texto": "aplicará medida de segurança, se cabível."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "387º",
                                                        "rotulo": "Art. 387º.",
                                                        "linha": 2629,
                                                        "caput": "O juiz, ao proferir sentença condenatória:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2631,
                                                                        "texto": "mencionará as circunstâncias agravantes ou atenuantes definidas no Código Penal, e cuja existência reconhecer; arts. 42 e 43 do Código Penal;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2635,
                                                                        "texto": "mencionará as outras circunstâncias apuradas e tudo o mais que deva ser levado em conta na aplicação da pena, de acordo com o disposto nos arts. 59 e 60 do Decreto-Lei no 2.848, de 7 de dezembro de 1940 - Código Penal; ."
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2639,
                                                                        "texto": "aplicará as penas de acordo com essas conclusões; ."
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2643,
                                                                        "texto": "fixará valor mínimo para reparação dos danos causados pela infração, considerando os prejuízos sofridos pelo ofendido; ."
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 2645,
                                                                        "texto": "atenderá, quanto à aplicação provisória de interdições de direitos e medidas de segurança, ao disposto no Título Xl deste Livro;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 2647,
                                                                        "texto": "determinará se a sentença deverá ser publicada na íntegra ou em resumo e designará o jornal em que será feita a publicação (art. 73, § 1o, do Código Penal)."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 2650,
                                                                        "texto": "O juiz decidirá, fundamentadamente, sobre a manutenção ou, se for o caso, a imposição de prisão preventiva ou de outra medida cautelar, sem prejuízo do conhecimento de apelação que vier a ser interposta."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 2652,
                                                                        "texto": "O tempo de prisão provisória, de prisão administrativa ou de internação, no Brasil ou no estrangeiro, será computado para fins de determinação do regime inicial de pena privativa de liberdade."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "388º",
                                                        "rotulo": "Art. 388º.",
                                                        "linha": 2654,
                                                        "caput": "A sentença poderá ser datilografada e neste caso o juiz a rubricará em todas as folhas."
                                                },
                                                {
                                                        "numero": "389º",
                                                        "rotulo": "Art. 389º.",
                                                        "linha": 2656,
                                                        "caput": "A sentença será publicada em mão do escrivão, que lavrará nos autos o respectivo termo, registrando-a em livro especialmente destinado a esse fim."
                                                },
                                                {
                                                        "numero": "390º",
                                                        "rotulo": "Art. 390º.",
                                                        "linha": 2658,
                                                        "caput": "O escrivão, dentro de três dias após a publicação, e sob pena de suspensão de cinco dias, dará conhecimento da sentença ao órgão do Ministério Público."
                                                },
                                                {
                                                        "numero": "391º",
                                                        "rotulo": "Art. 391º.",
                                                        "linha": 2660,
                                                        "caput": "O querelante ou o assistente será intimado da sentença, pessoalmente ou na pessoa de seu advogado. Se nenhum deles for encontrado no lugar da sede do juízo, a intimação será feita mediante edital com o prazo de 10 dias, afixado no lugar de costume."
                                                },
                                                {
                                                        "numero": "392º",
                                                        "rotulo": "Art. 392º.",
                                                        "linha": 2662,
                                                        "caput": "A intimação da sentença será feita:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 2664,
                                                                        "texto": "ao réu, pessoalmente, se estiver preso;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 2666,
                                                                        "texto": "ao réu, pessoalmente, ou ao defensor por ele constituído, quando se livrar solto, ou, sendo afiançável a infração, tiver prestado fiança;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 2668,
                                                                        "texto": "ao defensor constituído pelo réu, se este, afiançável, ou não, a infração, expedido o mandado de prisão, não tiver sido encontrado, e assim o certificar o oficial de justiça;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 2670,
                                                                        "texto": "mediante edital, nos casos do no II, se o réu e o defensor que houver constituído não forem encontrados, e assim o certificar o oficial de justiça;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 2672,
                                                                        "texto": "mediante edital, nos casos do no III, se o defensor que o réu houver constituído também não for encontrado, e assim o certificar o oficial de justiça;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 2674,
                                                                        "texto": "mediante edital, se o réu, não tendo constituído defensor, não for encontrado, e assim o certificar o oficial de justiça."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 2676,
                                                                        "texto": "O prazo do edital será de 90 dias, se tiver sido imposta pena privativa de liberdade por tempo igual ou superior a um ano, e de 60 dias, nos outros casos."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 2678,
                                                                        "texto": "O prazo para apelação correrá após o término do fixado no edital, salvo se, no curso deste, for feita a intimação por qualquer das outras formas estabelecidas neste artigo."
                                                                }
                                                        ]
                                                }
                                        ]
                                }
                        ],
                        "artigos": []
                },
                {
                        "tipo": "livro",
                        "rotulo": "LIVRO II",
                        "linha": 2682,
                        "divisoes": [
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO I",
                                        "linha": 2686,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 2690,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "394º",
                                                                        "rotulo": "Art. 394º.",
                                                                        "linha": 2695,
                                                                        "caput": "O procedimento será comum ou especial. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2697,
                                                                                        "texto": "O procedimento comum será ordinário, sumário ou sumaríssimo: .",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 2699,
                                                                                                        "texto": "ordinário, quando tiver por objeto crime cuja sanção máxima cominada for igual ou superior a 4 (quatro) anos de pena privativa de liberdade; ."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 2701,
                                                                                                        "texto": "sumário, quando tiver por objeto crime cuja sanção máxima cominada seja inferior a 4 (quatro) anos de pena privativa de liberdade; ."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 2703,
                                                                                                        "texto": "sumaríssimo, para as infrações penais de menor potencial ofensivo, na forma da lei. ."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2705,
                                                                                        "texto": "Aplica-se a todos os processos o procedimento comum, salvo disposições em contrário deste Código ou de lei especial. ."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 2707,
                                                                                        "texto": "Nos processos de competência do Tribunal do Júri, o procedimento observará as disposições estabelecidas nos arts. 406 a 497 deste Código. ."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 2709,
                                                                                        "texto": "As disposições dos arts. 395 a 398 deste Código aplicam-se a todos os procedimentos penais de primeiro grau, ainda que não regulados neste Código. ."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 2711,
                                                                                        "texto": "Aplicam-se subsidiariamente aos procedimentos especial, sumário e sumaríssimo as disposições do procedimento ordinário. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "394º-A",
                                                                        "rotulo": "Art. 394º-A.",
                                                                        "linha": 2715,
                                                                        "caput": "Os processos que apurem a prática de crime hediondo ou violência contra a mulher terão prioridade de tramitação em todas as instâncias.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2717,
                                                                                        "texto": "Os processos que apurem violência contra a mulher independerão do pagamento de custas, taxas ou despesas processuais, salvo em caso de má-fé."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2719,
                                                                                        "texto": "As isenções de que trata o § 1º deste artigo aplicam-se apenas à vítima e, em caso de morte, ao cônjuge, ascendente, descendente ou irmão, quando a estes couber o direito de representação ou de oferecer queixa ou prosseguir com a ação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "395º",
                                                                        "rotulo": "Art. 395º.",
                                                                        "linha": 2722,
                                                                        "caput": "A denúncia ou queixa será rejeitada quando: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2724,
                                                                                        "texto": "for manifestamente inepta; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2726,
                                                                                        "texto": "faltar pressuposto processual ou condição para o exercício da ação penal; ou ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2728,
                                                                                        "texto": "faltar justa causa para o exercício da ação penal. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "396º",
                                                                        "rotulo": "Art. 396º.",
                                                                        "linha": 2733,
                                                                        "caput": "Nos procedimentos ordinário e sumário, oferecida a denúncia ou queixa, o juiz, se não a rejeitar liminarmente, recebê-la-á e ordenará a citação do acusado para responder à acusação, por escrito, no prazo de 10 (dez) dias. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2735,
                                                                                        "texto": "No caso de citação por edital, o prazo para a defesa começará a fluir a partir do comparecimento pessoal do acusado ou do defensor constituído. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "396º-A",
                                                                        "rotulo": "Art. 396º-A.",
                                                                        "linha": 2737,
                                                                        "caput": "Na resposta, o acusado poderá argüir preliminares e alegar tudo o que interesse à sua defesa, oferecer documentos e justificações, especificar as provas pretendidas e arrolar testemunhas, qualificando-as e requerendo sua intimação, quando necessário. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2739,
                                                                                        "texto": "A exceção será processada em apartado, nos termos dos arts. 95 a 112 deste Código. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2741,
                                                                                        "texto": "Não apresentada a resposta no prazo legal, ou se o acusado, citado, não constituir defensor, o juiz nomeará defensor para oferecê-la, concedendo-lhe vista dos autos por 10 (dez) dias. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "397º",
                                                                        "rotulo": "Art. 397º.",
                                                                        "linha": 2744,
                                                                        "caput": "Após o cumprimento do disposto no art. 396-A, e parágrafos, deste Código, o juiz deverá absolver sumariamente o acusado quando verificar: .",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2746,
                                                                                        "texto": "a existência manifesta de causa excludente da ilicitude do fato; ."
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2748,
                                                                                        "texto": "a existência manifesta de causa excludente da culpabilidade do agente, salvo inimputabilidade; ."
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 2750,
                                                                                        "texto": "que o fato narrado evidentemente não constitui crime; ou ."
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 2752,
                                                                                        "texto": "extinta a punibilidade do agente. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "399º",
                                                                        "rotulo": "Art. 399º.",
                                                                        "linha": 2756,
                                                                        "caput": "Recebida a denúncia ou queixa, o juiz designará dia e hora para a audiência, ordenando a intimação do acusado, de seu defensor, do Ministério Público e, se for o caso, do querelante e do assistente. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2758,
                                                                                        "texto": "O acusado preso será requisitado para comparecer ao interrogatório, devendo o poder público providenciar sua apresentação. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2760,
                                                                                        "texto": "O juiz que presidiu a instrução deverá proferir a sentença. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "400º",
                                                                        "rotulo": "Art. 400º.",
                                                                        "linha": 2763,
                                                                        "caput": "Na audiência de instrução e julgamento, a ser realizada no prazo máximo de 60 (sessenta) dias, proceder-se-á à tomada de declarações do ofendido, à inquirição das testemunhas arroladas pela acusação e pela defesa, nesta ordem, ressalvado o disposto no art. 222 deste Código, bem como aos esclarecimentos dos peritos, às acareações e ao reconhecimento de pessoas e coisas, interrogando-se, em seguida, o acusado. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2765,
                                                                                        "texto": "As provas serão produzidas numa só audiência, podendo o juiz indeferir as consideradas irrelevantes, impertinentes ou protelatórias. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2767,
                                                                                        "texto": "Os esclarecimentos dos peritos dependerão de prévio requerimento das partes. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "400º-A",
                                                                        "rotulo": "Art. 400º-A.",
                                                                        "linha": 2769,
                                                                        "caput": "Na audiência de instrução e julgamento, e, em especial, nas que apurem crimes contra a dignidade sexual, todas as partes e demais sujeitos processuais presentes no ato deverão zelar pela integridade física e psicológica da vítima, sob pena de responsabilização civil, penal e administrativa, cabendo ao juiz garantir o cumprimento do disposto neste artigo, vedadas:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 2771,
                                                                                        "texto": "a manifestação sobre circunstâncias ou elementos alheios aos fatos objeto de apuração nos autos;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 2773,
                                                                                        "texto": "a utilização de linguagem, de informações ou de material que ofendam a dignidade da vítima ou de testemunhas."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "401º",
                                                                        "rotulo": "Art. 401º.",
                                                                        "linha": 2777,
                                                                        "caput": "Na instrução poderão ser inquiridas até 8 (oito) testemunhas arroladas pela acusação e 8 (oito) pela defesa. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2779,
                                                                                        "texto": "Nesse número não se compreendem as que não prestem compromisso e as referidas. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2781,
                                                                                        "texto": "A parte poderá desistir da inquirição de qualquer das testemunhas arroladas, ressalvado o disposto no art. 209 deste Código. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "402º",
                                                                        "rotulo": "Art. 402º.",
                                                                        "linha": 2784,
                                                                        "caput": "Produzidas as provas, ao final da audiência, o Ministério Público, o querelante e o assistente e, a seguir, o acusado poderão requerer diligências cuja necessidade se origine de circunstâncias ou fatos apurados na instrução. ."
                                                                },
                                                                {
                                                                        "numero": "403º",
                                                                        "rotulo": "Art. 403º.",
                                                                        "linha": 2787,
                                                                        "caput": "Não havendo requerimento de diligências, ou sendo indeferido, serão oferecidas alegações finais orais por 20 (vinte) minutos, respectivamente, pela acusação e pela defesa, prorrogáveis por mais 10 (dez), proferindo o juiz, a seguir, sentença. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2789,
                                                                                        "texto": "Havendo mais de um acusado, o tempo previsto para a defesa de cada um será individual. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2791,
                                                                                        "texto": "Ao assistente do Ministério Público, após a manifestação desse, serão concedidos 10 (dez) minutos, prorrogando-se por igual período o tempo de manifestação da defesa. ."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 2793,
                                                                                        "texto": "O juiz poderá, considerada a complexidade do caso ou o número de acusados, conceder às partes o prazo de 5 (cinco) dias sucessivamente para a apresentação de memoriais. Nesse caso, terá o prazo de 10 (dez) dias para proferir a sentença. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "404º",
                                                                        "rotulo": "Art. 404º.",
                                                                        "linha": 2796,
                                                                        "caput": "Ordenado diligência considerada imprescindível, de ofício ou a requerimento da parte, a audiência será concluída sem as alegações finais. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 2798,
                                                                                        "texto": "Realizada, em seguida, a diligência determinada, as partes apresentarão, no prazo sucessivo de 5 (cinco) dias, suas alegações finais, por memorial, e, no prazo de 10 (dez) dias, o juiz proferirá a sentença. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "405º",
                                                                        "rotulo": "Art. 405º.",
                                                                        "linha": 2801,
                                                                        "caput": "Do ocorrido em audiência será lavrado termo em livro próprio, assinado pelo juiz e pelas partes, contendo breve resumo dos fatos relevantes nela ocorridos. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 2803,
                                                                                        "texto": "Sempre que possível, o registro dos depoimentos do investigado, indiciado, ofendido e testemunhas será feito pelos meios ou recursos de gravação magnética, estenotipia, digital ou técnica similar, inclusive audiovisual, destinada a obter maior fidelidade das informações . ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 2805,
                                                                                        "texto": "No caso de registro por meio audiovisual, será encaminhado às partes cópia do registro original, sem necessidade de transcrição. ."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 3051,
                                                        "divisoes": [
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção I",
                                                                        "linha": 3056,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "406º",
                                                                                        "rotulo": "Art. 406º.",
                                                                                        "linha": 3060,
                                                                                        "caput": "O juiz, ao receber a denúncia ou a queixa, ordenará a citação do acusado para responder a acusação, por escrito, no prazo de 10 (dez) dias.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3062,
                                                                                                        "texto": "O prazo previsto no caputdeste artigo será contado a partir do efetivo cumprimento do mandado ou do comparecimento, em juízo, do acusado ou de defensor constituído, no caso de citação inválida ou por edital."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3064,
                                                                                                        "texto": "A acusação deverá arrolar testemunhas, até o máximo de 8 (oito), na denúncia ou na queixa."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3066,
                                                                                                        "texto": "Na resposta, o acusado poderá argüir preliminares e alegar tudo que interesse a sua defesa, oferecer documentos e justificações, especificar as provas pretendidas e arrolar testemunhas, até o máximo de 8 (oito), qualificando-as e requerendo sua intimação, quando necessário."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "407º",
                                                                                        "rotulo": "Art. 407º.",
                                                                                        "linha": 3068,
                                                                                        "caput": "As exceções serão processadas em apartado, nos termos dos arts. 95 a 112 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "408º",
                                                                                        "rotulo": "Art. 408º.",
                                                                                        "linha": 3070,
                                                                                        "caput": "Não apresentada a resposta no prazo legal, o juiz nomeará defensor para oferecê-la em até 10 (dez) dias, concedendo-lhe vista dos autos."
                                                                                },
                                                                                {
                                                                                        "numero": "409º",
                                                                                        "rotulo": "Art. 409º.",
                                                                                        "linha": 3072,
                                                                                        "caput": "Apresentada a defesa, o juiz ouvirá o Ministério Público ou o querelante sobre preliminares e documentos, em 5 (cinco) dias."
                                                                                },
                                                                                {
                                                                                        "numero": "410º",
                                                                                        "rotulo": "Art. 410º.",
                                                                                        "linha": 3074,
                                                                                        "caput": "O juiz determinará a inquirição das testemunhas e a realização das diligências requeridas pelas partes, no prazo máximo de 10 (dez) dias."
                                                                                },
                                                                                {
                                                                                        "numero": "411º",
                                                                                        "rotulo": "Art. 411º.",
                                                                                        "linha": 3076,
                                                                                        "caput": "Na audiência de instrução, proceder-se-á à tomada de declarações do ofendido, se possível, à inquirição das testemunhas arroladas pela acusação e pela defesa, nesta ordem, bem como aos esclarecimentos dos peritos, às acareações e ao reconhecimento de pessoas e coisas, interrogando-se, em seguida, o acusado e procedendo-se o debate.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3078,
                                                                                                        "texto": "Os esclarecimentos dos peritos dependerão de prévio requerimento e de deferimento pelo juiz."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3080,
                                                                                                        "texto": "As provas serão produzidas em uma só audiência, podendo o juiz indeferir as consideradas irrelevantes, impertinentes ou protelatórias."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3082,
                                                                                                        "texto": "Encerrada a instrução probatória, observar-se-á, se for o caso, o disposto no art. 384 deste Código."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "4",
                                                                                                        "rotulo": "§ 4",
                                                                                                        "linha": 3084,
                                                                                                        "texto": "As alegações serão orais, concedendo-se a palavra, respectivamente, à acusação e à defesa, pelo prazo de 20 (vinte) minutos, prorrogáveis por mais 10 (dez)."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "5",
                                                                                                        "rotulo": "§ 5",
                                                                                                        "linha": 3086,
                                                                                                        "texto": "Havendo mais de 1 (um) acusado, o tempo previsto para a acusação e a defesa de cada um deles será individual."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "6",
                                                                                                        "rotulo": "§ 6",
                                                                                                        "linha": 3088,
                                                                                                        "texto": "Ao assistente do Ministério Público, após a manifestação deste, serão concedidos 10 (dez) minutos, prorrogando-se por igual período o tempo de manifestação da defesa."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "7",
                                                                                                        "rotulo": "§ 7",
                                                                                                        "linha": 3090,
                                                                                                        "texto": "Nenhum ato será adiado, salvo quando imprescindível à prova faltante, determinando o juiz a condução coercitiva de quem deva comparecer."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "8",
                                                                                                        "rotulo": "§ 8",
                                                                                                        "linha": 3092,
                                                                                                        "texto": "A testemunha que comparecer será inquirida, independentemente da suspensão da audiência, observada em qualquer caso a ordem estabelecida no caputdeste artigo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "9",
                                                                                                        "rotulo": "§ 9",
                                                                                                        "linha": 3094,
                                                                                                        "texto": "Encerrados os debates, o juiz proferirá a sua decisão, ou o fará em 10 (dez) dias, ordenando que os autos para isso lhe sejam conclusos."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "412º",
                                                                                        "rotulo": "Art. 412º.",
                                                                                        "linha": 3096,
                                                                                        "caput": "O procedimento será concluído no prazo máximo de 90 (noventa) dias."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção II",
                                                                        "linha": 3098,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "413º",
                                                                                        "rotulo": "Art. 413º.",
                                                                                        "linha": 3103,
                                                                                        "caput": "O juiz, fundamentadamente, pronunciará o acusado, se convencido da materialidade do fato e da existência de indícios suficientes de autoria ou de participação.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3105,
                                                                                                        "texto": "A fundamentação da pronúncia limitar-se-á à indicação da materialidade do fato e da existência de indícios suficientes de autoria ou de participação, devendo o juiz declarar o dispositivo legal em que julgar incurso o acusado e especificar as circunstâncias qualificadoras e as causas de aumento de pena."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3107,
                                                                                                        "texto": "Se o crime for afiançável, o juiz arbitrará o valor da fiança para a concessão ou manutenção da liberdade provisória."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3109,
                                                                                                        "texto": "O juiz decidirá, motivadamente, no caso de manutenção, revogação ou substituição da prisão ou medida restritiva de liberdade anteriormente decretada e, tratando-se de acusado solto, sobre a necessidade da decretação da prisão ou imposição de quaisquer das medidas previstas no Título IX do Livro I deste Código."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "414º",
                                                                                        "rotulo": "Art. 414º.",
                                                                                        "linha": 3111,
                                                                                        "caput": "Não se convencendo da materialidade do fato ou da existência de indícios suficientes de autoria ou de participação, o juiz, fundamentadamente, impronunciará o acusado.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3113,
                                                                                                        "texto": "Enquanto não ocorrer a extinção da punibilidade, poderá ser formulada nova denúncia ou queixa se houver prova nova."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "415º",
                                                                                        "rotulo": "Art. 415º.",
                                                                                        "linha": 3115,
                                                                                        "caput": "O juiz, fundamentadamente, absolverá desde logo o acusado, quando:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3117,
                                                                                                        "texto": "provada a inexistência do fato;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3119,
                                                                                                        "texto": "provado não ser ele autor ou partícipe do fato;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3121,
                                                                                                        "texto": "fato não constituir infração penal;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 3123,
                                                                                                        "texto": "demonstrada causa de isenção de pena ou de exclusão do crime."
                                                                                                }
                                                                                        ],
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3125,
                                                                                                        "texto": "Não se aplica o disposto no inciso IV do caputdeste artigo ao caso de inimputabilidade prevista no caputdo art. 26 do Decreto-Lei no 2.848, de 7 de dezembro de 1940 – Código Penal, salvo quando esta for a única tese defensiva."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "416º",
                                                                                        "rotulo": "Art. 416º.",
                                                                                        "linha": 3127,
                                                                                        "caput": "Contra a sentença de impronúncia ou de absolvição sumária caberá apelação."
                                                                                },
                                                                                {
                                                                                        "numero": "417º",
                                                                                        "rotulo": "Art. 417º.",
                                                                                        "linha": 3129,
                                                                                        "caput": "Se houver indícios de autoria ou de participação de outras pessoas não incluídas na acusação, o juiz, ao pronunciar ou impronunciar o acusado, determinará o retorno dos autos ao Ministério Público, por 15 (quinze) dias, aplicável, no que couber, o art. 80 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "418º",
                                                                                        "rotulo": "Art. 418º.",
                                                                                        "linha": 3131,
                                                                                        "caput": "O juiz poderá dar ao fato definição jurídica diversa da constante da acusação, embora o acusado fique sujeito a pena mais grave."
                                                                                },
                                                                                {
                                                                                        "numero": "419º",
                                                                                        "rotulo": "Art. 419º.",
                                                                                        "linha": 3133,
                                                                                        "caput": "Quando o juiz se convencer, em discordância com a acusação, da existência de crime diverso dos referidos no § 1o do art. 74 deste Código e não for competente para o julgamento, remeterá os autos ao juiz que o seja.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3135,
                                                                                                        "texto": "Remetidos os autos do processo a outro juiz, à disposição deste ficará o acusado preso."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "420º",
                                                                                        "rotulo": "Art. 420º.",
                                                                                        "linha": 3137,
                                                                                        "caput": "A intimação da decisão de pronúncia será feita:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3139,
                                                                                                        "texto": "pessoalmente ao acusado, ao defensor nomeado e ao Ministério Público;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3141,
                                                                                                        "texto": "ao defensor constituído, ao querelante e ao assistente do Ministério Público, na forma do disposto no § 1o do art. 370 deste Código."
                                                                                                }
                                                                                        ],
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3143,
                                                                                                        "texto": "Será intimado por edital o acusado solto que não for encontrado."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "421º",
                                                                                        "rotulo": "Art. 421º.",
                                                                                        "linha": 3145,
                                                                                        "caput": "Preclusa a decisão de pronúncia, os autos serão encaminhados ao juiz presidente do Tribunal do Júri.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3147,
                                                                                                        "texto": "Ainda que preclusa a decisão de pronúncia, havendo circunstância superveniente que altere a classificação do crime, o juiz ordenará a remessa dos autos ao Ministério Público."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3149,
                                                                                                        "texto": "Em seguida, os autos serão conclusos ao juiz para decisão."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção III",
                                                                        "linha": 3151,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "422º",
                                                                                        "rotulo": "Art. 422º.",
                                                                                        "linha": 3156,
                                                                                        "caput": "Ao receber os autos, o presidente do Tribunal do Júri determinará a intimação do órgão do Ministério Público ou do querelante, no caso de queixa, e do defensor, para, no prazo de 5 (cinco) dias, apresentarem rol de testemunhas que irão depor em plenário, até o máximo de 5 (cinco), oportunidade em que poderão juntar documentos e requerer diligência."
                                                                                },
                                                                                {
                                                                                        "numero": "423º",
                                                                                        "rotulo": "Art. 423º.",
                                                                                        "linha": 3158,
                                                                                        "caput": "Deliberando sobre os requerimentos de provas a serem produzidas ou exibidas no plenário do júri, e adotadas as providências devidas, o juiz presidente:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3160,
                                                                                                        "texto": "ordenará as diligências necessárias para sanar qualquer nulidade ou esclarecer fato que interesse ao julgamento da causa;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3162,
                                                                                                        "texto": "fará relatório sucinto do processo, determinando sua inclusão em pauta da reunião do Tribunal do Júri."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "424º",
                                                                                        "rotulo": "Art. 424º.",
                                                                                        "linha": 3164,
                                                                                        "caput": "Quando a lei local de organização judiciária não atribuir ao presidente do Tribunal do Júri o preparo para julgamento, o juiz competente remeter-lhe-á os autos do processo preparado até 5 (cinco) dias antes do sorteio a que se refere o art. 433 deste Código.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3166,
                                                                                                        "texto": "Deverão ser remetidos, também, os processos preparados até o encerramento da reunião, para a realização de julgamento."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção IV",
                                                                        "linha": 3168,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "425º",
                                                                                        "rotulo": "Art. 425º.",
                                                                                        "linha": 3173,
                                                                                        "caput": "Anualmente, serão alistados pelo presidente do Tribunal do Júri de 800 (oitocentos) a 1.500 (um mil e quinhentos) jurados nas comarcas de mais de 1.000.000 (um milhão) de habitantes, de 300 (trezentos) a 700 (setecentos) nas comarcas de mais de 100.000 (cem mil) habitantes e de 80 (oitenta) a 400 (quatrocentos) nas comarcas de menor população.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3175,
                                                                                                        "texto": "Nas comarcas onde for necessário, poderá ser aumentado o número de jurados e, ainda, organizada lista de suplentes, depositadas as cédulas em urna especial, com as cautelas mencionadas na parte final do § 3o do art. 426 deste Código."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3177,
                                                                                                        "texto": "O juiz presidente requisitará às autoridades locais, associações de classe e de bairro, entidades associativas e culturais, instituições de ensino em geral, universidades, sindicatos, repartições públicas e outros núcleos comunitários a indicação de pessoas que reúnam as condições para exercer a função de jurado."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "426º",
                                                                                        "rotulo": "Art. 426º.",
                                                                                        "linha": 3179,
                                                                                        "caput": "A lista geral dos jurados, com indicação das respectivas profissões, será publicada pela imprensa até o dia 10 de outubro de cada ano e divulgada em editais afixados à porta do Tribunal do Júri.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3181,
                                                                                                        "texto": "A lista poderá ser alterada, de ofício ou mediante reclamação de qualquer do povo ao juiz presidente até o dia 10 de novembro, data de sua publicação definitiva."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3183,
                                                                                                        "texto": "Juntamente com a lista, serão transcritos os arts. 436 a 446 deste Código."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3185,
                                                                                                        "texto": "Os nomes e endereços dos alistados, em cartões iguais, após serem verificados na presença do Ministério Público, de advogado indicado pela Seção local da Ordem dos Advogados do Brasil e de defensor indicado pelas Defensorias Públicas competentes, permanecerão guardados em urna fechada a chave, sob a responsabilidade do juiz presidente."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "4",
                                                                                                        "rotulo": "§ 4",
                                                                                                        "linha": 3187,
                                                                                                        "texto": "O jurado que tiver integrado o Conselho de Sentença nos 12 (doze) meses que antecederem à publicação da lista geral fica dela excluído."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "5",
                                                                                                        "rotulo": "§ 5",
                                                                                                        "linha": 3189,
                                                                                                        "texto": "Anualmente, a lista geral de jurados será, obrigatoriamente, completada."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção V",
                                                                        "linha": 3191,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "427º",
                                                                                        "rotulo": "Art. 427º.",
                                                                                        "linha": 3196,
                                                                                        "caput": "Se o interesse da ordem pública o reclamar ou houver dúvida sobre a imparcialidade do júri ou a segurança pessoal do acusado, o Tribunal, a requerimento do Ministério Público, do assistente, do querelante ou do acusado ou mediante representação do juiz competente, poderá determinar o desaforamento do julgamento para outra comarca da mesma região, onde não existam aqueles motivos, preferindo-se as mais próximas.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3198,
                                                                                                        "texto": "O pedido de desaforamento será distribuído imediatamente e terá preferência de julgamento na Câmara ou Turma competente."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3200,
                                                                                                        "texto": "Sendo relevantes os motivos alegados, o relator poderá determinar, fundamentadamente, a suspensão do julgamento pelo júri."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3202,
                                                                                                        "texto": "Será ouvido o juiz presidente, quando a medida não tiver sido por ele solicitada."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "4",
                                                                                                        "rotulo": "§ 4",
                                                                                                        "linha": 3204,
                                                                                                        "texto": "Na pendência de recurso contra a decisão de pronúncia ou quando efetivado o julgamento, não se admitirá o pedido de desaforamento, salvo, nesta última hipótese, quanto a fato ocorrido durante ou após a realização de julgamento anulado."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "428º",
                                                                                        "rotulo": "Art. 428º.",
                                                                                        "linha": 3206,
                                                                                        "caput": "O desaforamento também poderá ser determinado, em razão do comprovado excesso de serviço, ouvidos o juiz presidente e a parte contrária, se o julgamento não puder ser realizado no prazo de 6 (seis) meses, contado do trânsito em julgado da decisão de pronúncia.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3208,
                                                                                                        "texto": "Para a contagem do prazo referido neste artigo, não se computará o tempo de adiamentos, diligências ou incidentes de interesse da defesa."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3210,
                                                                                                        "texto": "Não havendo excesso de serviço ou existência de processos aguardando julgamento em quantidade que ultrapasse a possibilidade de apreciação pelo Tribunal do Júri, nas reuniões periódicas previstas para o exercício, o acusado poderá requerer ao Tribunal que determine a imediata realização do julgamento."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção VI",
                                                                        "linha": 3212,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "429º",
                                                                                        "rotulo": "Art. 429º.",
                                                                                        "linha": 3217,
                                                                                        "caput": "Salvo motivo relevante que autorize alteração na ordem dos julgamentos, terão preferência:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3219,
                                                                                                        "texto": "os acusados presos;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3221,
                                                                                                        "texto": "dentre os acusados presos, aqueles que estiverem há mais tempo na prisão;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3223,
                                                                                                        "texto": "em igualdade de condições, os precedentemente pronunciados."
                                                                                                }
                                                                                        ],
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3225,
                                                                                                        "texto": "Antes do dia designado para o primeiro julgamento da reunião periódica, será afixada na porta do edifício do Tribunal do Júri a lista dos processos a serem julgados, obedecida a ordem prevista no caputdeste artigo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3227,
                                                                                                        "texto": "O juiz presidente reservará datas na mesma reunião periódica para a inclusão de processo que tiver o julgamento adiado."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "430º",
                                                                                        "rotulo": "Art. 430º.",
                                                                                        "linha": 3229,
                                                                                        "caput": "O assistente somente será admitido se tiver requerido sua habilitação até 5 (cinco) dias antes da data da sessão na qual pretenda atuar."
                                                                                },
                                                                                {
                                                                                        "numero": "431º",
                                                                                        "rotulo": "Art. 431º.",
                                                                                        "linha": 3231,
                                                                                        "caput": "Estando o processo em ordem, o juiz presidente mandará intimar as partes, o ofendido, se for possível, as testemunhas e os peritos, quando houver requerimento, para a sessão de instrução e julgamento, observando, no que couber, o disposto no art. 420 deste Código."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção VII",
                                                                        "linha": 3233,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "432º",
                                                                                        "rotulo": "Art. 432º.",
                                                                                        "linha": 3238,
                                                                                        "caput": "Em seguida à organização da pauta, o juiz presidente determinará a intimação do Ministério Público, da Ordem dos Advogados do Brasil e da Defensoria Pública para acompanharem, em dia e hora designados, o sorteio dos jurados que atuarão na reunião periódica."
                                                                                },
                                                                                {
                                                                                        "numero": "433º",
                                                                                        "rotulo": "Art. 433º.",
                                                                                        "linha": 3240,
                                                                                        "caput": "O sorteio, presidido pelo juiz, far-se-á a portas abertas, cabendo-lhe retirar as cédulas até completar o número de 25 (vinte e cinco) jurados, para a reunião periódica ou extraordinária.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3242,
                                                                                                        "texto": "O sorteio será realizado entre o 15o (décimo quinto) e o 10o (décimo) dia útil antecedente à instalação da reunião."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3244,
                                                                                                        "texto": "A audiência de sorteio não será adiada pelo não comparecimento das partes."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3246,
                                                                                                        "texto": "O jurado não sorteado poderá ter o seu nome novamente incluído para as reuniões futuras."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "434º",
                                                                                        "rotulo": "Art. 434º.",
                                                                                        "linha": 3248,
                                                                                        "caput": "Os jurados sorteados serão convocados pelo correio ou por qualquer outro meio hábil para comparecer no dia e hora designados para a reunião, sob as penas da lei.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3250,
                                                                                                        "texto": "No mesmo expediente de convocação serão transcritos os arts. 436 a 446 deste Código."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "435º",
                                                                                        "rotulo": "Art. 435º.",
                                                                                        "linha": 3252,
                                                                                        "caput": "Serão afixados na porta do edifício do Tribunal do Júri a relação dos jurados convocados, os nomes do acusado e dos procuradores das partes, além do dia, hora e local das sessões de instrução e julgamento."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção VIII",
                                                                        "linha": 3254,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "436º",
                                                                                        "rotulo": "Art. 436º.",
                                                                                        "linha": 3259,
                                                                                        "caput": "O serviço do júri é obrigatório. O alistamento compreenderá os cidadãos maiores de 18 (dezoito) anos de notória idoneidade.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3261,
                                                                                                        "texto": "Nenhum cidadão poderá ser excluído dos trabalhos do júri ou deixar de ser alistado em razão de cor ou etnia, raça, credo, sexo, profissão, classe social ou econômica, origem ou grau de instrução."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3263,
                                                                                                        "texto": "A recusa injustificada ao serviço do júri acarretará multa no valor de 1 (um) a 10 (dez) salários mínimos, a critério do juiz, de acordo com a condição econômica do jurado."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "437º",
                                                                                        "rotulo": "Art. 437º.",
                                                                                        "linha": 3265,
                                                                                        "caput": "Estão isentos do serviço do júri:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3267,
                                                                                                        "texto": "Presidente da República e os Ministros de Estado;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3269,
                                                                                                        "texto": "os Governadores e seus respectivos Secretários;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3271,
                                                                                                        "texto": "os membros do Congresso Nacional, das Assembléias Legislativas e das Câmaras Distrital e Municipais;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 3273,
                                                                                                        "texto": "os Prefeitos Municipais;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 3275,
                                                                                                        "texto": "os Magistrados e membros do Ministério Público e da Defensoria Pública;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 3277,
                                                                                                        "texto": "os servidores do Poder Judiciário, do Ministério Público e da Defensoria Pública;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VII",
                                                                                                        "rotulo": "VII",
                                                                                                        "linha": 3279,
                                                                                                        "texto": "as autoridades e os servidores da polícia e da segurança pública;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VIII",
                                                                                                        "rotulo": "VIII",
                                                                                                        "linha": 3281,
                                                                                                        "texto": "os militares em serviço ativo;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IX",
                                                                                                        "rotulo": "IX",
                                                                                                        "linha": 3283,
                                                                                                        "texto": "os cidadãos maiores de 70 (setenta) anos que requeiram sua dispensa;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "X",
                                                                                                        "rotulo": "X",
                                                                                                        "linha": 3285,
                                                                                                        "texto": "aqueles que o requererem, demonstrando justo impedimento."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "438º",
                                                                                        "rotulo": "Art. 438º.",
                                                                                        "linha": 3287,
                                                                                        "caput": "A recusa ao serviço do júri fundada em convicção religiosa, filosófica ou política importará no dever de prestar serviço alternativo, sob pena de suspensão dos direitos políticos, enquanto não prestar o serviço imposto.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3289,
                                                                                                        "texto": "Entende-se por serviço alternativo o exercício de atividades de caráter administrativo, assistencial, filantrópico ou mesmo produtivo, no Poder Judiciário, na Defensoria Pública, no Ministério Público ou em entidade conveniada para esses fins."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3291,
                                                                                                        "texto": "O juiz fixará o serviço alternativo atendendo aos princípios da proporcionalidade e da razoabilidade."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "439º",
                                                                                        "rotulo": "Art. 439º.",
                                                                                        "linha": 3294,
                                                                                        "caput": "O exercício efetivo da função de jurado constituirá serviço público relevante e estabelecerá presunção de idoneidade moral. ."
                                                                                },
                                                                                {
                                                                                        "numero": "440º",
                                                                                        "rotulo": "Art. 440º.",
                                                                                        "linha": 3296,
                                                                                        "caput": "Constitui também direito do jurado, na condição do art. 439 deste Código, preferência, em igualdade de condições, nas licitações públicas e no provimento, mediante concurso, de cargo ou função pública, bem como nos casos de promoção funcional ou remoção voluntária."
                                                                                },
                                                                                {
                                                                                        "numero": "441º",
                                                                                        "rotulo": "Art. 441º.",
                                                                                        "linha": 3298,
                                                                                        "caput": "Nenhum desconto será feito nos vencimentos ou salário do jurado sorteado que comparecer à sessão do júri."
                                                                                },
                                                                                {
                                                                                        "numero": "442º",
                                                                                        "rotulo": "Art. 442º.",
                                                                                        "linha": 3300,
                                                                                        "caput": "Ao jurado que, sem causa legítima, deixar de comparecer no dia marcado para a sessão ou retirar-se antes de ser dispensado pelo presidente será aplicada multa de 1 (um) a 10 (dez) salários mínimos, a critério do juiz, de acordo com a sua condição econômica."
                                                                                },
                                                                                {
                                                                                        "numero": "443º",
                                                                                        "rotulo": "Art. 443º.",
                                                                                        "linha": 3302,
                                                                                        "caput": "Somente será aceita escusa fundada em motivo relevante devidamente comprovado e apresentada, ressalvadas as hipóteses de força maior, até o momento da chamada dos jurados."
                                                                                },
                                                                                {
                                                                                        "numero": "444º",
                                                                                        "rotulo": "Art. 444º.",
                                                                                        "linha": 3304,
                                                                                        "caput": "O jurado somente será dispensado por decisão motivada do juiz presidente, consignada na ata dos trabalhos."
                                                                                },
                                                                                {
                                                                                        "numero": "445º",
                                                                                        "rotulo": "Art. 445º.",
                                                                                        "linha": 3306,
                                                                                        "caput": "O jurado, no exercício da função ou a pretexto de exercê-la, será responsável criminalmente nos mesmos termos em que o são os juízes togados."
                                                                                },
                                                                                {
                                                                                        "numero": "446º",
                                                                                        "rotulo": "Art. 446º.",
                                                                                        "linha": 3308,
                                                                                        "caput": "Aos suplentes, quando convocados, serão aplicáveis os dispositivos referentes às dispensas, faltas e escusas e à equiparação de responsabilidade penal prevista no art. 445 deste Código."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção IX",
                                                                        "linha": 3310,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "447º",
                                                                                        "rotulo": "Art. 447º.",
                                                                                        "linha": 3315,
                                                                                        "caput": "O Tribunal do Júri é composto por 1 (um) juiz togado, seu presidente e por 25 (vinte e cinco) jurados que serão sorteados dentre os alistados, 7 (sete) dos quais constituirão o Conselho de Sentença em cada sessão de julgamento."
                                                                                },
                                                                                {
                                                                                        "numero": "448º",
                                                                                        "rotulo": "Art. 448º.",
                                                                                        "linha": 3317,
                                                                                        "caput": "São impedidos de servir no mesmo Conselho:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3319,
                                                                                                        "texto": "marido e mulher;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3321,
                                                                                                        "texto": "ascendente e descendente;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3323,
                                                                                                        "texto": "sogro e genro ou nora;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 3325,
                                                                                                        "texto": "irmãos e cunhados, durante o cunhadio;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 3327,
                                                                                                        "texto": "tio e sobrinho;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 3329,
                                                                                                        "texto": "padrasto, madrasta ou enteado."
                                                                                                }
                                                                                        ],
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3331,
                                                                                                        "texto": "O mesmo impedimento ocorrerá em relação às pessoas que mantenham união estável reconhecida como entidade familiar."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3333,
                                                                                                        "texto": "Aplicar-se-á aos jurados o disposto sobre os impedimentos, a suspeição e as incompatibilidades dos juízes togados."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "449º",
                                                                                        "rotulo": "Art. 449º.",
                                                                                        "linha": 3335,
                                                                                        "caput": "Não poderá servir o jurado que:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3337,
                                                                                                        "texto": "tiver funcionado em julgamento anterior do mesmo processo, independentemente da causa determinante do julgamento posterior;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3339,
                                                                                                        "texto": "no caso do concurso de pessoas, houver integrado o Conselho de Sentença que julgou o outro acusado;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3341,
                                                                                                        "texto": "tiver manifestado prévia disposição para condenar ou absolver o acusado ."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "450º",
                                                                                        "rotulo": "Art. 450º.",
                                                                                        "linha": 3343,
                                                                                        "caput": "Dos impedidos entre si por parentesco ou relação de convivência, servirá o que houver sido sorteado em primeiro lugar."
                                                                                },
                                                                                {
                                                                                        "numero": "451º",
                                                                                        "rotulo": "Art. 451º.",
                                                                                        "linha": 3345,
                                                                                        "caput": "Os jurados excluídos por impedimento, suspeição ou incompatibilidade serão considerados para a constituição do número legal exigível para a realização da sessão."
                                                                                },
                                                                                {
                                                                                        "numero": "452º",
                                                                                        "rotulo": "Art. 452º.",
                                                                                        "linha": 3347,
                                                                                        "caput": "O mesmo Conselho de Sentença poderá conhecer de mais de um processo, no mesmo dia, se as partes o aceitarem, hipótese em que seus integrantes deverão prestar novo compromisso."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção X",
                                                                        "linha": 3349,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "453º",
                                                                                        "rotulo": "Art. 453º.",
                                                                                        "linha": 3354,
                                                                                        "caput": "O Tribunal do Júri reunir-se-á para as sessões de instrução e julgamento nos períodos e na forma estabelecida pela lei local de organização judiciária."
                                                                                },
                                                                                {
                                                                                        "numero": "454º",
                                                                                        "rotulo": "Art. 454º.",
                                                                                        "linha": 3356,
                                                                                        "caput": "Até o momento de abertura dos trabalhos da sessão, o juiz presidente decidirá os casos de isenção e dispensa de jurados e o pedido de adiamento de julgamento, mandando consignar em ata as deliberações."
                                                                                },
                                                                                {
                                                                                        "numero": "455º",
                                                                                        "rotulo": "Art. 455º.",
                                                                                        "linha": 3358,
                                                                                        "caput": "Se o Ministério Público não comparecer, o juiz presidente adiará o julgamento para o primeiro dia desimpedido da mesma reunião, cientificadas as partes e as testemunhas.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3360,
                                                                                                        "texto": "Se a ausência não for justificada, o fato será imediatamente comunicado ao Procurador-Geral de Justiça com a data designada para a nova sessão."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "456º",
                                                                                        "rotulo": "Art. 456º.",
                                                                                        "linha": 3362,
                                                                                        "caput": "Se a falta, sem escusa legítima, for do advogado do acusado, e se outro não for por este constituído, o fato será imediatamente comunicado ao presidente da seccional da Ordem dos Advogados do Brasil, com a data designada para a nova sessão.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3364,
                                                                                                        "texto": "Não havendo escusa legítima, o julgamento será adiado somente uma vez, devendo o acusado ser julgado quando chamado novamente."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3366,
                                                                                                        "texto": "Na hipótese do § 1o deste artigo, o juiz intimará a Defensoria Pública para o novo julgamento, que será adiado para o primeiro dia desimpedido, observado o prazo mínimo de 10 (dez) dias."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "457º",
                                                                                        "rotulo": "Art. 457º.",
                                                                                        "linha": 3368,
                                                                                        "caput": "O julgamento não será adiado pelo não comparecimento do acusado solto, do assistente ou do advogado do querelante, que tiver sido regularmente intimado.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3370,
                                                                                                        "texto": "Os pedidos de adiamento e as justificações de não comparecimento deverão ser, salvo comprovado motivo de força maior, previamente submetidos à apreciação do juiz presidente do Tribunal do Júri."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3372,
                                                                                                        "texto": "Se o acusado preso não for conduzido, o julgamento será adiado para o primeiro dia desimpedido da mesma reunião, salvo se houver pedido de dispensa de comparecimento subscrito por ele e seu defensor."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "458º",
                                                                                        "rotulo": "Art. 458º.",
                                                                                        "linha": 3374,
                                                                                        "caput": "Se a testemunha, sem justa causa, deixar de comparecer, o juiz presidente, sem prejuízo da ação penal pela desobediência, aplicar-lhe-á a multa prevista no § 2o do art. 436 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "459º",
                                                                                        "rotulo": "Art. 459º.",
                                                                                        "linha": 3376,
                                                                                        "caput": "Aplicar-se-á às testemunhas a serviço do Tribunal do Júri o disposto no art. 441 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "460º",
                                                                                        "rotulo": "Art. 460º.",
                                                                                        "linha": 3378,
                                                                                        "caput": "Antes de constituído o Conselho de Sentença, as testemunhas serão recolhidas a lugar onde umas não possam ouvir os depoimentos das outras."
                                                                                },
                                                                                {
                                                                                        "numero": "461º",
                                                                                        "rotulo": "Art. 461º.",
                                                                                        "linha": 3380,
                                                                                        "caput": "O julgamento não será adiado se a testemunha deixar de comparecer, salvo se uma das partes tiver requerido a sua intimação por mandado, na oportunidade de que trata o art. 422 deste Código, declarando não prescindir do depoimento e indicando a sua localização.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3382,
                                                                                                        "texto": "Se, intimada, a testemunha não comparecer, o juiz presidente suspenderá os trabalhos e mandará conduzi-la ou adiará o julgamento para o primeiro dia desimpedido, ordenando a sua condução."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3384,
                                                                                                        "texto": "O julgamento será realizado mesmo na hipótese de a testemunha não ser encontrada no local indicado, se assim for certificado por oficial de justiça."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "462º",
                                                                                        "rotulo": "Art. 462º.",
                                                                                        "linha": 3386,
                                                                                        "caput": "Realizadas as diligências referidas nos arts. 454 a 461 deste Código, o juiz presidente verificará se a urna contém as cédulas dos 25 (vinte e cinco) jurados sorteados, mandando que o escrivão proceda à chamada deles."
                                                                                },
                                                                                {
                                                                                        "numero": "463º",
                                                                                        "rotulo": "Art. 463º.",
                                                                                        "linha": 3388,
                                                                                        "caput": "Comparecendo, pelo menos, 15 (quinze) jurados, o juiz presidente declarará instalados os trabalhos, anunciando o processo que será submetido a julgamento.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3390,
                                                                                                        "texto": "O oficial de justiça fará o pregão, certificando a diligência nos autos."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3392,
                                                                                                        "texto": "Os jurados excluídos por impedimento ou suspeição serão computados para a constituição do número legal."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "464º",
                                                                                        "rotulo": "Art. 464º.",
                                                                                        "linha": 3394,
                                                                                        "caput": "Não havendo o número referido no art. 463 deste Código, proceder-se-á ao sorteio de tantos suplentes quantos necessários, e designar-se-á nova data para a sessão do júri."
                                                                                },
                                                                                {
                                                                                        "numero": "465º",
                                                                                        "rotulo": "Art. 465º.",
                                                                                        "linha": 3396,
                                                                                        "caput": "Os nomes dos suplentes serão consignados em ata, remetendo-se o expediente de convocação, com observância do disposto nos arts. 434 e 435 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "466º",
                                                                                        "rotulo": "Art. 466º.",
                                                                                        "linha": 3398,
                                                                                        "caput": "Antes do sorteio dos membros do Conselho de Sentença, o juiz presidente esclarecerá sobre os impedimentos, a suspeição e as incompatibilidades constantes dos arts. 448 e 449 deste Código.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3400,
                                                                                                        "texto": "O juiz presidente também advertirá os jurados de que, uma vez sorteados, não poderão comunicar-se entre si e com outrem, nem manifestar sua opinião sobre o processo, sob pena de exclusão do Conselho e multa, na forma do § 2o do art. 436 deste Código."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3402,
                                                                                                        "texto": "A incomunicabilidade será certificada nos autos pelo oficial de justiça."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "467º",
                                                                                        "rotulo": "Art. 467º.",
                                                                                        "linha": 3404,
                                                                                        "caput": "Verificando que se encontram na urna as cédulas relativas aos jurados presentes, o juiz presidente sorteará 7 (sete) dentre eles para a formação do Conselho de Sentença."
                                                                                },
                                                                                {
                                                                                        "numero": "468º",
                                                                                        "rotulo": "Art. 468º.",
                                                                                        "linha": 3406,
                                                                                        "caput": "À medida que as cédulas forem sendo retiradas da urna, o juiz presidente as lerá, e a defesa e, depois dela, o Ministério Público poderão recusar os jurados sorteados, até 3 (três) cada parte, sem motivar a recusa.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3408,
                                                                                                        "texto": "O jurado recusado imotivadamente por qualquer das partes será excluído daquela sessão de instrução e julgamento, prosseguindo-se o sorteio para a composição do Conselho de Sentença com os jurados remanescentes."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "469º",
                                                                                        "rotulo": "Art. 469º.",
                                                                                        "linha": 3410,
                                                                                        "caput": "Se forem 2 (dois) ou mais os acusados, as recusas poderão ser feitas por um só defensor.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3412,
                                                                                                        "texto": "A separação dos julgamentos somente ocorrerá se, em razão das recusas, não for obtido o número mínimo de 7 (sete) jurados para compor o Conselho de Sentença."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3414,
                                                                                                        "texto": "Determinada a separação dos julgamentos, será julgado em primeiro lugar o acusado a quem foi atribuída a autoria do fato ou, em caso de co-autoria, aplicar-se-á o critério de preferência disposto no art. 429 deste Código."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "470º",
                                                                                        "rotulo": "Art. 470º.",
                                                                                        "linha": 3416,
                                                                                        "caput": "Desacolhida a argüição de impedimento, de suspeição ou de incompatibilidade contra o juiz presidente do Tribunal do Júri, órgão do Ministério Público, jurado ou qualquer funcionário, o julgamento não será suspenso, devendo, entretanto, constar da ata o seu fundamento e a decisão."
                                                                                },
                                                                                {
                                                                                        "numero": "471º",
                                                                                        "rotulo": "Art. 471º.",
                                                                                        "linha": 3418,
                                                                                        "caput": "Se, em conseqüência do impedimento, suspeição, incompatibilidade, dispensa ou recusa, não houver número para a formação do Conselho, o julgamento será adiado para o primeiro dia desimpedido, após sorteados os suplentes, com observância do disposto no art. 464 deste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "472º",
                                                                                        "rotulo": "Art. 472º.",
                                                                                        "linha": 3420,
                                                                                        "caput": "Formado o Conselho de Sentença, o presidente, levantando-se, e, com ele, todos os presentes, fará aos jurados a seguinte exortação: Em nome da lei, concito-vos a examinar esta causa com imparcialidade e a proferir a vossa decisão de acordo com a vossa consciência e os ditames da justiça. Os jurados, nominalmente chamados pelo presidente, responderão: Assim o prometo.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3428,
                                                                                                        "texto": "O jurado, em seguida, receberá cópias da pronúncia ou, se for o caso, das decisões posteriores que julgaram admissível a acusação e do relatório do processo."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção XI",
                                                                        "linha": 3430,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "473º",
                                                                                        "rotulo": "Art. 473º.",
                                                                                        "linha": 3435,
                                                                                        "caput": "Prestado o compromisso pelos jurados, será iniciada a instrução plenária quando o juiz presidente, o Ministério Público, o assistente, o querelante e o defensor do acusado tomarão, sucessiva e diretamente, as declarações do ofendido, se possível, e inquirirão as testemunhas arroladas pela acusação.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3437,
                                                                                                        "texto": "Para a inquirição das testemunhas arroladas pela defesa, o defensor do acusado formulará as perguntas antes do Ministério Público e do assistente, mantidos no mais a ordem e os critérios estabelecidos neste artigo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3439,
                                                                                                        "texto": "Os jurados poderão formular perguntas ao ofendido e às testemunhas, por intermédio do juiz presidente."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3441,
                                                                                                        "texto": "As partes e os jurados poderão requerer acareações, reconhecimento de pessoas e coisas e esclarecimento dos peritos, bem como a leitura de peças que se refiram, exclusivamente, às provas colhidas por carta precatória e às provas cautelares, antecipadas ou não repetíveis."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "474º",
                                                                                        "rotulo": "Art. 474º.",
                                                                                        "linha": 3443,
                                                                                        "caput": "A seguir será o acusado interrogado, se estiver presente, na forma estabelecida no Capítulo III do Título VII do Livro I deste Código, com as alterações introduzidas nesta Seção.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3445,
                                                                                                        "texto": "O Ministério Público, o assistente, o querelante e o defensor, nessa ordem, poderão formular, diretamente, perguntas ao acusado."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3447,
                                                                                                        "texto": "Os jurados formularão perguntas por intermédio do juiz presidente."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3449,
                                                                                                        "texto": "Não se permitirá o uso de algemas no acusado durante o período em que permanecer no plenário do júri, salvo se absolutamente necessário à ordem dos trabalhos, à segurança das testemunhas ou à garantia da integridade física dos presentes."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "474º-A",
                                                                                        "rotulo": "Art. 474º-A.",
                                                                                        "linha": 3451,
                                                                                        "caput": "Durante a instrução em plenário, todas as partes e demais sujeitos processuais presentes no ato deverão respeitar a dignidade da vítima, sob pena de responsabilização civil, penal e administrativa, cabendo ao juiz presidente garantir o cumprimento do disposto neste artigo, vedadas:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3453,
                                                                                                        "texto": "a manifestação sobre circunstâncias ou elementos alheios aos fatos objeto de apuração nos autos;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3455,
                                                                                                        "texto": "a utilização de linguagem, de informações ou de material que ofendam a dignidade da vítima ou de testemunhas."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "475º",
                                                                                        "rotulo": "Art. 475º.",
                                                                                        "linha": 3457,
                                                                                        "caput": "O registro dos depoimentos e do interrogatório será feito pelos meios ou recursos de gravação magnética, eletrônica, estenotipia ou técnica similar, destinada a obter maior fidelidade e celeridade na colheita da prova.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3459,
                                                                                                        "texto": "A transcrição do registro, após feita a degravação, constará dos autos."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção XII",
                                                                        "linha": 3461,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "476º",
                                                                                        "rotulo": "Art. 476º.",
                                                                                        "linha": 3466,
                                                                                        "caput": "Encerrada a instrução, será concedida a palavra ao Ministério Público, que fará a acusação, nos limites da pronúncia ou das decisões posteriores que julgaram admissível a acusação, sustentando, se for o caso, a existência de circunstância agravante.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3468,
                                                                                                        "texto": "O assistente falará depois do Ministério Público."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3470,
                                                                                                        "texto": "Tratando-se de ação penal de iniciativa privada, falará em primeiro lugar o querelante e, em seguida, o Ministério Público, salvo se este houver retomado a titularidade da ação, na forma do art. 29 deste Código."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3472,
                                                                                                        "texto": "Finda a acusação, terá a palavra a defesa."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "4",
                                                                                                        "rotulo": "§ 4",
                                                                                                        "linha": 3474,
                                                                                                        "texto": "A acusação poderá replicar e a defesa treplicar, sendo admitida a reinquirição de testemunha já ouvida em plenário."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "477º",
                                                                                        "rotulo": "Art. 477º.",
                                                                                        "linha": 3476,
                                                                                        "caput": "O tempo destinado à acusação e à defesa será de uma hora e meia para cada, e de uma hora para a réplica e outro tanto para a tréplica.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3478,
                                                                                                        "texto": "Havendo mais de um acusador ou mais de um defensor, combinarão entre si a distribuição do tempo, que, na falta de acordo, será dividido pelo juiz presidente, de forma a não exceder o determinado neste artigo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3480,
                                                                                                        "texto": "Havendo mais de 1 (um) acusado, o tempo para a acusação e a defesa será acrescido de 1 (uma) hora e elevado ao dobro o da réplica e da tréplica, observado o disposto no § 1o deste artigo."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "478º",
                                                                                        "rotulo": "Art. 478º.",
                                                                                        "linha": 3482,
                                                                                        "caput": "Durante os debates as partes não poderão, sob pena de nulidade, fazer referências:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3484,
                                                                                                        "texto": "à decisão de pronúncia, às decisões posteriores que julgaram admissível a acusação ou à determinação do uso de algemas como argumento de autoridade que beneficiem ou prejudiquem o acusado;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3486,
                                                                                                        "texto": "ao silêncio do acusado ou à ausência de interrogatório por falta de requerimento, em seu prejuízo."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "479º",
                                                                                        "rotulo": "Art. 479º.",
                                                                                        "linha": 3488,
                                                                                        "caput": "Durante o julgamento não será permitida a leitura de documento ou a exibição de objeto que não tiver sido juntado aos autos com a antecedência mínima de 3 (três) dias úteis, dando-se ciência à outra parte.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3490,
                                                                                                        "texto": "Compreende-se na proibição deste artigo a leitura de jornais ou qualquer outro escrito, bem como a exibição de vídeos, gravações, fotografias, laudos, quadros, croqui ou qualquer outro meio assemelhado, cujo conteúdo versar sobre a matéria de fato submetida à apreciação e julgamento dos jurados."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "480º",
                                                                                        "rotulo": "Art. 480º.",
                                                                                        "linha": 3492,
                                                                                        "caput": "A acusação, a defesa e os jurados poderão, a qualquer momento e por intermédio do juiz presidente, pedir ao orador que indique a folha dos autos onde se encontra a peça por ele lida ou citada, facultando-se, ainda, aos jurados solicitar-lhe, pelo mesmo meio, o esclarecimento de fato por ele alegado.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3494,
                                                                                                        "texto": "Concluídos os debates, o presidente indagará dos jurados se estão habilitados a julgar ou se necessitam de outros esclarecimentos."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3496,
                                                                                                        "texto": "Se houver dúvida sobre questão de fato, o presidente prestará esclarecimentos à vista dos autos."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3498,
                                                                                                        "texto": "Os jurados, nesta fase do procedimento, terão acesso aos autos e aos instrumentos do crime se solicitarem ao juiz presidente."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "481º",
                                                                                        "rotulo": "Art. 481º.",
                                                                                        "linha": 3500,
                                                                                        "caput": "Se a verificação de qualquer fato, reconhecida como essencial para o julgamento da causa, não puder ser realizada imediatamente, o juiz presidente dissolverá o Conselho, ordenando a realização das diligências entendidas necessárias.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3502,
                                                                                                        "texto": "Se a diligência consistir na produção de prova pericial, o juiz presidente, desde logo, nomeará perito e formulará quesitos, facultando às partes também formulá-los e indicar assistentes técnicos, no prazo de 5 (cinco) dias."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção XIII",
                                                                        "linha": 3504,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "482º",
                                                                                        "rotulo": "Art. 482º.",
                                                                                        "linha": 3509,
                                                                                        "caput": "O Conselho de Sentença será questionado sobre matéria de fato e se o acusado deve ser absolvido.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3511,
                                                                                                        "texto": "Os quesitos serão redigidos em proposições afirmativas, simples e distintas, de modo que cada um deles possa ser respondido com suficiente clareza e necessária precisão. Na sua elaboração, o presidente levará em conta os termos da pronúncia ou das decisões posteriores que julgaram admissível a acusação, do interrogatório e das alegações das partes."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "483º",
                                                                                        "rotulo": "Art. 483º.",
                                                                                        "linha": 3513,
                                                                                        "caput": "Os quesitos serão formulados na seguinte ordem, indagando sobre:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3515,
                                                                                                        "texto": "a materialidade do fato;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3517,
                                                                                                        "texto": "a autoria ou participação;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3519,
                                                                                                        "texto": "se o acusado deve ser absolvido;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 3521,
                                                                                                        "texto": "se existe causa de diminuição de pena alegada pela defesa;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 3523,
                                                                                                        "texto": "se existe circunstância qualificadora ou causa de aumento de pena reconhecidas na pronúncia ou em decisões posteriores que julgaram admissível a acusação."
                                                                                                }
                                                                                        ],
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3525,
                                                                                                        "texto": "A resposta negativa, de mais de 3 (três) jurados, a qualquer dos quesitos referidos nos incisos I e II do caputdeste artigo encerra a votação e implica a absolvição do acusado."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3527,
                                                                                                        "texto": "Respondidos afirmativamente por mais de 3 (três) jurados os quesitos relativos aos incisos I e II do caputdeste artigo será formulado quesito com a seguinte redação: O jurado absolve o acusado?"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3531,
                                                                                                        "texto": "Decidindo os jurados pela condenação, o julgamento prossegue, devendo ser formulados quesitos sobre:",
                                                                                                        "incisos": [
                                                                                                                {
                                                                                                                        "numero": "I",
                                                                                                                        "rotulo": "I",
                                                                                                                        "linha": 3533,
                                                                                                                        "texto": "causa de diminuição de pena alegada pela defesa;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "numero": "II",
                                                                                                                        "rotulo": "II",
                                                                                                                        "linha": 3535,
                                                                                                                        "texto": "circunstância qualificadora ou causa de aumento de pena, reconhecidas na pronúncia ou em decisões posteriores que julgaram admissível a acusação."
                                                                                                                }
                                                                                                        ]
                                                                                                },
                                                                                                {
                                                                                                        "numero": "4",
                                                                                                        "rotulo": "§ 4",
                                                                                                        "linha": 3537,
                                                                                                        "texto": "Sustentada a desclassificação da infração para outra de competência do juiz singular, será formulado quesito a respeito, para ser respondido após o 2o (segundo) ou 3o (terceiro) quesito, conforme o caso."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "5",
                                                                                                        "rotulo": "§ 5",
                                                                                                        "linha": 3539,
                                                                                                        "texto": "Sustentada a tese de ocorrência do crime na sua forma tentada ou havendo divergência sobre a tipificação do delito, sendo este da competência do Tribunal do Júri, o juiz formulará quesito acerca destas questões, para ser respondido após o segundo quesito."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "6",
                                                                                                        "rotulo": "§ 6",
                                                                                                        "linha": 3541,
                                                                                                        "texto": "Havendo mais de um crime ou mais de um acusado, os quesitos serão formulados em séries distintas."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "484º",
                                                                                        "rotulo": "Art. 484º.",
                                                                                        "linha": 3543,
                                                                                        "caput": "A seguir, o presidente lerá os quesitos e indagará das partes se têm requerimento ou reclamação a fazer, devendo qualquer deles, bem como a decisão, constar da ata.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3545,
                                                                                                        "texto": "Ainda em plenário, o juiz presidente explicará aos jurados o significado de cada quesito."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "485º",
                                                                                        "rotulo": "Art. 485º.",
                                                                                        "linha": 3547,
                                                                                        "caput": "Não havendo dúvida a ser esclarecida, o juiz presidente, os jurados, o Ministério Público, o assistente, o querelante, o defensor do acusado, o escrivão e o oficial de justiça dirigir-se-ão à sala especial a fim de ser procedida a votação.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3549,
                                                                                                        "texto": "Na falta de sala especial, o juiz presidente determinará que o público se retire, permanecendo somente as pessoas mencionadas no caputdeste artigo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3551,
                                                                                                        "texto": "O juiz presidente advertirá as partes de que não será permitida qualquer intervenção que possa perturbar a livre manifestação do Conselho e fará retirar da sala quem se portar inconvenientemente."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "486º",
                                                                                        "rotulo": "Art. 486º.",
                                                                                        "linha": 3553,
                                                                                        "caput": "Antes de proceder-se à votação de cada quesito, o juiz presidente mandará distribuir aos jurados pequenas cédulas, feitas de papel opaco e facilmente dobráveis, contendo 7 (sete) delas a palavra sim, 7 (sete) a palavra não."
                                                                                },
                                                                                {
                                                                                        "numero": "487º",
                                                                                        "rotulo": "Art. 487º.",
                                                                                        "linha": 3555,
                                                                                        "caput": "Para assegurar o sigilo do voto, o oficial de justiça recolherá em urnas separadas as cédulas correspondentes aos votos e as não utilizadas."
                                                                                },
                                                                                {
                                                                                        "numero": "488º",
                                                                                        "rotulo": "Art. 488º.",
                                                                                        "linha": 3557,
                                                                                        "caput": "Após a resposta, verificados os votos e as cédulas não utilizadas, o presidente determinará que o escrivão registre no termo a votação de cada quesito, bem como o resultado do julgamento.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3559,
                                                                                                        "texto": "Do termo também constará a conferência das cédulas não utilizadas."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "489º",
                                                                                        "rotulo": "Art. 489º.",
                                                                                        "linha": 3561,
                                                                                        "caput": "As decisões do Tribunal do Júri serão tomadas por maioria de votos."
                                                                                },
                                                                                {
                                                                                        "numero": "490º",
                                                                                        "rotulo": "Art. 490º.",
                                                                                        "linha": 3563,
                                                                                        "caput": "Se a resposta a qualquer dos quesitos estiver em contradição com outra ou outras já dadas, o presidente, explicando aos jurados em que consiste a contradição, submeterá novamente à votação os quesitos a que se referirem tais respostas.",
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "único",
                                                                                                        "rotulo": "Parágrafo único",
                                                                                                        "linha": 3565,
                                                                                                        "texto": "Se, pela resposta dada a um dos quesitos, o presidente verificar que ficam prejudicados os seguintes, assim o declarará, dando por finda a votação."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "491º",
                                                                                        "rotulo": "Art. 491º.",
                                                                                        "linha": 3567,
                                                                                        "caput": "Encerrada a votação, será o termo a que se refere o art. 488 deste Código assinado pelo presidente, pelos jurados e pelas partes."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção XIV",
                                                                        "linha": 3569,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "492º",
                                                                                        "rotulo": "Art. 492º.",
                                                                                        "linha": 3574,
                                                                                        "caput": "Em seguida, o presidente proferirá sentença que:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3576,
                                                                                                        "texto": "no caso de condenação:",
                                                                                                        "alineas": [
                                                                                                                {
                                                                                                                        "letra": "a",
                                                                                                                        "rotulo": "a)",
                                                                                                                        "linha": 3578,
                                                                                                                        "texto": "fixará a pena-base;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "b",
                                                                                                                        "rotulo": "b)",
                                                                                                                        "linha": 3580,
                                                                                                                        "texto": "considerará as circunstâncias agravantes ou atenuantes alegadas nos debates;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "c",
                                                                                                                        "rotulo": "c)",
                                                                                                                        "linha": 3582,
                                                                                                                        "texto": "imporá os aumentos ou diminuições da pena, em atenção às causas admitidas pelo júri;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "d",
                                                                                                                        "rotulo": "d)",
                                                                                                                        "linha": 3584,
                                                                                                                        "texto": "observará as demais disposições do art. 387 deste Código;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "e",
                                                                                                                        "rotulo": "e)",
                                                                                                                        "linha": 3587,
                                                                                                                        "texto": "mandará o acusado recolher-se ou recomendá-lo-á à prisão em que se encontra, se presentes os requisitos da prisão preventiva, ou, no caso de condenação a uma pena igual ou superior a 15 (quinze) anos de reclusão, determinará a execução provisória das penas, com expedição do mandado de prisão, se for o caso, sem prejuízo do conhecimento de recursos que vierem a ser interpostos;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "f",
                                                                                                                        "rotulo": "f)",
                                                                                                                        "linha": 3589,
                                                                                                                        "texto": "estabelecerá os efeitos genéricos e específicos da condenação;"
                                                                                                                }
                                                                                                        ]
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3591,
                                                                                                        "texto": "no caso de absolvição:",
                                                                                                        "alineas": [
                                                                                                                {
                                                                                                                        "letra": "a",
                                                                                                                        "rotulo": "a)",
                                                                                                                        "linha": 3593,
                                                                                                                        "texto": "mandará colocar em liberdade o acusado se por outro motivo não estiver preso;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "b",
                                                                                                                        "rotulo": "b)",
                                                                                                                        "linha": 3595,
                                                                                                                        "texto": "revogará as medidas restritivas provisoriamente decretadas;"
                                                                                                                },
                                                                                                                {
                                                                                                                        "letra": "c",
                                                                                                                        "rotulo": "c)",
                                                                                                                        "linha": 3597,
                                                                                                                        "texto": "imporá, se for o caso, a medida de segurança cabível."
                                                                                                                }
                                                                                                        ]
                                                                                                }
                                                                                        ],
                                                                                        "paragrafos": [
                                                                                                {
                                                                                                        "numero": "1",
                                                                                                        "rotulo": "§ 1",
                                                                                                        "linha": 3599,
                                                                                                        "texto": "Se houver desclassificação da infração para outra, de competência do juiz singular, ao presidente do Tribunal do Júri caberá proferir sentença em seguida, aplicando-se, quando o delito resultante da nova tipificação for considerado pela lei como infração penal de menor potencial ofensivo, o disposto nos arts. 69 e seguintes da Lei no 9.099, de 26 de setembro de 1995."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "2",
                                                                                                        "rotulo": "§ 2",
                                                                                                        "linha": 3601,
                                                                                                        "texto": "Em caso de desclassificação, o crime conexo que não seja doloso contra a vida será julgado pelo juiz presidente do Tribunal do Júri, aplicando-se, no que couber, o disposto no § 1o deste artigo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "3",
                                                                                                        "rotulo": "§ 3",
                                                                                                        "linha": 3603,
                                                                                                        "texto": "O presidente poderá, excepcionalmente, deixar de autorizar a execução provisória das penas de que trata a alínea e do inciso I do caput deste artigo, se houver questão substancial cuja resolução pelo tribunal ao qual competir o julgamento possa plausivelmente levar à revisão da condenação."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "4",
                                                                                                        "rotulo": "§ 4",
                                                                                                        "linha": 3605,
                                                                                                        "texto": "A apelação interposta contra decisão condenatória do Tribunal do Júri a uma pena igual ou superior a 15 (quinze) anos de reclusão não terá efeito suspensivo."
                                                                                                },
                                                                                                {
                                                                                                        "numero": "5",
                                                                                                        "rotulo": "§ 5",
                                                                                                        "linha": 3607,
                                                                                                        "texto": "Excepcionalmente, poderá o tribunal atribuir efeito suspensivo à apelação de que trata o § 4º deste artigo, quando verificado cumulativamente que o recurso:",
                                                                                                        "incisos": [
                                                                                                                {
                                                                                                                        "numero": "I",
                                                                                                                        "rotulo": "I",
                                                                                                                        "linha": 3609,
                                                                                                                        "texto": "não tem propósito meramente protelatório; e"
                                                                                                                },
                                                                                                                {
                                                                                                                        "numero": "II",
                                                                                                                        "rotulo": "II",
                                                                                                                        "linha": 3611,
                                                                                                                        "texto": "levanta questão substancial e que pode resultar em absolvição, anulação da sentença, novo julgamento ou redução da pena para patamar inferior a 15 (quinze) anos de reclusão."
                                                                                                                }
                                                                                                        ]
                                                                                                },
                                                                                                {
                                                                                                        "numero": "6",
                                                                                                        "rotulo": "§ 6",
                                                                                                        "linha": 3613,
                                                                                                        "texto": "O pedido de concessão de efeito suspensivo poderá ser feito incidentemente na apelação ou por meio de petição em separado dirigida diretamente ao relator, instruída com cópias da sentença condenatória, das razões da apelação e de prova da tempestividade, das contrarrazões e das demais peças necessárias à compreensão da controvérsia."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "493º",
                                                                                        "rotulo": "Art. 493º.",
                                                                                        "linha": 3615,
                                                                                        "caput": "A sentença será lida em plenário pelo presidente antes de encerrada a sessão de instrução e julgamento."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção XV",
                                                                        "linha": 3617,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "494º",
                                                                                        "rotulo": "Art. 494º.",
                                                                                        "linha": 3622,
                                                                                        "caput": "De cada sessão de julgamento o escrivão lavrará ata, assinada pelo presidente e pelas partes."
                                                                                },
                                                                                {
                                                                                        "numero": "495º",
                                                                                        "rotulo": "Art. 495º.",
                                                                                        "linha": 3624,
                                                                                        "caput": "A ata descreverá fielmente todas as ocorrências, mencionando obrigatoriamente:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3626,
                                                                                                        "texto": "a data e a hora da instalação dos trabalhos;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3628,
                                                                                                        "texto": "magistrado que presidiu a sessão e os jurados presentes;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3630,
                                                                                                        "texto": "os jurados que deixaram de comparecer, com escusa ou sem ela, e as sanções aplicadas;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 3632,
                                                                                                        "texto": "ofício ou requerimento de isenção ou dispensa ;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 3634,
                                                                                                        "texto": "sorteio dos jurados suplentes;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 3636,
                                                                                                        "texto": "adiamento da sessão, se houver ocorrido, com a indicação do motivo;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VII",
                                                                                                        "rotulo": "VII",
                                                                                                        "linha": 3638,
                                                                                                        "texto": "a abertura da sessão e a presença do Ministério Público, do querelante e do assistente, se houver, e a do defensor do acusado;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VIII",
                                                                                                        "rotulo": "VIII",
                                                                                                        "linha": 3640,
                                                                                                        "texto": "pregão e a sanção imposta, no caso de não comparecimento;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IX",
                                                                                                        "rotulo": "IX",
                                                                                                        "linha": 3642,
                                                                                                        "texto": "as testemunhas dispensadas de depor;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "X",
                                                                                                        "rotulo": "X",
                                                                                                        "linha": 3644,
                                                                                                        "texto": "recolhimento das testemunhas a lugar de onde umas não pudessem ouvir o depoimento das outras;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "XI",
                                                                                                        "rotulo": "XI",
                                                                                                        "linha": 3646,
                                                                                                        "texto": "a verificação das cédulas pelo juiz presidente;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "XII",
                                                                                                        "rotulo": "XII",
                                                                                                        "linha": 3648,
                                                                                                        "texto": "a formação do Conselho de Sentença, com o registro dos nomes dos jurados sorteados e recusas; XIII – o compromisso e o interrogatório, com simples referência ao termo; XIV – os debates e as alegações das partes com os respectivos fundamentos; XV – os incidentes; XVI – o julgamento da causa; XVII – a publicidade dos atos da instrução plenária, das diligências e da sentença."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "496º",
                                                                                        "rotulo": "Art. 496º.",
                                                                                        "linha": 3660,
                                                                                        "caput": "A falta da ata sujeitará o responsável a sanções administrativa e penal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "tipo": "secao",
                                                                        "rotulo": "Seção XVI",
                                                                        "linha": 3662,
                                                                        "divisoes": [],
                                                                        "artigos": [
                                                                                {
                                                                                        "numero": "497º",
                                                                                        "rotulo": "Art. 497º.",
                                                                                        "linha": 3667,
                                                                                        "caput": "São atribuições do juiz presidente do Tribunal do Júri, além de outras expressamente referidas neste Código:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 3669,
                                                                                                        "texto": "regular a polícia das sessões e prender os desobedientes;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 3671,
                                                                                                        "texto": "requisitar o auxílio da força pública, que ficará sob sua exclusiva autoridade;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 3673,
                                                                                                        "texto": "dirigir os debates, intervindo em caso de abuso, excesso de linguagem ou mediante requerimento de uma das partes;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 3675,
                                                                                                        "texto": "resolver as questões incidentes que não dependam de pronunciamento do júri;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "V",
                                                                                                        "rotulo": "V",
                                                                                                        "linha": 3677,
                                                                                                        "texto": "nomear defensor ao acusado, quando considerá-lo indefeso, podendo, neste caso, dissolver o Conselho e designar novo dia para o julgamento, com a nomeação ou a constituição de novo defensor;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VI",
                                                                                                        "rotulo": "VI",
                                                                                                        "linha": 3679,
                                                                                                        "texto": "mandar retirar da sala o acusado que dificultar a realização do julgamento, o qual prosseguirá sem a sua presença;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VII",
                                                                                                        "rotulo": "VII",
                                                                                                        "linha": 3681,
                                                                                                        "texto": "suspender a sessão pelo tempo indispensável à realização das diligências requeridas ou entendidas necessárias, mantida a incomunicabilidade dos jurados;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "VIII",
                                                                                                        "rotulo": "VIII",
                                                                                                        "linha": 3683,
                                                                                                        "texto": "interromper a sessão por tempo razoável, para proferir sentença e para repouso ou refeição dos jurados;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IX",
                                                                                                        "rotulo": "IX",
                                                                                                        "linha": 3685,
                                                                                                        "texto": "decidir, de ofício, ouvidos o Ministério Público e a defesa, ou a requerimento de qualquer destes, a argüição de extinção de punibilidade;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "X",
                                                                                                        "rotulo": "X",
                                                                                                        "linha": 3687,
                                                                                                        "texto": "resolver as questões de direito suscitadas no curso do julgamento;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "XI",
                                                                                                        "rotulo": "XI",
                                                                                                        "linha": 3689,
                                                                                                        "texto": "determinar, de ofício ou a requerimento das partes ou de qualquer jurado, as diligências destinadas a sanar nulidade ou a suprir falta que prejudique o esclarecimento da verdade;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "XII",
                                                                                                        "rotulo": "XII",
                                                                                                        "linha": 3691,
                                                                                                        "texto": "regulamentar, durante os debates, a intervenção de uma das partes, quando a outra estiver com a palavra, podendo conceder até 3 (três) minutos para cada aparte requerido, que serão acrescidos ao tempo desta última."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                }
                                                        ],
                                                        "artigos": []
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 3693,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "513º",
                                                                        "rotulo": "Art. 513º.",
                                                                        "linha": 3699,
                                                                        "caput": "Os crimes de responsabilidade dos funcionários públicos, cujo processo e julgamento competirão aos juízes de direito, a queixa ou a denúncia será instruída com documentos ou justificação que façam presumir a existência do delito ou com declaração fundamentada da impossibilidade de apresentação de qualquer dessas provas."
                                                                },
                                                                {
                                                                        "numero": "514º",
                                                                        "rotulo": "Art. 514º.",
                                                                        "linha": 3701,
                                                                        "caput": "Nos crimes afiançáveis, estando a denúncia ou queixa em devida forma, o juiz mandará autuá-la e ordenará a notificação do acusado, para responder por escrito, dentro do prazo de quinze dias.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3703,
                                                                                        "texto": "Se não for conhecida a residência do acusado, ou este se achar fora da jurisdição do juiz, ser-lhe-á nomeado defensor, a quem caberá apresentar a resposta preliminar."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "515º",
                                                                        "rotulo": "Art. 515º.",
                                                                        "linha": 3705,
                                                                        "caput": "No caso previsto no artigo anterior, durante o prazo concedido para a resposta, os autos permanecerão em cartório, onde poderão ser examinados pelo acusado ou por seu defensor.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3707,
                                                                                        "texto": "A resposta poderá ser instruída com documentos e justificações."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "516º",
                                                                        "rotulo": "Art. 516º.",
                                                                        "linha": 3709,
                                                                        "caput": "O juiz rejeitará a queixa ou denúncia, em despacho fundamentado, se convencido, pela resposta do acusado ou do seu defensor, da inexistência do crime ou da improcedência da ação."
                                                                },
                                                                {
                                                                        "numero": "517º",
                                                                        "rotulo": "Art. 517º.",
                                                                        "linha": 3711,
                                                                        "caput": "Recebida a denúncia ou a queixa, será o acusado citado, na forma estabelecida no Capítulo I do Título X do Livro I."
                                                                },
                                                                {
                                                                        "numero": "518º",
                                                                        "rotulo": "Art. 518º.",
                                                                        "linha": 3713,
                                                                        "caput": "Na instrução criminal e nos demais termos do processo, observar-se-á o disposto nos Capítulos I e III, Título I, deste Livro."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 3715,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "519º",
                                                                        "rotulo": "Art. 519º.",
                                                                        "linha": 3721,
                                                                        "caput": "No processo por crime de calúnia ou injúria, para o qual não haja outra forma estabelecida em lei especial, observar-se-á o disposto nos Capítulos I e III, Titulo I, deste Livro, com as modificações constantes dos artigos seguintes."
                                                                },
                                                                {
                                                                        "numero": "520º",
                                                                        "rotulo": "Art. 520º.",
                                                                        "linha": 3723,
                                                                        "caput": "Antes de receber a queixa, o juiz oferecerá às partes oportunidade para se reconciliarem, fazendo-as comparecer em juízo e ouvindo-as, separadamente, sem a presença dos seus advogados, não se lavrando termo."
                                                                },
                                                                {
                                                                        "numero": "521º",
                                                                        "rotulo": "Art. 521º.",
                                                                        "linha": 3725,
                                                                        "caput": "Se depois de ouvir o querelante e o querelado, o juiz achar provável a reconciliação, promoverá entendimento entre eles, na sua presença."
                                                                },
                                                                {
                                                                        "numero": "522º",
                                                                        "rotulo": "Art. 522º.",
                                                                        "linha": 3727,
                                                                        "caput": "No caso de reconciliação, depois de assinado pelo querelante o termo da desistência, a queixa será arquivada."
                                                                },
                                                                {
                                                                        "numero": "523º",
                                                                        "rotulo": "Art. 523º.",
                                                                        "linha": 3729,
                                                                        "caput": "Quando for oferecida a exceção da verdade ou da notoriedade do fato imputado, o querelante poderá contestar a exceção no prazo de dois dias, podendo ser inquiridas as testemunhas arroladas na queixa, ou outras indicadas naquele prazo, em substituição às primeiras, ou para completar o máximo legal."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IV",
                                                        "linha": 3731,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "524º",
                                                                        "rotulo": "Art. 524º.",
                                                                        "linha": 3737,
                                                                        "caput": "No processo e julgamento dos crimes contra a propriedade imaterial, observar-se-á o disposto nos Capítulos I e III do Título I deste Livro, com as modificações constantes dos artigos seguintes."
                                                                },
                                                                {
                                                                        "numero": "525º",
                                                                        "rotulo": "Art. 525º.",
                                                                        "linha": 3739,
                                                                        "caput": "No caso de haver o crime deixado vestígio, a queixa ou a denúncia não será recebida se não for instruída com o exame pericial dos objetos que constituam o corpo de delito."
                                                                },
                                                                {
                                                                        "numero": "526º",
                                                                        "rotulo": "Art. 526º.",
                                                                        "linha": 3741,
                                                                        "caput": "Sem a prova de direito à ação, não será recebida a queixa, nem ordenada qualquer diligência preliminarmente requerida pelo ofendido."
                                                                },
                                                                {
                                                                        "numero": "527º",
                                                                        "rotulo": "Art. 527º.",
                                                                        "linha": 3743,
                                                                        "caput": "A diligência de busca ou de apreensão será realizada por dois peritos nomeados pelo juiz, que verificarão a existência de fundamento para a apreensão, e quer esta se realize, quer não, o laudo pericial será apresentado dentro de 3 (três) dias após o encerramento da diligência.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3745,
                                                                                        "texto": "O requerente da diligência poderá impugnar o laudo contrário à apreensão, e o juiz ordenará que esta se efetue, se reconhecer a improcedência das razões aduzidas pelos peritos."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "528º",
                                                                        "rotulo": "Art. 528º.",
                                                                        "linha": 3747,
                                                                        "caput": "Encerradas as diligências, os autos serão conclusos ao juiz para homologação do laudo."
                                                                },
                                                                {
                                                                        "numero": "529º",
                                                                        "rotulo": "Art. 529º.",
                                                                        "linha": 3749,
                                                                        "caput": "Nos crimes de ação privativa do ofendido, não será admitida queixa com fundamento em apreensão e em perícia, se decorrido o prazo de 30 dias, após a homologação do laudo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3751,
                                                                                        "texto": "Será dada vista ao Ministério Público dos autos de busca e apreensão requeridas pelo ofendido, se o crime for de ação pública e não tiver sido oferecida queixa no prazo fixado neste artigo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "530º",
                                                                        "rotulo": "Art. 530º.",
                                                                        "linha": 3753,
                                                                        "caput": "Se ocorrer prisão em flagrante e o réu não for posto em liberdade, o prazo a que se refere o artigo anterior será de 8 (oito) dias."
                                                                },
                                                                {
                                                                        "numero": "530º-A",
                                                                        "rotulo": "Art. 530º-A.",
                                                                        "linha": 3755,
                                                                        "caput": "O disposto nos arts. 524 a 530 será aplicável aos crimes em que se proceda mediante queixa."
                                                                },
                                                                {
                                                                        "numero": "530º-B",
                                                                        "rotulo": "Art. 530º-B.",
                                                                        "linha": 3757,
                                                                        "caput": "Nos casos das infrações previstas nos §§ 1o, 2o e 3o do art. 184 do Código Penal, a autoridade policial procederá à apreensão dos bens ilicitamente produzidos ou reproduzidos, em sua totalidade, juntamente com os equipamentos, suportes e materiais que possibilitaram a sua existência, desde que estes se destinem precipuamente à prática do ilícito ."
                                                                },
                                                                {
                                                                        "numero": "530º-C",
                                                                        "rotulo": "Art. 530º-C.",
                                                                        "linha": 3759,
                                                                        "caput": "Na ocasião da apreensão será lavrado termo, assinado por 2 (duas) ou mais testemunhas, com a descrição de todos os bens apreendidos e informações sobre suas origens, o qual deverá integrar o inquérito policial ou o processo."
                                                                },
                                                                {
                                                                        "numero": "530º-D",
                                                                        "rotulo": "Art. 530º-D.",
                                                                        "linha": 3761,
                                                                        "caput": "Subseqüente à apreensão, será realizada, por perito oficial, ou, na falta deste, por pessoa tecnicamente habilitada, perícia sobre todos os bens apreendidos e elaborado o laudo que deverá integrar o inquérito policial ou o processo."
                                                                },
                                                                {
                                                                        "numero": "530º-E",
                                                                        "rotulo": "Art. 530º-E.",
                                                                        "linha": 3763,
                                                                        "caput": "Os titulares de direito de autor e os que lhe são conexos serão os fiéis depositários de todos os bens apreendidos, devendo colocá-los à disposição do juiz quando do ajuizamento da ação."
                                                                },
                                                                {
                                                                        "numero": "530º-F",
                                                                        "rotulo": "Art. 530º-F.",
                                                                        "linha": 3765,
                                                                        "caput": "Ressalvada a possibilidade de se preservar o corpo de delito, o juiz poderá determinar, a requerimento da vítima, a destruição da produção ou reprodução apreendida quando não houver impugnação quanto à sua ilicitude ou quando a ação penal não puder ser iniciada por falta de determinação de quem seja o autor do ilícito."
                                                                },
                                                                {
                                                                        "numero": "530º-G",
                                                                        "rotulo": "Art. 530º-G.",
                                                                        "linha": 3767,
                                                                        "caput": "O juiz, ao prolatar a sentença condenatória, poderá determinar a destruição dos bens ilicitamente produzidos ou reproduzidos e o perdimento dos equipamentos apreendidos, desde que precipuamente destinados à produção e reprodução dos bens, em favor da Fazenda Nacional, que deverá destruí-los ou doá-los aos Estados, Municípios e Distrito Federal, a instituições públicas de ensino e pesquisa ou de assistência social, bem como incorporá-los, por economia ou interesse público, ao patrimônio da União, que não poderão retorná-los aos canais de comércio."
                                                                },
                                                                {
                                                                        "numero": "530º-H",
                                                                        "rotulo": "Art. 530º-H.",
                                                                        "linha": 3769,
                                                                        "caput": "As associações de titulares de direitos de autor e os que lhes são conexos poderão, em seu próprio nome, funcionar como assistente da acusação nos crimes previstos no art. 184 do Código Penal, quando praticado em detrimento de qualquer de seus associados."
                                                                },
                                                                {
                                                                        "numero": "530º-I",
                                                                        "rotulo": "Art. 530º-I.",
                                                                        "linha": 3771,
                                                                        "caput": "Nos crimes em que caiba ação penal pública incondicionada ou condicionada, observar-se-ão as normas constantes dos arts. 530-B, 530-C, 530-D, 530-E, 530-F, 530-G e 530-H."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 3773,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "531º",
                                                                        "rotulo": "Art. 531º.",
                                                                        "linha": 3778,
                                                                        "caput": "Na audiência de instrução e julgamento, a ser realizada no prazo máximo de 30 (trinta) dias, proceder-se-á à tomada de declarações do ofendido, se possível, à inquirição das testemunhas arroladas pela acusação e pela defesa, nesta ordem, ressalvado o disposto no art. 222 deste Código, bem como aos esclarecimentos dos peritos, às acareações e ao reconhecimento de pessoas e coisas, interrogando-se, em seguida, o acusado e procedendo-se, finalmente, ao debate. ."
                                                                },
                                                                {
                                                                        "numero": "532º",
                                                                        "rotulo": "Art. 532º.",
                                                                        "linha": 3782,
                                                                        "caput": "Na instrução, poderão ser inquiridas até 5 (cinco) testemunhas arroladas pela acusação e 5 (cinco) pela defesa. ."
                                                                },
                                                                {
                                                                        "numero": "533º",
                                                                        "rotulo": "Art. 533º.",
                                                                        "linha": 3785,
                                                                        "caput": "Aplica-se ao procedimento sumário o disposto nos parágrafos do art. 400 deste Código. ."
                                                                },
                                                                {
                                                                        "numero": "534º",
                                                                        "rotulo": "Art. 534º.",
                                                                        "linha": 3788,
                                                                        "caput": "As alegações finais serão orais, concedendo-se a palavra, respectivamente, à acusação e à defesa, pelo prazo de 20 (vinte) minutos, prorrogáveis por mais 10 (dez), proferindo o juiz, a seguir, sentença. .",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 3790,
                                                                                        "texto": "Havendo mais de um acusado, o tempo previsto para a defesa de cada um será individual. ."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 3792,
                                                                                        "texto": "Ao assistente do Ministério Público, após a manifestação deste, serão concedidos 10 (dez) minutos, prorrogando-se por igual período o tempo de manifestação da defesa. ."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "535º",
                                                                        "rotulo": "Art. 535º.",
                                                                        "linha": 3795,
                                                                        "caput": "Nenhum ato será adiado, salvo quando imprescindível a prova faltante, determinando o juiz a condução coercitiva de quem deva comparecer. ."
                                                                },
                                                                {
                                                                        "numero": "536º",
                                                                        "rotulo": "Art. 536º.",
                                                                        "linha": 3798,
                                                                        "caput": "A testemunha que comparecer será inquirida, independentemente da suspensão da audiência, observada em qualquer caso a ordem estabelecida no art. 531 deste Código. ."
                                                                },
                                                                {
                                                                        "numero": "537º",
                                                                        "rotulo": "Art. 537º.",
                                                                        "linha": 3800,
                                                                        "caput": ""
                                                                },
                                                                {
                                                                        "numero": "538º",
                                                                        "rotulo": "Art. 538º.",
                                                                        "linha": 3804,
                                                                        "caput": "Nas infrações penais de menor potencial ofensivo, quando o juizado especial criminal encaminhar ao juízo comum as peças existentes para a adoção de outro procedimento, observar-se-á o procedimento sumário previsto neste Capítulo. ."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 3806,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "541º",
                                                                        "rotulo": "Art. 541º.",
                                                                        "linha": 3810,
                                                                        "caput": "Os autos originais de processo penal extraviados ou destruídos, em primeira ou segunda instância, serão restaurados.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 3812,
                                                                                        "texto": "Se existir e for exibida cópia autêntica ou certidão do processo, será uma ou outra considerada como original."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 3814,
                                                                                        "texto": "Na falta de cópia autêntica ou certidão do processo, o juiz mandará, de ofício, ou a requerimento de qualquer das partes, que:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 3816,
                                                                                                        "texto": "escrivão certifique o estado do processo, segundo a sua lembrança, e reproduza o que houver a respeito em seus protocolos e registros;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 3818,
                                                                                                        "texto": "sejam requisitadas cópias do que constar a respeito no Instituto Médico-Legal, no Instituto de Identificação e Estatística ou em estabelecimentos congêneres, repartições públicas, penitenciárias ou cadeias;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 3820,
                                                                                                        "texto": "as partes sejam citadas pessoalmente, ou, se não forem encontradas, por edital, com o prazo de dez dias, para o processo de restauração dos autos."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 3822,
                                                                                        "texto": "Proceder-se-á à restauração na primeira instância, ainda que os autos se tenham extraviado na segunda."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "542º",
                                                                        "rotulo": "Art. 542º.",
                                                                        "linha": 3824,
                                                                        "caput": "No dia designado, as partes serão ouvidas, mencionando-se em termo circunstanciado os pontos em que estiverem acordes e a exibição e a conferência das certidões e mais reproduções do processo apresentadas e conferidas."
                                                                },
                                                                {
                                                                        "numero": "543º",
                                                                        "rotulo": "Art. 543º.",
                                                                        "linha": 3826,
                                                                        "caput": "O juiz determinará as diligências necessárias para a restauração, observando-se o seguinte:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 3828,
                                                                                        "texto": "caso ainda não tenha sido proferida a sentença, reinquirir-se-ão as testemunhas podendo ser substituídas as que tiverem falecido ou se encontrarem em lugar não sabido;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 3830,
                                                                                        "texto": "os exames periciais, quando possível, serão repetidos, e de preferência pelos mesmos peritos;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 3832,
                                                                                        "texto": "a prova documental será reproduzida por meio de cópia autêntica ou, quando impossível, por meio de testemunhas;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 3834,
                                                                                        "texto": "poderão também ser inquiridas sobre os atos do processo, que deverá ser restaurado, as autoridades, os serventuários, os peritos e mais pessoas que tenham nele funcionado;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 3836,
                                                                                        "texto": "Ministério Público e as partes poderão oferecer testemunhas e produzir documentos, para provar o teor do processo extraviado ou destruído."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "544º",
                                                                        "rotulo": "Art. 544º.",
                                                                        "linha": 3838,
                                                                        "caput": "Realizadas as diligências que, salvo motivo de força maior, deverão concluir-se dentro de vinte dias, serão os autos conclusos para julgamento.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3840,
                                                                                        "texto": "No curso do processo, e depois de subirem os autos conclusos para sentença, o juiz poderá, dentro em cinco dias, requisitar de autoridades ou de repartições todos os esclarecimentos para a restauração."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "545º",
                                                                        "rotulo": "Art. 545º.",
                                                                        "linha": 3842,
                                                                        "caput": "Os selos e as taxas judiciárias, já pagos nos autos originais, não serão novamente cobrados."
                                                                },
                                                                {
                                                                        "numero": "546º",
                                                                        "rotulo": "Art. 546º.",
                                                                        "linha": 3844,
                                                                        "caput": "Os causadores de extravio de autos responderão pelas custas, em dobro, sem prejuízo da responsabilidade criminal."
                                                                },
                                                                {
                                                                        "numero": "547º",
                                                                        "rotulo": "Art. 547º.",
                                                                        "linha": 3846,
                                                                        "caput": "Julgada a restauração, os autos respectivos valerão pelos originais.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3848,
                                                                                        "texto": "Se no curso da restauração aparecerem os autos originais, nestes continuará o processo, apensos a eles os autos da restauração."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "548º",
                                                                        "rotulo": "Art. 548º.",
                                                                        "linha": 3850,
                                                                        "caput": "Até à decisão que julgue restaurados os autos, a sentença condenatória em execução continuará a produzir efeito, desde que conste da respectiva guia arquivada na cadeia ou na penitenciária, onde o réu estiver cumprindo a pena, ou de registro que torne a sua existência inequívoca."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VII",
                                                        "linha": 3852,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "549º",
                                                                        "rotulo": "Art. 549º.",
                                                                        "linha": 3858,
                                                                        "caput": "Se a autoridade policial tiver conhecimento de fato que, embora não constituindo infração penal, possa determinar a aplicação de medida de segurança (Código Penal, arts. 14 e27), deverá proceder a inquérito, a fim de apurá-lo e averiguar todos os elementos que possam interessar à verificação da periculosidade do agente."
                                                                },
                                                                {
                                                                        "numero": "550º",
                                                                        "rotulo": "Art. 550º.",
                                                                        "linha": 3860,
                                                                        "caput": "O processo será promovido pelo Ministério Público, mediante requerimento que conterá a exposição sucinta do fato, as suas circunstâncias e todos os elementos em que se fundar o pedido."
                                                                },
                                                                {
                                                                        "numero": "551º",
                                                                        "rotulo": "Art. 551º.",
                                                                        "linha": 3862,
                                                                        "caput": "O juiz, ao deferir o requerimento, ordenará a intimação do interessado para comparecer em juízo, a fim de ser interrogado."
                                                                },
                                                                {
                                                                        "numero": "552º",
                                                                        "rotulo": "Art. 552º.",
                                                                        "linha": 3864,
                                                                        "caput": "Após o interrogatório ou dentro do prazo de dois dias, o interessado ou seu defensor poderá oferecer alegações.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3866,
                                                                                        "texto": "O juiz nomeará defensor ao interessado que não o tiver."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "553º",
                                                                        "rotulo": "Art. 553º.",
                                                                        "linha": 3868,
                                                                        "caput": "O Ministério Público, ao fazer o requerimento inicial, e a defesa, no prazo estabelecido no artigo anterior, poderão requerer exames, diligências e arrolar até três testemunhas."
                                                                },
                                                                {
                                                                        "numero": "554º",
                                                                        "rotulo": "Art. 554º.",
                                                                        "linha": 3870,
                                                                        "caput": "Após o prazo de defesa ou a realização dos exames e diligências ordenados pelo juiz, de ofício ou a requerimento das partes, será marcada audiência, em que, inquiridas as testemunhas e produzidas alegações orais pelo órgão do Ministério Público e pelo defensor, dentro de dez minutos para cada um, o juiz proferirá sentença.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3872,
                                                                                        "texto": "Se o juiz não se julgar habilitado a proferir a decisão, designará, desde logo, outra audiência, que se realizará dentro de cinco dias, para publicar a sentença."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "555º",
                                                                        "rotulo": "Art. 555º.",
                                                                        "linha": 3874,
                                                                        "caput": "Quando, instaurado processo por infração penal, o juiz, absolvendo ou impronunciando o réu, reconhecer a existência de qualquer dos fatos previstos no art. 14 ou no art. 27 do Código Penal, aplicar-lhe-á, se for caso, medida de segurança."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                }
                        ],
                        "artigos": []
                },
                {
                        "tipo": "livro",
                        "rotulo": "LIVRO III",
                        "linha": 3876,
                        "divisoes": [
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO I",
                                        "linha": 3880,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "563º",
                                                        "rotulo": "Art. 563º.",
                                                        "linha": 3884,
                                                        "caput": "Nenhum ato será declarado nulo, se da nulidade não resultar prejuízo para a acusação ou para a defesa."
                                                },
                                                {
                                                        "numero": "564º",
                                                        "rotulo": "Art. 564º.",
                                                        "linha": 3886,
                                                        "caput": "A nulidade ocorrerá nos seguintes casos:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 3888,
                                                                        "texto": "por incompetência, suspeição ou suborno do juiz;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 3890,
                                                                        "texto": "por ilegitimidade de parte;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 3892,
                                                                        "texto": "por falta das fórmulas ou dos termos seguintes:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 3894,
                                                                                        "texto": "a denúncia ou a queixa e a representação e, nos processos de contravenções penais, a portaria ou o auto de prisão em flagrante;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 3896,
                                                                                        "texto": "exame do corpo de delito nos crimes que deixam vestígios, ressalvado o disposto no Art. 167;"
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 3898,
                                                                                        "texto": "a nomeação de defensor ao réu presente, que o não tiver, ou ao ausente, e de curador ao menor de 21 anos;"
                                                                                },
                                                                                {
                                                                                        "letra": "d",
                                                                                        "rotulo": "d)",
                                                                                        "linha": 3900,
                                                                                        "texto": "a intervenção do Ministério Público em todos os termos da ação por ele intentada e nos da intentada pela parte ofendida, quando se tratar de crime de ação pública;"
                                                                                },
                                                                                {
                                                                                        "letra": "e",
                                                                                        "rotulo": "e)",
                                                                                        "linha": 3902,
                                                                                        "texto": "a citação do réu para ver-se processar, o seu interrogatório, quando presente, e os prazos concedidos à acusação e à defesa;"
                                                                                },
                                                                                {
                                                                                        "letra": "f",
                                                                                        "rotulo": "f)",
                                                                                        "linha": 3904,
                                                                                        "texto": "a sentença de pronúncia, o libelo e a entrega da respectiva cópia, com o rol de testemunhas, nos processos perante o Tribunal do Júri;"
                                                                                },
                                                                                {
                                                                                        "letra": "g",
                                                                                        "rotulo": "g)",
                                                                                        "linha": 3906,
                                                                                        "texto": "a intimação do réu para a sessão de julgamento, pelo Tribunal do Júri, quando a lei não permitir o julgamento à revelia;"
                                                                                },
                                                                                {
                                                                                        "letra": "h",
                                                                                        "rotulo": "h)",
                                                                                        "linha": 3908,
                                                                                        "texto": "a intimação das testemunhas arroladas no libelo e na contrariedade, nos termos estabelecidos pela lei;"
                                                                                },
                                                                                {
                                                                                        "letra": "i",
                                                                                        "rotulo": "i)",
                                                                                        "linha": 3910,
                                                                                        "texto": "a presença pelo menos de 15 jurados para a constituição do júri;"
                                                                                },
                                                                                {
                                                                                        "letra": "j",
                                                                                        "rotulo": "j)",
                                                                                        "linha": 3912,
                                                                                        "texto": "sorteio dos jurados do conselho de sentença em número legal e sua incomunicabilidade;"
                                                                                },
                                                                                {
                                                                                        "letra": "k",
                                                                                        "rotulo": "k)",
                                                                                        "linha": 3914,
                                                                                        "texto": "os quesitos e as respectivas respostas;"
                                                                                },
                                                                                {
                                                                                        "letra": "l",
                                                                                        "rotulo": "l)",
                                                                                        "linha": 3916,
                                                                                        "texto": "a acusação e a defesa, na sessão de julgamento;"
                                                                                },
                                                                                {
                                                                                        "letra": "m",
                                                                                        "rotulo": "m)",
                                                                                        "linha": 3918,
                                                                                        "texto": "a sentença;"
                                                                                },
                                                                                {
                                                                                        "letra": "n",
                                                                                        "rotulo": "n)",
                                                                                        "linha": 3920,
                                                                                        "texto": "recurso de oficio, nos casos em que a lei o tenha estabelecido;"
                                                                                },
                                                                                {
                                                                                        "letra": "o",
                                                                                        "rotulo": "o)",
                                                                                        "linha": 3922,
                                                                                        "texto": "a intimação, nas condições estabelecidas pela lei, para ciência de sentenças e despachos de que caiba recurso;"
                                                                                },
                                                                                {
                                                                                        "letra": "p",
                                                                                        "rotulo": "p)",
                                                                                        "linha": 3924,
                                                                                        "texto": "no Supremo Tribunal Federal e nos Tribunais de Apelação, o quorum legal para o julgamento;"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 3926,
                                                                        "texto": "por omissão de formalidade que constitua elemento essencial do ato."
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 3928,
                                                                        "texto": "em decorrência de decisão carente de fundamentação."
                                                                }
                                                        ],
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 3930,
                                                                        "texto": "Ocorrerá ainda a nulidade, por deficiência dos quesitos ou das suas respostas, e contradição entre estas."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "565º",
                                                        "rotulo": "Art. 565º.",
                                                        "linha": 3932,
                                                        "caput": "Nenhuma das partes poderá argüir nulidade a que haja dado causa, ou para que tenha concorrido, ou referente a formalidade cuja observância só à parte contrária interesse."
                                                },
                                                {
                                                        "numero": "566º",
                                                        "rotulo": "Art. 566º.",
                                                        "linha": 3934,
                                                        "caput": "Não será declarada a nulidade de ato processual que não houver influído na apuração da verdade substancial ou na decisão da causa."
                                                },
                                                {
                                                        "numero": "567º",
                                                        "rotulo": "Art. 567º.",
                                                        "linha": 3936,
                                                        "caput": "A incompetência do juízo anula somente os atos decisórios, devendo o processo, quando for declarada a nulidade, ser remetido ao juiz competente."
                                                },
                                                {
                                                        "numero": "568º",
                                                        "rotulo": "Art. 568º.",
                                                        "linha": 3938,
                                                        "caput": "A nulidade por ilegitimidade do representante da parte poderá ser a todo tempo sanada, mediante ratificação dos atos processuais."
                                                },
                                                {
                                                        "numero": "569º",
                                                        "rotulo": "Art. 569º.",
                                                        "linha": 3940,
                                                        "caput": "As omissões da denúncia ou da queixa, da representação, ou, nos processos das contravenções penais, da portaria ou do auto de prisão em flagrante, poderão ser supridas a todo o tempo, antes da sentença final."
                                                },
                                                {
                                                        "numero": "570º",
                                                        "rotulo": "Art. 570º.",
                                                        "linha": 3942,
                                                        "caput": "A falta ou a nulidade da citação, da intimação ou notificação estará sanada, desde que o interessado compareça, antes de o ato consumar-se, embora declare que o faz para o único fim de argüi-la. O juiz ordenará, todavia, a suspensão ou o adiamento do ato, quando reconhecer que a irregularidade poderá prejudicar direito da parte."
                                                },
                                                {
                                                        "numero": "571º",
                                                        "rotulo": "Art. 571º.",
                                                        "linha": 3944,
                                                        "caput": "As nulidades deverão ser argüidas:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 3946,
                                                                        "texto": "as da instrução criminal dos processos da competência do júri, nos prazos a que se refere o art. 406;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 3948,
                                                                        "texto": "as da instrução criminal dos processos de competência do juiz singular e dos processos especiais, salvo os dos Capítulos V e Vll do Título II do Livro II, nos prazos a que se refere o art. 500;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 3950,
                                                                        "texto": "as do processo sumário, no prazo a que se refere o art. 537, ou, se verificadas depois desse prazo, logo depois de aberta a audiência e apregoadas as partes;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 3952,
                                                                        "texto": "as do processo regulado no Capítulo VII do Título II do Livro II, logo depois de aberta a audiência;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 3954,
                                                                        "texto": "as ocorridas posteriormente à pronúncia, logo depois de anunciado o julgamento e apregoadas as partes (art. 447);"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 3956,
                                                                        "texto": "as de instrução criminal dos processos de competência do Supremo Tribunal Federal e dos Tribunais de Apelação, nos prazos a que se refere o art. 500;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 3958,
                                                                        "texto": "se verificadas após a decisão da primeira instância, nas razões de recurso ou logo depois de anunciado o julgamento do recurso e apregoadas as partes;"
                                                                },
                                                                {
                                                                        "numero": "VIII",
                                                                        "rotulo": "VIII",
                                                                        "linha": 3960,
                                                                        "texto": "as do julgamento em plenário, em audiência ou em sessão do tribunal, logo depois de ocorrerem."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "572º",
                                                        "rotulo": "Art. 572º.",
                                                        "linha": 3962,
                                                        "caput": "As nulidades previstas no art. 564, Ill, de e, segunda parte, g e h, e IV, considerar-se-ão sanadas:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 3964,
                                                                        "texto": "se não forem argüidas, em tempo oportuno, de acordo com o disposto no artigo anterior;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 3966,
                                                                        "texto": "se, praticado por outra forma, o ato tiver atingido o seu fim;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 3968,
                                                                        "texto": "se a parte, ainda que tacitamente, tiver aceito os seus efeitos."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "573º",
                                                        "rotulo": "Art. 573º.",
                                                        "linha": 3970,
                                                        "caput": "Os atos, cuja nulidade não tiver sido sanada, na forma dos artigos anteriores, serão renovados ou retificados.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 3972,
                                                                        "texto": "A nulidade de um ato, uma vez declarada, causará a dos atos que dele diretamente dependam ou sejam conseqüência."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 3974,
                                                                        "texto": "O juiz que pronunciar a nulidade declarará os atos a que ela se estende."
                                                                }
                                                        ]
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO II",
                                        "linha": 3976,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 3980,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "574º",
                                                                        "rotulo": "Art. 574º.",
                                                                        "linha": 3984,
                                                                        "caput": "Os recursos serão voluntários, excetuando-se os seguintes casos, em que deverão ser interpostos, de ofício, pelo juiz:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 3986,
                                                                                        "texto": "da sentença que conceder habeas corpus;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 3988,
                                                                                        "texto": "da que absolver desde logo o réu com fundamento na existência de circunstância que exclua o crime ou isente o réu de pena, nos termos do art. 411."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "575º",
                                                                        "rotulo": "Art. 575º.",
                                                                        "linha": 3990,
                                                                        "caput": "Não serão prejudicados os recursos que, por erro, falta ou omissão dos funcionários, não tiverem seguimento ou não forem apresentados dentro do prazo."
                                                                },
                                                                {
                                                                        "numero": "576º",
                                                                        "rotulo": "Art. 576º.",
                                                                        "linha": 3992,
                                                                        "caput": "O Ministério Público não poderá desistir de recurso que haja interposto."
                                                                },
                                                                {
                                                                        "numero": "577º",
                                                                        "rotulo": "Art. 577º.",
                                                                        "linha": 3994,
                                                                        "caput": "O recurso poderá ser interposto pelo Ministério Público, ou pelo querelante, ou pelo réu, seu procurador ou seu defensor.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 3996,
                                                                                        "texto": "Não se admitirá, entretanto, recurso da parte que não tiver interesse na reforma ou modificação da decisão."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "578º",
                                                                        "rotulo": "Art. 578º.",
                                                                        "linha": 3998,
                                                                        "caput": "O recurso será interposto por petição ou por termo nos autos, assinado pelo recorrente ou por seu representante.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4000,
                                                                                        "texto": "Não sabendo ou não podendo o réu assinar o nome, o termo será assinado por alguém, a seu rogo, na presença de duas testemunhas."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4002,
                                                                                        "texto": "A petição de interposição de recurso, com o despacho do juiz, será, até o dia seguinte ao último do prazo, entregue ao escrivão, que certificará no termo da juntada a data da entrega."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4004,
                                                                                        "texto": "Interposto por termo o recurso, o escrivão, sob pena de suspensão por dez a trinta dias, fará conclusos os autos ao juiz, até o dia seguinte ao último do prazo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "579º",
                                                                        "rotulo": "Art. 579º.",
                                                                        "linha": 4006,
                                                                        "caput": "Salvo a hipótese de má-fé, a parte não será prejudicada pela interposição de um recurso por outro.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4008,
                                                                                        "texto": "Se o juiz, desde logo, reconhecer a impropriedade do recurso interposto pela parte, mandará processá-lo de acordo com o rito do recurso cabível."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "580º",
                                                                        "rotulo": "Art. 580º.",
                                                                        "linha": 4010,
                                                                        "caput": "No caso de concurso de agentes (Código Penal, art. 25), a decisão do recurso interposto por um dos réus, se fundado em motivos que não sejam de caráter exclusivamente pessoal, aproveitará aos outros."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 4012,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "581º",
                                                                        "rotulo": "Art. 581º.",
                                                                        "linha": 4016,
                                                                        "caput": "Caberá recurso, no sentido estrito, da decisão, despacho ou sentença:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4018,
                                                                                        "texto": "que não receber a denúncia ou a queixa;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4020,
                                                                                        "texto": "que concluir pela incompetência do juízo;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4022,
                                                                                        "texto": "que julgar procedentes as exceções, salvo a de suspeição;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 4025,
                                                                                        "texto": "que pronunciar o réu;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 4029,
                                                                                        "texto": "que conceder, negar, arbitrar, cassar ou julgar inidônea a fiança, indeferir requerimento de prisão preventiva ou revogá-la, conceder liberdade provisória ou relaxar a prisão em flagrante;"
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 4031,
                                                                                        "texto": ""
                                                                                },
                                                                                {
                                                                                        "numero": "VII",
                                                                                        "rotulo": "VII",
                                                                                        "linha": 4033,
                                                                                        "texto": "que julgar quebrada a fiança ou perdido o seu valor;"
                                                                                },
                                                                                {
                                                                                        "numero": "VIII",
                                                                                        "rotulo": "VIII",
                                                                                        "linha": 4035,
                                                                                        "texto": "que decretar a prescrição ou julgar, por outro modo, extinta a punibilidade;"
                                                                                },
                                                                                {
                                                                                        "numero": "IX",
                                                                                        "rotulo": "IX",
                                                                                        "linha": 4037,
                                                                                        "texto": "que indeferir o pedido de reconhecimento da prescrição ou de outra causa extintiva da punibilidade;"
                                                                                },
                                                                                {
                                                                                        "numero": "X",
                                                                                        "rotulo": "X",
                                                                                        "linha": 4039,
                                                                                        "texto": "que conceder ou negar a ordem de habeas corpus;"
                                                                                },
                                                                                {
                                                                                        "numero": "XI",
                                                                                        "rotulo": "XI",
                                                                                        "linha": 4041,
                                                                                        "texto": "que conceder, negar ou revogar a suspensão condicional da pena;"
                                                                                },
                                                                                {
                                                                                        "numero": "XII",
                                                                                        "rotulo": "XII",
                                                                                        "linha": 4043,
                                                                                        "texto": "que conceder, negar ou revogar livramento condicional; XIII - que anular o processo da instrução criminal, no todo ou em parte; XIV - que incluir jurado na lista geral ou desta o excluir; XV - que denegar a apelação ou a julgar deserta; XVI - que ordenar a suspensão do processo, em virtude de questão prejudicial; XVII - que decidir sobre a unificação de penas; XVIII - que decidir o incidente de falsidade; XIX - que decretar medida de segurança, depois de transitar a sentença em julgado;"
                                                                                },
                                                                                {
                                                                                        "numero": "XX",
                                                                                        "rotulo": "XX",
                                                                                        "linha": 4059,
                                                                                        "texto": "que impuser medida de segurança por transgressão de outra; XXI - que mantiver ou substituir a medida de segurança, nos casos do art. 774; XXII - que revogar a medida de segurança; XXIII - que deixar de revogar a medida de segurança, nos casos em que a lei admita a revogação; XXIV - que converter a multa em detenção ou em prisão simples. XXV - que recusar homologação à proposta de acordo de não persecução penal, previsto no art. 28-A desta Lei."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "582º",
                                                                        "rotulo": "Art. 582º.",
                                                                        "linha": 4071,
                                                                        "caput": "- Os recursos serão sempre para o Tribunal de Apelação, salvo nos casos dos ns. V, X e XIV.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4073,
                                                                                        "texto": "O recurso, no caso do no XIV, será para o presidente do Tribunal de Apelação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "583º",
                                                                        "rotulo": "Art. 583º.",
                                                                        "linha": 4075,
                                                                        "caput": "Subirão nos próprios autos os recursos:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4077,
                                                                                        "texto": "quando interpostos de oficio;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4079,
                                                                                        "texto": "nos casos do art. 581, I, III, IV, VI, VIII e X;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4081,
                                                                                        "texto": "quando o recurso não prejudicar o andamento do processo."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4083,
                                                                                        "texto": "O recurso da pronúncia subirá em traslado, quando, havendo dois ou mais réus, qualquer deles se conformar com a decisão ou todos não tiverem sido ainda intimados da pronúncia."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "584º",
                                                                        "rotulo": "Art. 584º.",
                                                                        "linha": 4085,
                                                                        "caput": "Os recursos terão efeito suspensivo nos casos de perda da fiança, de concessão de livramento condicional e dos ns. XV, XVII e XXIV do art. 581.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4087,
                                                                                        "texto": "Ao recurso interposto de sentença de impronúncia ou no caso do no VIII do art. 581, aplicar-se-á o disposto nos arts. 596 e 598."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4089,
                                                                                        "texto": "O recurso da pronúncia suspenderá tão-somente o julgamento."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4091,
                                                                                        "texto": "O recurso do despacho que julgar quebrada a fiança suspenderá unicamente o efeito de perda da metade do seu valor."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4093,
                                                                                        "texto": "No caso previsto no inciso V do caput do art. 581, sem prejuízo do disposto no art. 589 deste Código, a qualquer tempo, até o julgamento, o recorrente poderá pedir ao Tribunal ad quem concessão de efeito suspensivo ou ativo ao recurso interposto, demonstrando a relevância dos motivos, a plausibilidade do direito alegado e a probabilidade de dano irreparável ou de difícil reparação, durante a tramitação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "585º",
                                                                        "rotulo": "Art. 585º.",
                                                                        "linha": 4095,
                                                                        "caput": "O réu não poderá recorrer da pronúncia senão depois de preso, salvo se prestar fiança, nos casos em que a lei a admitir."
                                                                },
                                                                {
                                                                        "numero": "586º",
                                                                        "rotulo": "Art. 586º.",
                                                                        "linha": 4097,
                                                                        "caput": "O recurso voluntário poderá ser interposto no prazo de cinco dias.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4099,
                                                                                        "texto": "No caso do art. 581, XIV, o prazo será de vinte dias, contado da data da publicação definitiva da lista de jurados."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "587º",
                                                                        "rotulo": "Art. 587º.",
                                                                        "linha": 4101,
                                                                        "caput": "Quando o recurso houver de subir por instrumento, a parte indicará, no respectivo termo, ou em requerimento avulso, as peças dos autos de que pretenda traslado.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4103,
                                                                                        "texto": "O traslado será extraído, conferido e concertado no prazo de cinco dias, e dele constarão sempre a decisão recorrida, a certidão de sua intimação, se por outra forma não for possível verificar-se a oportunidade do recurso, e o termo de interposição."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "588º",
                                                                        "rotulo": "Art. 588º.",
                                                                        "linha": 4105,
                                                                        "caput": "Dentro de dois dias, contados da interposição do recurso, ou do dia em que o escrivão, extraído o traslado, o fizer com vista ao recorrente, este oferecerá as razões e, em seguida, será aberta vista ao recorrido por igual prazo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4107,
                                                                                        "texto": "Se o recorrido for o réu, será intimado do prazo na pessoa do defensor."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "589º",
                                                                        "rotulo": "Art. 589º.",
                                                                        "linha": 4109,
                                                                        "caput": "Com a resposta do recorrido ou sem ela, será o recurso concluso ao juiz, que, dentro de dois dias, reformará ou sustentará o seu despacho, mandando instruir o recurso com os traslados que Ihe parecerem necessários.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4111,
                                                                                        "texto": "Se o juiz reformar o despacho recorrido, a parte contrária, por simples petição, poderá recorrer da nova decisão, se couber recurso, não sendo mais lícito ao juiz modificá-la. Neste caso, independentemente de novos arrazoados, subirá o recurso nos próprios autos ou em traslado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "590º",
                                                                        "rotulo": "Art. 590º.",
                                                                        "linha": 4113,
                                                                        "caput": "Quando for impossível ao escrivão extrair o traslado no prazo da lei, poderá o juiz prorrogá-lo até o dobro."
                                                                },
                                                                {
                                                                        "numero": "591º",
                                                                        "rotulo": "Art. 591º.",
                                                                        "linha": 4115,
                                                                        "caput": "Os recursos serão apresentados ao juiz ou tribunal ad quem, dentro de cinco dias da publicação da resposta do juiza quo, ou entregues ao Correio dentro do mesmo prazo."
                                                                },
                                                                {
                                                                        "numero": "592º",
                                                                        "rotulo": "Art. 592º.",
                                                                        "linha": 4117,
                                                                        "caput": "Publicada a decisão do juiz ou do tribunal ad quem, deverão os autos ser devolvidos, dentro de cinco dias, ao juiz a quo."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 4119,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "593º",
                                                                        "rotulo": "Art. 593º.",
                                                                        "linha": 4131,
                                                                        "caput": "Caberá apelação no prazo de 5 (cinco) dias:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4133,
                                                                                        "texto": "das sentenças definitivas de condenação ou absolvição proferidas por juiz singular;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4135,
                                                                                        "texto": "das decisões definitivas, ou com força de definitivas, proferidas por juiz singular nos casos não previstos no Capítulo anterior;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4137,
                                                                                        "texto": "das decisões do Tribunal do Júri, quando:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 4139,
                                                                                                        "texto": "ocorrer nulidade posterior à pronúncia;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 4141,
                                                                                                        "texto": "for a sentença do juiz-presidente contrária à lei expressa ou à decisão dos jurados;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 4143,
                                                                                                        "texto": "houver erro ou injustiça no tocante à aplicação da pena ou da medida de segurança;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "d",
                                                                                                        "rotulo": "d)",
                                                                                                        "linha": 4145,
                                                                                                        "texto": "for a decisão dos jurados manifestamente contrária à prova dos autos."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4147,
                                                                                        "texto": "Se a sentença do juiz-presidente for contrária à lei expressa ou divergir das respostas dos jurados aos quesitos, o tribunal ad quemfará a devida retificação."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4149,
                                                                                        "texto": "Interposta a apelação com fundamento no no III, c, deste artigo, o tribunal ad quem, se Ihe der provimento, retificará a aplicação da pena ou da medida de segurança."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4151,
                                                                                        "texto": "Se a apelação se fundar no no III, d, deste artigo, e o tribunal ad quem se convencer de que a decisão dos jurados é manifestamente contrária à prova dos autos, dar-lhe-á provimento para sujeitar o réu a novo julgamento; não se admite, porém, pelo mesmo motivo, segunda apelação."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4153,
                                                                                        "texto": "Quando cabível a apelação, não poderá ser usado o recurso em sentido estrito, ainda que somente de parte da decisão se recorra. (Parágrafo único renumerado pela Lei nº 263, de 23.2.1948)"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "594º",
                                                                        "rotulo": "Art. 594º.",
                                                                        "linha": 4156,
                                                                        "caput": ""
                                                                },
                                                                {
                                                                        "numero": "595º",
                                                                        "rotulo": "Art. 595º.",
                                                                        "linha": 4158,
                                                                        "caput": ""
                                                                },
                                                                {
                                                                        "numero": "596º",
                                                                        "rotulo": "Art. 596º.",
                                                                        "linha": 4166,
                                                                        "caput": "A apelação da sentença absolutória não impedirá que o réu seja posto imediatamente em liberdade.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4168,
                                                                                        "texto": "A apelação não suspenderá a execução da medida de segurança aplicada provisoriamente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "597º",
                                                                        "rotulo": "Art. 597º.",
                                                                        "linha": 4170,
                                                                        "caput": "A apelação de sentença condenatória terá efeito suspensivo, salvo o disposto no art. 393, a aplicação provisória de interdições de direitos e de medidas de segurança (arts. 374 e 378), e o caso de suspensão condicional de pena."
                                                                },
                                                                {
                                                                        "numero": "598º",
                                                                        "rotulo": "Art. 598º.",
                                                                        "linha": 4172,
                                                                        "caput": "Nos crimes de competência do Tribunal do Júri, ou do juiz singular, se da sentença não for interposta apelação pelo Ministério Público no prazo legal, o ofendido ou qualquer das pessoas enumeradas no art. 31, ainda que não se tenha habilitado como assistente, poderá interpor apelação, que não terá, porém, efeito suspensivo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4174,
                                                                                        "texto": "O prazo para interposição desse recurso será de quinze dias e correrá do dia em que terminar o do Ministério Público."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "599º",
                                                                        "rotulo": "Art. 599º.",
                                                                        "linha": 4176,
                                                                        "caput": "As apelações poderão ser interpostas quer em relação a todo o julgado, quer em relação a parte dele."
                                                                },
                                                                {
                                                                        "numero": "600º",
                                                                        "rotulo": "Art. 600º.",
                                                                        "linha": 4178,
                                                                        "caput": "Assinado o termo de apelação, o apelante e, depois dele, o apelado terão o prazo de oito dias cada um para oferecer razões, salvo nos processos de contravenção, em que o prazo será de três dias.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4180,
                                                                                        "texto": "Se houver assistente, este arrazoará, no prazo de três dias, após o Ministério Público."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4182,
                                                                                        "texto": "Se a ação penal for movida pela parte ofendida, o Ministério Público terá vista dos autos, no prazo do parágrafo anterior."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4184,
                                                                                        "texto": "Quando forem dois ou mais os apelantes ou apelados, os prazos serão comuns."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4186,
                                                                                        "texto": "Se o apelante declarar, na petição ou no termo, ao interpor a apelação, que deseja arrazoar na superior instância serão os autos remetidos ao tribunal ad quem onde será aberta vista às partes, observados os prazos legais, notificadas as partes pela publicação oficial."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "601º",
                                                                        "rotulo": "Art. 601º.",
                                                                        "linha": 4188,
                                                                        "caput": "Findos os prazos para razões, os autos serão remetidos à instância superior, com as razões ou sem elas, no prazo de 5 (cinco) dias, salvo no caso do art. 603, segunda parte, em que o prazo será de trinta dias.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4190,
                                                                                        "texto": "Se houver mais de um réu, e não houverem todos sido julgados, ou não tiverem todos apelado, caberá ao apelante promover extração do traslado dos autos, o qual deverá ser remetido à instância superior no prazo de trinta dias, contado da data da entrega das últimas razões de apelação, ou do vencimento do prazo para a apresentação das do apelado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4192,
                                                                                        "texto": "As despesas do traslado correrão por conta de quem o solicitar, salvo se o pedido for de réu pobre ou do Ministério Público."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "602º",
                                                                        "rotulo": "Art. 602º.",
                                                                        "linha": 4194,
                                                                        "caput": "Os autos serão, dentro dos prazos do artigo anterior, apresentados ao tribunal ad quem ou entregues ao Correio, sob registro."
                                                                },
                                                                {
                                                                        "numero": "603º",
                                                                        "rotulo": "Art. 603º.",
                                                                        "linha": 4196,
                                                                        "caput": "A apelação subirá nos autos originais e, a não ser no Distrito Federal e nas comarcas que forem sede de Tribunal de Apelação, ficará em cartório traslado dos termos essenciais do processo referidos no art. 564, n. III."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO V",
                                                        "linha": 4198,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "609º",
                                                                        "rotulo": "Art. 609º.",
                                                                        "linha": 4205,
                                                                        "caput": "Os recursos, apelações e embargos serão julgados pelos Tribunais de Justiça, câmaras ou turmas criminais, de acordo com a competência estabelecida nas leis de organização judiciária.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4207,
                                                                                        "texto": "Quando não for unânime a decisão de segunda instância, desfavorável ao réu, admitem-se embargos infringentes e de nulidade, que poderão ser opostos dentro de 10 (dez) dias, a contar da publicação de acórdão, na forma do art. 613. Se o desacordo for parcial, os embargos serão restritos à matéria objeto de divergência."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "610º",
                                                                        "rotulo": "Art. 610º.",
                                                                        "linha": 4209,
                                                                        "caput": "Nos recursos em sentido estrito, com exceção do de habeas corpus, e nas apelações interpostas das sentenças em processo de contravenção ou de crime a que a lei comine pena de detenção, os autos irão imediatamente com vista ao procurador-geral pelo prazo de cinco dias, e, em seguida, passarão, por igual prazo, ao relator, que pedirá designação de dia para o julgamento.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4211,
                                                                                        "texto": "Anunciado o julgamento pelo presidente, e apregoadas as partes, com a presença destas ou à sua revelia, o relator fará a exposição do feito e, em seguida, o presidente concederá, pelo prazo de 10 (dez) minutos, a palavra aos advogados ou às partes que a solicitarem e ao procurador-geral, quando o requerer, por igual prazo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "611º",
                                                                        "rotulo": "Art. 611º.",
                                                                        "linha": 4213,
                                                                        "caput": ""
                                                                },
                                                                {
                                                                        "numero": "612º",
                                                                        "rotulo": "Art. 612º.",
                                                                        "linha": 4215,
                                                                        "caput": "Os recursos de habeas corpus, designado o relator, serão julgados na primeira sessão."
                                                                },
                                                                {
                                                                        "numero": "613º",
                                                                        "rotulo": "Art. 613º.",
                                                                        "linha": 4217,
                                                                        "caput": "As apelações interpostas das sentenças proferidas em processos por crime a que a lei comine pena de reclusão, deverão ser processadas e julgadas pela forma estabelecida no Art. 610, com as seguintes modificações:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4219,
                                                                                        "texto": "exarado o relatório nos autos, passarão estes ao revisor, que terá igual prazo para o exame do processo e pedirá designação de dia para o julgamento;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4221,
                                                                                        "texto": "os prazos serão ampliados ao dobro;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4223,
                                                                                        "texto": "tempo para os debates será de um quarto de hora."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "614º",
                                                                        "rotulo": "Art. 614º.",
                                                                        "linha": 4225,
                                                                        "caput": "No caso de impossibilidade de observância de qualquer dos prazos marcados nos arts. 610 e 613, os motivos da demora serão declarados nos autos."
                                                                },
                                                                {
                                                                        "numero": "615º",
                                                                        "rotulo": "Art. 615º.",
                                                                        "linha": 4227,
                                                                        "caput": "O tribunal decidirá por maioria de votos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4229,
                                                                                        "texto": "Em todos os julgamentos em matéria penal ou processual penal em órgãos colegiados, havendo empate, prevalecerá a decisão mais favorável ao indivíduo imputado, proclamando-se de imediato esse resultado, ainda que, nas hipóteses de vaga aberta a ser preenchida, de impedimento, de suspeição ou de ausência, tenha sido o julgamento tomado sem a totalidade dos integrantes do colegiado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4231,
                                                                                        "texto": "O acórdão será apresentado à conferência na primeira sessão seguinte à do julgamento, ou no prazo de duas sessões, pelo juiz incumbido de lavrá-lo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "616º",
                                                                        "rotulo": "Art. 616º.",
                                                                        "linha": 4233,
                                                                        "caput": "No julgamento das apelações poderá o tribunal, câmara ou turma proceder a novo interrogatório do acusado, reinquirir testemunhas ou determinar outras diligências."
                                                                },
                                                                {
                                                                        "numero": "617º",
                                                                        "rotulo": "Art. 617º.",
                                                                        "linha": 4235,
                                                                        "caput": "O tribunal, câmara ou turma atenderá nas suas decisões ao disposto nos arts. 383, 386 e 387, no que for aplicável, não podendo, porém, ser agravada a pena, quando somente o réu houver apelado da sentença."
                                                                },
                                                                {
                                                                        "numero": "618º",
                                                                        "rotulo": "Art. 618º.",
                                                                        "linha": 4237,
                                                                        "caput": "Os regimentos dos Tribunais de Apelação estabelecerão as normas complementares para o processo e julgamento dos recursos e apelações."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VI",
                                                        "linha": 4239,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "619º",
                                                                        "rotulo": "Art. 619º.",
                                                                        "linha": 4243,
                                                                        "caput": "Aos acórdãos proferidos pelos Tribunais de Apelação, câmaras ou turmas, poderão ser opostos embargos de declaração, no prazo de dois dias contados da sua publicação, quando houver na sentença ambiguidade, obscuridade, contradição ou omissão."
                                                                },
                                                                {
                                                                        "numero": "620º",
                                                                        "rotulo": "Art. 620º.",
                                                                        "linha": 4245,
                                                                        "caput": "Os embargos de declaração serão deduzidos em requerimento de que constem os pontos em que o acórdão é ambíguo, obscuro, contraditório ou omisso.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4247,
                                                                                        "texto": "O requerimento será apresentado pelo relator e julgado, independentemente de revisão, na primeira sessão."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4249,
                                                                                        "texto": "Se não preenchidas as condições enumeradas neste artigo, o relator indeferirá desde logo o requerimento."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO VII",
                                                        "linha": 4251,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "621º",
                                                                        "rotulo": "Art. 621º.",
                                                                        "linha": 4255,
                                                                        "caput": "A revisão dos processos findos será admitida:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4257,
                                                                                        "texto": "quando a sentença condenatória for contrária ao texto expresso da lei penal ou à evidência dos autos;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4259,
                                                                                        "texto": "quando a sentença condenatória se fundar em depoimentos, exames ou documentos comprovadamente falsos;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4261,
                                                                                        "texto": "quando, após a sentença, se descobrirem novas provas de inocência do condenado ou de circunstância que determine ou autorize diminuição especial da pena."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "622º",
                                                                        "rotulo": "Art. 622º.",
                                                                        "linha": 4263,
                                                                        "caput": "A revisão poderá ser requerida em qualquer tempo, antes da extinção da pena ou após.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4265,
                                                                                        "texto": "Não será admissível a reiteração do pedido, salvo se fundado em novas provas."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "623º",
                                                                        "rotulo": "Art. 623º.",
                                                                        "linha": 4267,
                                                                        "caput": "A revisão poderá ser pedida pelo próprio réu ou por procurador legalmente habilitado ou, no caso de morte do réu, pelo cônjuge, ascendente, descendente ou irmão."
                                                                },
                                                                {
                                                                        "numero": "624º",
                                                                        "rotulo": "Art. 624º.",
                                                                        "linha": 4273,
                                                                        "caput": "As revisões criminais serão processadas e julgadas:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4275,
                                                                                        "texto": "pelo Supremo Tribunal Federal, quanto às condenações por ele proferidas;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4277,
                                                                                        "texto": "pelo Tribunal Federal de Recursos, Tribunais de Justiça ou de Alçada, nos demais casos."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4279,
                                                                                        "texto": "No Supremo Tribunal Federal e no Tribunal Federal de Recursos o processo e julgamento obedecerão ao que for estabelecido no respectivo regimento interno."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4281,
                                                                                        "texto": "Nos Tribunais de Justiça ou de Alçada, o julgamento será efetuado pelas câmaras ou turmas criminais, reunidas em sessão conjunta, quando houver mais de uma, e, no caso contrário, pelo tribunal pleno."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4283,
                                                                                        "texto": "Nos tribunais onde houver quatro ou mais câmaras ou turmas criminais, poderão ser constituídos dois ou mais grupos de câmaras ou turmas para o julgamento de revisão, obedecido o que for estabelecido no respectivo regimento interno."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "625º",
                                                                        "rotulo": "Art. 625º.",
                                                                        "linha": 4285,
                                                                        "caput": "O requerimento será distribuído a um relator e a um revisor, devendo funcionar como relator um desembargador que não tenha pronunciado decisão em qualquer fase do processo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4287,
                                                                                        "texto": "O requerimento será instruído com a certidão de haver passado em julgado a sentença condenatória e com as peças necessárias à comprovação dos fatos argüidos."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4289,
                                                                                        "texto": "O relator poderá determinar que se apensem os autos originais, se daí não advier dificuldade à execução normal da sentença."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4291,
                                                                                        "texto": "Se o relator julgar insuficientemente instruído o pedido e inconveniente ao interesse da justiça que se apensem os autos originais, indeferi-lo-á in limine, dando recurso para as câmaras reunidas ou para o tribunal, conforme o caso (art. 624, parágrafo único)."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4293,
                                                                                        "texto": "Interposto o recurso por petição e independentemente de termo, o relator apresentará o processo em mesa para o julgamento e o relatará, sem tomar parte na discussão."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 4295,
                                                                                        "texto": "Se o requerimento não for indeferido in limine, abrir-se-á vista dos autos ao procurador-geral, que dará parecer no prazo de dez dias. Em seguida, examinados os autos, sucessivamente, em igual prazo, pelo relator e revisor, julgar-se-á o pedido na sessão que o presidente designar."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "626º",
                                                                        "rotulo": "Art. 626º.",
                                                                        "linha": 4297,
                                                                        "caput": "Julgando procedente a revisão, o tribunal poderá alterar a classificação da infração, absolver o réu, modificar a pena ou anular o processo.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4299,
                                                                                        "texto": "De qualquer maneira, não poderá ser agravada a pena imposta pela decisão revista."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "627º",
                                                                        "rotulo": "Art. 627º.",
                                                                        "linha": 4301,
                                                                        "caput": "A absolvição implicará o restabelecimento de todos os direitos perdidos em virtude da condenação, devendo o tribunal, se for caso, impor a medida de segurança cabível."
                                                                },
                                                                {
                                                                        "numero": "628º",
                                                                        "rotulo": "Art. 628º.",
                                                                        "linha": 4303,
                                                                        "caput": "Os regimentos internos dos Tribunais de Apelação estabelecerão as normas complementares para o processo e julgamento das revisões criminais."
                                                                },
                                                                {
                                                                        "numero": "629º",
                                                                        "rotulo": "Art. 629º.",
                                                                        "linha": 4305,
                                                                        "caput": "À vista da certidão do acórdão que cassar a sentença condenatória, o juiz mandará juntá-la imediatamente aos autos, para inteiro cumprimento da decisão."
                                                                },
                                                                {
                                                                        "numero": "630º",
                                                                        "rotulo": "Art. 630º.",
                                                                        "linha": 4307,
                                                                        "caput": "O tribunal, se o interessado o requerer, poderá reconhecer o direito a uma justa indenização pelos prejuízos sofridos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4309,
                                                                                        "texto": "Por essa indenização, que será liquidada no juízo cível, responderá a União, se a condenação tiver sido proferida pela justiça do Distrito Federal ou de Território, ou o Estado, se o tiver sido pela respectiva justiça."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4311,
                                                                                        "texto": "A indenização não será devida:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 4313,
                                                                                                        "texto": "se o erro ou a injustiça da condenação proceder de ato ou falta imputável ao próprio impetrante, como a confissão ou a ocultação de prova em seu poder;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 4315,
                                                                                                        "texto": "se a acusação houver sido meramente privada."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "631º",
                                                                        "rotulo": "Art. 631º.",
                                                                        "linha": 4317,
                                                                        "caput": "Quando, no curso da revisão, falecer a pessoa, cuja condenação tiver de ser revista, o presidente do tribunal nomeará curador para a defesa."
                                                                },
                                                                {
                                                                        "numero": "637º",
                                                                        "rotulo": "Art. 637º.",
                                                                        "linha": 4319,
                                                                        "caput": "O recurso extraordinário não tem efeito suspensivo, e uma vez arrazoados pelo recorrido os autos do traslado, os originais baixarão à primeira instância, para a execução da sentença."
                                                                },
                                                                {
                                                                        "numero": "638º",
                                                                        "rotulo": "Art. 638º.",
                                                                        "linha": 4322,
                                                                        "caput": "O recurso extraordinário e o recurso especial serão processados e julgados no Supremo Tribunal Federal e no Superior Tribunal de Justiça na forma estabelecida por leis especiais, pela lei processual civil e pelos respectivos regimentos internos."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO IX",
                                                        "linha": 4324,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "639º",
                                                                        "rotulo": "Art. 639º.",
                                                                        "linha": 4328,
                                                                        "caput": "Dar-se-á carta testemunhável:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4330,
                                                                                        "texto": "da decisão que denegar o recurso;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4332,
                                                                                        "texto": "da que, admitindo embora o recurso, obstar à sua expedição e seguimento para o juízo ad quem."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "640º",
                                                                        "rotulo": "Art. 640º.",
                                                                        "linha": 4334,
                                                                        "caput": "A carta testemunhável será requerida ao escrivão, ou ao secretário do tribunal, conforme o caso, nas quarenta e oito horas seguintes ao despacho que denegar o recurso, indicando o requerente as peças do processo que deverão ser trasladadas."
                                                                },
                                                                {
                                                                        "numero": "641º",
                                                                        "rotulo": "Art. 641º.",
                                                                        "linha": 4336,
                                                                        "caput": "O escrivão, ou o secretário do tribunal, dará recibo da petição à parte e, no prazo máximo de cinco dias, no caso de recurso no sentido estrito, ou de sessenta dias, no caso de recurso extraordinário, fará entrega da carta, devidamente conferida e concertada."
                                                                },
                                                                {
                                                                        "numero": "642º",
                                                                        "rotulo": "Art. 642º.",
                                                                        "linha": 4338,
                                                                        "caput": "O escrivão, ou o secretário do tribunal, que se negar a dar o recibo, ou deixar de entregar, sob qualquer pretexto, o instrumento, será suspenso por trinta dias. O juiz, ou o presidente do Tribunal de Apelação, em face de representação do testemunhante, imporá a pena e mandará que seja extraído o instrumento, sob a mesma sanção, pelo substituto do escrivão ou do secretário do tribunal. Se o testemunhante não for atendido, poderá reclamar ao presidente do tribunal ad quem, que avocará os autos, para o efeito do julgamento do recurso e imposição da pena."
                                                                },
                                                                {
                                                                        "numero": "643º",
                                                                        "rotulo": "Art. 643º.",
                                                                        "linha": 4340,
                                                                        "caput": "Extraído e autuado o instrumento, observar-se-á o disposto nos arts. 588 a 592, no caso de recurso em sentido estrito, ou o processo estabelecido para o recurso extraordinário, se deste se tratar."
                                                                },
                                                                {
                                                                        "numero": "644º",
                                                                        "rotulo": "Art. 644º.",
                                                                        "linha": 4342,
                                                                        "caput": "O tribunal, câmara ou turma a que competir o julgamento da carta, se desta tomar conhecimento, mandará processar o recurso, ou, se estiver suficientemente instruída, decidirá logo, de meritis."
                                                                },
                                                                {
                                                                        "numero": "645º",
                                                                        "rotulo": "Art. 645º.",
                                                                        "linha": 4344,
                                                                        "caput": "O processo da carta testemunhável na instância superior seguirá o processo do recurso denegado."
                                                                },
                                                                {
                                                                        "numero": "646º",
                                                                        "rotulo": "Art. 646º.",
                                                                        "linha": 4346,
                                                                        "caput": "A carta testemunhável não terá efeito suspensivo."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO X",
                                                        "linha": 4348,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "647º",
                                                                        "rotulo": "Art. 647º.",
                                                                        "linha": 4352,
                                                                        "caput": "Dar-se-á habeas corpus sempre que alguém sofrer ou se achar na iminência de sofrer violência ou coação ilegal na sua liberdade de ir e vir, salvo nos casos de punição disciplinar."
                                                                },
                                                                {
                                                                        "numero": "647º-A",
                                                                        "rotulo": "Art. 647º-A.",
                                                                        "linha": 4354,
                                                                        "caput": "No âmbito de sua competência jurisdicional, qualquer autoridade judicial poderá expedir de ofício ordem de habeas corpus, individual ou coletivo, quando, no curso de qualquer processo judicial, verificar que, por violação ao ordenamento jurídico, alguém sofre ou se acha ameaçado de sofrer violência ou coação em sua liberdade de locomoção.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4356,
                                                                                        "texto": "A ordem de habeas corpus poderá ser concedida de ofício pelo juiz ou pelo tribunal em processo de competência originária ou recursal, ainda que não conhecidos a ação ou o recurso em que veiculado o pedido de cessação de coação ilegal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "648º",
                                                                        "rotulo": "Art. 648º.",
                                                                        "linha": 4358,
                                                                        "caput": "A coação considerar-se-á ilegal:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4360,
                                                                                        "texto": "quando não houver justa causa;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4362,
                                                                                        "texto": "quando alguém estiver preso por mais tempo do que determina a lei;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4364,
                                                                                        "texto": "quando quem ordenar a coação não tiver competência para fazê-lo;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 4366,
                                                                                        "texto": "quando houver cessado o motivo que autorizou a coação;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 4368,
                                                                                        "texto": "quando não for alguém admitido a prestar fiança, nos casos em que a lei a autoriza;"
                                                                                },
                                                                                {
                                                                                        "numero": "VI",
                                                                                        "rotulo": "VI",
                                                                                        "linha": 4370,
                                                                                        "texto": "quando o processo for manifestamente nulo;"
                                                                                },
                                                                                {
                                                                                        "numero": "VII",
                                                                                        "rotulo": "VII",
                                                                                        "linha": 4372,
                                                                                        "texto": "quando extinta a punibilidade."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "649º",
                                                                        "rotulo": "Art. 649º.",
                                                                        "linha": 4374,
                                                                        "caput": "O juiz ou o tribunal, dentro dos limites da sua jurisdição, fará passar imediatamente a ordem impetrada, nos casos em que tenha cabimento, seja qual for a autoridade coatora."
                                                                },
                                                                {
                                                                        "numero": "650º",
                                                                        "rotulo": "Art. 650º.",
                                                                        "linha": 4376,
                                                                        "caput": "Competirá conhecer, originariamente, do pedido de habeas corpus:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4378,
                                                                                        "texto": "ao Supremo Tribunal Federal, nos casos previstos no Art. 101, I, g, da Constituição;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4380,
                                                                                        "texto": "aos Tribunais de Apelação, sempre que os atos de violência ou coação forem atribuídos aos governadores ou interventores dos Estados ou Territórios e ao prefeito do Distrito Federal, ou a seus secretários, ou aos chefes de Polícia."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4382,
                                                                                        "texto": "A competência do juiz cessará sempre que a violência ou coação provier de autoridade judiciária de igual ou superior jurisdição."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4384,
                                                                                        "texto": "Não cabe ohabeas corpus contra a prisão administrativa, atual ou iminente, dos responsáveis por dinheiro ou valor pertencente à Fazenda Pública, alcançados ou omissos em fazer o seu recolhimento nos prazos legais, salvo se o pedido for acompanhado de prova de quitação ou de depósito do alcance verificado, ou se a prisão exceder o prazo legal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "651º",
                                                                        "rotulo": "Art. 651º.",
                                                                        "linha": 4386,
                                                                        "caput": "A concessão do habeas corpus não obstará, nem porá termo ao processo, desde que este não esteja em conflito com os fundamentos daquela."
                                                                },
                                                                {
                                                                        "numero": "652º",
                                                                        "rotulo": "Art. 652º.",
                                                                        "linha": 4388,
                                                                        "caput": "Se o habeas corpus for concedido em virtude de nulidade do processo, este será renovado."
                                                                },
                                                                {
                                                                        "numero": "653º",
                                                                        "rotulo": "Art. 653º.",
                                                                        "linha": 4390,
                                                                        "caput": "Ordenada a soltura do paciente em virtude de habeas corpus, será condenada nas custas a autoridade que, por má-fé ou evidente abuso de poder, tiver determinado a coação.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4392,
                                                                                        "texto": "Neste caso, será remetida ao Ministério Público cópia das peças necessárias para ser promovida a responsabilidade da autoridade."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "654º",
                                                                        "rotulo": "Art. 654º.",
                                                                        "linha": 4394,
                                                                        "caput": "O habeas corpus poderá ser impetrado por qualquer pessoa, em seu favor ou de outrem, bem como pelo Ministério Público.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4396,
                                                                                        "texto": "A petição de habeas corpus conterá:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 4398,
                                                                                                        "texto": "nome da pessoa que sofre ou está ameaçada de sofrer violência ou coação e o de quem exercer a violência, coação ou ameaça;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 4400,
                                                                                                        "texto": "a declaração da espécie de constrangimento ou, em caso de simples ameaça de coação, as razões em que funda o seu temor;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 4402,
                                                                                                        "texto": "a assinatura do impetrante, ou de alguém a seu rogo, quando não souber ou não puder escrever, e a designação das respectivas residências."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4404,
                                                                                        "texto": "Os juízes e os tribunais têm competência para expedir de ofício ordem de habeascorpus, quando no curso de processo verificarem que alguém sofre ou está na iminência de sofrer coação ilegal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "655º",
                                                                        "rotulo": "Art. 655º.",
                                                                        "linha": 4406,
                                                                        "caput": "O carcereiro ou o diretor da prisão, o escrivão, o oficial de justiça ou a autoridade judiciária ou policial que embaraçar ou procrastinar a expedição de ordem de habeas corpus, as informações sobre a causa da prisão, a condução e apresentação do paciente, ou a sua soltura, será multado na quantia de duzentos mil-réis a um conto de réis, sem prejuízo das penas em que incorrer. As multas serão impostas pelo juiz do tribunal que julgar o habeas corpus, salvo quando se tratar de autoridade judiciária, caso em que caberá ao Supremo Tribunal Federal ou ao Tribunal de Apelação impor as multas."
                                                                },
                                                                {
                                                                        "numero": "656º",
                                                                        "rotulo": "Art. 656º.",
                                                                        "linha": 4408,
                                                                        "caput": "Recebida a petição de habeas corpus, o juiz, se julgar necessário, e estiver preso o paciente, mandará que este Ihe seja imediatamente apresentado em dia e hora que designar.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4410,
                                                                                        "texto": "Em caso de desobediência, será expedido mandado de prisão contra o detentor, que será processado na forma da lei, e o juiz providenciará para que o paciente seja tirado da prisão e apresentado em juízo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "657º",
                                                                        "rotulo": "Art. 657º.",
                                                                        "linha": 4412,
                                                                        "caput": "Se o paciente estiver preso, nenhum motivo escusará a sua apresentação, salvo:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4414,
                                                                                        "texto": "grave enfermidade do paciente; Il - não estar ele sob a guarda da pessoa a quem se atribui a detenção;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4418,
                                                                                        "texto": "se o comparecimento não tiver sido determinado pelo juiz ou pelo tribunal."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4420,
                                                                                        "texto": "O juiz poderá ir ao local em que o paciente se encontrar, se este não puder ser apresentado por motivo de doença."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "658º",
                                                                        "rotulo": "Art. 658º.",
                                                                        "linha": 4422,
                                                                        "caput": "O detentor declarará à ordem de quem o paciente estiver preso."
                                                                },
                                                                {
                                                                        "numero": "659º",
                                                                        "rotulo": "Art. 659º.",
                                                                        "linha": 4424,
                                                                        "caput": "Se o juiz ou o tribunal verificar que já cessou a violência ou coação ilegal, julgará prejudicado o pedido."
                                                                },
                                                                {
                                                                        "numero": "660º",
                                                                        "rotulo": "Art. 660º.",
                                                                        "linha": 4426,
                                                                        "caput": "Efetuadas as diligências, e interrogado o paciente, o juiz decidirá, fundamentadamente, dentro de 24 (vinte e quatro) horas.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4428,
                                                                                        "texto": "Se a decisão for favorável ao paciente, será logo posto em liberdade, salvo se por outro motivo dever ser mantido na prisão."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4430,
                                                                                        "texto": "Se os documentos que instruírem a petição evidenciarem a ilegalidade da coação, o juiz ou o tribunal ordenará que cesse imediatamente o constrangimento."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4432,
                                                                                        "texto": "Se a ilegalidade decorrer do fato de não ter sido o paciente admitido a prestar fiança, o juiz arbitrará o valor desta, que poderá ser prestada perante ele, remetendo, neste caso, à autoridade os respectivos autos, para serem anexados aos do inquérito policial ou aos do processo judicial."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4434,
                                                                                        "texto": "Se a ordem de habeas corpus for concedida para evitar ameaça de violência ou coação ilegal, dar-se-á ao paciente salvo-conduto assinado pelo juiz."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 4436,
                                                                                        "texto": "Será incontinenti enviada cópia da decisão à autoridade que tiver ordenado a prisão ou tiver o paciente à sua disposição, a fim de juntar-se aos autos do processo."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 4438,
                                                                                        "texto": "Quando o paciente estiver preso em lugar que não seja o da sede do juízo ou do tribunal que conceder a ordem, o alvará de soltura será expedido pelo telégrafo, se houver, observadas as formalidades estabelecidas no art. 289, parágrafo único, in fine, ou por via postal."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "661º",
                                                                        "rotulo": "Art. 661º.",
                                                                        "linha": 4440,
                                                                        "caput": "Em caso de competência originária do Tribunal de Apelação, a petição de habeas corpus será apresentada ao secretário, que a enviará imediatamente ao presidente do tribunal, ou da câmara criminal, ou da turma, que estiver reunida, ou primeiro tiver de reunir-se."
                                                                },
                                                                {
                                                                        "numero": "662º",
                                                                        "rotulo": "Art. 662º.",
                                                                        "linha": 4442,
                                                                        "caput": "Se a petição contiver os requisitos do art. 654, § 1o, o presidente, se necessário, requisitará da autoridade indicada como coatora informações por escrito. Faltando, porém, qualquer daqueles requisitos, o presidente mandará preenchê-lo, logo que Ihe for apresentada a petição."
                                                                },
                                                                {
                                                                        "numero": "663º",
                                                                        "rotulo": "Art. 663º.",
                                                                        "linha": 4444,
                                                                        "caput": "As diligências do artigo anterior não serão ordenadas, se o presidente entender que o habeas corpus deva ser indeferido in limine. Nesse caso, levará a petição ao tribunal, câmara ou turma, para que delibere a respeito."
                                                                },
                                                                {
                                                                        "numero": "664º",
                                                                        "rotulo": "Art. 664º.",
                                                                        "linha": 4446,
                                                                        "caput": "Recebidas as informações, ou dispensadas, o habeas corpus será julgado na primeira sessão, podendo, entretanto, adiar-se o julgamento para a sessão seguinte.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4448,
                                                                                        "texto": "A decisão será tomada por maioria de votos. Havendo empate, se o presidente não tiver tomado parte na votação, proferirá voto de desempate; no caso contrário, prevalecerá a decisão mais favorável ao paciente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "665º",
                                                                        "rotulo": "Art. 665º.",
                                                                        "linha": 4450,
                                                                        "caput": "O secretário do tribunal lavrará a ordem que, assinada pelo presidente do tribunal, câmara ou turma, será dirigida, por ofício ou telegrama, ao detentor, ao carcereiro ou autoridade que exercer ou ameaçar exercer o constrangimento.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4452,
                                                                                        "texto": "A ordem transmitida por telegrama obedecerá ao disposto no art. 289, parágrafo único, in fine."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "666º",
                                                                        "rotulo": "Art. 666º.",
                                                                        "linha": 4454,
                                                                        "caput": "Os regimentos dos Tribunais de Apelação estabelecerão as normas complementares para o processo e julgamento do pedido de habeas corpus de sua competência originária."
                                                                },
                                                                {
                                                                        "numero": "667º",
                                                                        "rotulo": "Art. 667º.",
                                                                        "linha": 4456,
                                                                        "caput": "No processo e julgamento do habeas corpus de competência originária do Supremo Tribunal Federal, bem como nos de recurso das decisões de última ou única instância, denegatórias de habeas corpus, observar-se-á, no que Ihes for aplicável, o disposto nos artigos anteriores, devendo o regimento interno do tribunal estabelecer as regras complementares."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                }
                        ],
                        "artigos": []
                },
                {
                        "tipo": "livro",
                        "rotulo": "LIVRO IV",
                        "linha": 4458,
                        "divisoes": [
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO I",
                                        "linha": 4462,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "668º",
                                                        "rotulo": "Art. 668º.",
                                                        "linha": 4466,
                                                        "caput": "A execução, onde não houver juiz especial, incumbirá ao juiz da sentença, ou, se a decisão for do Tribunal do Júri, ao seu presidente.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 4468,
                                                                        "texto": "Se a decisão for de tribunal superior, nos casos de sua competência originária, caberá ao respectivo presidente prover-lhe a execução."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "669º",
                                                        "rotulo": "Art. 669º.",
                                                        "linha": 4470,
                                                        "caput": "Só depois de passar em julgado, será exeqüível a sentença, salvo:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 4472,
                                                                        "texto": "quando condenatória, para o efeito de sujeitar o réu a prisão, ainda no caso de crime afiançável, enquanto não for prestada a fiança;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 4474,
                                                                        "texto": "quando absolutória, para o fim de imediata soltura do réu, desde que não proferida em processo por crime a que a lei comine pena de reclusão, no máximo, por tempo igual ou superior a oito anos."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "670º",
                                                        "rotulo": "Art. 670º.",
                                                        "linha": 4476,
                                                        "caput": "No caso de decisão absolutória confirmada ou proferida em grau de apelação, incumbirá ao relator fazer expedir o alvará de soltura, de que dará imediatamente conhecimento ao juiz de primeira instância."
                                                },
                                                {
                                                        "numero": "671º",
                                                        "rotulo": "Art. 671º.",
                                                        "linha": 4478,
                                                        "caput": "Os incidentes da execução serão resolvidos pelo respectivo juiz."
                                                },
                                                {
                                                        "numero": "672º",
                                                        "rotulo": "Art. 672º.",
                                                        "linha": 4480,
                                                        "caput": "Computar-se-á na pena privativa da liberdade o tempo:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 4482,
                                                                        "texto": "de prisão preventiva no Brasil ou no estrangeiro;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 4484,
                                                                        "texto": "de prisão provisória no Brasil ou no estrangeiro;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 4486,
                                                                        "texto": "de internação em hospital ou manicômio."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "673º",
                                                        "rotulo": "Art. 673º.",
                                                        "linha": 4488,
                                                        "caput": "Verificado que o réu, pendente a apelação por ele interposta, já sofreu prisão por tempo igual ao da pena a que foi condenado, o relator do feito mandará pô-lo imediatamente em liberdade, sem prejuízo do julgamento do recurso, salvo se, no caso de crime a que a lei comine pena de reclusão, no máximo, por tempo igual ou superior a 8 anos, o querelante ou o Ministério Público também houver apelado da sentença condenatória."
                                                }
                                        ]
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO II",
                                        "linha": 4490,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 4494,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "674º",
                                                                        "rotulo": "Art. 674º.",
                                                                        "linha": 4498,
                                                                        "caput": "Transitando em julgado a sentença que impuser pena privativa de liberdade, se o réu já estiver preso, ou vier a ser preso, o juiz ordenará a expedição de carta de guia para o cumprimento da pena.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4500,
                                                                                        "texto": "Na hipótese do art. 82, última parte, a expedição da carta de guia será ordenada pelo juiz competente para a soma ou unificação das penas."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "675º",
                                                                        "rotulo": "Art. 675º.",
                                                                        "linha": 4502,
                                                                        "caput": "No caso de ainda não ter sido expedido mandado de prisão, por tratar-se de infração penal em que o réu se livra solto ou por estar afiançado, o juiz, ou o presidente da câmara ou tribunal, se tiver havido recurso, fará expedir o mandado de prisão, logo que transite em julgado a sentença condenatória.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4504,
                                                                                        "texto": "No caso de reformada pela superior instância, em grau de recurso, a sentença absolutória, estando o réu solto, o presidente da câmara ou do tribunal fará, logo após a sessão de julgamento, remeter ao chefe de Polícia o mandado de prisão do condenado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4506,
                                                                                        "texto": "Se o réu estiver em prisão especial, deverá, ressalvado o disposto na legislação relativa aos militares, ser expedida ordem para sua imediata remoção para prisão comum, até que se verifique a expedição de carta de guia para o cumprimento da pena."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "676º",
                                                                        "rotulo": "Art. 676º.",
                                                                        "linha": 4508,
                                                                        "caput": "A carta de guia, extraída pelo escrivão e assinada pelo juiz, que a rubricará em todas as folhas, será remetida ao diretor do estabelecimento em que tenha de ser cumprida a sentença condenatória, e conterá:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4510,
                                                                                        "texto": "nome do réu e a alcunha por que for conhecido; Il - a sua qualificação civil (naturalidade, filiação, idade, estado, profissão), instrução e, se constar, número do registro geral do Instituto de Identificação e Estatística ou de repartição congênere;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4514,
                                                                                        "texto": "teor integral da sentença condenatória e a data da terminação da pena."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4516,
                                                                                        "texto": "Expedida carta de guia para cumprimento de uma pena, se o réu estiver cumprindo outra, só depois de terminada a execução desta será aquela executada. Retificar-se-á a carta de guia sempre que sobrevenha modificação quanto ao início da execução ou ao tempo de duração da pena."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "677º",
                                                                        "rotulo": "Art. 677º.",
                                                                        "linha": 4518,
                                                                        "caput": "Da carta de guia e seus aditamentos se remeterá cópia ao Conselho Penitenciário."
                                                                },
                                                                {
                                                                        "numero": "678º",
                                                                        "rotulo": "Art. 678º.",
                                                                        "linha": 4520,
                                                                        "caput": "O diretor do estabelecimento, em que o réu tiver de cumprir a pena, passará recibo da carta de guia para juntar-se aos autos do processo."
                                                                },
                                                                {
                                                                        "numero": "679º",
                                                                        "rotulo": "Art. 679º.",
                                                                        "linha": 4522,
                                                                        "caput": "As cartas de guia serão registradas em livro especial, segundo a ordem cronológica do recebimento, fazendo-se no curso da execução as anotações necessárias."
                                                                },
                                                                {
                                                                        "numero": "680º",
                                                                        "rotulo": "Art. 680º.",
                                                                        "linha": 4524,
                                                                        "caput": "Computar-se-á no tempo da pena o período em que o condenado, por sentença irrecorrível, permanecer preso em estabelecimento diverso do destinado ao cumprimento dela."
                                                                },
                                                                {
                                                                        "numero": "681º",
                                                                        "rotulo": "Art. 681º.",
                                                                        "linha": 4526,
                                                                        "caput": "Se impostas cumulativamente penas privativas da liberdade, será executada primeiro a de reclusão, depois a de detenção e por último a de prisão simples."
                                                                },
                                                                {
                                                                        "numero": "682º",
                                                                        "rotulo": "Art. 682º.",
                                                                        "linha": 4528,
                                                                        "caput": "O sentenciado a que sobrevier doença mental, verificada por perícia médica, será internado em manicômio judiciário, ou, à falta, em outro estabelecimento adequado, onde Ihe seja assegurada a custódia.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4530,
                                                                                        "texto": "Em caso de urgência, o diretor do estabelecimento penal poderá determinar a remoção do sentenciado, comunicando imediatamente a providência ao juiz, que, em face da perícia médica, ratificará ou revogará a medida."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4532,
                                                                                        "texto": "Se a internação se prolongar até o término do prazo restante da pena e não houver sido imposta medida de segurança detentiva, o indivíduo terá o destino aconselhado pela sua enfermidade, feita a devida comunicação ao juiz de incapazes."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "683º",
                                                                        "rotulo": "Art. 683º.",
                                                                        "linha": 4534,
                                                                        "caput": "O diretor da prisão a que o réu tiver sido recolhido provisoriamente ou em cumprimento de pena comunicará imediatamente ao juiz o óbito, a fuga ou a soltura do detido ou sentenciado para que fique constando dos autos.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4536,
                                                                                        "texto": "A certidão de óbito acompanhará a comunicação."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "684º",
                                                                        "rotulo": "Art. 684º.",
                                                                        "linha": 4538,
                                                                        "caput": "A recaptura do réu evadido não depende de prévia ordem judicial e poderá ser efetuada por qualquer pessoa."
                                                                },
                                                                {
                                                                        "numero": "685º",
                                                                        "rotulo": "Art. 685º.",
                                                                        "linha": 4540,
                                                                        "caput": "Cumprida ou extinta a pena, o condenado será posto, imediatamente, em liberdade, mediante alvará do juiz, no qual se ressalvará a hipótese de dever o condenado continuar na prisão por outro motivo legal.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4542,
                                                                                        "texto": "Se tiver sido imposta medida de segurança detentiva, o condenado será removido para estabelecimento adequado (art. 762)."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 4544,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "686º",
                                                                        "rotulo": "Art. 686º.",
                                                                        "linha": 4548,
                                                                        "caput": "A pena de multa será paga dentro em 10 dias após haver transitado em julgado a sentença que a impuser.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4550,
                                                                                        "texto": "Se interposto recurso da sentença, esse prazo será contado do dia em que o juiz ordenar o cumprimento da decisão da superior instância."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "687º",
                                                                        "rotulo": "Art. 687º.",
                                                                        "linha": 4552,
                                                                        "caput": "O juiz poderá, desde que o condenado o requeira:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4554,
                                                                                        "texto": "prorrogar o prazo do pagamento da multa até três meses, se as circunstâncias justificarem essa prorrogação;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4557,
                                                                                        "texto": "permitir, nas mesmas circunstâncias, que o pagamento se faça em parcelas mensais, no prazo que fixar, mediante caução real ou fidejussória, quando necessário."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4559,
                                                                                        "texto": "O requerimento, tanto no caso do no I, como no do no II, será feito dentro do decêndio concedido para o pagamento da multa."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4562,
                                                                                        "texto": "A permissão para o pagamento em parcelas será revogada, se o juiz verificar que o condenado dela se vale para fraudar a execução da pena. Nesse caso, a caução resolver-se-á em valor monetário, devolvendo-se ao condenado o que exceder à satisfação da multa e das custas processuais."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "688º",
                                                                        "rotulo": "Art. 688º.",
                                                                        "linha": 4564,
                                                                        "caput": "Findo o decêndio ou a prorrogação sem que o condenado efetue o pagamento, ou ocorrendo a hipótese prevista no § 2o do artigo anterior, observar-se-á o seguinte:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4566,
                                                                                        "texto": "possuindo o condenado bens sobre os quais possa recair a execução, será extraída certidão da sentença condenatória, a fim de que o Ministério Público proceda à cobrança judicial;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4568,
                                                                                        "texto": "sendo o condenado insolvente, far-se-á a cobrança:",
                                                                                        "alineas": [
                                                                                                {
                                                                                                        "letra": "a",
                                                                                                        "rotulo": "a)",
                                                                                                        "linha": 4570,
                                                                                                        "texto": "mediante desconto de quarta parte de sua remuneração (arts. 29, § 1o, e 37 do Código Penal), quando cumprir pena privativa da liberdade, cumulativamente imposta com a de multa;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "b",
                                                                                                        "rotulo": "b)",
                                                                                                        "linha": 4572,
                                                                                                        "texto": "mediante desconto em seu vencimento ou salário, se, cumprida a pena privativa da liberdade, ou concedido o livramento condicional, a multa não houver sido resgatada;"
                                                                                                },
                                                                                                {
                                                                                                        "letra": "c",
                                                                                                        "rotulo": "c)",
                                                                                                        "linha": 4574,
                                                                                                        "texto": "mediante esse desconto, se a multa for a única pena imposta ou no caso de suspensão condicional da pena."
                                                                                                }
                                                                                        ]
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4576,
                                                                                        "texto": "O desconto, nos casos das letras b e c, será feito mediante ordem ao empregador, à repartição competente ou à administração da entidade paraestatal, e, antes de fixá-lo, o juiz requisitará informações e ordenará diligências, inclusive arbitramento, quando necessário, para observância do art. 37, § 3o, do Código Penal."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4578,
                                                                                        "texto": "Sob pena de desobediência e sem prejuízo da execução a que ficará sujeito, o empregador será intimado a recolher mensalmente, até o dia fixado pelo juiz, a importância correspondente ao desconto, em selo penitenciário, que será inutilizado nos autos pelo juiz."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4580,
                                                                                        "texto": "Se o condenado for funcionário estadual ou municipal ou empregado de entidade paraestatal, a importância do desconto será, semestralmente, recolhida ao Tesouro Nacional, delegacia fiscal ou coletoria federal, como receita do selo penitenciário."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4582,
                                                                                        "texto": "As quantias descontadas em folha de pagamento de funcionário federal constituirão renda do selo penitenciário."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "689º",
                                                                        "rotulo": "Art. 689º.",
                                                                        "linha": 4584,
                                                                        "caput": "A multa será convertida, à razão de dez mil-réis por dia, em detenção ou prisão simples, no caso de crime ou de contravenção:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4586,
                                                                                        "texto": "se o condenado solvente frustrar o pagamento da multa;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4589,
                                                                                        "texto": "se não forem pagas pelo condenado solvente as parcelas mensais autorizadas sem garantia."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4591,
                                                                                        "texto": "Se o juiz reconhecer desde logo a existência de causa para a conversão, a ela procederá de ofício ou a requerimento do Ministério Público, independentemente de audiência do condenado; caso contrário, depois de ouvir o condenado, se encontrado no lugar da sede do juízo, poderá admitir a apresentação de prova pelas partes, inclusive testemunhal, no prazo de três dias."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4593,
                                                                                        "texto": "O juiz, desde que transite em julgado a decisão, ordenará a expedição de mandado de prisão ou aditamento à carta de guia, conforme esteja o condenado solto ou em cumprimento de pena privativa da liberdade."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4595,
                                                                                        "texto": "Na hipótese do inciso II deste artigo, a conversão será feita pelo valor das parcelas não pagas."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "690º",
                                                                        "rotulo": "Art. 690º.",
                                                                        "linha": 4597,
                                                                        "caput": "O juiz tornará sem efeito a conversão, expedindo alvará de soltura ou cassando a ordem de prisão, se o condenado, em qualquer tempo:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4599,
                                                                                        "texto": "pagar a multa;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4601,
                                                                                        "texto": "prestar caução real ou fidejussória que Ihe assegure o pagamento."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4603,
                                                                                        "texto": "No caso do no II, antes de homologada a caução, será ouvido o Ministério Público dentro do prazo de dois dias."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 4605,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "691º",
                                                                        "rotulo": "Art. 691º.",
                                                                        "linha": 4609,
                                                                        "caput": "O juiz dará à autoridade administrativa competente conhecimento da sentença transitada em julgado, que impuser ou de que resultar a perda da função pública ou a incapacidade temporária para investidura em função pública ou para exercício de profissão ou atividade."
                                                                },
                                                                {
                                                                        "numero": "692º",
                                                                        "rotulo": "Art. 692º.",
                                                                        "linha": 4611,
                                                                        "caput": "No caso de incapacidade temporária ou permanente para o exercício do pátrio poder, da tutela ou da curatela, o juiz providenciará para que sejam acautelados, no juízo competente, a pessoa e os bens do menor ou do interdito."
                                                                },
                                                                {
                                                                        "numero": "693º",
                                                                        "rotulo": "Art. 693º.",
                                                                        "linha": 4613,
                                                                        "caput": "A incapacidade permanente ou temporária para o exercício da autoridade marital ou do pátrio poder será averbada no registro civil."
                                                                },
                                                                {
                                                                        "numero": "694º",
                                                                        "rotulo": "Art. 694º.",
                                                                        "linha": 4615,
                                                                        "caput": "As penas acessórias consistentes em interdições de direitos serão comunicadas ao Instituto de Identificação e Estatística ou estabelecimento congênere, figurarão na folha de antecedentes do condenado e serão mencionadas no rol de culpados."
                                                                },
                                                                {
                                                                        "numero": "695º",
                                                                        "rotulo": "Art. 695º.",
                                                                        "linha": 4617,
                                                                        "caput": "Iniciada a execução das interdições temporárias (art. 72, ae b, do Código Penal), o juiz, de ofício, a requerimento do Ministério Público ou do condenado, fixará o seu termo final, completando as providências determinadas nos artigos anteriores."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO III",
                                        "linha": 4619,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 4623,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "696º",
                                                                        "rotulo": "Art. 696º.",
                                                                        "linha": 4628,
                                                                        "caput": "O juiz poderá suspender, por tempo não inferior a 2 (dois) nem superior a 6 (seis) anos, a execução das penas de reclusão e de detenção que não excedam a 2 (dois) anos, ou, por tempo não inferior a 1 (um) nem superior a 3 (três) anos, a execução da pena de prisão simples, desde que o sentenciado:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4631,
                                                                                        "texto": "não haja sofrido, no País ou no estrangeiro, condenação irrecorrível por outro crime a pena privativa da liberdade, salvo o disposto no parágrafo único do art. 46 do Código Penal;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4633,
                                                                                        "texto": "os antecedentes e a personalidade do sentenciado, os motivos e as circunstâncias do crime autorizem a presunção de que não tornará a delinqüir."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4635,
                                                                                        "texto": "Processado o beneficiário por outro crime ou contravenção, considerar-se-á prorrogado o prazo da suspensão da pena até o julgamento definitivo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "697º",
                                                                        "rotulo": "Art. 697º.",
                                                                        "linha": 4638,
                                                                        "caput": "O juiz ou tribunal, na decisão que aplicar pena privativa da liberdade não superior a 2 (dois) anos, deverá pronunciar-se, motivadamente, sobre a suspensão condicional, quer a conceda quer a denegue."
                                                                },
                                                                {
                                                                        "numero": "698º",
                                                                        "rotulo": "Art. 698º.",
                                                                        "linha": 4641,
                                                                        "caput": "Concedida a suspensão, o juiz especificará as condições a que fica sujeito o condenado, pelo prazo previsto, começando este a correr da audiência em que se der conhecimento da sentença ao beneficiário e Ihe for entregue documento similar ao descrito no art. 724.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4643,
                                                                                        "texto": "As condições serão adequadas ao delito e à personalidade do condenado."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4645,
                                                                                        "texto": "Poderão ser impostas, além das estabelecidas no art. 767, como normas de conduta e obrigações, as seguintes condições:",
                                                                                        "incisos": [
                                                                                                {
                                                                                                        "numero": "I",
                                                                                                        "rotulo": "I",
                                                                                                        "linha": 4647,
                                                                                                        "texto": "freqüentar curso de habilitação profissional ou de instrução escolar;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "II",
                                                                                                        "rotulo": "II",
                                                                                                        "linha": 4649,
                                                                                                        "texto": "prestar serviços em favor da comunidade;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "III",
                                                                                                        "rotulo": "III",
                                                                                                        "linha": 4651,
                                                                                                        "texto": "atender aos encargos de família;"
                                                                                                },
                                                                                                {
                                                                                                        "numero": "IV",
                                                                                                        "rotulo": "IV",
                                                                                                        "linha": 4653,
                                                                                                        "texto": "submeter-se a tratamento de desintoxicação."
                                                                                                }
                                                                                        ]
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4655,
                                                                                        "texto": "O juiz poderá fixar, a qualquer tempo, de ofício ou a requerimento do Ministério Público, outras condições além das especificadas na sentença e das referidas no parágrafo anterior, desde que as circunstâncias o aconselhem."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 4657,
                                                                                        "texto": "A fiscalização do cumprimento das condições deverá ser regulada, nos Estados, Territórios e Distrito Federal, por normas supletivas e atribuída a serviço social penitenciário, patronato, conselho de comunidade ou entidades similares, inspecionadas pelo Conselho Penitenciário, pelo Ministério Público ou ambos, devendo o juiz da execução na comarca suprir, por ato, a falta das normas supletivas."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 4659,
                                                                                        "texto": "O beneficiário deverá comparecer periodicamente à entidade fiscalizadora, para comprovar a observância das condições a que está sujeito, comunicando, também, a sua ocupação, os salários ou proventos de que vive, as economias que conseguiu realizar e as dificuldades materiais ou sociais que enfrenta."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 4661,
                                                                                        "texto": "A entidade fiscalizadora deverá comunicar imediatamente ao órgão de inspeção, para os fins legais (arts. 730 e 731), qualquer fato capaz de acarretar a revogação do benefício, a prorrogação do prazo ou a modificação das condições."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 4663,
                                                                                        "texto": "Se for permitido ao beneficiário mudar-se, será feita comunicação ao juiz e à entidade fiscalizadora do local da nova residência, aos quais deverá apresentar-se imediatamente."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "699º",
                                                                        "rotulo": "Art. 699º.",
                                                                        "linha": 4665,
                                                                        "caput": "No caso de condenação pelo Tribunal do Júri, a suspensão condicional da pena competirá ao seu presidente."
                                                                },
                                                                {
                                                                        "numero": "700º",
                                                                        "rotulo": "Art. 700º.",
                                                                        "linha": 4667,
                                                                        "caput": "A suspensão não compreende a multa, as penas acessórias, os efeitos da condenação nem as custas."
                                                                },
                                                                {
                                                                        "numero": "701º",
                                                                        "rotulo": "Art. 701º.",
                                                                        "linha": 4669,
                                                                        "caput": "O juiz, ao conceder a suspensão, fixará, tendo em conta as condições econômicas ou profissionais do réu, o prazo para o pagamento, integral ou em prestações, das custas do processo e taxa penitenciária."
                                                                },
                                                                {
                                                                        "numero": "702º",
                                                                        "rotulo": "Art. 702º.",
                                                                        "linha": 4671,
                                                                        "caput": "Em caso de co-autoria, a suspensão poderá ser concedida a uns e negada a outros réus."
                                                                },
                                                                {
                                                                        "numero": "703º",
                                                                        "rotulo": "Art. 703º.",
                                                                        "linha": 4673,
                                                                        "caput": "O juiz que conceder a suspensão lerá ao réu, em audiência, a sentença respectiva, e o advertirá das conseqüências de nova infração penal e da transgressão das obrigações impostas."
                                                                },
                                                                {
                                                                        "numero": "704º",
                                                                        "rotulo": "Art. 704º.",
                                                                        "linha": 4675,
                                                                        "caput": "Quando for concedida a suspensão pela superior instância, a esta caberá estabelecer-lhe as condições, podendo a audiência ser presidida por qualquer membro do tribunal ou câmara, pelo juiz do processo ou por outro designado pelo presidente do tribunal ou câmara."
                                                                },
                                                                {
                                                                        "numero": "705º",
                                                                        "rotulo": "Art. 705º.",
                                                                        "linha": 4677,
                                                                        "caput": "Se, intimado pessoalmente ou por edital com prazo de 20 dias, o réu não comparecer à audiência a que se refere o art. 703, a suspensão ficará sem efeito e será executada imediatamente a pena, salvo prova de justo impedimento, caso em que será marcada nova audiência."
                                                                },
                                                                {
                                                                        "numero": "706º",
                                                                        "rotulo": "Art. 706º.",
                                                                        "linha": 4680,
                                                                        "caput": "A suspensão também ficará sem efeito se, em virtude de recurso, for aumentada a pena de modo que exclua a concessão do benefício."
                                                                },
                                                                {
                                                                        "numero": "707º",
                                                                        "rotulo": "Art. 707º.",
                                                                        "linha": 4687,
                                                                        "caput": "A suspensão será revogada se o beneficiário:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4689,
                                                                                        "texto": "é condenado, por sentença irrecorrível, a pena privativa da liberdade;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4691,
                                                                                        "texto": "frustra, embora solvente, o pagamento da multa, ou não efetua, sem motivo justificado, a reparação do dano."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4693,
                                                                                        "texto": "O juiz poderá revogar a suspensão, se o beneficiário deixa de cumprir qualquer das obrigações constantes da sentença, de observar proibições inerentes à pena acessória, ou é irrecorrivelmente condenado a pena que não seja privativa da liberdade; se não a revogar, deverá advertir o beneficiário, ou exacerbar as condições ou, ainda, prorrogar o período da suspensão até o máximo, se esse limite não foi o fixado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "708º",
                                                                        "rotulo": "Art. 708º.",
                                                                        "linha": 4695,
                                                                        "caput": "Expirado o prazo de suspensão ou a prorrogação, sem que tenha ocorrido motivo de revogação, a pena privativa de liberdade será declarada extinta.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4697,
                                                                                        "texto": "O juiz, quando julgar necessário, requisitará, antes do julgamento, nova folha de antecedentes do beneficiário."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "709º",
                                                                        "rotulo": "Art. 709º.",
                                                                        "linha": 4699,
                                                                        "caput": "A condenação será inscrita, com a nota de suspensão, em livros especiais do Instituto de Identificação e Estatística, ou repartição congênere, averbando-se, mediante comunicação do juiz ou do tribunal, a revogação da suspensão ou a extinção da pena. Em caso de revogação, será feita a averbação definitiva no registro geral.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4701,
                                                                                        "texto": "Nos lugares onde não houver Instituto de Identificação e Estatística ou repartição congênere, o registro e a averbação serão feitos em livro próprio no juízo ou no tribunal."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4703,
                                                                                        "texto": "O registro será secreto, salvo para efeito de informações requisitadas por autoridade judiciária, no caso de novo processo."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 4705,
                                                                                        "texto": "Não se aplicará o disposto no § 2o, quando houver sido imposta ou resultar de condenação pena acessória consistente em interdição de direitos."
                                                                                }
                                                                        ]
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 4707,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "710º",
                                                                        "rotulo": "Art. 710º.",
                                                                        "linha": 4717,
                                                                        "caput": "O livramento condicional poderá ser concedido ao condenado a pena privativa da liberdade igual ou superior a 2 (dois) anos, desde que se verifiquem as condições seguintes:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4719,
                                                                                        "texto": "cumprimento de mais da metade da pena, ou mais de três quartos, se reincidente o sentenciado;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4721,
                                                                                        "texto": "ausência ou cessação de periculosidade;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4723,
                                                                                        "texto": "bom comportamento durante a vida carcerária;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 4725,
                                                                                        "texto": "aptidão para prover à própria subsistência mediante trabalho honesto;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 4727,
                                                                                        "texto": "reparação do dano causado pela infração, salvo impossibilidade de fazê-lo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "711º",
                                                                        "rotulo": "Art. 711º.",
                                                                        "linha": 4730,
                                                                        "caput": "As penas que correspondem a infrações diversas podem somar-se, para efeito do livramento."
                                                                },
                                                                {
                                                                        "numero": "712º",
                                                                        "rotulo": "Art. 712º.",
                                                                        "linha": 4734,
                                                                        "caput": "O livramento condicional poderá ser concedido mediante requerimento do sentenciado, de seu cônjuge ou de parente em linha reta, ou por proposta do diretor do estabelecimento penal, ou por iniciativa do Conselho Penitenciário."
                                                                },
                                                                {
                                                                        "numero": "713º",
                                                                        "rotulo": "Art. 713º.",
                                                                        "linha": 4736,
                                                                        "caput": "As condições de admissibilidade, conveniência e oportunidade da concessão do livramento serão verificadas pelo Conselho Penitenciário, a cujo parecer não ficará, entretanto, adstrito o juiz."
                                                                },
                                                                {
                                                                        "numero": "714º",
                                                                        "rotulo": "Art. 714º.",
                                                                        "linha": 4738,
                                                                        "caput": "O diretor do estabelecimento penal remeterá ao Conselho Penitenciário minucioso relatório sobre:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4740,
                                                                                        "texto": "caráter do sentenciado, revelado pelos seus antecedentes e conduta na prisão;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4742,
                                                                                        "texto": "procedimento do liberando na prisão, sua aplicação ao trabalho e seu trato com os companheiros e funcionários do estabelecimento;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4744,
                                                                                        "texto": "suas relações, quer com a família, quer com estranhos;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 4746,
                                                                                        "texto": "seu grau de instrução e aptidão profissional, com a indicação dos serviços em que haja sido empregado e da especialização anterior ou adquirida na prisão;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 4748,
                                                                                        "texto": "sua situação financeira, e seus propósitos quanto ao seu futuro meio de vida, juntando o diretor, quando dada por pessoa idônea, promessa escrita de colocação do liberando, com indicação do serviço e do salário."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4750,
                                                                                        "texto": "O relatório será, dentro do prazo de quinze dias, remetido ao Conselho, com o prontuário do sentenciado, e, na falta, o Conselho opinará livremente, comunicando à autoridade competente a omissão do diretor da prisão."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "715º",
                                                                        "rotulo": "Art. 715º.",
                                                                        "linha": 4752,
                                                                        "caput": "Se tiver sido imposta medida de segurança detentiva, o livramento não poderá ser concedido sem que se verifique, mediante exame das condições do sentenciado, a cessação da periculosidade.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4754,
                                                                                        "texto": "Consistindo a medida de segurança em internação em casa de custódia e tratamento, proceder-se-á a exame mental do sentenciado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "716º",
                                                                        "rotulo": "Art. 716º.",
                                                                        "linha": 4756,
                                                                        "caput": "A petição ou a proposta de livramento será remetida ao juiz ou ao tribunal por ofício do presidente do Conselho Penitenciário, com a cópia do respectivo parecer e do relatório do diretor da prisão.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4758,
                                                                                        "texto": "Para emitir parecer, o Conselho poderá determinar diligências e requisitar os autos do processo."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4760,
                                                                                        "texto": "O juiz ou o tribunal mandará juntar a petição ou a proposta, com o ofício ou documento que a acompanhar, aos autos do processo, e proferirá sua decisão, previamente ouvido o Ministério Público."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "717º",
                                                                        "rotulo": "Art. 717º.",
                                                                        "linha": 4763,
                                                                        "caput": "Na ausência da condição prevista no art. 710, I, o requerimento será liminarmente indeferido."
                                                                },
                                                                {
                                                                        "numero": "718º",
                                                                        "rotulo": "Art. 718º.",
                                                                        "linha": 4768,
                                                                        "caput": "Deferido o pedido, o juiz, ao especificar as condições a que ficará subordinado o livramento, atenderá ao disposto no art. 698, §§ 1o, 2o e 5o.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4770,
                                                                                        "texto": "Se for permitido ao liberado residir fora da jurisdição do juiz da execução, remeter-se-á cópia da sentença do livramento à autoridade judiciária do lugar para onde ele se houver transferido, e à entidade de observação cautelar e proteção."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4772,
                                                                                        "texto": "O liberado será advertido da obrigação de apresentar-se imediatamente à autoridade judiciária e à entidade de observação cautelar e proteção. Redação dada pela Lei nº 6.416, de 24.5.1977)"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "719º",
                                                                        "rotulo": "Art. 719º.",
                                                                        "linha": 4774,
                                                                        "caput": "O livramento ficará também subordinado à obrigação de pagamento das custas do processo e da taxa penitenciária, salvo caso de insolvência comprovada.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4776,
                                                                                        "texto": "O juiz poderá fixar o prazo para o pagamento integral ou em prestações, tendo em consideração as condições econômicas ou profissionais do liberado."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "720º",
                                                                        "rotulo": "Art. 720º.",
                                                                        "linha": 4778,
                                                                        "caput": "A forma de pagamento da multa, ainda não paga pelo liberando, será determinada de acordo com o disposto no art. 688."
                                                                },
                                                                {
                                                                        "numero": "721º",
                                                                        "rotulo": "Art. 721º.",
                                                                        "linha": 4780,
                                                                        "caput": "Reformada a sentença denegatória do livramento, os autos baixarão ao juiz da primeira instância, a fim de que determine as condições que devam ser impostas ao liberando."
                                                                },
                                                                {
                                                                        "numero": "722º",
                                                                        "rotulo": "Art. 722º.",
                                                                        "linha": 4782,
                                                                        "caput": "Concedido o livramento, será expedida carta de guia, com a cópia integral da sentença em duas vias, remetendo-se uma ao diretor do estabelecimento penal e outra ao presidente do Conselho Penitenciário."
                                                                },
                                                                {
                                                                        "numero": "723º",
                                                                        "rotulo": "Art. 723º.",
                                                                        "linha": 4784,
                                                                        "caput": "A cerimônia do livramento condicional será realizada solenemente, em dia marcado pela autoridade que deva presidi-la, observando-se o seguinte:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4786,
                                                                                        "texto": "a sentença será lida ao liberando, na presença dos demais presos, salvo motivo relevante, pelo presidente do Conselho Penitenciário, ou pelo seu representante junto ao estabelecimento penal, ou, na falta, pela autoridade judiciária local;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4788,
                                                                                        "texto": "diretor do estabelecimento penal chamará a atenção do liberando para as condições impostas na sentença de livramento;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4790,
                                                                                        "texto": "preso declarará se aceita as condições."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4792,
                                                                                        "texto": "De tudo, em livro próprio, se lavrará termo, subscrito por quem presidir a cerimônia, e pelo liberando, ou alguém a seu rogo, se não souber ou não puder escrever."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4794,
                                                                                        "texto": "Desse termo, se remeterá cópia ao juiz do processo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "724º",
                                                                        "rotulo": "Art. 724º.",
                                                                        "linha": 4796,
                                                                        "caput": "Ao sair da prisão o liberado, ser-lhe-á entregue, além do saldo do seu pecúlio e do que Ihe pertencer, uma caderneta que exibirá à autoridade judiciária ou administrativa sempre que Ihe for exigido. Essa caderneta conterá:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4798,
                                                                                        "texto": "a reprodução da ficha de identidade, ou o retrato do liberado, sua qualificação e sinais característicos;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4800,
                                                                                        "texto": "texto impresso dos artigos do presente capítulo;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4802,
                                                                                        "texto": "as condições impostas ao liberado;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 4804,
                                                                                        "texto": "a pena acessória a que esteja sujeito."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 4806,
                                                                                        "texto": "Na falta de caderneta, será entregue ao liberado um salvo-conduto, em que constem as condições do livramento e a pena acessória, podendo substituir-se a ficha de identidade ou o retrato do liberado pela descrição dos sinais que possam identificá-lo."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 4808,
                                                                                        "texto": "Na caderneta e no salvo-conduto deve haver espaço para consignar o cumprimento das condições referidas no art. 718. bem ao juiz, que manterá ou não a detenção."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "725º",
                                                                        "rotulo": "Art. 725º.",
                                                                        "linha": 4817,
                                                                        "caput": "A observação cautelar e proteção realizadas por serviço social penitenciário, patronato, conselho de comunidade ou entidades similares, terá a finalidade de:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4819,
                                                                                        "texto": "fazer observar o cumprimento da pena acessória, bem como das condições especificadas na sentença concessiva do benefício;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4821,
                                                                                        "texto": "proteger o beneficiário, orientando-o na execução de suas obrigações e auxiliando-o na obtenção de atividade laborativa."
                                                                                }
                                                                        ],
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4823,
                                                                                        "texto": "As entidades encarregadas de observação cautelar e proteção do liberado apresentarão relatório ao Conselho Penitenciário, para efeito da representação prevista nos arts. 730 e 731."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "726º",
                                                                        "rotulo": "Art. 726º.",
                                                                        "linha": 4825,
                                                                        "caput": "Revogar-se-á o livramento condicional, se o liberado vier, por crime ou contravenção, a ser condenado por sentença irrecorrível a pena privativa de liberdade."
                                                                },
                                                                {
                                                                        "numero": "727º",
                                                                        "rotulo": "Art. 727º.",
                                                                        "linha": 4828,
                                                                        "caput": "O juiz pode, também, revogar o livramento, se o liberado deixar de cumprir qualquer das obrigações constantes da sentença, de observar proibições inerentes à pena acessória ou for irrecorrivelmente condenado, por crime, à pena que não seja privativa da liberdade.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "único",
                                                                                        "rotulo": "Parágrafo único",
                                                                                        "linha": 4830,
                                                                                        "texto": "Se o juiz não revogar o livramento, deverá advertir o liberado ou exacerbar as condições."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "728º",
                                                                        "rotulo": "Art. 728º.",
                                                                        "linha": 4832,
                                                                        "caput": "Se a revogação for motivada por infração penal anterior à vigência do livramento, computar-se-á no tempo da pena o período em que esteve solto o liberado, sendo permitida, para a concessão de novo livramento, a soma do tempo das duas penas."
                                                                },
                                                                {
                                                                        "numero": "729º",
                                                                        "rotulo": "Art. 729º.",
                                                                        "linha": 4834,
                                                                        "caput": "No caso de revogação por outro motivo, não se computará na pena o tempo em que esteve solto o liberado, e tampouco se concederá, em relação à mesma pena, novo livramento."
                                                                },
                                                                {
                                                                        "numero": "730º",
                                                                        "rotulo": "Art. 730º.",
                                                                        "linha": 4837,
                                                                        "caput": "A revogação do livramento será decretada mediante representação do Conselho Penitenciário, ou a requerimento do Ministério Público, ou de ofício, pelo juiz, que, antes, ouvirá o liberado, podendo ordenar diligências e permitir a produção de prova, no prazo de cinco dias."
                                                                },
                                                                {
                                                                        "numero": "731º",
                                                                        "rotulo": "Art. 731º.",
                                                                        "linha": 4840,
                                                                        "caput": "O juiz, de ofício, a requerimento do Ministério Público, ou mediante representação do Conselho Penitenciário, poderá modificar as condições ou normas de conduta especificadas na sentença, devendo a respectiva decisão ser lida ao liberado por uma das autoridades ou por um dos funcionários indicados no inciso I do art. 723, observado o disposto nos incisos II e III, e §§ 1o e 2o do mesmo artigo."
                                                                },
                                                                {
                                                                        "numero": "732º",
                                                                        "rotulo": "Art. 732º.",
                                                                        "linha": 4842,
                                                                        "caput": "Praticada pelo liberado nova infração, o juiz ou o tribunal poderá ordenar a sua prisão, ouvido o Conselho Penitenciário, suspendendo o curso do livramento condicional, cuja revogação ficará, entretanto, dependendo da decisão final no novo processo."
                                                                },
                                                                {
                                                                        "numero": "733º",
                                                                        "rotulo": "Art. 733º.",
                                                                        "linha": 4844,
                                                                        "caput": "O juiz, de ofício, ou a requerimento do interessado, do Ministério Público, ou do Conselho Penitenciário, julgará extinta a pena privativa de liberdade, se expirar o prazo do livramento sem revogação, ou na hipótese do artigo anterior, for o liberado absolvido por sentença irrecorrível."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO IV",
                                        "linha": 4846,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 4850,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "734º",
                                                                        "rotulo": "Art. 734º.",
                                                                        "linha": 4854,
                                                                        "caput": "A graça poderá ser provocada por petição do condenado, de qualquer pessoa do povo, do Conselho Penitenciário, ou do Ministério Público, ressalvada, entretanto, ao Presidente da República, a faculdade de concedê-la espontaneamente."
                                                                },
                                                                {
                                                                        "numero": "735º",
                                                                        "rotulo": "Art. 735º.",
                                                                        "linha": 4856,
                                                                        "caput": "A petição de graça, acompanhada dos documentos com que o impetrante a instruir, será remetida ao ministro da Justiça por intermédio do Conselho Penitenciário."
                                                                },
                                                                {
                                                                        "numero": "736º",
                                                                        "rotulo": "Art. 736º.",
                                                                        "linha": 4858,
                                                                        "caput": "O Conselho Penitenciário, à vista dos autos do processo, e depois de ouvir o diretor do estabelecimento penal a que estiver recolhido o condenado, fará, em relatório, a narração do fato criminoso, examinará as provas, mencionará qualquer formalidade ou circunstância omitida na petição e exporá os antecedentes do condenado e seu procedimento depois de preso, opinando sobre o mérito do pedido."
                                                                },
                                                                {
                                                                        "numero": "737º",
                                                                        "rotulo": "Art. 737º.",
                                                                        "linha": 4860,
                                                                        "caput": "Processada no Ministério da Justiça, com os documentos e o relatório do Conselho Penitenciário, a petição subirá a despacho do Presidente da República, a quem serão presentes os autos do processo ou a certidão de qualquer de suas peças, se ele o determinar."
                                                                },
                                                                {
                                                                        "numero": "738º",
                                                                        "rotulo": "Art. 738º.",
                                                                        "linha": 4862,
                                                                        "caput": "Concedida a graça e junta aos autos cópia do decreto, o juiz declarará extinta a pena ou penas, ou ajustará a execução aos termos do decreto, no caso de redução ou comutação de pena."
                                                                },
                                                                {
                                                                        "numero": "739º",
                                                                        "rotulo": "Art. 739º.",
                                                                        "linha": 4864,
                                                                        "caput": "O condenado poderá recusar a comutação da pena."
                                                                },
                                                                {
                                                                        "numero": "740º",
                                                                        "rotulo": "Art. 740º.",
                                                                        "linha": 4866,
                                                                        "caput": "Os autos da petição de graça serão arquivados no Ministério da Justiça."
                                                                },
                                                                {
                                                                        "numero": "741º",
                                                                        "rotulo": "Art. 741º.",
                                                                        "linha": 4868,
                                                                        "caput": "Se o réu for beneficiado por indulto, o juiz, de ofício ou a requerimento do interessado, do Ministério Público ou por iniciativa do Conselho Penitenciário, providenciará de acordo com o disposto no art. 738."
                                                                },
                                                                {
                                                                        "numero": "742º",
                                                                        "rotulo": "Art. 742º.",
                                                                        "linha": 4870,
                                                                        "caput": "Concedida a anistia após transitar em julgado a sentença condenatória, o juiz, de ofício ou a requerimento do interessado, do Ministério Público ou por iniciativa do Conselho Penitenciário, declarará extinta a pena."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 4872,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "743º",
                                                                        "rotulo": "Art. 743º.",
                                                                        "linha": 4876,
                                                                        "caput": "A reabilitação será requerida ao juiz da condenação, após o decurso de quatro ou oito anos, pelo menos, conforme se trate de condenado ou reincidente, contados do dia em que houver terminado a execução da pena principal ou da medida de segurança detentiva, devendo o requerente indicar as comarcas em que haja residido durante aquele tempo."
                                                                },
                                                                {
                                                                        "numero": "744º",
                                                                        "rotulo": "Art. 744º.",
                                                                        "linha": 4878,
                                                                        "caput": "O requerimento será instruído com:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 4880,
                                                                                        "texto": "certidões comprobatórias de não ter o requerente respondido, nem estar respondendo a processo penal, em qualquer das comarcas em que houver residido durante o prazo a que se refere o artigo anterior;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 4882,
                                                                                        "texto": "atestados de autoridades policiais ou outros documentos que comprovem ter residido nas comarcas indicadas e mantido, efetivamente, bom comportamento;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 4884,
                                                                                        "texto": "atestados de bom comportamento fornecidos por pessoas a cujo serviço tenha estado;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 4886,
                                                                                        "texto": "quaisquer outros documentos que sirvam como prova de sua regeneração;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 4888,
                                                                                        "texto": "prova de haver ressarcido o dano causado pelo crime ou persistir a impossibilidade de fazê-lo."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "745º",
                                                                        "rotulo": "Art. 745º.",
                                                                        "linha": 4890,
                                                                        "caput": "O juiz poderá ordenar as diligências necessárias para apreciação do pedido, cercando-as do sigilo possível e, antes da decisão final, ouvirá o Ministério Público."
                                                                },
                                                                {
                                                                        "numero": "746º",
                                                                        "rotulo": "Art. 746º.",
                                                                        "linha": 4892,
                                                                        "caput": "Da decisão que conceder a reabilitação haverá recurso de ofício."
                                                                },
                                                                {
                                                                        "numero": "747º",
                                                                        "rotulo": "Art. 747º.",
                                                                        "linha": 4894,
                                                                        "caput": "A reabilitação, depois de sentença irrecorrível, será comunicada ao Instituto de Identificação e Estatística ou repartição congênere."
                                                                },
                                                                {
                                                                        "numero": "748º",
                                                                        "rotulo": "Art. 748º.",
                                                                        "linha": 4896,
                                                                        "caput": "A condenação ou condenações anteriores não serão mencionadas na folha de antecedentes do reabilitado, nem em certidão extraída dos livros do juízo, salvo quando requisitadas por juiz criminal."
                                                                },
                                                                {
                                                                        "numero": "749º",
                                                                        "rotulo": "Art. 749º.",
                                                                        "linha": 4898,
                                                                        "caput": "Indeferida a reabilitação, o condenado não poderá renovar o pedido senão após o decurso de dois anos, salvo se o indeferimento tiver resultado de falta ou insuficiência de documentos."
                                                                },
                                                                {
                                                                        "numero": "750º",
                                                                        "rotulo": "Art. 750º.",
                                                                        "linha": 4900,
                                                                        "caput": "A revogação de reabilitação (Código Penal, art. 120) será decretada pelo juiz, de ofício ou a requerimento do Ministério Público."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                },
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO V",
                                        "linha": 4902,
                                        "divisoes": [],
                                        "artigos": [
                                                {
                                                        "numero": "751º",
                                                        "rotulo": "Art. 751º.",
                                                        "linha": 4906,
                                                        "caput": "Durante a execução da pena ou durante o tempo em que a ela se furtar o condenado, poderá ser imposta medida de segurança, se:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 4908,
                                                                        "texto": "juiz ou o tribunal, na sentença:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 4910,
                                                                                        "texto": "omitir sua decretação, nos casos de periculosidade presumida;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 4912,
                                                                                        "texto": "deixar de aplicá-la ou de excluí-la expressamente;"
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 4914,
                                                                                        "texto": "declarar os elementos constantes do processo insuficientes para a imposição ou exclusão da medida e ordenar indagações para a verificação da periculosidade do condenado;"
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 4916,
                                                                        "texto": "tendo sido, expressamente, excluída na sentença a periculosidade do condenado, novos fatos demonstrarem ser ele perigoso."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "752º",
                                                        "rotulo": "Art. 752º.",
                                                        "linha": 4918,
                                                        "caput": "Poderá ser imposta medida de segurança, depois de transitar em julgado a sentença, ainda quando não iniciada a execução da pena, por motivo diverso de fuga ou ocultação do condenado:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 4920,
                                                                        "texto": "no caso da letra ado no I do artigo anterior, bem como no da letra b, se tiver sido alegada a periculosidade;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 4922,
                                                                        "texto": "no caso da letra c do no I do mesmo artigo."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "753º",
                                                        "rotulo": "Art. 753º.",
                                                        "linha": 4924,
                                                        "caput": "Ainda depois de transitar em julgado a sentença absolutória, poderá ser imposta a medida de segurança, enquanto não decorrido tempo equivalente ao da sua duração mínima, a indivíduo que a lei presuma perigoso."
                                                },
                                                {
                                                        "numero": "754º",
                                                        "rotulo": "Art. 754º.",
                                                        "linha": 4926,
                                                        "caput": "A aplicação da medida de segurança, nos casos previstos nos arts. 751 e 752, competirá ao juiz da execução da pena, e, no caso do art. 753, ao juiz da sentença."
                                                },
                                                {
                                                        "numero": "755º",
                                                        "rotulo": "Art. 755º.",
                                                        "linha": 4928,
                                                        "caput": "A imposição da medida de segurança, nos casos dos arts. 751 a 753, poderá ser decretada de ofício ou a requerimento do Ministério Público.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "único",
                                                                        "rotulo": "Parágrafo único",
                                                                        "linha": 4930,
                                                                        "texto": "O diretor do estabelecimento penal, que tiver conhecimento de fatos indicativos da periculosidade do condenado a quem não tenha sido imposta medida de segurança, deverá logo comunicá-los ao juiz."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "756º",
                                                        "rotulo": "Art. 756º.",
                                                        "linha": 4932,
                                                        "caput": "Nos casos do no I, a e b, do art. 751, e no I do art. 752, poderá ser dispensada nova audiência do condenado."
                                                },
                                                {
                                                        "numero": "757º",
                                                        "rotulo": "Art. 757º.",
                                                        "linha": 4934,
                                                        "caput": "Nos casos do no I, c, e no II do art. 751 e no II do art. 752, o juiz, depois de proceder às diligências que julgar convenientes, ouvirá o Ministério Público e concederá ao condenado o prazo de três dias para alegações, devendo a prova requerida ou reputada necessária pelo juiz ser produzida dentro em dez dias.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 4936,
                                                                        "texto": "O juiz nomeará defensor ao condenado que o requerer."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 4938,
                                                                        "texto": "Se o réu estiver foragido, o juiz procederá às diligências que julgar convenientes, concedendo o prazo de provas, quando requerido pelo Ministério Público."
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 4940,
                                                                        "texto": "Findo o prazo de provas, o juiz proferirá a sentença dentro de três dias."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "758º",
                                                        "rotulo": "Art. 758º.",
                                                        "linha": 4942,
                                                        "caput": "A execução da medida de segurança incumbirá ao juiz da execução da sentença."
                                                },
                                                {
                                                        "numero": "759º",
                                                        "rotulo": "Art. 759º.",
                                                        "linha": 4944,
                                                        "caput": "No caso do art. 753, o juiz ouvirá o curador já nomeado ou que então nomear, podendo mandar submeter o condenado a exame mental, internando-o, desde logo, em estabelecimento adequado."
                                                },
                                                {
                                                        "numero": "760º",
                                                        "rotulo": "Art. 760º.",
                                                        "linha": 4946,
                                                        "caput": "Para a verificação da periculosidade, no caso do § 3o do art. 78 do Código Penal, observar-se-á o disposto no art. 757, no que for aplicável."
                                                },
                                                {
                                                        "numero": "761º",
                                                        "rotulo": "Art. 761º.",
                                                        "linha": 4948,
                                                        "caput": "Para a providência determinada no art. 84, § 2o, do Código Penal, se as sentenças forem proferidas por juízes diferentes, será competente o juiz que tiver sentenciado por último ou a autoridade de jurisdição prevalente no caso do art. 82."
                                                },
                                                {
                                                        "numero": "762º",
                                                        "rotulo": "Art. 762º.",
                                                        "linha": 4950,
                                                        "caput": "A ordem de internação, expedida para executar-se medida de segurança detentiva, conterá:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 4952,
                                                                        "texto": "a qualificação do internando;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 4954,
                                                                        "texto": "teor da decisão que tiver imposto a medida de segurança;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 4956,
                                                                        "texto": "a data em que terminará o prazo mínimo da internação."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "763º",
                                                        "rotulo": "Art. 763º.",
                                                        "linha": 4958,
                                                        "caput": "Se estiver solto o internando, expedir-se-á mandado de captura, que será cumprido por oficial de justiça ou por autoridade policial."
                                                },
                                                {
                                                        "numero": "764º",
                                                        "rotulo": "Art. 764º.",
                                                        "linha": 4960,
                                                        "caput": "O trabalho nos estabelecimentos referidos no art. 88, § 1o, III, do Código Penal, será educativo e remunerado, de modo que assegure ao internado meios de subsistência, quando cessar a internação.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 4962,
                                                                        "texto": "O trabalho poderá ser praticado ao ar livre."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 4964,
                                                                        "texto": "Nos outros estabelecimentos, o trabalho dependerá das condições pessoais do internado."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "765º",
                                                        "rotulo": "Art. 765º.",
                                                        "linha": 4966,
                                                        "caput": "A quarta parte do salário caberá ao Estado ou, no Distrito Federal e nos Territórios, à União, e o restante será depositado em nome do internado ou, se este preferir, entregue à sua família."
                                                },
                                                {
                                                        "numero": "766º",
                                                        "rotulo": "Art. 766º.",
                                                        "linha": 4968,
                                                        "caput": "A internação das mulheres será feita em estabelecimento próprio ou em seção especial."
                                                },
                                                {
                                                        "numero": "767º",
                                                        "rotulo": "Art. 767º.",
                                                        "linha": 4970,
                                                        "caput": "O juiz fixará as normas de conduta que serão observadas durante a liberdade vigiada.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 4972,
                                                                        "texto": "Serão normas obrigatórias, impostas ao indivíduo sujeito à liberdade vigiada:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 4974,
                                                                                        "texto": "tomar ocupação, dentro de prazo razoável, se for apto para o trabalho;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 4976,
                                                                                        "texto": "não mudar do território da jurisdição do juiz, sem prévia autorização deste."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 4978,
                                                                        "texto": "Poderão ser impostas ao indivíduo sujeito à liberdade vigiada, entre outras obrigações, as seguintes:",
                                                                        "alineas": [
                                                                                {
                                                                                        "letra": "a",
                                                                                        "rotulo": "a)",
                                                                                        "linha": 4980,
                                                                                        "texto": "não mudar de habitação sem aviso prévio ao juiz, ou à autoridade incumbida da vigilância;"
                                                                                },
                                                                                {
                                                                                        "letra": "b",
                                                                                        "rotulo": "b)",
                                                                                        "linha": 4982,
                                                                                        "texto": "recolher-se cedo à habitação;"
                                                                                },
                                                                                {
                                                                                        "letra": "c",
                                                                                        "rotulo": "c)",
                                                                                        "linha": 4984,
                                                                                        "texto": "não trazer consigo armas ofensivas ou instrumentos capazes de ofender;"
                                                                                },
                                                                                {
                                                                                        "letra": "d",
                                                                                        "rotulo": "d)",
                                                                                        "linha": 4986,
                                                                                        "texto": "não freqüentar casas de bebidas ou de tavolagem, nem certas reuniões, espetáculos ou diversões públicas."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "3",
                                                                        "rotulo": "§ 3",
                                                                        "linha": 4988,
                                                                        "texto": "Será entregue ao indivíduo sujeito à liberdade vigiada uma caderneta, de que constarão as obrigações impostas."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "768º",
                                                        "rotulo": "Art. 768º.",
                                                        "linha": 4990,
                                                        "caput": "As obrigações estabelecidas na sentença serão comunicadas à autoridade policial."
                                                },
                                                {
                                                        "numero": "769º",
                                                        "rotulo": "Art. 769º.",
                                                        "linha": 4992,
                                                        "caput": "A vigilância será exercida discretamente, de modo que não prejudique o indivíduo a ela sujeito."
                                                },
                                                {
                                                        "numero": "770º",
                                                        "rotulo": "Art. 770º.",
                                                        "linha": 4994,
                                                        "caput": "Mediante representação da autoridade incumbida da vigilância, a requerimento do Ministério Público ou de ofício, poderá o juiz modificar as normas fixadas ou estabelecer outras."
                                                },
                                                {
                                                        "numero": "771º",
                                                        "rotulo": "Art. 771º.",
                                                        "linha": 4996,
                                                        "caput": "Para execução do exílio local, o juiz comunicará sua decisão à autoridade policial do lugar ou dos lugares onde o exilado está proibido de permanecer ou de residir.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 4998,
                                                                        "texto": "O infrator da medida será conduzido à presença do juiz que poderá mantê-lo detido até proferir decisão."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 5000,
                                                                        "texto": "Se for reconhecida a transgressão e imposta, conseqüentemente, a liberdade vigiada, determinará o juiz que a autoridade policial providencie a fim de que o infrator siga imediatamente para o lugar de residência por ele escolhido, e oficiará à autoridade policial desse lugar, observando-se o disposto no art. 768."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "772º",
                                                        "rotulo": "Art. 772º.",
                                                        "linha": 5002,
                                                        "caput": "A proibição de freqüentar determinados lugares será comunicada pelo juiz à autoridade policial, que Ihe dará conhecimento de qualquer transgressão."
                                                },
                                                {
                                                        "numero": "773º",
                                                        "rotulo": "Art. 773º.",
                                                        "linha": 5004,
                                                        "caput": "A medida de fechamento de estabelecimento ou de interdição de associação será comunicada pelo juiz à autoridade policial, para que a execute."
                                                },
                                                {
                                                        "numero": "774º",
                                                        "rotulo": "Art. 774º.",
                                                        "linha": 5006,
                                                        "caput": "Nos casos do parágrafo único do art. 83 do Código Penal, ou quando a transgressão de uma medida de segurança importar a imposição de outra, observar-se-á o disposto no art. 757, no que for aplicável."
                                                },
                                                {
                                                        "numero": "775º",
                                                        "rotulo": "Art. 775º.",
                                                        "linha": 5008,
                                                        "caput": "A cessação ou não da periculosidade se verificará ao fim do prazo mínimo de duração da medida de segurança pelo exame das condições da pessoa a que tiver sido imposta, observando-se o seguinte:",
                                                        "incisos": [
                                                                {
                                                                        "numero": "I",
                                                                        "rotulo": "I",
                                                                        "linha": 5010,
                                                                        "texto": "diretor do estabelecimento de internação ou a autoridade policial incumbida da vigilância, até um mês antes de expirado o prazo de duração mínima da medida, se não for inferior a um ano, ou até quinze dias nos outros casos, remeterá ao juiz da execução minucioso relatório, que o habilite a resolver sobre a cessação ou permanência da medida;"
                                                                },
                                                                {
                                                                        "numero": "II",
                                                                        "rotulo": "II",
                                                                        "linha": 5012,
                                                                        "texto": "se o indivíduo estiver internado em manicômio judiciário ou em casa de custódia e tratamento, o relatório será acompanhado do laudo de exame pericial feito por dois médicos designados pelo diretor do estabelecimento;"
                                                                },
                                                                {
                                                                        "numero": "III",
                                                                        "rotulo": "III",
                                                                        "linha": 5014,
                                                                        "texto": "diretor do estabelecimento de internação ou a autoridade policial deverá, no relatório, concluir pela conveniência da revogação, ou não, da medida de segurança;"
                                                                },
                                                                {
                                                                        "numero": "IV",
                                                                        "rotulo": "IV",
                                                                        "linha": 5016,
                                                                        "texto": "se a medida de segurança for o exílio local ou a proibição de freqüentar determinados lugares, o juiz, até um mês ou quinze dias antes de expirado o prazo mínimo de duração, ordenará as diligências necessárias, para verificar se desapareceram as causas da aplicação da medida;"
                                                                },
                                                                {
                                                                        "numero": "V",
                                                                        "rotulo": "V",
                                                                        "linha": 5018,
                                                                        "texto": "junto aos autos o relatório, ou realizadas as diligências, serão ouvidos sucessivamente o Ministério Público e o curador ou o defensor, no prazo de três dias para cada um;"
                                                                },
                                                                {
                                                                        "numero": "VI",
                                                                        "rotulo": "VI",
                                                                        "linha": 5020,
                                                                        "texto": "juiz nomeará curador ou defensor ao interessado que o não tiver;"
                                                                },
                                                                {
                                                                        "numero": "VII",
                                                                        "rotulo": "VII",
                                                                        "linha": 5022,
                                                                        "texto": "juiz, de ofício, ou a requerimento de qualquer das partes, poderá determinar novas diligências, ainda que já expirado o prazo de duração mínima da medida de segurança;"
                                                                },
                                                                {
                                                                        "numero": "VIII",
                                                                        "rotulo": "VIII",
                                                                        "linha": 5024,
                                                                        "texto": "ouvidas as partes ou realizadas as diligências a que se refere o número anterior o juiz proferirá a sua decisão, no prazo de três dias."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "776º",
                                                        "rotulo": "Art. 776º.",
                                                        "linha": 5026,
                                                        "caput": "Nos exames sucessivos a que se referem o § 1º, II, e § 2o do art. 81 do Código Penal, observar-se-á, no que Ihes for aplicável, o disposto no artigo anterior."
                                                },
                                                {
                                                        "numero": "777º",
                                                        "rotulo": "Art. 777º.",
                                                        "linha": 5028,
                                                        "caput": "Em qualquer tempo, ainda durante o prazo mínimo de duração da medida de segurança, poderá o tribunal, câmara ou turma, a requerimento do Ministério Público ou do interessado, seu defensor ou curador, ordenar o exame, para a verificação da cessação da periculosidade.",
                                                        "paragrafos": [
                                                                {
                                                                        "numero": "1",
                                                                        "rotulo": "§ 1",
                                                                        "linha": 5030,
                                                                        "texto": "Designado o relator e ouvido o procurador-geral, se a medida não tiver sido por ele requerida, o pedido será julgado na primeira sessão."
                                                                },
                                                                {
                                                                        "numero": "2",
                                                                        "rotulo": "§ 2",
                                                                        "linha": 5032,
                                                                        "texto": "Deferido o pedido, a decisão será imediatamente comunicada ao juiz, que requisitará, marcando prazo, o relatório e o exame a que se referem os ns. I e II do art. 775 ou ordenará as diligências mencionadas no no IV do mesmo artigo, prosseguindo de acordo com o disposto nos outros incisos do citado artigo."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "numero": "778º",
                                                        "rotulo": "Art. 778º.",
                                                        "linha": 5034,
                                                        "caput": "Transitando em julgado a sentença de revogação, o juiz expedirá ordem para a desinternação, quando se tratar de medida detentiva, ou para que cesse a vigilância ou a proibição, nos outros casos."
                                                },
                                                {
                                                        "numero": "779º",
                                                        "rotulo": "Art. 779º.",
                                                        "linha": 5036,
                                                        "caput": "O confisco dos instrumentos e produtos do crime, no caso previsto no art. 100 do Código Penal, será decretado no despacho de arquivamento do inquérito, na sentença de impronúncia ou na sentença absolutória."
                                                }
                                        ]
                                }
                        ],
                        "artigos": []
                },
                {
                        "tipo": "livro",
                        "rotulo": "LIVRO V",
                        "linha": 5038,
                        "divisoes": [
                                {
                                        "tipo": "titulo",
                                        "rotulo": "TÍTULO ÚNICO",
                                        "linha": 5042,
                                        "divisoes": [
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO I",
                                                        "linha": 5044,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "780º",
                                                                        "rotulo": "Art. 780º.",
                                                                        "linha": 5048,
                                                                        "caput": "Sem prejuízo de convenções ou tratados, aplicar-se-á o disposto neste Título à homologação de sentenças penais estrangeiras e à expedição e ao cumprimento de cartas rogatórias para citações, inquirições e outras diligências necessárias à instrução de processo penal."
                                                                },
                                                                {
                                                                        "numero": "781º",
                                                                        "rotulo": "Art. 781º.",
                                                                        "linha": 5050,
                                                                        "caput": "As sentenças estrangeiras não serão homologadas, nem as cartas rogatórias cumpridas, se contrárias à ordem pública e aos bons costumes."
                                                                },
                                                                {
                                                                        "numero": "782º",
                                                                        "rotulo": "Art. 782º.",
                                                                        "linha": 5052,
                                                                        "caput": "O trânsito, por via diplomática, dos documentos apresentados constituirá prova bastante de sua autenticidade."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO II",
                                                        "linha": 5054,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "783º",
                                                                        "rotulo": "Art. 783º.",
                                                                        "linha": 5058,
                                                                        "caput": "As cartas rogatórias serão, pelo respectivo juiz, remetidas ao Ministro da Justiça, a fim de ser pedido o seu cumprimento, por via diplomática, às autoridades estrangeiras competentes."
                                                                },
                                                                {
                                                                        "numero": "784º",
                                                                        "rotulo": "Art. 784º.",
                                                                        "linha": 5060,
                                                                        "caput": "As cartas rogatórias emanadas de autoridades estrangeiras competentes não dependem de homologação e serão atendidas se encaminhadas por via diplomática e desde que o crime, segundo a lei brasileira, não exclua a extradição.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 5062,
                                                                                        "texto": "As rogatórias, acompanhadas de tradução em língua nacional, feita por tradutor oficial ou juramentado, serão, após exequatur do presidente do Supremo Tribunal Federal, cumpridas pelo juiz criminal do lugar onde as diligências tenham de efetuar-se, observadas as formalidades prescritas neste Código."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 5064,
                                                                                        "texto": "A carta rogatória será pelo presidente do Supremo Tribunal Federal remetida ao presidente do Tribunal de Apelação do Estado, do Distrito Federal, ou do Território, a fim de ser encaminhada ao juiz competente."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 5066,
                                                                                        "texto": "Versando sobre crime de ação privada, segundo a lei brasileira, o andamento, após o exequatur, dependerá do interessado, a quem incumbirá o pagamento das despesas."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 5068,
                                                                                        "texto": "Ficará sempre na secretaria do Supremo Tribunal Federal cópia da carta rogatória."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "785º",
                                                                        "rotulo": "Art. 785º.",
                                                                        "linha": 5070,
                                                                        "caput": "Concluídas as diligências, a carta rogatória será devolvida ao presidente do Supremo Tribunal Federal, por intermédio do presidente do Tribunal de Apelação, o qual, antes de devolvê-la, mandará completar qualquer diligência ou sanar qualquer nulidade."
                                                                },
                                                                {
                                                                        "numero": "786º",
                                                                        "rotulo": "Art. 786º.",
                                                                        "linha": 5072,
                                                                        "caput": "O despacho que conceder o exequatur marcará, para o cumprimento da diligência, prazo razoável, que poderá ser excedido, havendo justa causa, ficando esta consignada em ofício dirigido ao presidente do Supremo Tribunal Federal, juntamente com a carta rogatória."
                                                                }
                                                        ]
                                                },
                                                {
                                                        "tipo": "capitulo",
                                                        "rotulo": "CAPÍTULO III",
                                                        "linha": 5074,
                                                        "divisoes": [],
                                                        "artigos": [
                                                                {
                                                                        "numero": "787º",
                                                                        "rotulo": "Art. 787º.",
                                                                        "linha": 5078,
                                                                        "caput": "As sentenças estrangeiras deverão ser previamente homologadas pelo Supremo Tribunal Federal para que produzam os efeitos do art. 7o do Código Penal."
                                                                },
                                                                {
                                                                        "numero": "788º",
                                                                        "rotulo": "Art. 788º.",
                                                                        "linha": 5080,
                                                                        "caput": "A sentença penal estrangeira será homologada, quando a aplicação da lei brasileira produzir na espécie as mesmas conseqüências e concorrem os seguintes requisitos:",
                                                                        "incisos": [
                                                                                {
                                                                                        "numero": "I",
                                                                                        "rotulo": "I",
                                                                                        "linha": 5082,
                                                                                        "texto": "estar revestida das formalidades externas necessárias, segundo a legislação do país de origem;"
                                                                                },
                                                                                {
                                                                                        "numero": "II",
                                                                                        "rotulo": "II",
                                                                                        "linha": 5084,
                                                                                        "texto": "haver sido proferida por juiz competente, mediante citação regular, segundo a mesma legislação;"
                                                                                },
                                                                                {
                                                                                        "numero": "III",
                                                                                        "rotulo": "III",
                                                                                        "linha": 5086,
                                                                                        "texto": "ter passado em julgado;"
                                                                                },
                                                                                {
                                                                                        "numero": "IV",
                                                                                        "rotulo": "IV",
                                                                                        "linha": 5088,
                                                                                        "texto": "estar devidamente autenticada por cônsul brasileiro;"
                                                                                },
                                                                                {
                                                                                        "numero": "V",
                                                                                        "rotulo": "V",
                                                                                        "linha": 5090,
                                                                                        "texto": "estar acompanhada de tradução, feita por tradutor público."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "789º",
                                                                        "rotulo": "Art. 789º.",
                                                                        "linha": 5092,
                                                                        "caput": "O procurador-geral da República, sempre que tiver conhecimento da existência de sentença penal estrangeira, emanada de Estado que tenha com o Brasil tratado de extradição e que haja imposto medida de segurança pessoal ou pena acessória que deva ser cumprida no Brasil, pedirá ao Ministro da Justiça providências para obtenção de elementos que o habilitem a requerer a homologação da sentença.",
                                                                        "paragrafos": [
                                                                                {
                                                                                        "numero": "1",
                                                                                        "rotulo": "§ 1",
                                                                                        "linha": 5094,
                                                                                        "texto": "A homologação de sentença emanada de autoridade judiciária de Estado, que não tiver tratado de extradição com o Brasil, dependerá de requisição do Ministro da Justiça."
                                                                                },
                                                                                {
                                                                                        "numero": "2",
                                                                                        "rotulo": "§ 2",
                                                                                        "linha": 5096,
                                                                                        "texto": "Distribuído o requerimento de homologação, o relator mandará citar o interessado para deduzir embargos, dentro de dez dias, se residir no Distrito Federal, de trinta dias, no caso contrário."
                                                                                },
                                                                                {
                                                                                        "numero": "3",
                                                                                        "rotulo": "§ 3",
                                                                                        "linha": 5098,
                                                                                        "texto": "Se nesse prazo o interessado não deduzir os embargos, ser-lhe-á pelo relator nomeado defensor, o qual dentro de dez dias produzirá a defesa."
                                                                                },
                                                                                {
                                                                                        "numero": "4",
                                                                                        "rotulo": "§ 4",
                                                                                        "linha": 5100,
                                                                                        "texto": "Os embargos somente poderão fundar-se em dúvida sobre a autenticidade do documento, sobre a inteligência da sentença, ou sobre a falta de qualquer dos requisitos enumerados nos arts. 781 e 788."
                                                                                },
                                                                                {
                                                                                        "numero": "5",
                                                                                        "rotulo": "§ 5",
                                                                                        "linha": 5102,
                                                                                        "texto": "Contestados os embargos dentro de dez dias, pelo procurador-geral, irá o processo ao relator e ao revisor, observando-se no seu julgamento o Regimento Interno do Supremo Tribunal Federal."
                                                                                },
                                                                                {
                                                                                        "numero": "6",
                                                                                        "rotulo": "§ 6",
                                                                                        "linha": 5104,
                                                                                        "texto": "Homologada a sentença, a respectiva carta será remetida ao presidente do Tribunal de Apelação do Distrito Federal, do Estado, ou do Território."
                                                                                },
                                                                                {
                                                                                        "numero": "7",
                                                                                        "rotulo": "§ 7",
                                                                                        "linha": 5106,
                                                                                        "texto": "Recebida a carta de sentença, o presidente do Tribunal de Apelação a remeterá ao juiz do lugar de residência do condenado, para a aplicação da medida de segurança ou da pena acessória, observadas as disposições do Título II, Capítulo III, e Título V do Livro IV deste Código."
                                                                                }
                                                                        ]
                                                                },
                                                                {
                                                                        "numero": "790º",
                                                                        "rotulo": "Art. 790º.",
                                                                        "linha": 5108,
                                                                        "caput": "O interessado na execução de sentença penal estrangeira, para a reparação do dano, restituição e outros efeitos civis, poderá requerer ao Supremo Tribunal Federal a sua homologação, observando-se o que a respeito prescreve o Código de Processo Civil."
                                                                }
                                                        ]
                                                }
                                        ],
                                        "artigos": []
                                }
                        ],
                        "artigos": []
                },
                {
                        "tipo": "livro",
                        "rotulo": "LIVRO VI",
                        "linha": 5110,
                        "divisoes": [],
                        "artigos": [
                                {
                                        "numero": "791º",
                                        "rotulo": "Art. 791º.",
                                        "linha": 5114,
                                        "caput": "Em todos os juízos e tribunais do crime, além das audiências e sessões ordinárias, haverá as extraordinárias, de acordo com as necessidades do rápido andamento dos feitos."
                                },
                                {
                                        "numero": "792º",
                                        "rotulo": "Art. 792º.",
                                        "linha": 5116,
                                        "caput": "As audiências, sessões e os atos processuais serão, em regra, públicos e se realizarão nas sedes dos juízos e tribunais, com assistência dos escrivães, do secretário, do oficial de justiça que servir de porteiro, em dia e hora certos, ou previamente designados.",
                                        "paragrafos": [
                                                {
                                                        "numero": "1",
                                                        "rotulo": "§ 1",
                                                        "linha": 5118,
                                                        "texto": "Se da publicidade da audiência, da sessão ou do ato processual, puder resultar escândalo, inconveniente grave ou perigo de perturbação da ordem, o juiz, ou o tribunal, câmara, ou turma, poderá, de ofício ou a requerimento da parte ou do Ministério Público, determinar que o ato seja realizado a portas fechadas, limitando o número de pessoas que possam estar presentes."
                                                },
                                                {
                                                        "numero": "2",
                                                        "rotulo": "§ 2",
                                                        "linha": 5120,
                                                        "texto": "As audiências, as sessões e os atos processuais, em caso de necessidade, poderão realizar-se na residência do juiz, ou em outra casa por ele especialmente designada."
                                                }
                                        ]
                                },
                                {
                                        "numero": "793º",
                                        "rotulo": "Art. 793º.",
                                        "linha": 5122,
                                        "caput": "Nas audiências e nas sessões, os advogados, as partes, os escrivães e os espectadores poderão estar sentados. Todos, porém, se levantarão quando se dirigirem aos juízes ou quando estes se levantarem para qualquer ato do processo.",
                                        "paragrafos": [
                                                {
                                                        "numero": "único",
                                                        "rotulo": "Parágrafo único",
                                                        "linha": 5124,
                                                        "texto": "Nos atos da instrução criminal, perante os juízes singulares, os advogados poderão requerer sentados."
                                                }
                                        ]
                                },
                                {
                                        "numero": "794º",
                                        "rotulo": "Art. 794º.",
                                        "linha": 5126,
                                        "caput": "A polícia das audiências e das sessões compete aos respectivos juízes ou ao presidente do tribunal, câmara, ou turma, que poderão determinar o que for conveniente à manutenção da ordem. Para tal fim, requisitarão força pública, que ficará exclusivamente à sua disposição."
                                },
                                {
                                        "numero": "795º",
                                        "rotulo": "Art. 795º.",
                                        "linha": 5128,
                                        "caput": "Os espectadores das audiências ou das sessões não poderão manifestar-se.",
                                        "paragrafos": [
                                                {
                                                        "numero": "único",
                                                        "rotulo": "Parágrafo único",
                                                        "linha": 5130,
                                                        "texto": "O juiz ou o presidente fará retirar da sala os desobedientes, que, em caso de resistência, serão presos e autuados."
                                                }
                                        ]
                                },
                                {
                                        "numero": "796º",
                                        "rotulo": "Art. 796º.",
                                        "linha": 5132,
                                        "caput": "Os atos de instrução ou julgamento prosseguirão com a assistência do defensor, se o réu se portar inconvenientemente."
                                },
                                {
                                        "numero": "797º",
                                        "rotulo": "Art. 797º.",
                                        "linha": 5134,
                                        "caput": "Excetuadas as sessões de julgamento, que não serão marcadas para domingo ou dia feriado, os demais atos do processo poderão ser praticados em período de férias, em domingos e dias feriados. Todavia, os julgamentos iniciados em dia útil não se interromperão pela superveniência de feriado ou domingo."
                                },
                                {
                                        "numero": "798º",
                                        "rotulo": "Art. 798º.",
                                        "linha": 5136,
                                        "caput": "Todos os prazos correrão em cartório e serão contínuos e peremptórios, não se interrompendo por férias, domingo ou dia feriado.",
                                        "paragrafos": [
                                                {
                                                        "numero": "1",
                                                        "rotulo": "§ 1",
                                                        "linha": 5138,
                                                        "texto": "Não se computará no prazo o dia do começo, incluindo-se, porém, o do vencimento."
                                                },
                                                {
                                                        "numero": "2",
                                                        "rotulo": "§ 2",
                                                        "linha": 5140,
                                                        "texto": "A terminação dos prazos será certificada nos autos pelo escrivão; será, porém, considerado findo o prazo, ainda que omitida aquela formalidade, se feita a prova do dia em que começou a correr."
                                                },
                                                {
                                                        "numero": "3",
                                                        "rotulo": "§ 3",
                                                        "linha": 5142,
                                                        "texto": "O prazo que terminar em domingo ou dia feriado considerar-se-á prorrogado até o dia útil imediato."
                                                },
                                                {
                                                        "numero": "4",
                                                        "rotulo": "§ 4",
                                                        "linha": 5144,
                                                        "texto": "Não correrão os prazos, se houver impedimento do juiz, força maior, ou obstáculo judicial oposto pela parte contrária."
                                                },
                                                {
                                                        "numero": "5",
                                                        "rotulo": "§ 5",
                                                        "linha": 5146,
                                                        "texto": "Salvo os casos expressos, os prazos correrão:",
                                                        "alineas": [
                                                                {
                                                                        "letra": "a",
                                                                        "rotulo": "a)",
                                                                        "linha": 5148,
                                                                        "texto": "da intimação;"
                                                                },
                                                                {
                                                                        "letra": "b",
                                                                        "rotulo": "b)",
                                                                        "linha": 5150,
                                                                        "texto": "da audiência ou sessão em que for proferida a decisão, se a ela estiver presente a parte;"
                                                                },
                                                                {
                                                                        "letra": "c",
                                                                        "rotulo": "c)",
                                                                        "linha": 5152,
                                                                        "texto": "do dia em que a parte manifestar nos autos ciência inequívoca da sentença ou despacho."
                                                                }
                                                        ]
                                                }
                                        ]
                                },
                                {
                                        "numero": "798º-A",
                                        "rotulo": "Art. 798º-A.",
                                        "linha": 5154,
                                        "caput": "Suspende-se o curso do prazo processual nos dias compreendidos entre 20 de dezembro e 20 de janeiro, inclusive, salvo nos seguintes casos:",
                                        "incisos": [
                                                {
                                                        "numero": "I",
                                                        "rotulo": "I",
                                                        "linha": 5156,
                                                        "texto": "que envolvam réus presos, nos processos vinculados a essas prisões;"
                                                },
                                                {
                                                        "numero": "II",
                                                        "rotulo": "II",
                                                        "linha": 5158,
                                                        "texto": "nos procedimentos regidos pela Lei nº 11.340, de 7 de agosto de 2006 (Lei Maria da Penha);"
                                                },
                                                {
                                                        "numero": "III",
                                                        "rotulo": "III",
                                                        "linha": 5160,
                                                        "texto": "nas medidas consideradas urgentes, mediante despacho fundamentado do juízo competente."
                                                }
                                        ],
                                        "paragrafos": [
                                                {
                                                        "numero": "único",
                                                        "rotulo": "Parágrafo único",
                                                        "linha": 5162,
                                                        "texto": "Durante o período a que se refere o caput deste artigo, fica vedada a realização de audiências e de sessões de julgamento, salvo nas hipóteses dos incisos I, II e III do caput deste artigo."
                                                }
                                        ]
                                },
                                {
                                        "numero": "799º",
                                        "rotulo": "Art. 799º.",
                                        "linha": 5164,
                                        "caput": "O escrivão, sob pena de multa de cinqüenta a quinhentos mil-réis e, na reincidência, suspensão até 30 (trinta) dias, executará dentro do prazo de dois dias os atos determinados em lei ou ordenados pelo juiz."
                                },
                                {
                                        "numero": "800º",
                                        "rotulo": "Art. 800º.",
                                        "linha": 5166,
                                        "caput": "Os juízes singulares darão seus despachos e decisões dentro dos prazos seguintes, quando outros não estiverem estabelecidos:",
                                        "incisos": [
                                                {
                                                        "numero": "I",
                                                        "rotulo": "I",
                                                        "linha": 5168,
                                                        "texto": "de dez dias, se a decisão for definitiva, ou interlocutória mista;"
                                                },
                                                {
                                                        "numero": "II",
                                                        "rotulo": "II",
                                                        "linha": 5170,
                                                        "texto": "de cinco dias, se for interlocutória simples;"
                                                },
                                                {
                                                        "numero": "III",
                                                        "rotulo": "III",
                                                        "linha": 5172,
                                                        "texto": "de um dia, se se tratar de despacho de expediente."
                                                }
                                        ],
                                        "paragrafos": [
                                                {
                                                        "numero": "1",
                                                        "rotulo": "§ 1",
                                                        "linha": 5174,
                                                        "texto": "Os prazos para o juiz contar-se-ão do termo de conclusão."
                                                },
                                                {
                                                        "numero": "2",
                                                        "rotulo": "§ 2",
                                                        "linha": 5176,
                                                        "texto": "Os prazos do Ministério Público contar-se-ão do termo de vista, salvo para a interposição do recurso (art. 798, § 5o)."
                                                },
                                                {
                                                        "numero": "3",
                                                        "rotulo": "§ 3",
                                                        "linha": 5178,
                                                        "texto": "Em qualquer instância, declarando motivo justo, poderá o juiz exceder por igual tempo os prazos a ele fixados neste Código."
                                                },
                                                {
                                                        "numero": "4",
                                                        "rotulo": "§ 4",
                                                        "linha": 5180,
                                                        "texto": "O escrivão que não enviar os autos ao juiz ou ao órgão do Ministério Público no dia em que assinar termo de conclusão ou de vista estará sujeito à sanção estabelecida no art. 799."
                                                }
                                        ]
                                },
                                {
                                        "numero": "801º",
                                        "rotulo": "Art. 801º.",
                                        "linha": 5182,
                                        "caput": "Findos os respectivos prazos, os juízes e os órgãos do Ministério Público, responsáveis pelo retardamento, perderão tantos dias de vencimentos quantos forem os excedidos. Na contagem do tempo de serviço, para o efeito de promoção e aposentadoria, a perda será do dobro dos dias excedidos."
                                },
                                {
                                        "numero": "802º",
                                        "rotulo": "Art. 802º.",
                                        "linha": 5184,
                                        "caput": "O desconto referido no artigo antecedente far-se-á à vista da certidão do escrivão do processo ou do secretário do tribunal, que deverão, de ofício, ou a requerimento de qualquer interessado, remetê-la às repartições encarregadas do pagamento e da contagem do tempo de serviço, sob pena de incorrerem, de pleno direito, na multa de quinhentos mil-réis, imposta por autoridade fiscal."
                                },
                                {
                                        "numero": "803º",
                                        "rotulo": "Art. 803º.",
                                        "linha": 5186,
                                        "caput": "Salvo nos casos expressos em lei, é proibida a retirada de autos do cartório, ainda que em confiança, sob pena de responsabilidade do escrivão."
                                },
                                {
                                        "numero": "804º",
                                        "rotulo": "Art. 804º.",
                                        "linha": 5188,
                                        "caput": "A sentença ou o acórdão, que julgar a ação, qualquer incidente ou recurso, condenará nas custas o vencido."
                                },
                                {
                                        "numero": "805º",
                                        "rotulo": "Art. 805º.",
                                        "linha": 5190,
                                        "caput": "As custas serão contadas e cobradas de acordo com os regulamentos expedidos pela União e pelos Estados."
                                },
                                {
                                        "numero": "806º",
                                        "rotulo": "Art. 806º.",
                                        "linha": 5192,
                                        "caput": "Salvo o caso do art. 32, nas ações intentadas mediante queixa, nenhum ato ou diligência se realizará, sem que seja depositada em cartório a importância das custas.",
                                        "paragrafos": [
                                                {
                                                        "numero": "1",
                                                        "rotulo": "§ 1",
                                                        "linha": 5194,
                                                        "texto": "Igualmente, nenhum ato requerido no interesse da defesa será realizado, sem o prévio pagamento das custas, salvo se o acusado for pobre."
                                                },
                                                {
                                                        "numero": "2",
                                                        "rotulo": "§ 2",
                                                        "linha": 5196,
                                                        "texto": "A falta do pagamento das custas, nos prazos fixados em lei, ou marcados pelo juiz, importará renúncia à diligência requerida ou deserção do recurso interposto."
                                                },
                                                {
                                                        "numero": "3",
                                                        "rotulo": "§ 3",
                                                        "linha": 5198,
                                                        "texto": "A falta de qualquer prova ou diligência que deixe de realizar-se em virtude do não-pagamento de custas não implicará a nulidade do processo, se a prova de pobreza do acusado só posteriormente foi feita."
                                                }
                                        ]
                                },
                                {
                                        "numero": "807º",
                                        "rotulo": "Art. 807º.",
                                        "linha": 5200,
                                        "caput": "O disposto no artigo anterior não obstará à faculdade atribuída ao juiz de determinar de ofício inquirição de testemunhas ou outras diligências."
                                },
                                {
                                        "numero": "808º",
                                        "rotulo": "Art. 808º.",
                                        "linha": 5202,
                                        "caput": "Na falta ou impedimento do escrivão e seu substituto, servirá pessoa idônea, nomeada pela autoridade, perante quem prestará compromisso, lavrando o respectivo termo."
                                },
                                {
                                        "numero": "809º",
                                        "rotulo": "Art. 809º.",
                                        "linha": 5204,
                                        "caput": "A estatística judiciária criminal, a cargo do Instituto de Identificação e Estatística ou repartições congêneres, terá por base o boletim individual, que é parte integrante dos processos e versará sobre:",
                                        "incisos": [
                                                {
                                                        "numero": "I",
                                                        "rotulo": "I",
                                                        "linha": 5206,
                                                        "texto": "os crimes e as contravenções praticados durante o trimestre, com especificação da natureza de cada um, meios utilizados e circunstâncias de tempo e lugar;"
                                                },
                                                {
                                                        "numero": "II",
                                                        "rotulo": "II",
                                                        "linha": 5208,
                                                        "texto": "as armas proibidas que tenham sido apreendidas;"
                                                },
                                                {
                                                        "numero": "III",
                                                        "rotulo": "III",
                                                        "linha": 5210,
                                                        "texto": "número de delinqüentes, mencionadas as infrações que praticaram, sua nacionalidade, sexo, idade, filiação, estado civil, prole, residência, meios de vida e condições econômicas, grau de instrução, religião, e condições de saúde física e psíquica;"
                                                },
                                                {
                                                        "numero": "IV",
                                                        "rotulo": "IV",
                                                        "linha": 5212,
                                                        "texto": "número dos casos de co-delinqüência;"
                                                },
                                                {
                                                        "numero": "V",
                                                        "rotulo": "V",
                                                        "linha": 5214,
                                                        "texto": "a reincidência e os antecedentes judiciários;"
                                                },
                                                {
                                                        "numero": "VI",
                                                        "rotulo": "VI",
                                                        "linha": 5216,
                                                        "texto": "as sentenças condenatórias ou absolutórias, bem como as de pronúncia ou de impronúncia;"
                                                },
                                                {
                                                        "numero": "VII",
                                                        "rotulo": "VII",
                                                        "linha": 5218,
                                                        "texto": "a natureza das penas impostas;"
                                                },
                                                {
                                                        "numero": "VIII",
                                                        "rotulo": "VIII",
                                                        "linha": 5220,
                                                        "texto": "a natureza das medidas de segurança aplicadas;"
                                                },
                                                {
                                                        "numero": "IX",
                                                        "rotulo": "IX",
                                                        "linha": 5222,
                                                        "texto": "a suspensão condicional da execução da pena, quando concedida;"
                                                },
                                                {
                                                        "numero": "X",
                                                        "rotulo": "X",
                                                        "linha": 5224,
                                                        "texto": "as concessões ou denegações de habeas corpus."
                                                }
                                        ],
                                        "paragrafos": [
                                                {
                                                        "numero": "1",
                                                        "rotulo": "§ 1",
                                                        "linha": 5226,
                                                        "texto": "Os dados acima enumerados constituem o mínimo exigível, podendo ser acrescidos de outros elementos úteis ao serviço da estatística criminal."
                                                },
                                                {
                                                        "numero": "2",
                                                        "rotulo": "§ 2",
                                                        "linha": 5229,
                                                        "texto": "Esses dados serão lançados semestralmente em mapa e remetidos ao Serviço de Estatística Demográfica Moral e Política do Ministério da Justiça."
                                                },
                                                {
                                                        "numero": "3",
                                                        "rotulo": "§ 3",
                                                        "linha": 5231,
                                                        "texto": "O boletim individual a que se refere este artigo é dividido em três partes destacáveis, conforme modelo anexo a este Código, e será adotado nos Estados, no Distrito Federal e nos Territórios. A primeira parte ficará arquivada no cartório policial; a segunda será remetida ao Instituto de Identificação e Estatística, ou repartição congênere; e a terceira acompanhará o processo, e, depois de passar em julgado a sentença definitiva, lançados os dados finais, será enviada ao referido Instituto ou repartição congênere."
                                                }
                                        ]
                                },
                                {
                                        "numero": "810º",
                                        "rotulo": "Art. 810º.",
                                        "linha": 5233,
                                        "caput": "Este Código entrará em vigor no dia 1o de janeiro de 1942."
                                },
                                {
                                        "numero": "811º",
                                        "rotulo": "Art. 811º.",
                                        "linha": 5235,
                                        "caput": "Revogam-se as disposições em contrário."
                                }
                        ]
                }
        ],
        "fecho": {
                "texto": "Rio de Janeiro, em 3 de outubro de 1941; 120o da Independência e 53o da República.",
                "linha": 5237
        }
}