{
    "id": "Codigo_de_Processo_Civil",
    "titulo": "LEI Nº 13.105, DE 16 DE MARÇO DE 2015.",
    "apelido": "Código de Processo Civil.",
    "sigla": "CPC",
    "fonte": "codigo_de_processo_civil.txt",
    "fonteHtmlLocal": "l13105.htm",
    "fonteOficial": "https://www.planalto.gov.br/ccivil_03/leis/l13105.htm",
    "ementa": "Código de Processo Civil.",
    "preambulo": [
        {
            "texto": "LEI Nº 13.105, DE 16 DE MARÇO DE 2015.",
            "linha": 1
        },
        {
            "texto": "Código de Processo Civil.",
            "linha": 3
        },
        {
            "texto": "A PRESIDENTA DA REPÚBLICA Faço saber que o Congresso Nacional decreta e eu sanciono a seguinte Lei:",
            "linha": 5
        },
        {
            "texto": "PARTE GERAL",
            "linha": 7
        },
        {
            "texto": "LIVRO I",
            "linha": 9
        }
    ],
    "divisoes": [
        {
            "tipo": "titulo",
            "rotulo": "TÍTULO ÚNICO",
            "linha": 13,
            "divisoes": [
                {
                    "tipo": "capitulo",
                    "rotulo": "CAPÍTULO I",
                    "linha": 17,
                    "artigos": [
                        {
                            "numero": "1º",
                            "rotulo": "Art. 1º.",
                            "linha": 21,
                            "caput": "O processo civil será ordenado, disciplinado e interpretado conforme os valores e as normas fundamentais estabelecidos na Constituição da República Federativa do Brasil , observando-se as disposições deste Código."
                        },
                        {
                            "numero": "2º",
                            "rotulo": "Art. 2º.",
                            "linha": 23,
                            "caput": "O processo começa por iniciativa da parte e se desenvolve por impulso oficial, salvo as exceções previstas em lei."
                        },
                        {
                            "numero": "3º",
                            "rotulo": "Art. 3º.",
                            "linha": 25,
                            "caput": "Não se excluirá da apreciação jurisdicional ameaça ou lesão a direito.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 27,
                                    "texto": "É permitida a arbitragem, na forma da lei."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 29,
                                    "texto": "O Estado promoverá, sempre que possível, a solução consensual dos conflitos."
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 31,
                                    "texto": "A conciliação, a mediação e outros métodos de solução consensual de conflitos deverão ser estimulados por juízes, advogados, defensores públicos e membros do Ministério Público, inclusive no curso do processo judicial."
                                }
                            ]
                        },
                        {
                            "numero": "4º",
                            "rotulo": "Art. 4º.",
                            "linha": 33,
                            "caput": "As partes têm o direito de obter em prazo razoável a solução integral do mérito, incluída a atividade satisfativa."
                        },
                        {
                            "numero": "5º",
                            "rotulo": "Art. 5º.",
                            "linha": 35,
                            "caput": "Aquele que de qualquer forma participa do processo deve comportar-se de acordo com a boa-fé."
                        },
                        {
                            "numero": "6º",
                            "rotulo": "Art. 6º.",
                            "linha": 37,
                            "caput": "Todos os sujeitos do processo devem cooperar entre si para que se obtenha, em tempo razoável, decisão de mérito justa e efetiva."
                        },
                        {
                            "numero": "7º",
                            "rotulo": "Art. 7º.",
                            "linha": 39,
                            "caput": "É assegurada às partes paridade de tratamento em relação ao exercício de direitos e faculdades processuais, aos meios de defesa, aos ônus, aos deveres e à aplicação de sanções processuais, competindo ao juiz zelar pelo efetivo contraditório."
                        },
                        {
                            "numero": "8º",
                            "rotulo": "Art. 8º.",
                            "linha": 41,
                            "caput": "Ao aplicar o ordenamento jurídico, o juiz atenderá aos fins sociais e às exigências do bem comum, resguardando e promovendo a dignidade da pessoa humana e observando a proporcionalidade, a razoabilidade, a legalidade, a publicidade e a eficiência."
                        },
                        {
                            "numero": "9º",
                            "rotulo": "Art. 9º.",
                            "linha": 43,
                            "caput": "Não se proferirá decisão contra uma das partes sem que ela seja previamente ouvida.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 45,
                                    "texto": "O disposto no caput não se aplica:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 47,
                                            "texto": "à tutela provisória de urgência;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 49,
                                            "texto": "às hipóteses de tutela da evidência previstas no art. 311, incisos II e III;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 311, incisos II e III",
                                                    "href": "#art311ii",
                                                    "inicio": 49,
                                                    "fim": 75
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 51,
                                            "texto": "à decisão prevista no art. 701.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 701",
                                                    "href": "#art701",
                                                    "inicio": 22,
                                                    "fim": 30
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "numero": "10º",
                            "rotulo": "Art. 10º.",
                            "linha": 53,
                            "caput": "O juiz não pode decidir, em grau algum de jurisdição, com base em fundamento a respeito do qual não se tenha dado às partes oportunidade de se manifestar, ainda que se trate de matéria sobre a qual deva decidir de ofício."
                        },
                        {
                            "numero": "11º",
                            "rotulo": "Art. 11º.",
                            "linha": 55,
                            "caput": "Todos os julgamentos dos órgãos do Poder Judiciário serão públicos, e fundamentadas todas as decisões, sob pena de nulidade.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 57,
                                    "texto": "Nos casos de segredo de justiça, pode ser autorizada a presença somente das partes, de seus advogados, de defensores públicos ou do Ministério Público."
                                }
                            ]
                        },
                        {
                            "numero": "12º",
                            "rotulo": "Art. 12º.",
                            "linha": 60,
                            "caput": "Os juízes e os tribunais atenderão, preferencialmente, à ordem cronológica de conclusão para proferir sentença ou acórdão.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 62,
                                    "texto": "A lista de processos aptos a julgamento deverá estar permanentemente à disposição para consulta pública em cartório e na rede mundial de computadores."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 64,
                                    "texto": "Estão excluídos da regra do caput :",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 66,
                                            "texto": "as sentenças proferidas em audiência, homologatórias de acordo ou de improcedência liminar do pedido;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 68,
                                            "texto": "o julgamento de processos em bloco para aplicação de tese jurídica firmada em julgamento de casos repetitivos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 70,
                                            "texto": "o julgamento de recursos repetitivos ou de incidente de resolução de demandas repetitivas;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 72,
                                            "texto": "as decisões proferidas com base nos arts. 485 e 932;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 485",
                                                    "href": "#art485",
                                                    "inicio": 36,
                                                    "fim": 45
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "932",
                                                    "href": "#art932",
                                                    "inicio": 48,
                                                    "fim": 51
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 74,
                                            "texto": "o julgamento de embargos de declaração;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 76,
                                            "texto": "o julgamento de agravo interno;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 78,
                                            "texto": "as preferências legais e as metas estabelecidas pelo Conselho Nacional de Justiça;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 80,
                                            "texto": "os processos criminais, nos órgãos jurisdicionais que tenham competência penal;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 82,
                                            "texto": "a causa que exija urgência no julgamento, assim reconhecida por decisão fundamentada."
                                        }
                                    ]
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 84,
                                    "texto": "Após elaboração de lista própria, respeitar-se-á a ordem cronológica das conclusões entre as preferências legais."
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 86,
                                    "texto": "Após a inclusão do processo na lista de que trata o § 1º, o requerimento formulado pela parte não altera a ordem cronológica para a decisão, exceto quando implicar a reabertura da instrução ou a conversão do julgamento em diligência."
                                },
                                {
                                    "numero": "5º",
                                    "rotulo": "§ 5º",
                                    "linha": 88,
                                    "texto": "Decidido o requerimento previsto no § 4º, o processo retornará à mesma posição em que anteriormente se encontrava na lista."
                                },
                                {
                                    "numero": "6º",
                                    "rotulo": "§ 6º",
                                    "linha": 90,
                                    "texto": "Ocupará o primeiro lugar na lista prevista no § 1º ou, conforme o caso, no § 3º, o processo que:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 92,
                                            "texto": "tiver sua sentença ou acórdão anulado, salvo quando houver necessidade de realização de diligência ou de complementação da instrução;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 94,
                                            "texto": "se enquadrar na hipótese do art. 1.040, inciso II.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.040, inciso II",
                                                    "href": "#art1040",
                                                    "inicio": 28,
                                                    "fim": 49
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ],
                    "titulo": "DAS NORMAS FUNDAMENTAIS DO PROCESSO CIVIL",
                    "linhaTitulo": 19
                },
                {
                    "tipo": "capitulo",
                    "rotulo": "CAPÍTULO II",
                    "linha": 96,
                    "artigos": [
                        {
                            "numero": "13º",
                            "rotulo": "Art. 13º.",
                            "linha": 100,
                            "caput": "A jurisdição civil será regida pelas normas processuais brasileiras, ressalvadas as disposições específicas previstas em tratados, convenções ou acordos internacionais de que o Brasil seja parte."
                        },
                        {
                            "numero": "14º",
                            "rotulo": "Art. 14º.",
                            "linha": 102,
                            "caput": "A norma processual não retroagirá e será aplicável imediatamente aos processos em curso, respeitados os atos processuais praticados e as situações jurídicas consolidadas sob a vigência da norma revogada."
                        },
                        {
                            "numero": "15º",
                            "rotulo": "Art. 15º.",
                            "linha": 104,
                            "caput": "Na ausência de normas que regulem processos eleitorais, trabalhistas ou administrativos, as disposições deste Código lhes serão aplicadas supletiva e subsidiariamente."
                        }
                    ],
                    "titulo": "DA APLICAÇÃO DAS NORMAS PROCESSUAIS",
                    "linhaTitulo": 98
                }
            ],
            "titulo": "DAS NORMAS FUNDAMENTAIS E DA APLICAÇÃO DAS NORMAS PROCESSUAIS",
            "linhaTitulo": 15
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO II",
            "linha": 106,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 110,
                    "artigos": [
                        {
                            "numero": "16º",
                            "rotulo": "Art. 16º.",
                            "linha": 114,
                            "caput": "A jurisdição civil é exercida pelos juízes e pelos tribunais em todo o território nacional, conforme as disposições deste Código."
                        },
                        {
                            "numero": "17º",
                            "rotulo": "Art. 17º.",
                            "linha": 116,
                            "caput": "Para postular em juízo é necessário ter interesse e legitimidade."
                        },
                        {
                            "numero": "18º",
                            "rotulo": "Art. 18º.",
                            "linha": 118,
                            "caput": "Ninguém poderá pleitear direito alheio em nome próprio, salvo quando autorizado pelo ordenamento jurídico.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 120,
                                    "texto": "Havendo substituição processual, o substituído poderá intervir como assistente litisconsorcial."
                                }
                            ]
                        },
                        {
                            "numero": "19º",
                            "rotulo": "Art. 19º.",
                            "linha": 122,
                            "caput": "O interesse do autor pode limitar-se à declaração:",
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 124,
                                    "texto": "da existência, da inexistência ou do modo de ser de uma relação jurídica;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 126,
                                    "texto": "da autenticidade ou da falsidade de documento."
                                }
                            ]
                        },
                        {
                            "numero": "20º",
                            "rotulo": "Art. 20º.",
                            "linha": 128,
                            "caput": "É admissível a ação meramente declaratória, ainda que tenha ocorrido a violação do direito."
                        }
                    ],
                    "titulo": "DA JURISDIÇÃO E DA AÇÃO",
                    "linhaTitulo": 112
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 130,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 134,
                            "artigos": [
                                {
                                    "numero": "21º",
                                    "rotulo": "Art. 21º.",
                                    "linha": 138,
                                    "caput": "Compete à autoridade judiciária brasileira processar e julgar as ações em que:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 146,
                                            "texto": "Para o fim do disposto no inciso I, considera-se domiciliada no Brasil a pessoa jurídica estrangeira que nele tiver agência, filial ou sucursal."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 140,
                                            "texto": "o réu, qualquer que seja a sua nacionalidade, estiver domiciliado no Brasil;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 142,
                                            "texto": "no Brasil tiver de ser cumprida a obrigação;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 144,
                                            "texto": "o fundamento seja fato ocorrido ou ato praticado no Brasil."
                                        }
                                    ]
                                },
                                {
                                    "numero": "22º",
                                    "rotulo": "Art. 22º.",
                                    "linha": 148,
                                    "caput": "Compete, ainda, à autoridade judiciária brasileira processar e julgar as ações:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 150,
                                            "texto": "de alimentos, quando:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 152,
                                                    "texto": "o credor tiver domicílio ou residência no Brasil;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 154,
                                                    "texto": "o réu mantiver vínculos no Brasil, tais como posse ou propriedade de bens, recebimento de renda ou obtenção de benefícios econômicos;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 156,
                                            "texto": "decorrentes de relações de consumo, quando o consumidor tiver domicílio ou residência no Brasil;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 158,
                                            "texto": "em que as partes, expressa ou tacitamente, se submeterem à jurisdição nacional."
                                        }
                                    ]
                                },
                                {
                                    "numero": "23º",
                                    "rotulo": "Art. 23º.",
                                    "linha": 160,
                                    "caput": "Compete à autoridade judiciária brasileira, com exclusão de qualquer outra:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 162,
                                            "texto": "conhecer de ações relativas a imóveis situados no Brasil;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 164,
                                            "texto": "em matéria de sucessão hereditária, proceder à confirmação de testamento particular e ao inventário e à partilha de bens situados no Brasil, ainda que o autor da herança seja de nacionalidade estrangeira ou tenha domicílio fora do território nacional;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 166,
                                            "texto": "em divórcio, separação judicial ou dissolução de união estável, proceder à partilha de bens situados no Brasil, ainda que o titular seja de nacionalidade estrangeira ou tenha domicílio fora do território nacional."
                                        }
                                    ]
                                },
                                {
                                    "numero": "24º",
                                    "rotulo": "Art. 24º.",
                                    "linha": 168,
                                    "caput": "A ação proposta perante tribunal estrangeiro não induz litispendência e não obsta a que a autoridade judiciária brasileira conheça da mesma causa e das que lhe são conexas, ressalvadas as disposições em contrário de tratados internacionais e acordos bilaterais em vigor no Brasil.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 170,
                                            "texto": "A pendência de causa perante a jurisdição brasileira não impede a homologação de sentença judicial estrangeira quando exigida para produzir efeitos no Brasil."
                                        }
                                    ]
                                },
                                {
                                    "numero": "25º",
                                    "rotulo": "Art. 25º.",
                                    "linha": 172,
                                    "caput": "Não compete à autoridade judiciária brasileira o processamento e o julgamento da ação quando houver cláusula de eleição de foro exclusivo estrangeiro em contrato internacional, arguida pelo réu na contestação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 174,
                                            "texto": "Não se aplica o disposto no caput às hipóteses de competência internacional exclusiva previstas neste Capítulo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 176,
                                            "texto": "Aplica-se à hipótese do caput o art. 63, §§ 1º a 4º."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DOS LIMITES DA JURISDIÇÃO NACIONAL",
                            "linhaTitulo": 136
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 178,
                            "artigos": [
                                {
                                    "numero": "26º",
                                    "rotulo": "Art. 26º.",
                                    "linha": 186,
                                    "caput": "A cooperação jurídica internacional será regida por tratado de que o Brasil faz parte e observará:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 198,
                                            "texto": "Na ausência de tratado, a cooperação jurídica internacional poderá realizar-se com base em reciprocidade, manifestada por via diplomática."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 200,
                                            "texto": "Não se exigirá a reciprocidade referida no § 1º para homologação de sentença estrangeira."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 202,
                                            "texto": "Na cooperação jurídica internacional não será admitida a prática de atos que contrariem ou que produzam resultados incompatíveis com as normas fundamentais que regem o Estado brasileiro."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 204,
                                            "texto": "O Ministério da Justiça exercerá as funções de autoridade central na ausência de designação específica."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 188,
                                            "texto": "o respeito às garantias do devido processo legal no Estado requerente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 190,
                                            "texto": "a igualdade de tratamento entre nacionais e estrangeiros, residentes ou não no Brasil, em relação ao acesso à justiça e à tramitação dos processos, assegurando-se assistência judiciária aos necessitados;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 192,
                                            "texto": "a publicidade processual, exceto nas hipóteses de sigilo previstas na legislação brasileira ou na do Estado requerente;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 194,
                                            "texto": "a existência de autoridade central para recepção e transmissão dos pedidos de cooperação;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 196,
                                            "texto": "a espontaneidade na transmissão de informações a autoridades estrangeiras."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 184
                                },
                                {
                                    "numero": "27º",
                                    "rotulo": "Art. 27º.",
                                    "linha": 206,
                                    "caput": "A cooperação jurídica internacional terá por objeto:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 208,
                                            "texto": "citação, intimação e notificação judicial e extrajudicial;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 210,
                                            "texto": "colheita de provas e obtenção de informações;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 212,
                                            "texto": "homologação e cumprimento de decisão;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 214,
                                            "texto": "concessão de medida judicial de urgência;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 216,
                                            "texto": "assistência jurídica internacional;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 218,
                                            "texto": "qualquer outra medida judicial ou extrajudicial não proibida pela lei brasileira. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "28º",
                                    "rotulo": "Art. 28º.",
                                    "linha": 224,
                                    "caput": "Cabe auxílio direto quando a medida não decorrer diretamente de decisão de autoridade jurisdicional estrangeira a ser submetida a juízo de delibação no Brasil.",
                                    "rubrica": "Do Auxílio Direto",
                                    "linhaRubrica": 222
                                },
                                {
                                    "numero": "29º",
                                    "rotulo": "Art. 29º.",
                                    "linha": 226,
                                    "caput": "A solicitação de auxílio direto será encaminhada pelo órgão estrangeiro interessado à autoridade central, cabendo ao Estado requerente assegurar a autenticidade e a clareza do pedido."
                                },
                                {
                                    "numero": "30º",
                                    "rotulo": "Art. 30º.",
                                    "linha": 228,
                                    "caput": "Além dos casos previstos em tratados de que o Brasil faz parte, o auxílio direto terá os seguintes objetos:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 230,
                                            "texto": "obtenção e prestação de informações sobre o ordenamento jurídico e sobre processos administrativos ou jurisdicionais findos ou em curso;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 232,
                                            "texto": "colheita de provas, salvo se a medida for adotada em processo, em curso no estrangeiro, de competência exclusiva de autoridade judiciária brasileira;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 234,
                                            "texto": "qualquer outra medida judicial ou extrajudicial não proibida pela lei brasileira."
                                        }
                                    ]
                                },
                                {
                                    "numero": "31º",
                                    "rotulo": "Art. 31º.",
                                    "linha": 236,
                                    "caput": "A autoridade central brasileira comunicar-se-á diretamente com suas congêneres e, se necessário, com outros órgãos estrangeiros responsáveis pela tramitação e pela execução de pedidos de cooperação enviados e recebidos pelo Estado brasileiro, respeitadas disposições específicas constantes de tratado."
                                },
                                {
                                    "numero": "32º",
                                    "rotulo": "Art. 32º.",
                                    "linha": 238,
                                    "caput": "No caso de auxílio direto para a prática de atos que, segundo a lei brasileira, não necessitem de prestação jurisdicional, a autoridade central adotará as providências necessárias para seu cumprimento."
                                },
                                {
                                    "numero": "33º",
                                    "rotulo": "Art. 33º.",
                                    "linha": 240,
                                    "caput": "Recebido o pedido de auxílio direto passivo, a autoridade central o encaminhará à Advocacia-Geral da União, que requererá em juízo a medida solicitada.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 242,
                                            "texto": "O Ministério Público requererá em juízo a medida solicitada quando for autoridade central."
                                        }
                                    ]
                                },
                                {
                                    "numero": "34º",
                                    "rotulo": "Art. 34º.",
                                    "linha": 244,
                                    "caput": "Compete ao juízo federal do lugar em que deva ser executada a medida apreciar pedido de auxílio direto passivo que demande prestação de atividade jurisdicional. Seção III"
                                },
                                {
                                    "numero": "36º",
                                    "rotulo": "Art. 36º.",
                                    "linha": 250,
                                    "caput": "O procedimento da carta rogatória perante o Superior Tribunal de Justiça é de jurisdição contenciosa e deve assegurar às partes as garantias do devido processo legal.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 252,
                                            "texto": "A defesa restringir-se-á à discussão quanto ao atendimento dos requisitos para que o pronunciamento judicial estrangeiro produza efeitos no Brasil."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 254,
                                            "texto": "Em qualquer hipótese, é vedada a revisão do mérito do pronunciamento judicial estrangeiro pela autoridade judiciária brasileira. Seção IV"
                                        }
                                    ],
                                    "rubrica": "Da Carta Rogatória",
                                    "linhaRubrica": 248
                                },
                                {
                                    "numero": "37º",
                                    "rotulo": "Art. 37º.",
                                    "linha": 260,
                                    "caput": "O pedido de cooperação jurídica internacional oriundo de autoridade brasileira competente será encaminhado à autoridade central para posterior envio ao Estado requerido para lhe dar andamento.",
                                    "rubrica": "Disposições Comuns às Seções Anteriores",
                                    "linhaRubrica": 258
                                },
                                {
                                    "numero": "38º",
                                    "rotulo": "Art. 38º.",
                                    "linha": 262,
                                    "caput": "O pedido de cooperação oriundo de autoridade brasileira competente e os documentos anexos que o instruem serão encaminhados à autoridade central, acompanhados de tradução para a língua oficial do Estado requerido."
                                },
                                {
                                    "numero": "39º",
                                    "rotulo": "Art. 39º.",
                                    "linha": 264,
                                    "caput": "O pedido passivo de cooperação jurídica internacional será recusado se configurar manifesta ofensa à ordem pública."
                                },
                                {
                                    "numero": "40º",
                                    "rotulo": "Art. 40º.",
                                    "linha": 266,
                                    "caput": "A cooperação jurídica internacional para execução de decisão estrangeira dar-se-á por meio de carta rogatória ou de ação de homologação de sentença estrangeira, de acordo com o art. 960.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 960",
                                            "href": "#art960",
                                            "inicio": 177,
                                            "fim": 185
                                        }
                                    ]
                                },
                                {
                                    "numero": "41º",
                                    "rotulo": "Art. 41º.",
                                    "linha": 268,
                                    "caput": "Considera-se autêntico o documento que instruir pedido de cooperação jurídica internacional, inclusive tradução para a língua portuguesa, quando encaminhado ao Estado brasileiro por meio de autoridade central ou por via diplomática, dispensando-se ajuramentação, autenticação ou qualquer procedimento de legalização.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 270,
                                            "texto": "O disposto no caput não impede, quando necessária, a aplicação pelo Estado brasileiro do princípio da reciprocidade de tratamento."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA COOPERAÇÃO INTERNACIONAL",
                            "linhaTitulo": 180
                        }
                    ],
                    "titulo": "DOS LIMITES DA JURISDIÇÃO NACIONAL E DA COOPERAÇÃO INTERNACIONAL",
                    "linhaTitulo": 132
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 272,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 276,
                            "artigos": [
                                {
                                    "numero": "42º",
                                    "rotulo": "Art. 42º.",
                                    "linha": 284,
                                    "caput": "As causas cíveis serão processadas e decididas pelo juiz nos limites de sua competência, ressalvado às partes o direito de instituir juízo arbitral, na forma da lei.",
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 282
                                },
                                {
                                    "numero": "43º",
                                    "rotulo": "Art. 43º.",
                                    "linha": 286,
                                    "caput": "Determina-se a competência no momento do registro ou da distribuição da petição inicial, sendo irrelevantes as modificações do estado de fato ou de direito ocorridas posteriormente, salvo quando suprimirem órgão judiciário ou alterarem a competência absoluta."
                                },
                                {
                                    "numero": "44º",
                                    "rotulo": "Art. 44º.",
                                    "linha": 288,
                                    "caput": "Obedecidos os limites estabelecidos pela Constituição Federal, a competência é determinada pelas normas previstas neste Código ou em legislação especial, pelas normas de organização judiciária e, ainda, no que couber, pelas constituições dos Estados."
                                },
                                {
                                    "numero": "45º",
                                    "rotulo": "Art. 45º.",
                                    "linha": 290,
                                    "caput": "Tramitando o processo perante outro juízo, os autos serão remetidos ao juízo federal competente se nele intervier a União, suas empresas públicas, entidades autárquicas e fundações, ou conselho de fiscalização de atividade profissional, na qualidade de parte ou de terceiro interveniente, exceto as ações:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 296,
                                            "texto": "Os autos não serão remetidos se houver pedido cuja apreciação seja de competência do juízo perante o qual foi proposta a ação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 298,
                                            "texto": "Na hipótese do § 1º, o juiz, ao não admitir a cumulação de pedidos em razão da incompetência para apreciar qualquer deles, não examinará o mérito daquele em que exista interesse da União, de suas entidades autárquicas ou de suas empresas públicas."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 300,
                                            "texto": "O juízo federal restituirá os autos ao juízo estadual sem suscitar conflito se o ente federal cuja presença ensejou a remessa for excluído do processo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 292,
                                            "texto": "de recuperação judicial, falência, insolvência civil e acidente de trabalho;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 294,
                                            "texto": "sujeitas à justiça eleitoral e à justiça do trabalho."
                                        }
                                    ]
                                },
                                {
                                    "numero": "46º",
                                    "rotulo": "Art. 46º.",
                                    "linha": 302,
                                    "caput": "A ação fundada em direito pessoal ou em direito real sobre bens móveis será proposta, em regra, no foro de domicílio do réu.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 304,
                                            "texto": "Tendo mais de um domicílio, o réu será demandado no foro de qualquer deles."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 306,
                                            "texto": "Sendo incerto ou desconhecido o domicílio do réu, ele poderá ser demandado onde for encontrado ou no foro de domicílio do autor."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 308,
                                            "texto": "Quando o réu não tiver domicílio ou residência no Brasil, a ação será proposta no foro de domicílio do autor, e, se este também residir fora do Brasil, a ação será proposta em qualquer foro."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 310,
                                            "texto": "Havendo 2 (dois) ou mais réus com diferentes domicílios, serão demandados no foro de qualquer deles, à escolha do autor."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 312,
                                            "texto": "A execução fiscal será proposta no foro de domicílio do réu, no de sua residência ou no do lugar onde for encontrado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "47º",
                                    "rotulo": "Art. 47º.",
                                    "linha": 314,
                                    "caput": "Para as ações fundadas em direito real sobre imóveis é competente o foro de situação da coisa.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 316,
                                            "texto": "O autor pode optar pelo foro de domicílio do réu ou pelo foro de eleição se o litígio não recair sobre direito de propriedade, vizinhança, servidão, divisão e demarcação de terras e de nunciação de obra nova."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 318,
                                            "texto": "A ação possessória imobiliária será proposta no foro de situação da coisa, cujo juízo tem competência absoluta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "48º",
                                    "rotulo": "Art. 48º.",
                                    "linha": 320,
                                    "caput": "O foro de domicílio do autor da herança, no Brasil, é o competente para o inventário, a partilha, a arrecadação, o cumprimento de disposições de última vontade, a impugnação ou anulação de partilha extrajudicial e para todas as ações em que o espólio for réu, ainda que o óbito tenha ocorrido no estrangeiro.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 322,
                                            "texto": "Se o autor da herança não possuía domicílio certo, é competente:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 324,
                                                    "texto": "o foro de situação dos bens imóveis;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 326,
                                                    "texto": "havendo bens imóveis em foros diferentes, qualquer destes;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 328,
                                                    "texto": "não havendo bens imóveis, o foro do local de qualquer dos bens do espólio."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "49º",
                                    "rotulo": "Art. 49º.",
                                    "linha": 330,
                                    "caput": "A ação em que o ausente for réu será proposta no foro de seu último domicílio, também competente para a arrecadação, o inventário, a partilha e o cumprimento de disposições testamentárias."
                                },
                                {
                                    "numero": "50º",
                                    "rotulo": "Art. 50º.",
                                    "linha": 332,
                                    "caput": "A ação em que o incapaz for réu será proposta no foro de domicílio de seu representante ou assistente."
                                },
                                {
                                    "numero": "51º",
                                    "rotulo": "Art. 51º.",
                                    "linha": 334,
                                    "caput": "É competente o foro de domicílio do réu para as causas em que seja autora a União.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 336,
                                            "texto": "Se a União for a demandada, a ação poderá ser proposta no foro de domicílio do autor, no de ocorrência do ato ou fato que originou a demanda, no de situação da coisa ou no Distrito Federal."
                                        }
                                    ]
                                },
                                {
                                    "numero": "52º",
                                    "rotulo": "Art. 52º.",
                                    "linha": 338,
                                    "caput": "É competente o foro de domicílio do réu para as causas em que seja autor Estado ou o Distrito Federal.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 340,
                                            "texto": "Se Estado ou o Distrito Federal for o demandado, a ação poderá ser proposta no foro de domicílio do autor, no de ocorrência do ato ou fato que originou a demanda, no de situação da coisa ou na capital do respectivo ente federado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "53º",
                                    "rotulo": "Art. 53º.",
                                    "linha": 342,
                                    "caput": "É competente o foro:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 344,
                                            "texto": "para a ação de divórcio, separação, anulação de casamento e reconhecimento ou dissolução de união estável:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 346,
                                                    "texto": "de domicílio do guardião de filho incapaz;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 348,
                                                    "texto": "do último domicílio do casal, caso não haja filho incapaz;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 350,
                                                    "texto": "de domicílio do réu, se nenhuma das partes residir no antigo domicílio do casal;"
                                                },
                                                {
                                                    "letra": "d",
                                                    "rotulo": "d)",
                                                    "linha": 352,
                                                    "texto": "de domicílio da vítima de violência doméstica e familiar, nos termos da Lei nº 11.340, de 7 de agosto de 2006 (Lei Maria da Penha);",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "11",
                                                            "href": "../../../LEIS/L1060.htm#art11",
                                                            "inicio": 79,
                                                            "fim": 81
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 354,
                                            "texto": "de domicílio ou residência do alimentando, para a ação em que se pedem alimentos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 356,
                                            "texto": "do lugar:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 358,
                                                    "texto": "onde está a sede, para a ação em que for ré pessoa jurídica;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 360,
                                                    "texto": "onde se acha agência ou sucursal, quanto às obrigações que a pessoa jurídica contraiu;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 362,
                                                    "texto": "onde exerce suas atividades, para a ação em que for ré sociedade ou associação sem personalidade jurídica;"
                                                },
                                                {
                                                    "letra": "d",
                                                    "rotulo": "d)",
                                                    "linha": 364,
                                                    "texto": "onde a obrigação deve ser satisfeita, para a ação em que se lhe exigir o cumprimento;"
                                                },
                                                {
                                                    "letra": "e",
                                                    "rotulo": "e)",
                                                    "linha": 366,
                                                    "texto": "de residência do idoso, para a causa que verse sobre direito previsto no respectivo estatuto;"
                                                },
                                                {
                                                    "letra": "f",
                                                    "rotulo": "f)",
                                                    "linha": 368,
                                                    "texto": "da sede da serventia notarial ou de registro, para a ação de reparação de dano por ato praticado em razão do ofício;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 370,
                                            "texto": "do lugar do ato ou fato para a ação:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 372,
                                                    "texto": "de reparação de dano;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 374,
                                                    "texto": "em que for réu administrador ou gestor de negócios alheios;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 376,
                                            "texto": "de domicílio do autor ou do local do fato, para a ação de reparação de dano sofrido em razão de delito ou acidente de veículos, inclusive aeronaves. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "54º",
                                    "rotulo": "Art. 54º.",
                                    "linha": 382,
                                    "caput": "A competência relativa poderá modificar-se pela conexão ou pela continência, observado o disposto nesta Seção.",
                                    "rubrica": "Da Modificação da Competência",
                                    "linhaRubrica": 380
                                },
                                {
                                    "numero": "55º",
                                    "rotulo": "Art. 55º.",
                                    "linha": 384,
                                    "caput": "Reputam-se conexas 2 (duas) ou mais ações quando lhes for comum o pedido ou a causa de pedir.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 386,
                                            "texto": "Os processos de ações conexas serão reunidos para decisão conjunta, salvo se um deles já houver sido sentenciado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 388,
                                            "texto": "Aplica-se o disposto no caput :",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 390,
                                                    "texto": "à execução de título extrajudicial e à ação de conhecimento relativa ao mesmo ato jurídico;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 392,
                                                    "texto": "às execuções fundadas no mesmo título executivo."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 394,
                                            "texto": "Serão reunidos para julgamento conjunto os processos que possam gerar risco de prolação de decisões conflitantes ou contraditórias caso decididos separadamente, mesmo sem conexão entre eles."
                                        }
                                    ]
                                },
                                {
                                    "numero": "56º",
                                    "rotulo": "Art. 56º.",
                                    "linha": 396,
                                    "caput": "Dá-se a continência entre 2 (duas) ou mais ações quando houver identidade quanto às partes e à causa de pedir, mas o pedido de uma, por ser mais amplo, abrange o das demais."
                                },
                                {
                                    "numero": "57º",
                                    "rotulo": "Art. 57º.",
                                    "linha": 398,
                                    "caput": "Quando houver continência e a ação continente tiver sido proposta anteriormente, no processo relativo à ação contida será proferida sentença sem resolução de mérito, caso contrário, as ações serão necessariamente reunidas."
                                },
                                {
                                    "numero": "58º",
                                    "rotulo": "Art. 58º.",
                                    "linha": 400,
                                    "caput": "A reunião das ações propostas em separado far-se-á no juízo prevento, onde serão decididas simultaneamente."
                                },
                                {
                                    "numero": "59º",
                                    "rotulo": "Art. 59º.",
                                    "linha": 402,
                                    "caput": "O registro ou a distribuição da petição inicial torna prevento o juízo."
                                },
                                {
                                    "numero": "60º",
                                    "rotulo": "Art. 60º.",
                                    "linha": 404,
                                    "caput": "Se o imóvel se achar situado em mais de um Estado, comarca, seção ou subseção judiciária, a competência territorial do juízo prevento estender-se-á sobre a totalidade do imóvel."
                                },
                                {
                                    "numero": "61º",
                                    "rotulo": "Art. 61º.",
                                    "linha": 406,
                                    "caput": "A ação acessória será proposta no juízo competente para a ação principal."
                                },
                                {
                                    "numero": "62º",
                                    "rotulo": "Art. 62º.",
                                    "linha": 408,
                                    "caput": "A competência determinada em razão da matéria, da pessoa ou da função é inderrogável por convenção das partes."
                                },
                                {
                                    "numero": "63º",
                                    "rotulo": "Art. 63º.",
                                    "linha": 410,
                                    "caput": "As partes podem modificar a competência em razão do valor e do território, elegendo foro onde será proposta ação oriunda de direitos e obrigações.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 412,
                                            "texto": "A eleição de foro somente produz efeito quando constar de instrumento escrito, aludir expressamente a determinado negócio jurídico e guardar pertinência com o domicílio ou a residência de uma das partes ou com o local da obrigação, ressalvada a pactuação consumerista, quando favorável ao consumidor."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 414,
                                            "texto": "O foro contratual obriga os herdeiros e sucessores das partes."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 416,
                                            "texto": "Antes da citação, a cláusula de eleição de foro, se abusiva, pode ser reputada ineficaz de ofício pelo juiz, que determinará a remessa dos autos ao juízo do foro de domicílio do réu."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 418,
                                            "texto": "Citado, incumbe ao réu alegar a abusividade da cláusula de eleição de foro na contestação, sob pena de preclusão."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 420,
                                            "texto": "O ajuizamento de ação em juízo aleatório, entendido como aquele sem vinculação com o domicílio ou a residência das partes ou com o negócio jurídico discutido na demanda, constitui prática abusiva que justifica a declinação de competência de ofício. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "64º",
                                    "rotulo": "Art. 64º.",
                                    "linha": 426,
                                    "caput": "A incompetência, absoluta ou relativa, será alegada como questão preliminar de contestação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 428,
                                            "texto": "A incompetência absoluta pode ser alegada em qualquer tempo e grau de jurisdição e deve ser declarada de ofício."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 430,
                                            "texto": "Após manifestação da parte contrária, o juiz decidirá imediatamente a alegação de incompetência."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 432,
                                            "texto": "Caso a alegação de incompetência seja acolhida, os autos serão remetidos ao juízo competente."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 434,
                                            "texto": "Salvo decisão judicial em sentido contrário, conservar-se-ão os efeitos de decisão proferida pelo juízo incompetente até que outra seja proferida, se for o caso, pelo juízo competente."
                                        }
                                    ],
                                    "rubrica": "Da Incompetência",
                                    "linhaRubrica": 424
                                },
                                {
                                    "numero": "65º",
                                    "rotulo": "Art. 65º.",
                                    "linha": 436,
                                    "caput": "Prorrogar-se-á a competência relativa se o réu não alegar a incompetência em preliminar de contestação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 438,
                                            "texto": "A incompetência relativa pode ser alegada pelo Ministério Público nas causas em que atuar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "66º",
                                    "rotulo": "Art. 66º.",
                                    "linha": 440,
                                    "caput": "Há conflito de competência quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 448,
                                            "texto": "O juiz que não acolher a competência declinada deverá suscitar o conflito, salvo se a atribuir a outro juízo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 442,
                                            "texto": "2 (dois) ou mais juízes se declaram competentes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 444,
                                            "texto": "2 (dois) ou mais juízes se consideram incompetentes, atribuindo um ao outro a competência;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 446,
                                            "texto": "entre 2 (dois) ou mais juízes surge controvérsia acerca da reunião ou separação de processos."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA COMPETÊNCIA",
                            "linhaTitulo": 278
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 450,
                            "artigos": [
                                {
                                    "numero": "67º",
                                    "rotulo": "Art. 67º.",
                                    "linha": 454,
                                    "caput": "Aos órgãos do Poder Judiciário, estadual ou federal, especializado ou comum, em todas as instâncias e graus de jurisdição, inclusive aos tribunais superiores, incumbe o dever de recíproca cooperação, por meio de seus magistrados e servidores."
                                },
                                {
                                    "numero": "68º",
                                    "rotulo": "Art. 68º.",
                                    "linha": 456,
                                    "caput": "Os juízos poderão formular entre si pedido de cooperação para prática de qualquer ato processual."
                                },
                                {
                                    "numero": "69º",
                                    "rotulo": "Art. 69º.",
                                    "linha": 458,
                                    "caput": "O pedido de cooperação jurisdicional deve ser prontamente atendido, prescinde de forma específica e pode ser executado como:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 468,
                                            "texto": "As cartas de ordem, precatória e arbitral seguirão o regime previsto neste Código."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 470,
                                            "texto": "Os atos concertados entre os juízes cooperantes poderão consistir, além de outros, no estabelecimento de procedimento para:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 472,
                                                    "texto": "a prática de citação, intimação ou notificação de ato;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 474,
                                                    "texto": "a obtenção e apresentação de provas e a coleta de depoimentos;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 476,
                                                    "texto": "a efetivação de tutela provisória;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 478,
                                                    "texto": "a efetivação de medidas e providências para recuperação e preservação de empresas;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 480,
                                                    "texto": "a facilitação de habilitação de créditos na falência e na recuperação judicial;"
                                                },
                                                {
                                                    "numero": "VI",
                                                    "rotulo": "VI",
                                                    "linha": 482,
                                                    "texto": "a centralização de processos repetitivos;"
                                                },
                                                {
                                                    "numero": "VII",
                                                    "rotulo": "VII",
                                                    "linha": 484,
                                                    "texto": "a execução de decisão jurisdicional."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 486,
                                            "texto": "O pedido de cooperação judiciária pode ser realizado entre órgãos jurisdicionais de diferentes ramos do Poder Judiciário."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 460,
                                            "texto": "auxílio direto;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 462,
                                            "texto": "reunião ou apensamento de processos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 464,
                                            "texto": "prestação de informações;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 466,
                                            "texto": "atos concertados entre os juízes cooperantes."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA COOPERAÇÃO NACIONAL",
                            "linhaTitulo": 452
                        }
                    ],
                    "titulo": "DA COMPETÊNCIA INTERNA",
                    "linhaTitulo": 274
                }
            ],
            "titulo": "DA FUNÇÃO JURISDICIONAL",
            "linhaTitulo": 108
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO III",
            "linha": 488,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 492,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 496,
                            "artigos": [
                                {
                                    "numero": "70º",
                                    "rotulo": "Art. 70º.",
                                    "linha": 500,
                                    "caput": "Toda pessoa que se encontre no exercício de seus direitos tem capacidade para estar em juízo."
                                },
                                {
                                    "numero": "71º",
                                    "rotulo": "Art. 71º.",
                                    "linha": 502,
                                    "caput": "O incapaz será representado ou assistido por seus pais, por tutor ou por curador, na forma da lei."
                                },
                                {
                                    "numero": "72º",
                                    "rotulo": "Art. 72º.",
                                    "linha": 504,
                                    "caput": "O juiz nomeará curador especial ao:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 510,
                                            "texto": "A curatela especial será exercida pela Defensoria Pública, nos termos da lei."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 506,
                                            "texto": "incapaz, se não tiver representante legal ou se os interesses deste colidirem com os daquele, enquanto durar a incapacidade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 508,
                                            "texto": "réu preso revel, bem como ao réu revel citado por edital ou com hora certa, enquanto não for constituído advogado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "73º",
                                    "rotulo": "Art. 73º.",
                                    "linha": 512,
                                    "caput": "O cônjuge necessitará do consentimento do outro para propor ação que verse sobre direito real imobiliário, salvo quando casados sob o regime de separação absoluta de bens.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 514,
                                            "texto": "Ambos os cônjuges serão necessariamente citados para a ação:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 516,
                                                    "texto": "que verse sobre direito real imobiliário, salvo quando casados sob o regime de separação absoluta de bens;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 518,
                                                    "texto": "resultante de fato que diga respeito a ambos os cônjuges ou de ato praticado por eles;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 520,
                                                    "texto": "fundada em dívida contraída por um dos cônjuges a bem da família;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 522,
                                                    "texto": "que tenha por objeto o reconhecimento, a constituição ou a extinção de ônus sobre imóvel de um ou de ambos os cônjuges."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 524,
                                            "texto": "Nas ações possessórias, a participação do cônjuge do autor ou do réu somente é indispensável nas hipóteses de composse ou de ato por ambos praticado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 526,
                                            "texto": "Aplica-se o disposto neste artigo à união estável comprovada nos autos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "74º",
                                    "rotulo": "Art. 74º.",
                                    "linha": 528,
                                    "caput": "O consentimento previsto no art. 73 pode ser suprido judicialmente quando for negado por um dos cônjuges sem justo motivo, ou quando lhe seja impossível concedê-lo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 530,
                                            "texto": "A falta de consentimento, quando necessário e não suprido pelo juiz, invalida o processo."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 73",
                                            "href": "#art73",
                                            "inicio": 28,
                                            "fim": 35
                                        }
                                    ]
                                },
                                {
                                    "numero": "75º",
                                    "rotulo": "Art. 75º.",
                                    "linha": 532,
                                    "caput": "Serão representados em juízo, ativa e passivamente:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 556,
                                            "texto": "Quando o inventariante for dativo, os sucessores do falecido serão intimados no processo no qual o espólio seja parte."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 558,
                                            "texto": "A sociedade ou associação sem personalidade jurídica não poderá opor a irregularidade de sua constituição quando demandada."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 560,
                                            "texto": "O gerente de filial ou agência presume-se autorizado pela pessoa jurídica estrangeira a receber citação para qualquer processo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 562,
                                            "texto": "Os Estados e o Distrito Federal poderão ajustar compromisso recíproco para prática de ato processual por seus procuradores em favor de outro ente federado, mediante convênio firmado pelas respectivas procuradorias."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 564,
                                            "texto": "A representação judicial do Município pela Associação de Representação de Municípios somente poderá ocorrer em questões de interesse comum dos Municípios associados e dependerá de autorização do respectivo chefe do Poder Executivo municipal, com indicação específica do direito ou da obrigação a ser objeto das medidas judiciais."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 534,
                                            "texto": "a União, pela Advocacia-Geral da União, diretamente ou mediante órgão vinculado;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 536,
                                            "texto": "o Estado e o Distrito Federal, por seus procuradores;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 538,
                                            "texto": "o Município, por seu prefeito, procurador ou Associação de Representação de Municípios, quando expressamente autorizada;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 540,
                                            "texto": "a autarquia e a fundação de direito público, por quem a lei do ente federado designar;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 542,
                                            "texto": "a massa falida, pelo administrador judicial;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 544,
                                            "texto": "a herança jacente ou vacante, por seu curador;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 546,
                                            "texto": "o espólio, pelo inventariante;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 548,
                                            "texto": "a pessoa jurídica, por quem os respectivos atos constitutivos designarem ou, não havendo essa designação, por seus diretores;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 550,
                                            "texto": "a sociedade e a associação irregulares e outros entes organizados sem personalidade jurídica, pela pessoa a quem couber a administração de seus bens;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 552,
                                            "texto": "a pessoa jurídica estrangeira, pelo gerente, representante ou administrador de sua filial, agência ou sucursal aberta ou instalada no Brasil;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 554,
                                            "texto": "o condomínio, pelo administrador ou síndico."
                                        }
                                    ]
                                },
                                {
                                    "numero": "76º",
                                    "rotulo": "Art. 76º.",
                                    "linha": 566,
                                    "caput": "Verificada a incapacidade processual ou a irregularidade da representação da parte, o juiz suspenderá o processo e designará prazo razoável para que seja sanado o vício.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 568,
                                            "texto": "Descumprida a determinação, caso o processo esteja na instância originária:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 570,
                                                    "texto": "o processo será extinto, se a providência couber ao autor;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 572,
                                                    "texto": "o réu será considerado revel, se a providência lhe couber;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 574,
                                                    "texto": "o terceiro será considerado revel ou excluído do processo, dependendo do polo em que se encontre."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 576,
                                            "texto": "Descumprida a determinação em fase recursal perante tribunal de justiça, tribunal regional federal ou tribunal superior, o relator:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 578,
                                                    "texto": "não conhecerá do recurso, se a providência couber ao recorrente;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 580,
                                                    "texto": "determinará o desentranhamento das contrarrazões, se a providência couber ao recorrido."
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA CAPACIDADE PROCESSUAL",
                            "linhaTitulo": 498
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 582,
                            "artigos": [
                                {
                                    "numero": "77º",
                                    "rotulo": "Art. 77º.",
                                    "linha": 590,
                                    "caput": "Além de outros previstos neste Código, são deveres das partes, de seus procuradores e de todos aqueles que de qualquer forma participem do processo:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 606,
                                            "texto": "Nas hipóteses dos incisos IV e VI, o juiz advertirá qualquer das pessoas mencionadas no caput de que sua conduta poderá ser punida como ato atentatório à dignidade da justiça."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 608,
                                            "texto": "A violação ao disposto nos incisos IV e VI constitui ato atentatório à dignidade da justiça, devendo o juiz, sem prejuízo das sanções criminais, civis e processuais cabíveis, aplicar ao responsável multa de até vinte por cento do valor da causa, de acordo com a gravidade da conduta."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 610,
                                            "texto": "Não sendo paga no prazo a ser fixado pelo juiz, a multa prevista no § 2º será inscrita como dívida ativa da União ou do Estado após o trânsito em julgado da decisão que a fixou, e sua execução observará o procedimento da execução fiscal, revertendo-se aos fundos previstos no art. 97 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 97",
                                                    "href": "#art97",
                                                    "inicio": 276,
                                                    "fim": 283
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 612,
                                            "texto": "A multa estabelecida no § 2º poderá ser fixada independentemente da incidência das previstas nos arts. 523, § 1º, e 536, § 1º."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 614,
                                            "texto": "Quando o valor da causa for irrisório ou inestimável, a multa prevista no § 2º poderá ser fixada em até 10 (dez) vezes o valor do salário-mínimo."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 616,
                                            "texto": "Aos advogados públicos ou privados e aos membros da Defensoria Pública e do Ministério Público não se aplica o disposto nos §§ 2º a 5º, devendo eventual responsabilidade disciplinar ser apurada pelo respectivo órgão de classe ou corregedoria, ao qual o juiz oficiará."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 618,
                                            "texto": "Reconhecida violação ao disposto no inciso VI, o juiz determinará o restabelecimento do estado anterior, podendo, ainda, proibir a parte de falar nos autos até a purgação do atentado, sem prejuízo da aplicação do § 2º."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 620,
                                            "texto": "O representante judicial da parte não pode ser compelido a cumprir decisão em seu lugar."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 592,
                                            "texto": "expor os fatos em juízo conforme a verdade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 594,
                                            "texto": "não formular pretensão ou de apresentar defesa quando cientes de que são destituídas de fundamento;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 596,
                                            "texto": "não produzir provas e não praticar atos inúteis ou desnecessários à declaração ou à defesa do direito;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 598,
                                            "texto": "cumprir com exatidão as decisões jurisdicionais, de natureza provisória ou final, e não criar embaraços à sua efetivação;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 600,
                                            "texto": "declinar, no primeiro momento que lhes couber falar nos autos, o endereço residencial ou profissional onde receberão intimações, atualizando essa informação sempre que ocorrer qualquer modificação temporária ou definitiva;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 602,
                                            "texto": "não praticar inovação ilegal no estado de fato de bem ou direito litigioso."
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 604,
                                            "texto": "informar e manter atualizados seus dados cadastrais perante os órgãos do Poder Judiciário e, no caso do § 6º do art. 246 deste Código, da Administração Tributária, para recebimento de citações e intimações."
                                        }
                                    ],
                                    "rubrica": "Dos Deveres",
                                    "linhaRubrica": 588
                                },
                                {
                                    "numero": "78º",
                                    "rotulo": "Art. 78º.",
                                    "linha": 622,
                                    "caput": "É vedado às partes, a seus procuradores, aos juízes, aos membros do Ministério Público e da Defensoria Pública e a qualquer pessoa que participe do processo empregar expressões ofensivas nos escritos apresentados.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 624,
                                            "texto": "Quando expressões ou condutas ofensivas forem manifestadas oral ou presencialmente, o juiz advertirá o ofensor de que não as deve usar ou repetir, sob pena de lhe ser cassada a palavra."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 626,
                                            "texto": "De ofício ou a requerimento do ofendido, o juiz determinará que as expressões ofensivas sejam riscadas e, a requerimento do ofendido, determinará a expedição de certidão com inteiro teor das expressões ofensivas e a colocará à disposição da parte interessada. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "79º",
                                    "rotulo": "Art. 79º.",
                                    "linha": 632,
                                    "caput": "Responde por perdas e danos aquele que litigar de má-fé como autor, réu ou interveniente.",
                                    "rubrica": "Da Responsabilidade das Partes por Dano Processual",
                                    "linhaRubrica": 630
                                },
                                {
                                    "numero": "80º",
                                    "rotulo": "Art. 80º.",
                                    "linha": 634,
                                    "caput": "Considera-se litigante de má-fé aquele que:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 636,
                                            "texto": "deduzir pretensão ou defesa contra texto expresso de lei ou fato incontroverso;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 638,
                                            "texto": "alterar a verdade dos fatos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 640,
                                            "texto": "usar do processo para conseguir objetivo ilegal;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 642,
                                            "texto": "opuser resistência injustificada ao andamento do processo;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 644,
                                            "texto": "proceder de modo temerário em qualquer incidente ou ato do processo;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 646,
                                            "texto": "provocar incidente manifestamente infundado;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 648,
                                            "texto": "interpuser recurso com intuito manifestamente protelatório."
                                        }
                                    ]
                                },
                                {
                                    "numero": "81º",
                                    "rotulo": "Art. 81º.",
                                    "linha": 650,
                                    "caput": "De ofício ou a requerimento, o juiz condenará o litigante de má-fé a pagar multa, que deverá ser superior a um por cento e inferior a dez por cento do valor corrigido da causa, a indenizar a parte contrária pelos prejuízos que esta sofreu e a arcar com os honorários advocatícios e com todas as despesas que efetuou.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 652,
                                            "texto": "Quando forem 2 (dois) ou mais os litigantes de má-fé, o juiz condenará cada um na proporção de seu respectivo interesse na causa ou solidariamente aqueles que se coligaram para lesar a parte contrária."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 654,
                                            "texto": "Quando o valor da causa for irrisório ou inestimável, a multa poderá ser fixada em até 10 (dez) vezes o valor do salário-mínimo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 656,
                                            "texto": "O valor da indenização será fixado pelo juiz ou, caso não seja possível mensurá-lo, liquidado por arbitramento ou pelo procedimento comum, nos próprios autos. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "82º",
                                    "rotulo": "Art. 82º.",
                                    "linha": 662,
                                    "caput": "Salvo as disposições concernentes à gratuidade da justiça, incumbe às partes prover as despesas dos atos que realizarem ou requererem no processo, antecipando-lhes o pagamento, desde o início até a sentença final ou, na execução, até a plena satisfação do direito reconhecido no título.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 664,
                                            "texto": "Incumbe ao autor adiantar as despesas relativas a ato cuja realização o juiz determinar de ofício ou a requerimento do Ministério Público, quando sua intervenção ocorrer como fiscal da ordem jurídica."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 666,
                                            "texto": "A sentença condenará o vencido a pagar ao vencedor as despesas que antecipou."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 668,
                                            "texto": "Nas ações de cobrança por qualquer procedimento, comum ou especial, bem como nas execuções ou cumprimentos de sentença de honorários advocatícios, o advogado ficará dispensado de adiantar o pagamento de custas processuais, e caberá ao réu ou executado suprir, ao final do processo, o seu pagamento, se tiver dado causa ao processo."
                                        }
                                    ],
                                    "rubrica": "Das Despesas, dos Honorários Advocatícios e das Multas",
                                    "linhaRubrica": 660
                                },
                                {
                                    "numero": "83º",
                                    "rotulo": "Art. 83º.",
                                    "linha": 670,
                                    "caput": "O autor, brasileiro ou estrangeiro, que residir fora do Brasil ou deixar de residir no país ao longo da tramitação de processo prestará caução suficiente ao pagamento das custas e dos honorários de advogado da parte contrária nas ações que propuser, se não tiver no Brasil bens imóveis que lhes assegurem o pagamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 672,
                                            "texto": "Não se exigirá a caução de que trata o caput :",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 674,
                                                    "texto": "quando houver dispensa prevista em acordo ou tratado internacional de que o Brasil faz parte;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 676,
                                                    "texto": "na execução fundada em título extrajudicial e no cumprimento de sentença;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 678,
                                                    "texto": "na reconvenção."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 680,
                                            "texto": "Verificando-se no trâmite do processo que se desfalcou a garantia, poderá o interessado exigir reforço da caução, justificando seu pedido com a indicação da depreciação do bem dado em garantia e a importância do reforço que pretende obter."
                                        }
                                    ]
                                },
                                {
                                    "numero": "84º",
                                    "rotulo": "Art. 84º.",
                                    "linha": 682,
                                    "caput": "As despesas abrangem as custas dos atos do processo, a indenização de viagem, a remuneração do assistente técnico e a diária de testemunha."
                                },
                                {
                                    "numero": "85º",
                                    "rotulo": "Art. 85º.",
                                    "linha": 684,
                                    "caput": "A sentença condenará o vencido a pagar honorários ao advogado do vencedor.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 686,
                                            "texto": "São devidos honorários advocatícios na reconvenção, no cumprimento de sentença, provisório ou definitivo, na execução, resistida ou não, e nos recursos interpostos, cumulativamente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 688,
                                            "texto": "Os honorários serão fixados entre o mínimo de dez e o máximo de vinte por cento sobre o valor da condenação, do proveito econômico obtido ou, não sendo possível mensurá-lo, sobre o valor atualizado da causa, atendidos:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 690,
                                                    "texto": "o grau de zelo do profissional;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 692,
                                                    "texto": "o lugar de prestação do serviço;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 694,
                                                    "texto": "a natureza e a importância da causa;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 696,
                                                    "texto": "o trabalho realizado pelo advogado e o tempo exigido para o seu serviço."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 698,
                                            "texto": "Nas causas em que a Fazenda Pública for parte, a fixação dos honorários observará os critérios estabelecidos nos incisos I a IV do § 2º e os seguintes percentuais:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 700,
                                                    "texto": "mínimo de dez e máximo de vinte por cento sobre o valor da condenação ou do proveito econômico obtido até 200 (duzentos) salários-mínimos;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 702,
                                                    "texto": "mínimo de oito e máximo de dez por cento sobre o valor da condenação ou do proveito econômico obtido acima de 200 (duzentos) salários-mínimos até 2.000 (dois mil) salários-mínimos;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 704,
                                                    "texto": "mínimo de cinco e máximo de oito por cento sobre o valor da condenação ou do proveito econômico obtido acima de 2.000 (dois mil) salários-mínimos até 20.000 (vinte mil) salários-mínimos;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 706,
                                                    "texto": "mínimo de três e máximo de cinco por cento sobre o valor da condenação ou do proveito econômico obtido acima de 20.000 (vinte mil) salários-mínimos até 100.000 (cem mil) salários-mínimos;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 708,
                                                    "texto": "mínimo de um e máximo de três por cento sobre o valor da condenação ou do proveito econômico obtido acima de 100.000 (cem mil) salários-mínimos."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 710,
                                            "texto": "Em qualquer das hipóteses do § 3º :",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 712,
                                                    "texto": "os percentuais previstos nos incisos I a V devem ser aplicados desde logo, quando for líquida a sentença;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 714,
                                                    "texto": "não sendo líquida a sentença, a definição do percentual, nos termos previstos nos incisos I a V, somente ocorrerá quando liquidado o julgado;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 716,
                                                    "texto": "não havendo condenação principal ou não sendo possível mensurar o proveito econômico obtido, a condenação em honorários dar-se-á sobre o valor atualizado da causa;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 718,
                                                    "texto": "será considerado o salário-mínimo vigente quando prolatada sentença líquida ou o que estiver em vigor na data da decisão de liquidação."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 720,
                                            "texto": "Quando, conforme o caso, a condenação contra a Fazenda Pública ou o benefício econômico obtido pelo vencedor ou o valor da causa for superior ao valor previsto no inciso I do § 3º, a fixação do percentual de honorários deve observar a faixa inicial e, naquilo que a exceder, a faixa subsequente, e assim sucessivamente."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 722,
                                            "texto": "Os limites e critérios previstos nos §§ 2º e 3º aplicam-se independentemente de qual seja o conteúdo da decisão, inclusive aos casos de improcedência ou de sentença sem resolução de mérito."
                                        },
                                        {
                                            "numero": "6º-A",
                                            "rotulo": "§ 6º-A",
                                            "linha": 724,
                                            "texto": "Quando o valor da condenação ou do proveito econômico obtido ou o valor atualizado da causa for líquido ou liquidável, para fins de fixação dos honorários advocatícios, nos termos dos §§ 2º e 3º, é proibida a apreciação equitativa, salvo nas hipóteses expressamente previstas no § 8º deste artigo."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 726,
                                            "texto": "Não serão devidos honorários no cumprimento de sentença contra a Fazenda Pública que enseje expedição de precatório, desde que não tenha sido impugnada."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 728,
                                            "texto": "Nas causas em que for inestimável ou irrisório o proveito econômico ou, ainda, quando o valor da causa for muito baixo, o juiz fixará o valor dos honorários por apreciação equitativa, observando o disposto nos incisos do § 2º."
                                        },
                                        {
                                            "numero": "8º-A",
                                            "rotulo": "§ 8º-A",
                                            "linha": 730,
                                            "texto": "Na hipótese do § 8º deste artigo, para fins de fixação equitativa de honorários sucumbenciais, o juiz deverá observar os valores recomendados pelo Conselho Seccional da Ordem dos Advogados do Brasil a título de honorários advocatícios ou o limite mínimo de 10% (dez por cento) estabelecido no § 2º deste artigo, aplicando-se o que for maior."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 732,
                                            "texto": "Na ação de indenização por ato ilícito contra pessoa, o percentual de honorários incidirá sobre a soma das prestações vencidas acrescida de 12 (doze) prestações vincendas.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "12",
                                                    "href": "../../../LEIS/L1060.htm#art12",
                                                    "inicio": 140,
                                                    "fim": 142
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "10º",
                                            "rotulo": "§ 10º",
                                            "linha": 734,
                                            "texto": "Nos casos de perda do objeto, os honorários serão devidos por quem deu causa ao processo."
                                        },
                                        {
                                            "numero": "11º",
                                            "rotulo": "§ 11º",
                                            "linha": 736,
                                            "texto": "O tribunal, ao julgar recurso, majorará os honorários fixados anteriormente levando em conta o trabalho adicional realizado em grau recursal, observando, conforme o caso, o disposto nos §§ 2º a 6º, sendo vedado ao tribunal, no cômputo geral da fixação de honorários devidos ao advogado do vencedor, ultrapassar os respectivos limites estabelecidos nos §§ 2º e 3º para a fase de conhecimento."
                                        },
                                        {
                                            "numero": "12º",
                                            "rotulo": "§ 12º",
                                            "linha": 738,
                                            "texto": "Os honorários referidos no § 11 são cumuláveis com multas e outras sanções processuais, inclusive as previstas no art. 77.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 77",
                                                    "href": "#art77",
                                                    "inicio": 114,
                                                    "fim": 121
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "11",
                                                    "href": "../../../LEIS/L1060.htm#art11",
                                                    "inicio": 29,
                                                    "fim": 31
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "13º",
                                            "rotulo": "§ 13º",
                                            "linha": 740,
                                            "texto": "As verbas de sucumbência arbitradas em embargos à execução rejeitados ou julgados improcedentes e em fase de cumprimento de sentença serão acrescidas no valor do débito principal, para todos os efeitos legais."
                                        },
                                        {
                                            "numero": "14º",
                                            "rotulo": "§ 14º",
                                            "linha": 742,
                                            "texto": "Os honorários constituem direito do advogado e têm natureza alimentar, com os mesmos privilégios dos créditos oriundos da legislação do trabalho, sendo vedada a compensação em caso de sucumbência parcial."
                                        },
                                        {
                                            "numero": "15º",
                                            "rotulo": "§ 15º",
                                            "linha": 744,
                                            "texto": "O advogado pode requerer que o pagamento dos honorários que lhe caibam seja efetuado em favor da sociedade de advogados que integra na qualidade de sócio, aplicando-se à hipótese o disposto no § 14."
                                        },
                                        {
                                            "numero": "16º",
                                            "rotulo": "§ 16º",
                                            "linha": 746,
                                            "texto": "Quando os honorários forem fixados em quantia certa, os juros moratórios incidirão a partir da data do trânsito em julgado da decisão."
                                        },
                                        {
                                            "numero": "17º",
                                            "rotulo": "§ 17º",
                                            "linha": 748,
                                            "texto": "Os honorários serão devidos quando o advogado atuar em causa própria."
                                        },
                                        {
                                            "numero": "18º",
                                            "rotulo": "§ 18º",
                                            "linha": 750,
                                            "texto": "Caso a decisão transitada em julgado seja omissa quanto ao direito aos honorários ou ao seu valor, é cabível ação autônoma para sua definição e cobrança."
                                        },
                                        {
                                            "numero": "19º",
                                            "rotulo": "§ 19º",
                                            "linha": 752,
                                            "texto": "Os advogados públicos perceberão honorários de sucumbência, nos termos da lei."
                                        },
                                        {
                                            "numero": "20º",
                                            "rotulo": "§ 20º",
                                            "linha": 754,
                                            "texto": "O disposto nos §§ 2º, 3º, 4º, 5º, 6º, 6º-A, 8º, 8º-A, 9º e 10 deste artigo aplica-se aos honorários fixados por arbitramento judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "86º",
                                    "rotulo": "Art. 86º.",
                                    "linha": 756,
                                    "caput": "Se cada litigante for, em parte, vencedor e vencido, serão proporcionalmente distribuídas entre eles as despesas.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 758,
                                            "texto": "Se um litigante sucumbir em parte mínima do pedido, o outro responderá, por inteiro, pelas despesas e pelos honorários."
                                        }
                                    ]
                                },
                                {
                                    "numero": "87º",
                                    "rotulo": "Art. 87º.",
                                    "linha": 760,
                                    "caput": "Concorrendo diversos autores ou diversos réus, os vencidos respondem proporcionalmente pelas despesas e pelos honorários.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 762,
                                            "texto": "A sentença deverá distribuir entre os litisconsortes, de forma expressa, a responsabilidade proporcional pelo pagamento das verbas previstas no caput ."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 764,
                                            "texto": "Se a distribuição de que trata o § 1º não for feita, os vencidos responderão solidariamente pelas despesas e pelos honorários."
                                        }
                                    ]
                                },
                                {
                                    "numero": "88º",
                                    "rotulo": "Art. 88º.",
                                    "linha": 766,
                                    "caput": "Nos procedimentos de jurisdição voluntária, as despesas serão adiantadas pelo requerente e rateadas entre os interessados."
                                },
                                {
                                    "numero": "89º",
                                    "rotulo": "Art. 89º.",
                                    "linha": 768,
                                    "caput": "Nos juízos divisórios, não havendo litígio, os interessados pagarão as despesas proporcionalmente a seus quinhões."
                                },
                                {
                                    "numero": "90º",
                                    "rotulo": "Art. 90º.",
                                    "linha": 770,
                                    "caput": "Proferida sentença com fundamento em desistência, em renúncia ou em reconhecimento do pedido, as despesas e os honorários serão pagos pela parte que desistiu, renunciou ou reconheceu.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 772,
                                            "texto": "Sendo parcial a desistência, a renúncia ou o reconhecimento, a responsabilidade pelas despesas e pelos honorários será proporcional à parcela reconhecida, à qual se renunciou ou da qual se desistiu."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 774,
                                            "texto": "Havendo transação e nada tendo as partes disposto quanto às despesas, estas serão divididas igualmente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 776,
                                            "texto": "Se a transação ocorrer antes da sentença, as partes ficam dispensadas do pagamento das custas processuais remanescentes, se houver."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 778,
                                            "texto": "Se o réu reconhecer a procedência do pedido e, simultaneamente, cumprir integralmente a prestação reconhecida, os honorários serão reduzidos pela metade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "91º",
                                    "rotulo": "Art. 91º.",
                                    "linha": 780,
                                    "caput": "As despesas dos atos processuais praticados a requerimento da Fazenda Pública, do Ministério Público ou da Defensoria Pública serão pagas ao final pelo vencido.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 782,
                                            "texto": "As perícias requeridas pela Fazenda Pública, pelo Ministério Público ou pela Defensoria Pública poderão ser realizadas por entidade pública ou, havendo previsão orçamentária, ter os valores adiantados por aquele que requerer a prova."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 784,
                                            "texto": "Não havendo previsão orçamentária no exercício financeiro para adiantamento dos honorários periciais, eles serão pagos no exercício seguinte ou ao final, pelo vencido, caso o processo se encerre antes do adiantamento a ser feito pelo ente público."
                                        }
                                    ]
                                },
                                {
                                    "numero": "92º",
                                    "rotulo": "Art. 92º.",
                                    "linha": 786,
                                    "caput": "Quando, a requerimento do réu, o juiz proferir sentença sem resolver o mérito, o autor não poderá propor novamente a ação sem pagar ou depositar em cartório as despesas e os honorários a que foi condenado."
                                },
                                {
                                    "numero": "93º",
                                    "rotulo": "Art. 93º.",
                                    "linha": 788,
                                    "caput": "As despesas de atos adiados ou cuja repetição for necessária ficarão a cargo da parte, do auxiliar da justiça, do órgão do Ministério Público ou da Defensoria Pública ou do juiz que, sem justo motivo, houver dado causa ao adiamento ou à repetição."
                                },
                                {
                                    "numero": "94º",
                                    "rotulo": "Art. 94º.",
                                    "linha": 790,
                                    "caput": "Se o assistido for vencido, o assistente será condenado ao pagamento das custas em proporção à atividade que houver exercido no processo."
                                },
                                {
                                    "numero": "95º",
                                    "rotulo": "Art. 95º.",
                                    "linha": 792,
                                    "caput": "Cada parte adiantará a remuneração do assistente técnico que houver indicado, sendo a do perito adiantada pela parte que houver requerido a perícia ou rateada quando a perícia for determinada de ofício ou requerida por ambas as partes.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 794,
                                            "texto": "O juiz poderá determinar que a parte responsável pelo pagamento dos honorários do perito deposite em juízo o valor correspondente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 796,
                                            "texto": "A quantia recolhida em depósito bancário à ordem do juízo será corrigida monetariamente e paga de acordo com o art. 465, § 4º.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 465",
                                                    "href": "#art465",
                                                    "inicio": 111,
                                                    "fim": 119
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 798,
                                            "texto": "Quando o pagamento da perícia for de responsabilidade de beneficiário de gratuidade da justiça, ela poderá ser:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 800,
                                                    "texto": "custeada com recursos alocados no orçamento do ente público e realizada por servidor do Poder Judiciário ou por órgão público conveniado;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 802,
                                                    "texto": "paga com recursos alocados no orçamento da União, do Estado ou do Distrito Federal, no caso de ser realizada por particular, hipótese em que o valor será fixado conforme tabela do tribunal respectivo ou, em caso de sua omissão, do Conselho Nacional de Justiça."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 804,
                                            "texto": "Na hipótese do § 3º, o juiz, após o trânsito em julgado da decisão final, oficiará a Fazenda Pública para que promova, contra quem tiver sido condenado ao pagamento das despesas processuais, a execução dos valores gastos com a perícia particular ou com a utilização de servidor público ou da estrutura de órgão público, observando-se, caso o responsável pelo pagamento das despesas seja beneficiário de gratuidade da justiça, o disposto no art. 98, § 2º."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 806,
                                            "texto": "Para fins de aplicação do § 3º, é vedada a utilização de recursos do fundo de custeio da Defensoria Pública."
                                        }
                                    ]
                                },
                                {
                                    "numero": "96º",
                                    "rotulo": "Art. 96º.",
                                    "linha": 808,
                                    "caput": "O valor das sanções impostas ao litigante de má-fé reverterá em benefício da parte contrária, e o valor das sanções impostas aos serventuários pertencerá ao Estado ou à União."
                                },
                                {
                                    "numero": "97º",
                                    "rotulo": "Art. 97º.",
                                    "linha": 810,
                                    "caput": "A União e os Estados podem criar fundos de modernização do Poder Judiciário, aos quais serão revertidos os valores das sanções pecuniárias processuais destinadas à União e aos Estados, e outras verbas previstas em lei. Seção IV"
                                },
                                {
                                    "numero": "98º",
                                    "rotulo": "Art. 98º.",
                                    "linha": 816,
                                    "caput": "A pessoa natural ou jurídica, brasileira ou estrangeira, com insuficiência de recursos para pagar as custas, as despesas processuais e os honorários advocatícios tem direito à gratuidade da justiça, na forma da lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 818,
                                            "texto": "A gratuidade da justiça compreende:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 820,
                                                    "texto": "as taxas ou as custas judiciais;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 822,
                                                    "texto": "os selos postais;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 824,
                                                    "texto": "as despesas com publicação na imprensa oficial, dispensando-se a publicação em outros meios;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 826,
                                                    "texto": "a indenização devida à testemunha que, quando empregada, receberá do empregador salário integral, como se em serviço estivesse;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 828,
                                                    "texto": "as despesas com a realização de exame de código genético - DNA e de outros exames considerados essenciais;"
                                                },
                                                {
                                                    "numero": "VI",
                                                    "rotulo": "VI",
                                                    "linha": 830,
                                                    "texto": "os honorários do advogado e do perito e a remuneração do intérprete ou do tradutor nomeado para apresentação de versão em português de documento redigido em língua estrangeira;"
                                                },
                                                {
                                                    "numero": "VII",
                                                    "rotulo": "VII",
                                                    "linha": 832,
                                                    "texto": "o custo com a elaboração de memória de cálculo, quando exigida para instauração da execução;"
                                                },
                                                {
                                                    "numero": "VIII",
                                                    "rotulo": "VIII",
                                                    "linha": 834,
                                                    "texto": "os depósitos previstos em lei para interposição de recurso, para propositura de ação e para a prática de outros atos processuais inerentes ao exercício da ampla defesa e do contraditório;"
                                                },
                                                {
                                                    "numero": "IX",
                                                    "rotulo": "IX",
                                                    "linha": 836,
                                                    "texto": "os emolumentos devidos a notários ou registradores em decorrência da prática de registro, averbação ou qualquer outro ato notarial necessário à efetivação de decisão judicial ou à continuidade de processo judicial no qual o benefício tenha sido concedido."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 838,
                                            "texto": "A concessão de gratuidade não afasta a responsabilidade do beneficiário pelas despesas processuais e pelos honorários advocatícios decorrentes de sua sucumbência."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 840,
                                            "texto": "Vencido o beneficiário, as obrigações decorrentes de sua sucumbência ficarão sob condição suspensiva de exigibilidade e somente poderão ser executadas se, nos 5 (cinco) anos subsequentes ao trânsito em julgado da decisão que as certificou, o credor demonstrar que deixou de existir a situação de insuficiência de recursos que justificou a concessão de gratuidade, extinguindo-se, passado esse prazo, tais obrigações do beneficiário."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 842,
                                            "texto": "A concessão de gratuidade não afasta o dever de o beneficiário pagar, ao final, as multas processuais que lhe sejam impostas."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 844,
                                            "texto": "A gratuidade poderá ser concedida em relação a algum ou a todos os atos processuais, ou consistir na redução percentual de despesas processuais que o beneficiário tiver de adiantar no curso do procedimento."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 846,
                                            "texto": "Conforme o caso, o juiz poderá conceder direito ao parcelamento de despesas processuais que o beneficiário tiver de adiantar no curso do procedimento."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 848,
                                            "texto": "Aplica-se o disposto no art. 95, §§ 3º a 5º, ao custeio dos emolumentos previstos no § 1º, inciso IX, do presente artigo, observada a tabela e as condições da lei estadual ou distrital respectiva.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 95",
                                                    "href": "#art95",
                                                    "inicio": 24,
                                                    "fim": 31
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 850,
                                            "texto": "Na hipótese do § 1º, inciso IX, havendo dúvida fundada quanto ao preenchimento atual dos pressupostos para a concessão de gratuidade, o notário ou registrador, após praticar o ato, pode requerer, ao juízo competente para decidir questões notariais ou registrais, a revogação total ou parcial do benefício ou a sua substituição pelo parcelamento de que trata o § 6º deste artigo, caso em que o beneficiário será citado para, em 15 (quinze) dias, manifestar-se sobre esse requerimento."
                                        }
                                    ],
                                    "rubrica": "Da Gratuidade da Justiça",
                                    "linhaRubrica": 814
                                },
                                {
                                    "numero": "99º",
                                    "rotulo": "Art. 99º.",
                                    "linha": 852,
                                    "caput": "O pedido de gratuidade da justiça pode ser formulado na petição inicial, na contestação, na petição para ingresso de terceiro no processo ou em recurso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 854,
                                            "texto": "Se superveniente à primeira manifestação da parte na instância, o pedido poderá ser formulado por petição simples, nos autos do próprio processo, e não suspenderá seu curso."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 856,
                                            "texto": "O juiz somente poderá indeferir o pedido se houver nos autos elementos que evidenciem a falta dos pressupostos legais para a concessão de gratuidade, devendo, antes de indeferir o pedido, determinar à parte a comprovação do preenchimento dos referidos pressupostos."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 858,
                                            "texto": "Presume-se verdadeira a alegação de insuficiência deduzida exclusivamente por pessoa natural."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 860,
                                            "texto": "A assistência do requerente por advogado particular não impede a concessão de gratuidade da justiça."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 862,
                                            "texto": "Na hipótese do § 4º, o recurso que verse exclusivamente sobre valor de honorários de sucumbência fixados em favor do advogado de beneficiário estará sujeito a preparo, salvo se o próprio advogado demonstrar que tem direito à gratuidade."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 864,
                                            "texto": "O direito à gratuidade da justiça é pessoal, não se estendendo a litisconsorte ou a sucessor do beneficiário, salvo requerimento e deferimento expressos."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 866,
                                            "texto": "Requerida a concessão de gratuidade da justiça em recurso, o recorrente estará dispensado de comprovar o recolhimento do preparo, incumbindo ao relator, neste caso, apreciar o requerimento e, se indeferi-lo, fixar prazo para realização do recolhimento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "100º",
                                    "rotulo": "Art. 100º.",
                                    "linha": 868,
                                    "caput": "Deferido o pedido, a parte contrária poderá oferecer impugnação na contestação, na réplica, nas contrarrazões de recurso ou, nos casos de pedido superveniente ou formulado por terceiro, por meio de petição simples, a ser apresentada no prazo de 15 (quinze) dias, nos autos do próprio processo, sem suspensão de seu curso.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 870,
                                            "texto": "Revogado o benefício, a parte arcará com as despesas processuais que tiver deixado de adiantar e pagará, em caso de má-fé, até o décuplo de seu valor a título de multa, que será revertida em benefício da Fazenda Pública estadual ou federal e poderá ser inscrita em dívida ativa."
                                        }
                                    ]
                                },
                                {
                                    "numero": "101º",
                                    "rotulo": "Art. 101º.",
                                    "linha": 872,
                                    "caput": "Contra a decisão que indeferir a gratuidade ou a que acolher pedido de sua revogação caberá agravo de instrumento, exceto quando a questão for resolvida na sentença, contra a qual caberá apelação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 874,
                                            "texto": "O recorrente estará dispensado do recolhimento de custas até decisão do relator sobre a questão, preliminarmente ao julgamento do recurso."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 876,
                                            "texto": "Confirmada a denegação ou a revogação da gratuidade, o relator ou o órgão colegiado determinará ao recorrente o recolhimento das custas processuais, no prazo de 5 (cinco) dias, sob pena de não conhecimento do recurso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "102º",
                                    "rotulo": "Art. 102º.",
                                    "linha": 878,
                                    "caput": "Sobrevindo o trânsito em julgado de decisão que revoga a gratuidade, a parte deverá efetuar o recolhimento de todas as despesas de cujo adiantamento foi dispensada, inclusive as relativas ao recurso interposto, se houver, no prazo fixado pelo juiz, sem prejuízo de aplicação das sanções previstas em lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 880,
                                            "texto": "Não efetuado o recolhimento, o processo será extinto sem resolução de mérito, tratando-se do autor, e, nos demais casos, não poderá ser deferida a realização de nenhum ato ou diligência requerida pela parte enquanto não efetuado o depósito."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DOS DEVERES DAS PARTES E DE SEUS PROCURADORES",
                            "linhaTitulo": 584
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 882,
                            "artigos": [
                                {
                                    "numero": "103º",
                                    "rotulo": "Art. 103º.",
                                    "linha": 886,
                                    "caput": "A parte será representada em juízo por advogado regularmente inscrito na Ordem dos Advogados do Brasil.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 888,
                                            "texto": "É lícito à parte postular em causa própria quando tiver habilitação legal."
                                        }
                                    ]
                                },
                                {
                                    "numero": "104º",
                                    "rotulo": "Art. 104º.",
                                    "linha": 890,
                                    "caput": "O advogado não será admitido a postular em juízo sem procuração, salvo para evitar preclusão, decadência ou prescrição, ou para praticar ato considerado urgente.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 892,
                                            "texto": "Nas hipóteses previstas no caput , o advogado deverá, independentemente de caução, exibir a procuração no prazo de 15 (quinze) dias, prorrogável por igual período por despacho do juiz."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 894,
                                            "texto": "O ato não ratificado será considerado ineficaz relativamente àquele em cujo nome foi praticado, respondendo o advogado pelas despesas e por perdas e danos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "105º",
                                    "rotulo": "Art. 105º.",
                                    "linha": 896,
                                    "caput": "A procuração geral para o foro, outorgada por instrumento público ou particular assinado pela parte, habilita o advogado a praticar todos os atos do processo, exceto receber citação, confessar, reconhecer a procedência do pedido, transigir, desistir, renunciar ao direito sobre o qual se funda a ação, receber, dar quitação, firmar compromisso e assinar declaração de hipossuficiência econômica, que devem constar de cláusula específica.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 898,
                                            "texto": "A procuração pode ser assinada digitalmente, na forma da lei."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 900,
                                            "texto": "A procuração deverá conter o nome do advogado, seu número de inscrição na Ordem dos Advogados do Brasil e endereço completo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 902,
                                            "texto": "Se o outorgado integrar sociedade de advogados, a procuração também deverá conter o nome dessa, seu número de registro na Ordem dos Advogados do Brasil e endereço completo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 904,
                                            "texto": "Salvo disposição expressa em sentido contrário constante do próprio instrumento, a procuração outorgada na fase de conhecimento é eficaz para todas as fases do processo, inclusive para o cumprimento de sentença."
                                        }
                                    ]
                                },
                                {
                                    "numero": "106º",
                                    "rotulo": "Art. 106º.",
                                    "linha": 906,
                                    "caput": "Quando postular em causa própria, incumbe ao advogado:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 912,
                                            "texto": "Se o advogado descumprir o disposto no inciso I, o juiz ordenará que se supra a omissão, no prazo de 5 (cinco) dias, antes de determinar a citação do réu, sob pena de indeferimento da petição."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 914,
                                            "texto": "Se o advogado infringir o previsto no inciso II, serão consideradas válidas as intimações enviadas por carta registrada ou meio eletrônico ao endereço constante dos autos."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 908,
                                            "texto": "declarar, na petição inicial ou na contestação, o endereço, seu número de inscrição na Ordem dos Advogados do Brasil e o nome da sociedade de advogados da qual participa, para o recebimento de intimações;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 910,
                                            "texto": "comunicar ao juízo qualquer mudança de endereço."
                                        }
                                    ]
                                },
                                {
                                    "numero": "107º",
                                    "rotulo": "Art. 107º.",
                                    "linha": 916,
                                    "caput": "O advogado tem direito a:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 924,
                                            "texto": "Ao receber os autos, o advogado assinará carga em livro ou documento próprio."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 926,
                                            "texto": "Sendo o prazo comum às partes, os procuradores poderão retirar os autos somente em conjunto ou mediante prévio ajuste, por petição nos autos."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 928,
                                            "texto": "Na hipótese do § 2º, é lícito ao procurador retirar os autos para obtenção de cópias, pelo prazo de 2 (duas) a 6 (seis) horas, independentemente de ajuste e sem prejuízo da continuidade do prazo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 930,
                                            "texto": "O procurador perderá no mesmo processo o direito a que se refere o § 3º se não devolver os autos tempestivamente, salvo se o prazo for prorrogado pelo juiz."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 932,
                                            "texto": "O disposto no inciso I do caput deste artigo aplica-se integralmente a processos eletrônicos."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 918,
                                            "texto": "examinar, em cartório de fórum e secretaria de tribunal, mesmo sem procuração, autos de qualquer processo, independentemente da fase de tramitação, assegurados a obtenção de cópias e o registro de anotações, salvo na hipótese de segredo de justiça, nas quais apenas o advogado constituído terá acesso aos autos;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 920,
                                            "texto": "requerer, como procurador, vista dos autos de qualquer processo, pelo prazo de 5 (cinco) dias;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 922,
                                            "texto": "retirar os autos do cartório ou da secretaria, pelo prazo legal, sempre que neles lhe couber falar por determinação do juiz, nos casos previstos em lei."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DOS PROCURADORES",
                            "linhaTitulo": 884
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 934,
                            "artigos": [
                                {
                                    "numero": "108º",
                                    "rotulo": "Art. 108º.",
                                    "linha": 938,
                                    "caput": "No curso do processo, somente é lícita a sucessão voluntária das partes nos casos expressos em lei."
                                },
                                {
                                    "numero": "109º",
                                    "rotulo": "Art. 109º.",
                                    "linha": 940,
                                    "caput": "A alienação da coisa ou do direito litigioso por ato entre vivos, a título particular, não altera a legitimidade das partes.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 942,
                                            "texto": "O adquirente ou cessionário não poderá ingressar em juízo, sucedendo o alienante ou cedente, sem que o consinta a parte contrária."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 944,
                                            "texto": "O adquirente ou cessionário poderá intervir no processo como assistente litisconsorcial do alienante ou cedente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 946,
                                            "texto": "Estendem-se os efeitos da sentença proferida entre as partes originárias ao adquirente ou cessionário."
                                        }
                                    ]
                                },
                                {
                                    "numero": "110º",
                                    "rotulo": "Art. 110º.",
                                    "linha": 948,
                                    "caput": "Ocorrendo a morte de qualquer das partes, dar-se-á a sucessão pelo seu espólio ou pelos seus sucessores, observado o disposto no art. 313, §§ 1º e 2º.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 313",
                                            "href": "#art313",
                                            "inicio": 129,
                                            "fim": 137
                                        }
                                    ]
                                },
                                {
                                    "numero": "111º",
                                    "rotulo": "Art. 111º.",
                                    "linha": 950,
                                    "caput": "A parte que revogar o mandato outorgado a seu advogado constituirá, no mesmo ato, outro que assuma o patrocínio da causa.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 952,
                                            "texto": "Não sendo constituído novo procurador no prazo de 15 (quinze) dias, observar-se-á o disposto no art. 76.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 76",
                                                    "href": "#art76",
                                                    "inicio": 96,
                                                    "fim": 103
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "112º",
                                    "rotulo": "Art. 112º.",
                                    "linha": 954,
                                    "caput": "O advogado poderá renunciar ao mandato a qualquer tempo, provando, na forma prevista neste Código, que comunicou a renúncia ao mandante, a fim de que este nomeie sucessor.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 956,
                                            "texto": "Durante os 10 (dez) dias seguintes, o advogado continuará a representar o mandante, desde que necessário para lhe evitar prejuízo"
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 958,
                                            "texto": "Dispensa-se a comunicação referida no caput quando a procuração tiver sido outorgada a vários advogados e a parte continuar representada por outro, apesar da renúncia."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA SUCESSÃO DAS PARTES E DOS PROCURADORES",
                            "linhaTitulo": 936
                        }
                    ],
                    "titulo": "DAS PARTES E DOS PROCURADORES",
                    "linhaTitulo": 494
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 960,
                    "artigos": [
                        {
                            "numero": "113º",
                            "rotulo": "Art. 113º.",
                            "linha": 964,
                            "caput": "Duas ou mais pessoas podem litigar, no mesmo processo, em conjunto, ativa ou passivamente, quando:",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 972,
                                    "texto": "O juiz poderá limitar o litisconsórcio facultativo quanto ao número de litigantes na fase de conhecimento, na liquidação de sentença ou na execução, quando este comprometer a rápida solução do litígio ou dificultar a defesa ou o cumprimento da sentença."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 974,
                                    "texto": "O requerimento de limitação interrompe o prazo para manifestação ou resposta, que recomeçará da intimação da decisão que o solucionar."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 966,
                                    "texto": "entre elas houver comunhão de direitos ou de obrigações relativamente à lide;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 968,
                                    "texto": "entre as causas houver conexão pelo pedido ou pela causa de pedir;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 970,
                                    "texto": "ocorrer afinidade de questões por ponto comum de fato ou de direito."
                                }
                            ]
                        },
                        {
                            "numero": "114º",
                            "rotulo": "Art. 114º.",
                            "linha": 976,
                            "caput": "O litisconsórcio será necessário por disposição de lei ou quando, pela natureza da relação jurídica controvertida, a eficácia da sentença depender da citação de todos que devam ser litisconsortes."
                        },
                        {
                            "numero": "115º",
                            "rotulo": "Art. 115º.",
                            "linha": 978,
                            "caput": "A sentença de mérito, quando proferida sem a integração do contraditório, será:",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 984,
                                    "texto": "Nos casos de litisconsórcio passivo necessário, o juiz determinará ao autor que requeira a citação de todos que devam ser litisconsortes, dentro do prazo que assinar, sob pena de extinção do processo."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 980,
                                    "texto": "nula, se a decisão deveria ser uniforme em relação a todos que deveriam ter integrado o processo;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 982,
                                    "texto": "ineficaz, nos outros casos, apenas para os que não foram citados."
                                }
                            ]
                        },
                        {
                            "numero": "116º",
                            "rotulo": "Art. 116º.",
                            "linha": 986,
                            "caput": "O litisconsórcio será unitário quando, pela natureza da relação jurídica, o juiz tiver de decidir o mérito de modo uniforme para todos os litisconsortes."
                        },
                        {
                            "numero": "117º",
                            "rotulo": "Art. 117º.",
                            "linha": 988,
                            "caput": "Os litisconsortes serão considerados, em suas relações com a parte adversa, como litigantes distintos, exceto no litisconsórcio unitário, caso em que os atos e as omissões de um não prejudicarão os outros, mas os poderão beneficiar."
                        },
                        {
                            "numero": "118º",
                            "rotulo": "Art. 118º.",
                            "linha": 990,
                            "caput": "Cada litisconsorte tem o direito de promover o andamento do processo, e todos devem ser intimados dos respectivos atos."
                        }
                    ],
                    "titulo": "DO LITISCONSÓRCIO",
                    "linhaTitulo": 962
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 992,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 996,
                            "artigos": [
                                {
                                    "numero": "119º",
                                    "rotulo": "Art. 119º.",
                                    "linha": 1004,
                                    "caput": "Pendendo causa entre 2 (duas) ou mais pessoas, o terceiro juridicamente interessado em que a sentença seja favorável a uma delas poderá intervir no processo para assisti-la.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1006,
                                            "texto": "A assistência será admitida em qualquer procedimento e em todos os graus de jurisdição, recebendo o assistente o processo no estado em que se encontre."
                                        }
                                    ],
                                    "rubrica": "Disposições Comuns",
                                    "linhaRubrica": 1002
                                },
                                {
                                    "numero": "120º",
                                    "rotulo": "Art. 120º.",
                                    "linha": 1008,
                                    "caput": "Não havendo impugnação no prazo de 15 (quinze) dias, o pedido do assistente será deferido, salvo se for caso de rejeição liminar.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1010,
                                            "texto": "Se qualquer parte alegar que falta ao requerente interesse jurídico para intervir, o juiz decidirá o incidente, sem suspensão do processo. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "121º",
                                    "rotulo": "Art. 121º.",
                                    "linha": 1016,
                                    "caput": "O assistente simples atuará como auxiliar da parte principal, exercerá os mesmos poderes e sujeitar-se-á aos mesmos ônus processuais que o assistido.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1018,
                                            "texto": "Sendo revel ou, de qualquer outro modo, omisso o assistido, o assistente será considerado seu substituto processual."
                                        }
                                    ],
                                    "rubrica": "Da Assistência Simples",
                                    "linhaRubrica": 1014
                                },
                                {
                                    "numero": "122º",
                                    "rotulo": "Art. 122º.",
                                    "linha": 1020,
                                    "caput": "A assistência simples não obsta a que a parte principal reconheça a procedência do pedido, desista da ação, renuncie ao direito sobre o que se funda a ação ou transija sobre direitos controvertidos."
                                },
                                {
                                    "numero": "123º",
                                    "rotulo": "Art. 123º.",
                                    "linha": 1022,
                                    "caput": "Transitada em julgado a sentença no processo em que interveio o assistente, este não poderá, em processo posterior, discutir a justiça da decisão, salvo se alegar e provar que:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1024,
                                            "texto": "pelo estado em que recebeu o processo ou pelas declarações e pelos atos do assistido, foi impedido de produzir provas suscetíveis de influir na sentença;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1026,
                                            "texto": "desconhecia a existência de alegações ou de provas das quais o assistido, por dolo ou culpa, não se valeu. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "124º",
                                    "rotulo": "Art. 124º.",
                                    "linha": 1032,
                                    "caput": "Considera-se litisconsorte da parte principal o assistente sempre que a sentença influir na relação jurídica entre ele e o adversário do assistido.",
                                    "rubrica": "Da Assistência Litisconsorcial",
                                    "linhaRubrica": 1030
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA ASSISTÊNCIA",
                            "linhaTitulo": 998
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 1034,
                            "artigos": [
                                {
                                    "numero": "125º",
                                    "rotulo": "Art. 125º.",
                                    "linha": 1038,
                                    "caput": "É admissível a denunciação da lide, promovida por qualquer das partes:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1044,
                                            "texto": "O direito regressivo será exercido por ação autônoma quando a denunciação da lide for indeferida, deixar de ser promovida ou não for permitida."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1046,
                                            "texto": "Admite-se uma única denunciação sucessiva, promovida pelo denunciado, contra seu antecessor imediato na cadeia dominial ou quem seja responsável por indenizá-lo, não podendo o denunciado sucessivo promover nova denunciação, hipótese em que eventual direito de regresso será exercido por ação autônoma."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1040,
                                            "texto": "ao alienante imediato, no processo relativo à coisa cujo domínio foi transferido ao denunciante, a fim de que possa exercer os direitos que da evicção lhe resultam;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1042,
                                            "texto": "àquele que estiver obrigado, por lei ou pelo contrato, a indenizar, em ação regressiva, o prejuízo de quem for vencido no processo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "126º",
                                    "rotulo": "Art. 126º.",
                                    "linha": 1048,
                                    "caput": "A citação do denunciado será requerida na petição inicial, se o denunciante for autor, ou na contestação, se o denunciante for réu, devendo ser realizada na forma e nos prazos previstos no art. 131.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 131",
                                            "href": "#art131",
                                            "inicio": 189,
                                            "fim": 197
                                        }
                                    ]
                                },
                                {
                                    "numero": "127º",
                                    "rotulo": "Art. 127º.",
                                    "linha": 1050,
                                    "caput": "Feita a denunciação pelo autor, o denunciado poderá assumir a posição de litisconsorte do denunciante e acrescentar novos argumentos à petição inicial, procedendo-se em seguida à citação do réu."
                                },
                                {
                                    "numero": "128º",
                                    "rotulo": "Art. 128º.",
                                    "linha": 1052,
                                    "caput": "Feita a denunciação pelo réu:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1060,
                                            "texto": "Procedente o pedido da ação principal, pode o autor, se for o caso, requerer o cumprimento da sentença também contra o denunciado, nos limites da condenação deste na ação regressiva."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1054,
                                            "texto": "se o denunciado contestar o pedido formulado pelo autor, o processo prosseguirá tendo, na ação principal, em litisconsórcio, denunciante e denunciado;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1056,
                                            "texto": "se o denunciado for revel, o denunciante pode deixar de prosseguir com sua defesa, eventualmente oferecida, e abster-se de recorrer, restringindo sua atuação à ação regressiva;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1058,
                                            "texto": "se o denunciado confessar os fatos alegados pelo autor na ação principal, o denunciante poderá prosseguir com sua defesa ou, aderindo a tal reconhecimento, pedir apenas a procedência da ação de regresso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "129º",
                                    "rotulo": "Art. 129º.",
                                    "linha": 1062,
                                    "caput": "Se o denunciante for vencido na ação principal, o juiz passará ao julgamento da denunciação da lide.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1064,
                                            "texto": "Se o denunciante for vencedor, a ação de denunciação não terá o seu pedido examinado, sem prejuízo da condenação do denunciante ao pagamento das verbas de sucumbência em favor do denunciado."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA DENUNCIAÇÃO DA LIDE",
                            "linhaTitulo": 1036
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 1066,
                            "artigos": [
                                {
                                    "numero": "130º",
                                    "rotulo": "Art. 130º.",
                                    "linha": 1070,
                                    "caput": "É admissível o chamamento ao processo, requerido pelo réu:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1072,
                                            "texto": "do afiançado, na ação em que o fiador for réu;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1074,
                                            "texto": "dos demais fiadores, na ação proposta contra um ou alguns deles;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1076,
                                            "texto": "dos demais devedores solidários, quando o credor exigir de um ou de alguns o pagamento da dívida comum."
                                        }
                                    ]
                                },
                                {
                                    "numero": "131º",
                                    "rotulo": "Art. 131º.",
                                    "linha": 1078,
                                    "caput": "A citação daqueles que devam figurar em litisconsórcio passivo será requerida pelo réu na contestação e deve ser promovida no prazo de 30 (trinta) dias, sob pena de ficar sem efeito o chamamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1080,
                                            "texto": "Se o chamado residir em outra comarca, seção ou subseção judiciárias, ou em lugar incerto, o prazo será de 2 (dois) meses."
                                        }
                                    ]
                                },
                                {
                                    "numero": "132º",
                                    "rotulo": "Art. 132º.",
                                    "linha": 1082,
                                    "caput": "A sentença de procedência valerá como título executivo em favor do réu que satisfizer a dívida, a fim de que possa exigi-la, por inteiro, do devedor principal, ou, de cada um dos codevedores, a sua quota, na proporção que lhes tocar."
                                }
                            ],
                            "titulo": "DO CHAMAMENTO AO PROCESSO",
                            "linhaTitulo": 1068
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 1084,
                            "artigos": [
                                {
                                    "numero": "133º",
                                    "rotulo": "Art. 133º.",
                                    "linha": 1088,
                                    "caput": "O incidente de desconsideração da personalidade jurídica será instaurado a pedido da parte ou do Ministério Público, quando lhe couber intervir no processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1090,
                                            "texto": "O pedido de desconsideração da personalidade jurídica observará os pressupostos previstos em lei."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1092,
                                            "texto": "Aplica-se o disposto neste Capítulo à hipótese de desconsideração inversa da personalidade jurídica."
                                        }
                                    ]
                                },
                                {
                                    "numero": "134º",
                                    "rotulo": "Art. 134º.",
                                    "linha": 1094,
                                    "caput": "O incidente de desconsideração é cabível em todas as fases do processo de conhecimento, no cumprimento de sentença e na execução fundada em título executivo extrajudicial.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1096,
                                            "texto": "A instauração do incidente será imediatamente comunicada ao distribuidor para as anotações devidas."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1098,
                                            "texto": "Dispensa-se a instauração do incidente se a desconsideração da personalidade jurídica for requerida na petição inicial, hipótese em que será citado o sócio ou a pessoa jurídica."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1100,
                                            "texto": "A instauração do incidente suspenderá o processo, salvo na hipótese do § 2º."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1102,
                                            "texto": "O requerimento deve demonstrar o preenchimento dos pressupostos legais específicos para desconsideração da personalidade jurídica."
                                        }
                                    ]
                                },
                                {
                                    "numero": "135º",
                                    "rotulo": "Art. 135º.",
                                    "linha": 1104,
                                    "caput": "Instaurado o incidente, o sócio ou a pessoa jurídica será citado para manifestar-se e requerer as provas cabíveis no prazo de 15 (quinze) dias."
                                },
                                {
                                    "numero": "136º",
                                    "rotulo": "Art. 136º.",
                                    "linha": 1106,
                                    "caput": "Concluída a instrução, se necessária, o incidente será resolvido por decisão interlocutória.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1108,
                                            "texto": "Se a decisão for proferida pelo relator, cabe agravo interno."
                                        }
                                    ]
                                },
                                {
                                    "numero": "137º",
                                    "rotulo": "Art. 137º.",
                                    "linha": 1110,
                                    "caput": "Acolhido o pedido de desconsideração, a alienação ou a oneração de bens, havida em fraude de execução, será ineficaz em relação ao requerente."
                                }
                            ],
                            "titulo": "DO INCIDENTE DE DESCONSIDERAÇÃO DA PERSONALIDADE JURÍDICA",
                            "linhaTitulo": 1086
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 1112,
                            "artigos": [
                                {
                                    "numero": "138º",
                                    "rotulo": "Art. 138º.",
                                    "linha": 1116,
                                    "caput": "O juiz ou o relator, considerando a relevância da matéria, a especificidade do tema objeto da demanda ou a repercussão social da controvérsia, poderá, por decisão irrecorrível, de ofício ou a requerimento das partes ou de quem pretenda manifestar-se, solicitar ou admitir a participação de pessoa natural ou jurídica, órgão ou entidade especializada, com representatividade adequada, no prazo de 15 (quinze) dias de sua intimação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1118,
                                            "texto": "A intervenção de que trata o caput não implica alteração de competência nem autoriza a interposição de recursos, ressalvadas a oposição de embargos de declaração e a hipótese do § 3º."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1120,
                                            "texto": "Caberá ao juiz ou ao relator, na decisão que solicitar ou admitir a intervenção, definir os poderes do amicus curiae ."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1122,
                                            "texto": "O amicus curiae pode recorrer da decisão que julgar o incidente de resolução de demandas repetitivas."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO AMICUS CURIAE",
                            "linhaTitulo": 1114
                        }
                    ],
                    "titulo": "DA INTERVENÇÃO DE TERCEIROS",
                    "linhaTitulo": 994
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO IV",
                    "linha": 1124,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 1128,
                            "artigos": [
                                {
                                    "numero": "139º",
                                    "rotulo": "Art. 139º.",
                                    "linha": 1132,
                                    "caput": "O juiz dirigirá o processo conforme as disposições deste Código, incumbindo-lhe:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1154,
                                            "texto": "A dilação de prazos prevista no inciso VI somente pode ser determinada antes de encerrado o prazo regular."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1134,
                                            "texto": "assegurar às partes igualdade de tratamento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1136,
                                            "texto": "velar pela duração razoável do processo;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1138,
                                            "texto": "prevenir ou reprimir qualquer ato contrário à dignidade da justiça e indeferir postulações meramente protelatórias;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1140,
                                            "texto": "determinar todas as medidas indutivas, coercitivas, mandamentais ou sub-rogatórias necessárias para assegurar o cumprimento de ordem judicial, inclusive nas ações que tenham por objeto prestação pecuniária;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1142,
                                            "texto": "promover, a qualquer tempo, a autocomposição, preferencialmente com auxílio de conciliadores e mediadores judiciais;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 1144,
                                            "texto": "dilatar os prazos processuais e alterar a ordem de produção dos meios de prova, adequando-os às necessidades do conflito de modo a conferir maior efetividade à tutela do direito;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 1146,
                                            "texto": "exercer o poder de polícia, requisitando, quando necessário, força policial, além da segurança interna dos fóruns e tribunais;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 1148,
                                            "texto": "determinar, a qualquer tempo, o comparecimento pessoal das partes, para inquiri-las sobre os fatos da causa, hipótese em que não incidirá a pena de confesso;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 1150,
                                            "texto": "determinar o suprimento de pressupostos processuais e o saneamento de outros vícios processuais;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 1152,
                                            "texto": "quando se deparar com diversas demandas individuais repetitivas, oficiar o Ministério Público, a Defensoria Pública e, na medida do possível, outros legitimados a que se referem o art. 5º da Lei nº 7.347, de 24 de julho de 1985, e o art. 82 da Lei nº 8.078, de 11 de setembro de 1990, para, se for o caso, promover a propositura da ação coletiva respectiva.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "11",
                                                    "href": "../../../LEIS/L1060.htm#art11",
                                                    "inicio": 261,
                                                    "fim": 263
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "140º",
                                    "rotulo": "Art. 140º.",
                                    "linha": 1156,
                                    "caput": "O juiz não se exime de decidir sob a alegação de lacuna ou obscuridade do ordenamento jurídico.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1158,
                                            "texto": "O juiz só decidirá por equidade nos casos previstos em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "141º",
                                    "rotulo": "Art. 141º.",
                                    "linha": 1160,
                                    "caput": "O juiz decidirá o mérito nos limites propostos pelas partes, sendo-lhe vedado conhecer de questões não suscitadas a cujo respeito a lei exige iniciativa da parte."
                                },
                                {
                                    "numero": "142º",
                                    "rotulo": "Art. 142º.",
                                    "linha": 1162,
                                    "caput": "Convencendo-se, pelas circunstâncias, de que autor e réu se serviram do processo para praticar ato simulado ou conseguir fim vedado por lei, o juiz proferirá decisão que impeça os objetivos das partes, aplicando, de ofício, as penalidades da litigância de má-fé."
                                },
                                {
                                    "numero": "143º",
                                    "rotulo": "Art. 143º.",
                                    "linha": 1164,
                                    "caput": "O juiz responderá, civil e regressivamente, por perdas e danos quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1170,
                                            "texto": "As hipóteses previstas no inciso II somente serão verificadas depois que a parte requerer ao juiz que determine a providência e o requerimento não for apreciado no prazo de 10 (dez) dias."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1166,
                                            "texto": "no exercício de suas funções, proceder com dolo ou fraude;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1168,
                                            "texto": "recusar, omitir ou retardar, sem justo motivo, providência que deva ordenar de ofício ou a requerimento da parte."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DOS PODERES, DOS DEVERES E DA RESPONSABILIDADE DO JUIZ",
                            "linhaTitulo": 1130
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 1172,
                            "artigos": [
                                {
                                    "numero": "144º",
                                    "rotulo": "Art. 144º.",
                                    "linha": 1176,
                                    "caput": "Há impedimento do juiz, sendo-lhe vedado exercer suas funções no processo:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1196,
                                            "texto": "Na hipótese do inciso III, o impedimento só se verifica quando o defensor público, o advogado ou o membro do Ministério Público já integrava o processo antes do início da atividade judicante do juiz."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1198,
                                            "texto": "É vedada a criação de fato superveniente a fim de caracterizar impedimento do juiz."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1200,
                                            "texto": "O impedimento previsto no inciso III também se verifica no caso de mandato conferido a membro de escritório de advocacia que tenha em seus quadros advogado que individualmente ostente a condição nele prevista, mesmo que não intervenha diretamente no processo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1178,
                                            "texto": "em que interveio como mandatário da parte, oficiou como perito, funcionou como membro do Ministério Público ou prestou depoimento como testemunha;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1180,
                                            "texto": "de que conheceu em outro grau de jurisdição, tendo proferido decisão;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1182,
                                            "texto": "quando nele estiver postulando, como defensor público, advogado ou membro do Ministério Público, seu cônjuge ou companheiro, ou qualquer parente, consanguíneo ou afim, em linha reta ou colateral, até o terceiro grau, inclusive;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1184,
                                            "texto": "quando for parte no processo ele próprio, seu cônjuge ou companheiro, ou parente, consanguíneo ou afim, em linha reta ou colateral, até o terceiro grau, inclusive;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1186,
                                            "texto": "quando for sócio ou membro de direção ou de administração de pessoa jurídica parte no processo;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 1188,
                                            "texto": "quando for herdeiro presuntivo, donatário ou empregador de qualquer das partes;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 1190,
                                            "texto": "em que figure como parte instituição de ensino com a qual tenha relação de emprego ou decorrente de contrato de prestação de serviços;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 1192,
                                            "texto": "em que figure como parte cliente do escritório de advocacia de seu cônjuge, companheiro ou parente, consanguíneo ou afim, em linha reta ou colateral, até o terceiro grau, inclusive, mesmo que patrocinado por advogado de outro escritório;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 1194,
                                            "texto": "quando promover ação contra a parte ou seu advogado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "145º",
                                    "rotulo": "Art. 145º.",
                                    "linha": 1202,
                                    "caput": "Há suspeição do juiz:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1212,
                                            "texto": "Poderá o juiz declarar-se suspeito por motivo de foro íntimo, sem necessidade de declarar suas razões."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1214,
                                            "texto": "Será ilegítima a alegação de suspeição quando:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 1216,
                                                    "texto": "houver sido provocada por quem a alega;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 1218,
                                                    "texto": "a parte que a alega houver praticado ato que signifique manifesta aceitação do arguido."
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1204,
                                            "texto": "amigo íntimo ou inimigo de qualquer das partes ou de seus advogados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1206,
                                            "texto": "que receber presentes de pessoas que tiverem interesse na causa antes ou depois de iniciado o processo, que aconselhar alguma das partes acerca do objeto da causa ou que subministrar meios para atender às despesas do litígio;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1208,
                                            "texto": "quando qualquer das partes for sua credora ou devedora, de seu cônjuge ou companheiro ou de parentes destes, em linha reta até o terceiro grau, inclusive;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1210,
                                            "texto": "interessado no julgamento do processo em favor de qualquer das partes."
                                        }
                                    ]
                                },
                                {
                                    "numero": "146º",
                                    "rotulo": "Art. 146º.",
                                    "linha": 1220,
                                    "caput": "No prazo de 15 (quinze) dias, a contar do conhecimento do fato, a parte alegará o impedimento ou a suspeição, em petição específica dirigida ao juiz do processo, na qual indicará o fundamento da recusa, podendo instruí-la com documentos em que se fundar a alegação e com rol de testemunhas.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1222,
                                            "texto": "Se reconhecer o impedimento ou a suspeição ao receber a petição, o juiz ordenará imediatamente a remessa dos autos a seu substituto legal, caso contrário, determinará a autuação em apartado da petição e, no prazo de 15 (quinze) dias, apresentará suas razões, acompanhadas de documentos e de rol de testemunhas, se houver, ordenando a remessa do incidente ao tribunal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1224,
                                            "texto": "Distribuído o incidente, o relator deverá declarar os seus efeitos, sendo que, se o incidente for recebido:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 1226,
                                                    "texto": "sem efeito suspensivo, o processo voltará a correr;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 1228,
                                                    "texto": "com efeito suspensivo, o processo permanecerá suspenso até o julgamento do incidente."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1230,
                                            "texto": "Enquanto não for declarado o efeito em que é recebido o incidente ou quando este for recebido com efeito suspensivo, a tutela de urgência será requerida ao substituto legal."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1232,
                                            "texto": "Verificando que a alegação de impedimento ou de suspeição é improcedente, o tribunal rejeitá-la-á."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1234,
                                            "texto": "Acolhida a alegação, tratando-se de impedimento ou de manifesta suspeição, o tribunal condenará o juiz nas custas e remeterá os autos ao seu substituto legal, podendo o juiz recorrer da decisão."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 1236,
                                            "texto": "Reconhecido o impedimento ou a suspeição, o tribunal fixará o momento a partir do qual o juiz não poderia ter atuado."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 1238,
                                            "texto": "O tribunal decretará a nulidade dos atos do juiz, se praticados quando já presente o motivo de impedimento ou de suspeição."
                                        }
                                    ]
                                },
                                {
                                    "numero": "147º",
                                    "rotulo": "Art. 147º.",
                                    "linha": 1240,
                                    "caput": "Quando 2 (dois) ou mais juízes forem parentes, consanguíneos ou afins, em linha reta ou colateral, até o terceiro grau, inclusive, o primeiro que conhecer do processo impede que o outro nele atue, caso em que o segundo se escusará, remetendo os autos ao seu substituto legal."
                                },
                                {
                                    "numero": "148º",
                                    "rotulo": "Art. 148º.",
                                    "linha": 1242,
                                    "caput": "Aplicam-se os motivos de impedimento e de suspeição:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1250,
                                            "texto": "A parte interessada deverá arguir o impedimento ou a suspeição, em petição fundamentada e devidamente instruída, na primeira oportunidade em que lhe couber falar nos autos."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1252,
                                            "texto": "O juiz mandará processar o incidente em separado e sem suspensão do processo, ouvindo o arguido no prazo de 15 (quinze) dias e facultando a produção de prova, quando necessária."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1254,
                                            "texto": "Nos tribunais, a arguição a que se refere o § 1º será disciplinada pelo regimento interno."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1256,
                                            "texto": "O disposto nos §§ 1º e 2º não se aplica à arguição de impedimento ou de suspeição de testemunha."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1244,
                                            "texto": "ao membro do Ministério Público;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1246,
                                            "texto": "aos auxiliares da justiça;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1248,
                                            "texto": "aos demais sujeitos imparciais do processo."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DOS IMPEDIMENTOS E DA SUSPEIÇÃO",
                            "linhaTitulo": 1174
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 1258,
                            "artigos": [
                                {
                                    "numero": "149º",
                                    "rotulo": "Art. 149º.",
                                    "linha": 1262,
                                    "caput": "São auxiliares da Justiça, além de outros cujas atribuições sejam determinadas pelas normas de organização judiciária, o escrivão, o chefe de secretaria, o oficial de justiça, o perito, o depositário, o administrador, o intérprete, o tradutor, o mediador, o conciliador judicial, o partidor, o distribuidor, o contabilista e o regulador de avarias. Seção I"
                                },
                                {
                                    "numero": "150º",
                                    "rotulo": "Art. 150º.",
                                    "linha": 1268,
                                    "caput": "Em cada juízo haverá um ou mais ofícios de justiça, cujas atribuições serão determinadas pelas normas de organização judiciária.",
                                    "rubrica": "Do Escrivão, do Chefe de Secretaria e do Oficial de Justiça",
                                    "linhaRubrica": 1266
                                },
                                {
                                    "numero": "151º",
                                    "rotulo": "Art. 151º.",
                                    "linha": 1270,
                                    "caput": "Em cada comarca, seção ou subseção judiciária haverá, no mínimo, tantos oficiais de justiça quantos sejam os juízos."
                                },
                                {
                                    "numero": "152º",
                                    "rotulo": "Art. 152º.",
                                    "linha": 1272,
                                    "caput": "Incumbe ao escrivão ou ao chefe de secretaria:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1294,
                                            "texto": "O juiz titular editará ato a fim de regulamentar a atribuição prevista no inciso VI."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1296,
                                            "texto": "No impedimento do escrivão ou chefe de secretaria, o juiz convocará substituto e, não o havendo, nomeará pessoa idônea para o ato."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1274,
                                            "texto": "redigir, na forma legal, os ofícios, os mandados, as cartas precatórias e os demais atos que pertençam ao seu ofício;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1276,
                                            "texto": "efetivar as ordens judiciais, realizar citações e intimações, bem como praticar todos os demais atos que lhe forem atribuídos pelas normas de organização judiciária;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1278,
                                            "texto": "comparecer às audiências ou, não podendo fazê-lo, designar servidor para substituí-lo;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1280,
                                            "texto": "manter sob sua guarda e responsabilidade os autos, não permitindo que saiam do cartório, exceto:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 1282,
                                                    "texto": "quando tenham de seguir à conclusão do juiz;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 1284,
                                                    "texto": "com vista a procurador, à Defensoria Pública, ao Ministério Público ou à Fazenda Pública;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 1286,
                                                    "texto": "quando devam ser remetidos ao contabilista ou ao partidor;"
                                                },
                                                {
                                                    "letra": "d",
                                                    "rotulo": "d)",
                                                    "linha": 1288,
                                                    "texto": "quando forem remetidos a outro juízo em razão da modificação da competência;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1290,
                                            "texto": "fornecer certidão de qualquer ato ou termo do processo, independentemente de despacho, observadas as disposições referentes ao segredo de justiça;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 1292,
                                            "texto": "praticar, de ofício, os atos meramente ordinatórios."
                                        }
                                    ]
                                },
                                {
                                    "numero": "153º",
                                    "rotulo": "Art. 153º.",
                                    "linha": 1298,
                                    "caput": "O escrivão ou o chefe de secretaria atenderá, preferencialmente, à ordem cronológica de recebimento para publicação e efetivação dos pronunciamentos judiciais.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1300,
                                            "texto": "A lista de processos recebidos deverá ser disponibilizada, de forma permanente, para consulta pública."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1302,
                                            "texto": "Estão excluídos da regra do caput :",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 1304,
                                                    "texto": "os atos urgentes, assim reconhecidos pelo juiz no pronunciamento judicial a ser efetivado;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 1306,
                                                    "texto": "as preferências legais."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1308,
                                            "texto": "Após elaboração de lista própria, respeitar-se-ão a ordem cronológica de recebimento entre os atos urgentes e as preferências legais."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1310,
                                            "texto": "A parte que se considerar preterida na ordem cronológica poderá reclamar, nos próprios autos, ao juiz do processo, que requisitará informações ao servidor, a serem prestadas no prazo de 2 (dois) dias."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1312,
                                            "texto": "Constatada a preterição, o juiz determinará o imediato cumprimento do ato e a instauração de processo administrativo disciplinar contra o servidor."
                                        }
                                    ]
                                },
                                {
                                    "numero": "154º",
                                    "rotulo": "Art. 154º.",
                                    "linha": 1314,
                                    "caput": "Incumbe ao oficial de justiça:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1328,
                                            "texto": "Certificada a proposta de autocomposição prevista no inciso VI, o juiz ordenará a intimação da parte contrária para manifestar-se, no prazo de 5 (cinco) dias, sem prejuízo do andamento regular do processo, entendendo-se o silêncio como recusa."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1316,
                                            "texto": "fazer pessoalmente citações, prisões, penhoras, arrestos e demais diligências próprias do seu ofício, sempre que possível na presença de 2 (duas) testemunhas, certificando no mandado o ocorrido, com menção ao lugar, ao dia e à hora;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1318,
                                            "texto": "executar as ordens do juiz a que estiver subordinado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1320,
                                            "texto": "entregar o mandado em cartório após seu cumprimento;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1322,
                                            "texto": "auxiliar o juiz na manutenção da ordem;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1324,
                                            "texto": "efetuar avaliações, quando for o caso;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 1326,
                                            "texto": "certificar, em mandado, proposta de autocomposição apresentada por qualquer das partes, na ocasião de realização de ato de comunicação que lhe couber."
                                        }
                                    ]
                                },
                                {
                                    "numero": "155º",
                                    "rotulo": "Art. 155º.",
                                    "linha": 1330,
                                    "caput": "O escrivão, o chefe de secretaria e o oficial de justiça são responsáveis, civil e regressivamente, quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1332,
                                            "texto": "sem justo motivo, se recusarem a cumprir no prazo os atos impostos pela lei ou pelo juiz a que estão subordinados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1334,
                                            "texto": "praticarem ato nulo com dolo ou culpa. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "156º",
                                    "rotulo": "Art. 156º.",
                                    "linha": 1340,
                                    "caput": "O juiz será assistido por perito quando a prova do fato depender de conhecimento técnico ou científico.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1342,
                                            "texto": "Os peritos serão nomeados entre os profissionais legalmente habilitados e os órgãos técnicos ou científicos devidamente inscritos em cadastro mantido pelo tribunal ao qual o juiz está vinculado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1344,
                                            "texto": "Para formação do cadastro, os tribunais devem realizar consulta pública, por meio de divulgação na rede mundial de computadores ou em jornais de grande circulação, além de consulta direta a universidades, a conselhos de classe, ao Ministério Público, à Defensoria Pública e à Ordem dos Advogados do Brasil, para a indicação de profissionais ou de órgãos técnicos interessados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1346,
                                            "texto": "Os tribunais realizarão avaliações e reavaliações periódicas para manutenção do cadastro, considerando a formação profissional, a atualização do conhecimento e a experiência dos peritos interessados."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1348,
                                            "texto": "Para verificação de eventual impedimento ou motivo de suspeição, nos termos dos arts. 148 e 467, o órgão técnico ou científico nomeado para realização da perícia informará ao juiz os nomes e os dados de qualificação dos profissionais que participarão da atividade.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 148",
                                                    "href": "#art148",
                                                    "inicio": 80,
                                                    "fim": 89
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "467",
                                                    "href": "#art467",
                                                    "inicio": 92,
                                                    "fim": 95
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "148",
                                                    "href": "#art148",
                                                    "inicio": 86,
                                                    "fim": 89
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1350,
                                            "texto": "Na localidade onde não houver inscrito no cadastro disponibilizado pelo tribunal, a nomeação do perito é de livre escolha pelo juiz e deverá recair sobre profissional ou órgão técnico ou científico comprovadamente detentor do conhecimento necessário à realização da perícia."
                                        }
                                    ],
                                    "rubrica": "Do Perito",
                                    "linhaRubrica": 1338
                                },
                                {
                                    "numero": "157º",
                                    "rotulo": "Art. 157º.",
                                    "linha": 1352,
                                    "caput": "O perito tem o dever de cumprir o ofício no prazo que lhe designar o juiz, empregando toda sua diligência, podendo escusar-se do encargo alegando motivo legítimo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1354,
                                            "texto": "A escusa será apresentada no prazo de 15 (quinze) dias, contado da intimação, da suspeição ou do impedimento supervenientes, sob pena de renúncia ao direito a alegá-la."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1356,
                                            "texto": "Será organizada lista de peritos na vara ou na secretaria, com disponibilização dos documentos exigidos para habilitação à consulta de interessados, para que a nomeação seja distribuída de modo equitativo, observadas a capacidade técnica e a área de conhecimento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "158º",
                                    "rotulo": "Art. 158º.",
                                    "linha": 1358,
                                    "caput": "O perito que, por dolo ou culpa, prestar informações inverídicas responderá pelos prejuízos que causar à parte e ficará inabilitado para atuar em outras perícias no prazo de 2 (dois) a 5 (cinco) anos, independentemente das demais sanções previstas em lei, devendo o juiz comunicar o fato ao respectivo órgão de classe para adoção das medidas que entender cabíveis. Seção III"
                                },
                                {
                                    "numero": "159º",
                                    "rotulo": "Art. 159º.",
                                    "linha": 1364,
                                    "caput": "A guarda e a conservação de bens penhorados, arrestados, sequestrados ou arrecadados serão confiadas a depositário ou a administrador, não dispondo a lei de outro modo.",
                                    "rubrica": "Do Depositário e do Administrador",
                                    "linhaRubrica": 1362
                                },
                                {
                                    "numero": "160º",
                                    "rotulo": "Art. 160º.",
                                    "linha": 1366,
                                    "caput": "Por seu trabalho o depositário ou o administrador perceberá remuneração que o juiz fixará levando em conta a situação dos bens, ao tempo do serviço e às dificuldades de sua execução.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1368,
                                            "texto": "O juiz poderá nomear um ou mais prepostos por indicação do depositário ou do administrador."
                                        }
                                    ]
                                },
                                {
                                    "numero": "161º",
                                    "rotulo": "Art. 161º.",
                                    "linha": 1370,
                                    "caput": "O depositário ou o administrador responde pelos prejuízos que, por dolo ou culpa, causar à parte, perdendo a remuneração que lhe foi arbitrada, mas tem o direito a haver o que legitimamente despendeu no exercício do encargo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1372,
                                            "texto": "O depositário infiel responde civilmente pelos prejuízos causados, sem prejuízo de sua responsabilidade penal e da imposição de sanção por ato atentatório à dignidade da justiça. Seção IV"
                                        }
                                    ]
                                },
                                {
                                    "numero": "162º",
                                    "rotulo": "Art. 162º.",
                                    "linha": 1378,
                                    "caput": "O juiz nomeará intérprete ou tradutor quando necessário para:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1380,
                                            "texto": "traduzir documento redigido em língua estrangeira;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1382,
                                            "texto": "verter para o português as declarações das partes e das testemunhas que não conhecerem o idioma nacional;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1384,
                                            "texto": "realizar a interpretação simultânea dos depoimentos das partes e testemunhas com deficiência auditiva que se comuniquem por meio da Língua Brasileira de Sinais, ou equivalente, quando assim for solicitado."
                                        }
                                    ],
                                    "rubrica": "Do Intérprete e do Tradutor",
                                    "linhaRubrica": 1376
                                },
                                {
                                    "numero": "163º",
                                    "rotulo": "Art. 163º.",
                                    "linha": 1386,
                                    "caput": "Não pode ser intérprete ou tradutor quem:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1388,
                                            "texto": "não tiver a livre administração de seus bens;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1390,
                                            "texto": "for arrolado como testemunha ou atuar como perito no processo;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1392,
                                            "texto": "estiver inabilitado para o exercício da profissão por sentença penal condenatória, enquanto durarem seus efeitos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "164º",
                                    "rotulo": "Art. 164º.",
                                    "linha": 1394,
                                    "caput": "O intérprete ou tradutor, oficial ou não, é obrigado a desempenhar seu ofício, aplicando-se-lhe o disposto nos arts. 157 e 158. Seção V",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 157 e 158",
                                            "href": "#art157",
                                            "inicio": 111,
                                            "fim": 126
                                        }
                                    ]
                                },
                                {
                                    "numero": "165º",
                                    "rotulo": "Art. 165º.",
                                    "linha": 1400,
                                    "caput": "Os tribunais criarão centros judiciários de solução consensual de conflitos, responsáveis pela realização de sessões e audiências de conciliação e mediação e pelo desenvolvimento de programas destinados a auxiliar, orientar e estimular a autocomposição.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1402,
                                            "texto": "A composição e a organização dos centros serão definidas pelo respectivo tribunal, observadas as normas do Conselho Nacional de Justiça."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1404,
                                            "texto": "O conciliador, que atuará preferencialmente nos casos em que não houver vínculo anterior entre as partes, poderá sugerir soluções para o litígio, sendo vedada a utilização de qualquer tipo de constrangimento ou intimidação para que as partes conciliem."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1406,
                                            "texto": "O mediador, que atuará preferencialmente nos casos em que houver vínculo anterior entre as partes, auxiliará aos interessados a compreender as questões e os interesses em conflito, de modo que eles possam, pelo restabelecimento da comunicação, identificar, por si próprios, soluções consensuais que gerem benefícios mútuos."
                                        }
                                    ],
                                    "rubrica": "Dos Conciliadores e Mediadores Judiciais",
                                    "linhaRubrica": 1398
                                },
                                {
                                    "numero": "166º",
                                    "rotulo": "Art. 166º.",
                                    "linha": 1408,
                                    "caput": "A conciliação e a mediação são informadas pelos princípios da independência, da imparcialidade, da autonomia da vontade, da confidencialidade, da oralidade, da informalidade e da decisão informada.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1410,
                                            "texto": "A confidencialidade estende-se a todas as informações produzidas no curso do procedimento, cujo teor não poderá ser utilizado para fim diverso daquele previsto por expressa deliberação das partes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1412,
                                            "texto": "Em razão do dever de sigilo, inerente às suas funções, o conciliador e o mediador, assim como os membros de suas equipes, não poderão divulgar ou depor acerca de fatos ou elementos oriundos da conciliação ou da mediação."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1414,
                                            "texto": "Admite-se a aplicação de técnicas negociais, com o objetivo de proporcionar ambiente favorável à autocomposição."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1416,
                                            "texto": "A mediação e a conciliação serão regidas conforme a livre autonomia dos interessados, inclusive no que diz respeito à definição das regras procedimentais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "167º",
                                    "rotulo": "Art. 167º.",
                                    "linha": 1418,
                                    "caput": "Os conciliadores, os mediadores e as câmaras privadas de conciliação e mediação serão inscritos em cadastro nacional e em cadastro de tribunal de justiça ou de tribunal regional federal, que manterá registro de profissionais habilitados, com indicação de sua área profissional.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1420,
                                            "texto": "Preenchendo o requisito da capacitação mínima, por meio de curso realizado por entidade credenciada, conforme parâmetro curricular definido pelo Conselho Nacional de Justiça em conjunto com o Ministério da Justiça, o conciliador ou o mediador, com o respectivo certificado, poderá requerer sua inscrição no cadastro nacional e no cadastro de tribunal de justiça ou de tribunal regional federal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1422,
                                            "texto": "Efetivado o registro, que poderá ser precedido de concurso público, o tribunal remeterá ao diretor do foro da comarca, seção ou subseção judiciária onde atuará o conciliador ou o mediador os dados necessários para que seu nome passe a constar da respectiva lista, a ser observada na distribuição alternada e aleatória, respeitado o princípio da igualdade dentro da mesma área de atuação profissional."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1424,
                                            "texto": "Do credenciamento das câmaras e do cadastro de conciliadores e mediadores constarão todos os dados relevantes para a sua atuação, tais como o número de processos de que participou, o sucesso ou insucesso da atividade, a matéria sobre a qual versou a controvérsia, bem como outros dados que o tribunal julgar relevantes."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1426,
                                            "texto": "Os dados colhidos na forma do § 3º serão classificados sistematicamente pelo tribunal, que os publicará, ao menos anualmente, para conhecimento da população e para fins estatísticos e de avaliação da conciliação, da mediação, das câmaras privadas de conciliação e de mediação, dos conciliadores e dos mediadores."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1428,
                                            "texto": "Os conciliadores e mediadores judiciais cadastrados na forma do caput , se advogados, estarão impedidos de exercer a advocacia nos juízos em que desempenhem suas funções."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 1430,
                                            "texto": "O tribunal poderá optar pela criação de quadro próprio de conciliadores e mediadores, a ser preenchido por concurso público de provas e títulos, observadas as disposições deste Capítulo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "168º",
                                    "rotulo": "Art. 168º.",
                                    "linha": 1432,
                                    "caput": "As partes podem escolher, de comum acordo, o conciliador, o mediador ou a câmara privada de conciliação e de mediação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1434,
                                            "texto": "O conciliador ou mediador escolhido pelas partes poderá ou não estar cadastrado no tribunal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1436,
                                            "texto": "Inexistindo acordo quanto à escolha do mediador ou conciliador, haverá distribuição entre aqueles cadastrados no registro do tribunal, observada a respectiva formação."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1438,
                                            "texto": "Sempre que recomendável, haverá a designação de mais de um mediador ou conciliador."
                                        }
                                    ]
                                },
                                {
                                    "numero": "169º",
                                    "rotulo": "Art. 169º.",
                                    "linha": 1440,
                                    "caput": "Ressalvada a hipótese do art. 167, § 6º, o conciliador e o mediador receberão pelo seu trabalho remuneração prevista em tabela fixada pelo tribunal, conforme parâmetros estabelecidos pelo Conselho Nacional de Justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1442,
                                            "texto": "A mediação e a conciliação podem ser realizadas como trabalho voluntário, observada a legislação pertinente e a regulamentação do tribunal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1444,
                                            "texto": "Os tribunais determinarão o percentual de audiências não remuneradas que deverão ser suportadas pelas câmaras privadas de conciliação e mediação, com o fim de atender aos processos em que deferida gratuidade da justiça, como contrapartida de seu credenciamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "170º",
                                    "rotulo": "Art. 170º.",
                                    "linha": 1446,
                                    "caput": "No caso de impedimento, o conciliador ou mediador o comunicará imediatamente, de preferência por meio eletrônico, e devolverá os autos ao juiz do processo ou ao coordenador do centro judiciário de solução de conflitos, devendo este realizar nova distribuição.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1448,
                                            "texto": "Se a causa de impedimento for apurada quando já iniciado o procedimento, a atividade será interrompida, lavrando-se ata com relatório do ocorrido e solicitação de distribuição para novo conciliador ou mediador."
                                        }
                                    ]
                                },
                                {
                                    "numero": "171º",
                                    "rotulo": "Art. 171º.",
                                    "linha": 1450,
                                    "caput": "No caso de impossibilidade temporária do exercício da função, o conciliador ou mediador informará o fato ao centro, preferencialmente por meio eletrônico, para que, durante o período em que perdurar a impossibilidade, não haja novas distribuições"
                                },
                                {
                                    "numero": "172º",
                                    "rotulo": "Art. 172º.",
                                    "linha": 1452,
                                    "caput": "O conciliador e o mediador ficam impedidos, pelo prazo de 1 (um) ano, contado do término da última audiência em que atuaram, de assessorar, representar ou patrocinar qualquer das partes."
                                },
                                {
                                    "numero": "173º",
                                    "rotulo": "Art. 173º.",
                                    "linha": 1454,
                                    "caput": "Será excluído do cadastro de conciliadores e mediadores aquele que:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1460,
                                            "texto": "Os casos previstos neste artigo serão apurados em processo administrativo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1462,
                                            "texto": "O juiz do processo ou o juiz coordenador do centro de conciliação e mediação, se houver, verificando atuação inadequada do mediador ou conciliador, poderá afastá-lo de suas atividades por até 180 (cento e oitenta) dias, por decisão fundamentada, informando o fato imediatamente ao tribunal para instauração do respectivo processo administrativo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1456,
                                            "texto": "agir com dolo ou culpa na condução da conciliação ou da mediação sob sua responsabilidade ou violar qualquer dos deveres decorrentes do art. 166, §§ 1º e 2º;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1458,
                                            "texto": "atuar em procedimento de mediação ou conciliação, apesar de impedido ou suspeito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "174º",
                                    "rotulo": "Art. 174º.",
                                    "linha": 1464,
                                    "caput": "A União, os Estados, o Distrito Federal e os Municípios criarão câmaras de mediação e conciliação, com atribuições relacionadas à solução consensual de conflitos no âmbito administrativo, tais como:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1466,
                                            "texto": "dirimir conflitos envolvendo órgãos e entidades da administração pública;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1468,
                                            "texto": "avaliar a admissibilidade dos pedidos de resolução de conflitos, por meio de conciliação, no âmbito da administração pública;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1470,
                                            "texto": "promover, quando couber, a celebração de termo de ajustamento de conduta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "175º",
                                    "rotulo": "Art. 175º.",
                                    "linha": 1472,
                                    "caput": "As disposições desta Seção não excluem outras formas de conciliação e mediação extrajudiciais vinculadas a órgãos institucionais ou realizadas por intermédio de profissionais independentes, que poderão ser regulamentadas por lei específica.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1474,
                                            "texto": "Os dispositivos desta Seção aplicam-se, no que couber, às câmaras privadas de conciliação e mediação."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DOS AUXILIARES DA JUSTIÇA",
                            "linhaTitulo": 1260
                        }
                    ],
                    "titulo": "DO JUIZ E DOS AUXILIARES DA JUSTIÇA",
                    "linhaTitulo": 1126
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO V",
                    "linha": 1476,
                    "artigos": [
                        {
                            "numero": "176º",
                            "rotulo": "Art. 176º.",
                            "linha": 1480,
                            "caput": "O Ministério Público atuará na defesa da ordem jurídica, do regime democrático e dos interesses e direitos sociais e individuais indisponíveis."
                        },
                        {
                            "numero": "177º",
                            "rotulo": "Art. 177º.",
                            "linha": 1482,
                            "caput": "O Ministério Público exercerá o direito de ação em conformidade com suas atribuições constitucionais."
                        },
                        {
                            "numero": "178º",
                            "rotulo": "Art. 178º.",
                            "linha": 1484,
                            "caput": "O Ministério Público será intimado para, no prazo de 30 (trinta) dias, intervir como fiscal da ordem jurídica nas hipóteses previstas em lei ou na Constituição Federal e nos processos que envolvam:",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 1492,
                                    "texto": "A participação da Fazenda Pública não configura, por si só, hipótese de intervenção do Ministério Público."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 1486,
                                    "texto": "interesse público ou social;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 1488,
                                    "texto": "interesse de incapaz;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 1490,
                                    "texto": "litígios coletivos pela posse de terra rural ou urbana."
                                }
                            ]
                        },
                        {
                            "numero": "179º",
                            "rotulo": "Art. 179º.",
                            "linha": 1494,
                            "caput": "Nos casos de intervenção como fiscal da ordem jurídica, o Ministério Público:",
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 1496,
                                    "texto": "terá vista dos autos depois das partes, sendo intimado de todos os atos do processo;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 1498,
                                    "texto": "poderá produzir provas, requerer as medidas processuais pertinentes e recorrer."
                                }
                            ]
                        },
                        {
                            "numero": "180º",
                            "rotulo": "Art. 180º.",
                            "linha": 1500,
                            "caput": "O Ministério Público gozará de prazo em dobro para manifestar-se nos autos, que terá início a partir de sua intimação pessoal, nos termos do art. 183, § 1º.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 1502,
                                    "texto": "Findo o prazo para manifestação do Ministério Público sem o oferecimento de parecer, o juiz requisitará os autos e dará andamento ao processo."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 1504,
                                    "texto": "Não se aplica o benefício da contagem em dobro quando a lei estabelecer, de forma expressa, prazo próprio para o Ministério Público."
                                }
                            ]
                        },
                        {
                            "numero": "181º",
                            "rotulo": "Art. 181º.",
                            "linha": 1506,
                            "caput": "O membro do Ministério Público será civil e regressivamente responsável quando agir com dolo ou fraude no exercício de suas funções."
                        }
                    ],
                    "titulo": "DO MINISTÉRIO PÚBLICO",
                    "linhaTitulo": 1478
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO VI",
                    "linha": 1508,
                    "artigos": [
                        {
                            "numero": "182º",
                            "rotulo": "Art. 182º.",
                            "linha": 1511,
                            "caput": "Incumbe à Advocacia Pública, na forma da lei, defender e promover os interesses públicos da União, dos Estados, do Distrito Federal e dos Municípios, por meio da representação judicial, em todos os âmbitos federativos, das pessoas jurídicas de direito público que integram a administração direta e indireta."
                        },
                        {
                            "numero": "183º",
                            "rotulo": "Art. 183º.",
                            "linha": 1513,
                            "caput": "A União, os Estados, o Distrito Federal, os Municípios e suas respectivas autarquias e fundações de direito público gozarão de prazo em dobro para todas as suas manifestações processuais, cuja contagem terá início a partir da intimação pessoal.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 1515,
                                    "texto": "A intimação pessoal far-se-á por carga, remessa ou meio eletrônico."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 1517,
                                    "texto": "Não se aplica o benefício da contagem em dobro quando a lei estabelecer, de forma expressa, prazo próprio para o ente público."
                                }
                            ]
                        },
                        {
                            "numero": "184º",
                            "rotulo": "Art. 184º.",
                            "linha": 1519,
                            "caput": "O membro da Advocacia Pública será civil e regressivamente responsável quando agir com dolo ou fraude no exercício de suas funções"
                        }
                    ],
                    "titulo": "DA ADVOCACIA PÚBLICA",
                    "linhaTitulo": 1509
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO VII",
                    "linha": 1521,
                    "artigos": [
                        {
                            "numero": "185º",
                            "rotulo": "Art. 185º.",
                            "linha": 1524,
                            "caput": "A Defensoria Pública exercerá a orientação jurídica, a promoção dos direitos humanos e a defesa dos direitos individuais e coletivos dos necessitados, em todos os graus, de forma integral e gratuita."
                        },
                        {
                            "numero": "186º",
                            "rotulo": "Art. 186º.",
                            "linha": 1526,
                            "caput": "A Defensoria Pública gozará de prazo em dobro para todas as suas manifestações processuais.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 1528,
                                    "texto": "O prazo tem início com a intimação pessoal do defensor público, nos termos do art. 183, § 1º."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 1530,
                                    "texto": "A requerimento da Defensoria Pública, o juiz determinará a intimação pessoal da parte patrocinada quando o ato processual depender de providência ou informação que somente por ela possa ser realizada ou prestada."
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 1532,
                                    "texto": "O disposto no caput aplica-se aos escritórios de prática jurídica das faculdades de Direito reconhecidas na forma da lei e às entidades que prestam assistência jurídica gratuita em razão de convênios firmados com a Defensoria Pública."
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 1534,
                                    "texto": "Não se aplica o benefício da contagem em dobro quando a lei estabelecer, de forma expressa, prazo próprio para a Defensoria Pública."
                                }
                            ]
                        },
                        {
                            "numero": "187º",
                            "rotulo": "Art. 187º.",
                            "linha": 1536,
                            "caput": "O membro da Defensoria Pública será civil e regressivamente responsável quando agir com dolo ou fraude no exercício de suas funções."
                        }
                    ],
                    "titulo": "DA DEFENSORIA PÚBLICA",
                    "linhaTitulo": 1522
                }
            ],
            "titulo": "DOS SUJEITOS DO PROCESSO",
            "linhaTitulo": 490
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO IV",
            "linha": 1538,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 1541,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 1544,
                            "artigos": [
                                {
                                    "numero": "188º",
                                    "rotulo": "Art. 188º.",
                                    "linha": 1550,
                                    "caput": "Os atos e os termos processuais independem de forma determinada, salvo quando a lei expressamente a exigir, considerando-se válidos os que, realizados de outro modo, lhe preencham a finalidade essencial.",
                                    "rubrica": "Dos Atos em Geral",
                                    "linhaRubrica": 1548
                                },
                                {
                                    "numero": "189º",
                                    "rotulo": "Art. 189º.",
                                    "linha": 1552,
                                    "caput": "Os atos processuais são públicos, todavia tramitam em segredo de justiça os processos:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1562,
                                            "texto": "O direito de consultar os autos de processo que tramite em segredo de justiça e de pedir certidões de seus atos é restrito às partes e aos seus procuradores."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1564,
                                            "texto": "O terceiro que demonstrar interesse jurídico pode requerer ao juiz certidão do dispositivo da sentença, bem como de inventário e de partilha resultantes de divórcio ou separação."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1554,
                                            "texto": "em que o exija o interesse público ou social;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1556,
                                            "texto": "que versem sobre casamento, separação de corpos, divórcio, separação, união estável, filiação, alimentos e guarda de crianças e adolescentes;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1558,
                                            "texto": "em que constem dados protegidos pelo direito constitucional à intimidade;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1560,
                                            "texto": "que versem sobre arbitragem, inclusive sobre cumprimento de carta arbitral, desde que a confidencialidade estipulada na arbitragem seja comprovada perante o juízo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "190º",
                                    "rotulo": "Art. 190º.",
                                    "linha": 1566,
                                    "caput": "Versando o processo sobre direitos que admitam autocomposição, é lícito às partes plenamente capazes estipular mudanças no procedimento para ajustá-lo às especificidades da causa e convencionar sobre os seus ônus, poderes, faculdades e deveres processuais, antes ou durante o processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1568,
                                            "texto": "De ofício ou a requerimento, o juiz controlará a validade das convenções previstas neste artigo, recusando-lhes aplicação somente nos casos de nulidade ou de inserção abusiva em contrato de adesão ou em que alguma parte se encontre em manifesta situação de vulnerabilidade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "191º",
                                    "rotulo": "Art. 191º.",
                                    "linha": 1570,
                                    "caput": "De comum acordo, o juiz e as partes podem fixar calendário para a prática dos atos processuais, quando for o caso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1572,
                                            "texto": "O calendário vincula as partes e o juiz, e os prazos nele previstos somente serão modificados em casos excepcionais, devidamente justificados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1574,
                                            "texto": "Dispensa-se a intimação das partes para a prática de ato processual ou a realização de audiência cujas datas tiverem sido designadas no calendário."
                                        }
                                    ]
                                },
                                {
                                    "numero": "192º",
                                    "rotulo": "Art. 192º.",
                                    "linha": 1576,
                                    "caput": "Em todos os atos e termos do processo é obrigatório o uso da língua portuguesa.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1578,
                                            "texto": "O documento redigido em língua estrangeira somente poderá ser juntado aos autos quando acompanhado de versão para a língua portuguesa tramitada por via diplomática ou pela autoridade central, ou firmada por tradutor juramentado. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "193º",
                                    "rotulo": "Art. 193º.",
                                    "linha": 1584,
                                    "caput": "Os atos processuais podem ser total ou parcialmente digitais, de forma a permitir que sejam produzidos, comunicados, armazenados e validados por meio eletrônico, na forma da lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1586,
                                            "texto": "O disposto nesta Seção aplica-se, no que for cabível, à prática de atos notariais e de registro."
                                        }
                                    ],
                                    "rubrica": "Da Prática Eletrônica de Atos Processuais",
                                    "linhaRubrica": 1582
                                },
                                {
                                    "numero": "194º",
                                    "rotulo": "Art. 194º.",
                                    "linha": 1588,
                                    "caput": "Os sistemas de automação processual respeitarão a publicidade dos atos, o acesso e a participação das partes e de seus procuradores, inclusive nas audiências e sessões de julgamento, observadas as garantias da disponibilidade, independência da plataforma computacional, acessibilidade e interoperabilidade dos sistemas, serviços, dados e informações que o Poder Judiciário administre no exercício de suas funções."
                                },
                                {
                                    "numero": "195º",
                                    "rotulo": "Art. 195º.",
                                    "linha": 1590,
                                    "caput": "O registro de ato processual eletrônico deverá ser feito em padrões abertos, que atenderão aos requisitos de autenticidade, integridade, temporalidade, não repúdio, conservação e, nos casos que tramitem em segredo de justiça, confidencialidade, observada a infraestrutura de chaves públicas unificada nacionalmente, nos termos da lei."
                                },
                                {
                                    "numero": "196º",
                                    "rotulo": "Art. 196º.",
                                    "linha": 1592,
                                    "caput": "Compete ao Conselho Nacional de Justiça e, supletivamente, aos tribunais, regulamentar a prática e a comunicação oficial de atos processuais por meio eletrônico e velar pela compatibilidade dos sistemas, disciplinando a incorporação progressiva de novos avanços tecnológicos e editando, para esse fim, os atos que forem necessários, respeitadas as normas fundamentais deste Código."
                                },
                                {
                                    "numero": "197º",
                                    "rotulo": "Art. 197º.",
                                    "linha": 1594,
                                    "caput": "Os tribunais divulgarão as informações constantes de seu sistema de automação em página própria na rede mundial de computadores, gozando a divulgação de presunção de veracidade e confiabilidade.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1596,
                                            "texto": "Nos casos de problema técnico do sistema e de erro ou omissão do auxiliar da justiça responsável pelo registro dos andamentos, poderá ser configurada a justa causa prevista no art. 223, caput e § 1º.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 223,",
                                                    "href": "#art223",
                                                    "inicio": 176,
                                                    "fim": 185
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "198º",
                                    "rotulo": "Art. 198º.",
                                    "linha": 1598,
                                    "caput": "As unidades do Poder Judiciário deverão manter gratuitamente, à disposição dos interessados, equipamentos necessários à prática de atos processuais e à consulta e ao acesso ao sistema e aos documentos dele constantes.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1600,
                                            "texto": "Será admitida a prática de atos por meio não eletrônico no local onde não estiverem disponibilizados os equipamentos previstos no caput ."
                                        }
                                    ]
                                },
                                {
                                    "numero": "199º",
                                    "rotulo": "Art. 199º.",
                                    "linha": 1602,
                                    "caput": "As unidades do Poder Judiciário assegurarão às pessoas com deficiência acessibilidade aos seus sítios na rede mundial de computadores, ao meio eletrônico de prática de atos judiciais, à comunicação eletrônica dos atos processuais e à assinatura eletrônica. Seção III"
                                },
                                {
                                    "numero": "200º",
                                    "rotulo": "Art. 200º.",
                                    "linha": 1607,
                                    "caput": "Os atos das partes consistentes em declarações unilaterais ou bilaterais de vontade produzem imediatamente a constituição, modificação ou extinção de direitos processuais.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1609,
                                            "texto": "A desistência da ação só produzirá efeitos após homologação judicial."
                                        }
                                    ],
                                    "rubrica": "Dos Atos das Partes",
                                    "linhaRubrica": 1605
                                },
                                {
                                    "numero": "201º",
                                    "rotulo": "Art. 201º.",
                                    "linha": 1611,
                                    "caput": "As partes poderão exigir recibo de petições, arrazoados, papéis e documentos que entregarem em cartório."
                                },
                                {
                                    "numero": "202º",
                                    "rotulo": "Art. 202º.",
                                    "linha": 1613,
                                    "caput": "É vedado lançar nos autos cotas marginais ou interlineares, as quais o juiz mandará riscar, impondo a quem as escrever multa correspondente à metade do salário-mínimo. Seção IV"
                                },
                                {
                                    "numero": "203º",
                                    "rotulo": "Art. 203º.",
                                    "linha": 1618,
                                    "caput": "Os pronunciamentos do juiz consistirão em sentenças, decisões interlocutórias e despachos.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1620,
                                            "texto": "Ressalvadas as disposições expressas dos procedimentos especiais, sentença é o pronunciamento por meio do qual o juiz, com fundamento nos arts. 485 e 487, põe fim à fase cognitiva do procedimento comum, bem como extingue a execução.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 485",
                                                    "href": "#art485",
                                                    "inicio": 138,
                                                    "fim": 147
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "487",
                                                    "href": "#art487",
                                                    "inicio": 150,
                                                    "fim": 153
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1622,
                                            "texto": "Decisão interlocutória é todo pronunciamento judicial de natureza decisória que não se enquadre no § 1º."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1624,
                                            "texto": "São despachos todos os demais pronunciamentos do juiz praticados no processo, de ofício ou a requerimento da parte."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1626,
                                            "texto": "Os atos meramente ordinatórios, como a juntada e a vista obrigatória, independem de despacho, devendo ser praticados de ofício pelo servidor e revistos pelo juiz quando necessário."
                                        }
                                    ],
                                    "rubrica": "Dos Pronunciamentos do Juiz",
                                    "linhaRubrica": 1616
                                },
                                {
                                    "numero": "204º",
                                    "rotulo": "Art. 204º.",
                                    "linha": 1628,
                                    "caput": "Acórdão é o julgamento colegiado proferido pelos tribunais."
                                },
                                {
                                    "numero": "205º",
                                    "rotulo": "Art. 205º.",
                                    "linha": 1630,
                                    "caput": "Os despachos, as decisões, as sentenças e os acórdãos serão redigidos, datados e assinados pelos juízes.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1632,
                                            "texto": "Quando os pronunciamentos previstos no caput forem proferidos oralmente, o servidor os documentará, submetendo-os aos juízes para revisão e assinatura."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1634,
                                            "texto": "A assinatura dos juízes, em todos os graus de jurisdição, pode ser feita eletronicamente, na forma da lei."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1636,
                                            "texto": "Os despachos, as decisões interlocutórias, o dispositivo das sentenças e a ementa dos acórdãos serão publicados no Diário de Justiça Eletrônico. Seção V"
                                        }
                                    ]
                                },
                                {
                                    "numero": "206º",
                                    "rotulo": "Art. 206º.",
                                    "linha": 1641,
                                    "caput": "Ao receber a petição inicial de processo, o escrivão ou o chefe de secretaria a autuará, mencionando o juízo, a natureza do processo, o número de seu registro, os nomes das partes e a data de seu início, e procederá do mesmo modo em relação aos volumes em formação.",
                                    "rubrica": "Dos Atos do Escrivão ou do Chefe de Secretaria",
                                    "linhaRubrica": 1639
                                },
                                {
                                    "numero": "207º",
                                    "rotulo": "Art. 207º.",
                                    "linha": 1643,
                                    "caput": "O escrivão ou o chefe de secretaria numerará e rubricará todas as folhas dos autos.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1645,
                                            "texto": "À parte, ao procurador, ao membro do Ministério Público, ao defensor público e aos auxiliares da justiça é facultado rubricar as folhas correspondentes aos atos em que intervierem."
                                        }
                                    ]
                                },
                                {
                                    "numero": "208º",
                                    "rotulo": "Art. 208º.",
                                    "linha": 1647,
                                    "caput": "Os termos de juntada, vista, conclusão e outros semelhantes constarão de notas datadas e rubricadas pelo escrivão ou pelo chefe de secretaria."
                                },
                                {
                                    "numero": "209º",
                                    "rotulo": "Art. 209º.",
                                    "linha": 1649,
                                    "caput": "Os atos e os termos do processo serão assinados pelas pessoas que neles intervierem, todavia, quando essas não puderem ou não quiserem firmá-los, o escrivão ou o chefe de secretaria certificará a ocorrência.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1651,
                                            "texto": "Quando se tratar de processo total ou parcialmente documentado em autos eletrônicos, os atos processuais praticados na presença do juiz poderão ser produzidos e armazenados de modo integralmente digital em arquivo eletrônico inviolável, na forma da lei, mediante registro em termo, que será assinado digitalmente pelo juiz e pelo escrivão ou chefe de secretaria, bem como pelos advogados das partes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1653,
                                            "texto": "Na hipótese do § 1º, eventuais contradições na transcrição deverão ser suscitadas oralmente no momento de realização do ato, sob pena de preclusão, devendo o juiz decidir de plano e ordenar o registro, no termo, da alegação e da decisão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "210º",
                                    "rotulo": "Art. 210º.",
                                    "linha": 1655,
                                    "caput": "É lícito o uso da taquigrafia, da estenotipia ou de outro método idôneo em qualquer juízo ou tribunal."
                                },
                                {
                                    "numero": "211º",
                                    "rotulo": "Art. 211º.",
                                    "linha": 1657,
                                    "caput": "Não se admitem nos atos e termos processuais espaços em branco, salvo os que forem inutilizados, assim como entrelinhas, emendas ou rasuras, exceto quando expressamente ressalvadas."
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA FORMA DOS ATOS PROCESSUAIS",
                            "linhaTitulo": 1545
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 1659,
                            "artigos": [
                                {
                                    "numero": "212º",
                                    "rotulo": "Art. 212º.",
                                    "linha": 1665,
                                    "caput": "Os atos processuais serão realizados em dias úteis, das 6 (seis) às 20 (vinte) horas.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1667,
                                            "texto": "Serão concluídos após as 20 (vinte) horas os atos iniciados antes, quando o adiamento prejudicar a diligência ou causar grave dano."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1669,
                                            "texto": "Independentemente de autorização judicial, as citações, intimações e penhoras poderão realizar-se no período de férias forenses, onde as houver, e nos feriados ou dias úteis fora do horário estabelecido neste artigo, observado o disposto no art. 5º, inciso XI, da Constituição Federal ."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1671,
                                            "texto": "Quando o ato tiver de ser praticado por meio de petição em autos não eletrônicos, essa deverá ser protocolada no horário de funcionamento do fórum ou tribunal, conforme o disposto na lei de organização judiciária local."
                                        }
                                    ],
                                    "rubrica": "Do Tempo",
                                    "linhaRubrica": 1663
                                },
                                {
                                    "numero": "213º",
                                    "rotulo": "Art. 213º.",
                                    "linha": 1673,
                                    "caput": "A prática eletrônica de ato processual pode ocorrer em qualquer horário até as 24 (vinte e quatro) horas do último dia do prazo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1675,
                                            "texto": "O horário vigente no juízo perante o qual o ato deve ser praticado será considerado para fins de atendimento do prazo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "214º",
                                    "rotulo": "Art. 214º.",
                                    "linha": 1677,
                                    "caput": "Durante as férias forenses e nos feriados, não se praticarão atos processuais, excetuando-se:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1679,
                                            "texto": "os atos previstos no art. 212, § 2º;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1681,
                                            "texto": "a tutela de urgência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "215º",
                                    "rotulo": "Art. 215º.",
                                    "linha": 1683,
                                    "caput": "Processam-se durante as férias forenses, onde as houver, e não se suspendem pela superveniência delas:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1685,
                                            "texto": "os procedimentos de jurisdição voluntária e os necessários à conservação de direitos, quando puderem ser prejudicados pelo adiamento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1687,
                                            "texto": "a ação de alimentos e os processos de nomeação ou remoção de tutor e curador;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1689,
                                            "texto": "os processos que a lei determinar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "216º",
                                    "rotulo": "Art. 216º.",
                                    "linha": 1691,
                                    "caput": "Além dos declarados em lei, são feriados, para efeito forense, os sábados, os domingos e os dias em que não haja expediente forense. Seção II"
                                },
                                {
                                    "numero": "217º",
                                    "rotulo": "Art. 217º.",
                                    "linha": 1696,
                                    "caput": "Os atos processuais realizar-se-ão ordinariamente na sede do juízo, ou, excepcionalmente, em outro lugar em razão de deferência, de interesse da justiça, da natureza do ato ou de obstáculo arguido pelo interessado e acolhido pelo juiz.",
                                    "rubrica": "Do Lugar",
                                    "linhaRubrica": 1694
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DO TEMPO E DO LUGAR DOS ATOS PROCESSUAIS",
                            "linhaTitulo": 1660
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 1698,
                            "artigos": [
                                {
                                    "numero": "218º",
                                    "rotulo": "Art. 218º.",
                                    "linha": 1704,
                                    "caput": "Os atos processuais serão realizados nos prazos prescritos em lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1706,
                                            "texto": "Quando a lei for omissa, o juiz determinará os prazos em consideração à complexidade do ato."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1708,
                                            "texto": "Quando a lei ou o juiz não determinar prazo, as intimações somente obrigarão a comparecimento após decorridas 48 (quarenta e oito) horas."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1710,
                                            "texto": "Inexistindo preceito legal ou prazo determinado pelo juiz, será de 5 (cinco) dias o prazo para a prática de ato processual a cargo da parte."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1712,
                                            "texto": "Será considerado tempestivo o ato praticado antes do termo inicial do prazo."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 1702
                                },
                                {
                                    "numero": "219º",
                                    "rotulo": "Art. 219º.",
                                    "linha": 1714,
                                    "caput": "Na contagem de prazo em dias, estabelecido por lei ou pelo juiz, computar-se-ão somente os dias úteis.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1716,
                                            "texto": "O disposto neste artigo aplica-se somente aos prazos processuais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "220º",
                                    "rotulo": "Art. 220º.",
                                    "linha": 1718,
                                    "caput": "Suspende-se o curso do prazo processual nos dias compreendidos entre 20 de dezembro e 20 de janeiro, inclusive.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1720,
                                            "texto": "Ressalvadas as férias individuais e os feriados instituídos por lei, os juízes, os membros do Ministério Público, da Defensoria Pública e da Advocacia Pública e os auxiliares da Justiça exercerão suas atribuições durante o período previsto no caput ."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1722,
                                            "texto": "Durante a suspensão do prazo, não se realizarão audiências nem sessões de julgamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "221º",
                                    "rotulo": "Art. 221º.",
                                    "linha": 1724,
                                    "caput": "Suspende-se o curso do prazo por obstáculo criado em detrimento da parte ou ocorrendo qualquer das hipóteses do art. 313, devendo o prazo ser restituído por tempo igual ao que faltava para sua complementação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1726,
                                            "texto": "Suspendem-se os prazos durante a execução de programa instituído pelo Poder Judiciário para promover a autocomposição, incumbindo aos tribunais especificar, com antecedência, a duração dos trabalhos."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 313",
                                            "href": "#art313",
                                            "inicio": 112,
                                            "fim": 120
                                        }
                                    ]
                                },
                                {
                                    "numero": "222º",
                                    "rotulo": "Art. 222º.",
                                    "linha": 1728,
                                    "caput": "Na comarca, seção ou subseção judiciária onde for difícil o transporte, o juiz poderá prorrogar os prazos por até 2 (dois) meses.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1730,
                                            "texto": "Ao juiz é vedado reduzir prazos peremptórios sem anuência das partes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1732,
                                            "texto": "Havendo calamidade pública, o limite previsto no caput para prorrogação de prazos poderá ser excedido."
                                        }
                                    ]
                                },
                                {
                                    "numero": "223º",
                                    "rotulo": "Art. 223º.",
                                    "linha": 1734,
                                    "caput": "Decorrido o prazo, extingue-se o direito de praticar ou de emendar o ato processual, independentemente de declaração judicial, ficando assegurado, porém, à parte provar que não o realizou por justa causa.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1736,
                                            "texto": "Considera-se justa causa o evento alheio à vontade da parte e que a impediu de praticar o ato por si ou por mandatário."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1738,
                                            "texto": "Verificada a justa causa, o juiz permitirá à parte a prática do ato no prazo que lhe assinar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "224º",
                                    "rotulo": "Art. 224º.",
                                    "linha": 1740,
                                    "caput": "Salvo disposição em contrário, os prazos serão contados excluindo o dia do começo e incluindo o dia do vencimento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1742,
                                            "texto": "Os dias do começo e do vencimento do prazo serão protraídos para o primeiro dia útil seguinte, se coincidirem com dia em que o expediente forense for encerrado antes ou iniciado depois da hora normal ou houver indisponibilidade da comunicação eletrônica."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1744,
                                            "texto": "Considera-se como data de publicação o primeiro dia útil seguinte ao da disponibilização da informação no Diário da Justiça eletrônico."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1746,
                                            "texto": "A contagem do prazo terá início no primeiro dia útil que seguir ao da publicação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "225º",
                                    "rotulo": "Art. 225º.",
                                    "linha": 1748,
                                    "caput": "A parte poderá renunciar ao prazo estabelecido exclusivamente em seu favor, desde que o faça de maneira expressa."
                                },
                                {
                                    "numero": "226º",
                                    "rotulo": "Art. 226º.",
                                    "linha": 1750,
                                    "caput": "O juiz proferirá:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1752,
                                            "texto": "os despachos no prazo de 5 (cinco) dias;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1754,
                                            "texto": "as decisões interlocutórias no prazo de 10 (dez) dias;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1756,
                                            "texto": "as sentenças no prazo de 30 (trinta) dias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "227º",
                                    "rotulo": "Art. 227º.",
                                    "linha": 1758,
                                    "caput": "Em qualquer grau de jurisdição, havendo motivo justificado, pode o juiz exceder, por igual tempo, os prazos a que está submetido."
                                },
                                {
                                    "numero": "228º",
                                    "rotulo": "Art. 228º.",
                                    "linha": 1760,
                                    "caput": "Incumbirá ao serventuário remeter os autos conclusos no prazo de 1 (um) dia e executar os atos processuais no prazo de 5 (cinco) dias, contado da data em que:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1766,
                                            "texto": "Ao receber os autos, o serventuário certificará o dia e a hora em que teve ciência da ordem referida no inciso II."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1768,
                                            "texto": "Nos processos em autos eletrônicos, a juntada de petições ou de manifestações em geral ocorrerá de forma automática, independentemente de ato de serventuário da justiça."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1762,
                                            "texto": "houver concluído o ato processual anterior, se lhe foi imposto pela lei;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1764,
                                            "texto": "tiver ciência da ordem, quando determinada pelo juiz."
                                        }
                                    ]
                                },
                                {
                                    "numero": "229º",
                                    "rotulo": "Art. 229º.",
                                    "linha": 1770,
                                    "caput": "Os litisconsortes que tiverem diferentes procuradores, de escritórios de advocacia distintos, terão prazos contados em dobro para todas as suas manifestações, em qualquer juízo ou tribunal, independentemente de requerimento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1772,
                                            "texto": "Cessa a contagem do prazo em dobro se, havendo apenas 2 (dois) réus, é oferecida defesa por apenas um deles."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1774,
                                            "texto": "Não se aplica o disposto no caput aos processos em autos eletrônicos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "230º",
                                    "rotulo": "Art. 230º.",
                                    "linha": 1776,
                                    "caput": "O prazo para a parte, o procurador, a Advocacia Pública, a Defensoria Pública e o Ministério Público será contado da citação, da intimação ou da notificação."
                                },
                                {
                                    "numero": "231º",
                                    "rotulo": "Art. 231º.",
                                    "linha": 1778,
                                    "caput": "Salvo disposição em sentido diverso, considera-se dia do começo do prazo:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1798,
                                            "texto": "Quando houver mais de um réu, o dia do começo do prazo para contestar corresponderá à última das datas a que se referem os incisos I a VI do caput ."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1800,
                                            "texto": "Havendo mais de um intimado, o prazo para cada um é contado individualmente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1802,
                                            "texto": "Quando o ato tiver de ser praticado diretamente pela parte ou por quem, de qualquer forma, participe do processo, sem a intermediação de representante judicial, o dia do começo do prazo para cumprimento da determinação judicial corresponderá à data em que se der a comunicação."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1804,
                                            "texto": "Aplica-se o disposto no inciso II do caput à citação com hora certa."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1780,
                                            "texto": "a data de juntada aos autos do aviso de recebimento, quando a citação ou a intimação for pelo correio;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1782,
                                            "texto": "a data de juntada aos autos do mandado cumprido, quando a citação ou a intimação for por oficial de justiça;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1784,
                                            "texto": "a data de ocorrência da citação ou da intimação, quando ela se der por ato do escrivão ou do chefe de secretaria;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1786,
                                            "texto": "o dia útil seguinte ao fim da dilação assinada pelo juiz, quando a citação ou a intimação for por edital;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1788,
                                            "texto": "o dia útil seguinte à consulta ao teor da citação ou da intimação ou ao término do prazo para que a consulta se dê, quando a citação ou a intimação for eletrônica;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 1790,
                                            "texto": "a data de juntada do comunicado de que trata o art. 232 ou, não havendo esse, a data de juntada da carta aos autos de origem devidamente cumprida, quando a citação ou a intimação se realizar em cumprimento de carta;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 232",
                                                    "href": "#art232",
                                                    "inicio": 47,
                                                    "fim": 55
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 1792,
                                            "texto": "a data de publicação, quando a intimação se der pelo Diário da Justiça impresso ou eletrônico;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 1794,
                                            "texto": "o dia da carga, quando a intimação se der por meio da retirada dos autos, em carga, do cartório ou da secretaria."
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 1796,
                                            "texto": "o quinto dia útil seguinte à confirmação, na forma prevista na mensagem de citação, do recebimento da citação realizada por meio eletrônico."
                                        }
                                    ]
                                },
                                {
                                    "numero": "232º",
                                    "rotulo": "Art. 232º.",
                                    "linha": 1806,
                                    "caput": "Nos atos de comunicação por carta precatória, rogatória ou de ordem, a realização da citação ou da intimação será imediatamente informada, por meio eletrônico, pelo juiz deprecado ao juiz deprecante. Seção II"
                                },
                                {
                                    "numero": "233º",
                                    "rotulo": "Art. 233º.",
                                    "linha": 1811,
                                    "caput": "Incumbe ao juiz verificar se o serventuário excedeu, sem motivo legítimo, os prazos estabelecidos em lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1813,
                                            "texto": "Constatada a falta, o juiz ordenará a instauração de processo administrativo, na forma da lei."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1815,
                                            "texto": "Qualquer das partes, o Ministério Público ou a Defensoria Pública poderá representar ao juiz contra o serventuário que injustificadamente exceder os prazos previstos em lei."
                                        }
                                    ],
                                    "rubrica": "Da Verificação dos Prazos e das Penalidades",
                                    "linhaRubrica": 1809
                                },
                                {
                                    "numero": "234º",
                                    "rotulo": "Art. 234º.",
                                    "linha": 1817,
                                    "caput": "Os advogados públicos ou privados, o defensor público e o membro do Ministério Público devem restituir os autos no prazo do ato a ser praticado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1819,
                                            "texto": "É lícito a qualquer interessado exigir os autos do advogado que exceder prazo legal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1821,
                                            "texto": "Se, intimado, o advogado não devolver os autos no prazo de 3 (três) dias, perderá o direito à vista fora de cartório e incorrerá em multa correspondente à metade do salário-mínimo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1823,
                                            "texto": "Verificada a falta, o juiz comunicará o fato à seção local da Ordem dos Advogados do Brasil para procedimento disciplinar e imposição de multa."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1825,
                                            "texto": "Se a situação envolver membro do Ministério Público, da Defensoria Pública ou da Advocacia Pública, a multa, se for o caso, será aplicada ao agente público responsável pelo ato."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1827,
                                            "texto": "Verificada a falta, o juiz comunicará o fato ao órgão competente responsável pela instauração de procedimento disciplinar contra o membro que atuou no feito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "235º",
                                    "rotulo": "Art. 235º.",
                                    "linha": 1829,
                                    "caput": "Qualquer parte, o Ministério Público ou a Defensoria Pública poderá representar ao corregedor do tribunal ou ao Conselho Nacional de Justiça contra juiz ou relator que injustificadamente exceder os prazos previstos em lei, regulamento ou regimento interno.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1831,
                                            "texto": "Distribuída a representação ao órgão competente e ouvido previamente o juiz, não sendo caso de arquivamento liminar, será instaurado procedimento para apuração da responsabilidade, com intimação do representado por meio eletrônico para, querendo, apresentar justificativa no prazo de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1833,
                                            "texto": "Sem prejuízo das sanções administrativas cabíveis, em até 48 (quarenta e oito) horas após a apresentação ou não da justificativa de que trata o § 1º, se for o caso, o corregedor do tribunal ou o relator no Conselho Nacional de Justiça determinará a intimação do representado por meio eletrônico para que, em 10 (dez) dias, pratique o ato."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1835,
                                            "texto": "Mantida a inércia, os autos serão remetidos ao substituto legal do juiz ou do relator contra o qual se representou para decisão em 10 (dez) dias."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DOS PRAZOS",
                            "linhaTitulo": 1699
                        }
                    ],
                    "titulo": "DA FORMA, DO TEMPO E DO LUGAR DOS ATOS PROCESSUAIS",
                    "linhaTitulo": 1542
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 1837,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 1840,
                            "artigos": [
                                {
                                    "numero": "236º",
                                    "rotulo": "Art. 236º.",
                                    "linha": 1843,
                                    "caput": "Os atos processuais serão cumpridos por ordem judicial.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1845,
                                            "texto": "Será expedida carta para a prática de atos fora dos limites territoriais do tribunal, da comarca, da seção ou da subseção judiciárias, ressalvadas as hipóteses previstas em lei."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1847,
                                            "texto": "O tribunal poderá expedir carta para juízo a ele vinculado, se o ato houver de se realizar fora dos limites territoriais do local de sua sede."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1849,
                                            "texto": "Admite-se a prática de atos processuais por meio de videoconferência ou outro recurso tecnológico de transmissão de sons e imagens em tempo real."
                                        }
                                    ]
                                },
                                {
                                    "numero": "237º",
                                    "rotulo": "Art. 237º.",
                                    "linha": 1851,
                                    "caput": "Será expedida carta:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1861,
                                            "texto": "Se o ato relativo a processo em curso na justiça federal ou em tribunal superior houver de ser praticado em local onde não haja vara federal, a carta poderá ser dirigida ao juízo estadual da respectiva comarca."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1853,
                                            "texto": "de ordem, pelo tribunal, na hipótese do § 2º do art. 236;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1855,
                                            "texto": "rogatória, para que órgão jurisdicional estrangeiro pratique ato de cooperação jurídica internacional, relativo a processo em curso perante órgão jurisdicional brasileiro;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1857,
                                            "texto": "precatória, para que órgão jurisdicional brasileiro pratique ou determine o cumprimento, na área de sua competência territorial, de ato relativo a pedido de cooperação judiciária formulado por órgão jurisdicional de competência territorial diversa;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1859,
                                            "texto": "arbitral, para que órgão do Poder Judiciário pratique ou determine o cumprimento, na área de sua competência territorial, de ato objeto de pedido de cooperação judiciária formulado por juízo arbitral, inclusive os que importem efetivação de tutela provisória."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 1841
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 1863,
                            "artigos": [
                                {
                                    "numero": "238º",
                                    "rotulo": "Art. 238º.",
                                    "linha": 1866,
                                    "caput": "Citação é o ato pelo qual são convocados o réu, o executado ou o interessado para integrar a relação processual.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1868,
                                            "texto": "A citação será efetivada em até 45 (quarenta e cinco) dias a partir da propositura da ação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "239º",
                                    "rotulo": "Art. 239º.",
                                    "linha": 1870,
                                    "caput": "Para a validade do processo é indispensável a citação do réu ou do executado, ressalvadas as hipóteses de indeferimento da petição inicial ou de improcedência liminar do pedido.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1872,
                                            "texto": "O comparecimento espontâneo do réu ou do executado supre a falta ou a nulidade da citação, fluindo a partir desta data o prazo para apresentação de contestação ou de embargos à execução."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1874,
                                            "texto": "Rejeitada a alegação de nulidade, tratando-se de processo de:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 1876,
                                                    "texto": "conhecimento, o réu será considerado revel;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 1878,
                                                    "texto": "execução, o feito terá seguimento."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "240º",
                                    "rotulo": "Art. 240º.",
                                    "linha": 1880,
                                    "caput": "A citação válida, ainda quando ordenada por juízo incompetente, induz litispendência, torna litigiosa a coisa e constitui em mora o devedor, ressalvado o disposto nos arts. 397 e 398 da Lei nº 10.406, de 10 de janeiro de 2002 (Código Civil).",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1882,
                                            "texto": "A interrupção da prescrição, operada pelo despacho que ordena a citação, ainda que proferido por juízo incompetente, retroagirá à data de propositura da ação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1884,
                                            "texto": "Incumbe ao autor adotar, no prazo de 10 (dez) dias, as providências necessárias para viabilizar a citação, sob pena de não se aplicar o disposto no § 1º."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1886,
                                            "texto": "A parte não será prejudicada pela demora imputável exclusivamente ao serviço judiciário."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1888,
                                            "texto": "O efeito retroativo a que se refere o § 1º aplica-se à decadência e aos demais prazos extintivos previstos em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "241º",
                                    "rotulo": "Art. 241º.",
                                    "linha": 1890,
                                    "caput": "Transitada em julgado a sentença de mérito proferida em favor do réu antes da citação, incumbe ao escrivão ou ao chefe de secretaria comunicar-lhe o resultado do julgamento."
                                },
                                {
                                    "numero": "242º",
                                    "rotulo": "Art. 242º.",
                                    "linha": 1892,
                                    "caput": "A citação será pessoal, podendo, no entanto, ser feita na pessoa do representante legal ou do procurador do réu, do executado ou do interessado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1894,
                                            "texto": "Na ausência do citando, a citação será feita na pessoa de seu mandatário, administrador, preposto ou gerente, quando a ação se originar de atos por eles praticados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1896,
                                            "texto": "O locador que se ausentar do Brasil sem cientificar o locatário de que deixou, na localidade onde estiver situado o imóvel, procurador com poderes para receber citação será citado na pessoa do administrador do imóvel encarregado do recebimento dos aluguéis, que será considerado habilitado para representar o locador em juízo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1898,
                                            "texto": "A citação da União, dos Estados, do Distrito Federal, dos Municípios e de suas respectivas autarquias e fundações de direito público será realizada perante o órgão de Advocacia Pública responsável por sua representação judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "243º",
                                    "rotulo": "Art. 243º.",
                                    "linha": 1900,
                                    "caput": "A citação poderá ser feita em qualquer lugar em que se encontre o réu, o executado ou o interessado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 1902,
                                            "texto": "O militar em serviço ativo será citado na unidade em que estiver servindo, se não for conhecida sua residência ou nela não for encontrado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "244º",
                                    "rotulo": "Art. 244º.",
                                    "linha": 1904,
                                    "caput": "Não se fará a citação, salvo para evitar o perecimento do direito:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1906,
                                            "texto": "de quem estiver participando de ato de culto religioso;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1908,
                                            "texto": "de cônjuge, de companheiro ou de qualquer parente do morto, consanguíneo ou afim, em linha reta ou na linha colateral em segundo grau, no dia do falecimento e nos 7 (sete) dias seguintes;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1910,
                                            "texto": "de noivos, nos 3 (três) primeiros dias seguintes ao casamento;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1912,
                                            "texto": "de doente, enquanto grave o seu estado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "245º",
                                    "rotulo": "Art. 245º.",
                                    "linha": 1914,
                                    "caput": "Não se fará citação quando se verificar que o citando é mentalmente incapaz ou está impossibilitado de recebê-la.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1916,
                                            "texto": "O oficial de justiça descreverá e certificará minuciosamente a ocorrência."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1918,
                                            "texto": "Para examinar o citando, o juiz nomeará médico, que apresentará laudo no prazo de 5 (cinco) dias."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1920,
                                            "texto": "Dispensa-se a nomeação de que trata o § 2º se pessoa da família apresentar declaração do médico do citando que ateste a incapacidade deste."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1922,
                                            "texto": "Reconhecida a impossibilidade, o juiz nomeará curador ao citando, observando, quanto à sua escolha, a preferência estabelecida em lei e restringindo a nomeação à causa."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1924,
                                            "texto": "A citação será feita na pessoa do curador, a quem incumbirá a defesa dos interesses do citando."
                                        }
                                    ]
                                },
                                {
                                    "numero": "246º",
                                    "rotulo": "Art. 246º.",
                                    "linha": 1927,
                                    "caput": "A citação será feita preferencialmente por meio eletrônico, no prazo de até 2 (dois) dias úteis, contado da decisão que a determinar, por meio dos endereços eletrônicos indicados pelo citando no banco de dados do Poder Judiciário, conforme regulamento do Conselho Nacional de Justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1930,
                                            "texto": "As empresas públicas e privadas são obrigadas a manter cadastro nos sistemas de processo em autos eletrônicos, para efeito de recebimento de citações e intimações, as quais serão efetuadas preferencialmente por esse meio."
                                        },
                                        {
                                            "numero": "1º-A",
                                            "rotulo": "§ 1º-A",
                                            "linha": 1932,
                                            "texto": "A ausência de confirmação, em até 3 (três) dias úteis, contados do recebimento da citação eletrônica, implicará a realização da citação:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 1934,
                                                    "texto": "pelo correio;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 1936,
                                                    "texto": "por oficial de justiça;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 1938,
                                                    "texto": "pelo escrivão ou chefe de secretaria, se o citando comparecer em cartório;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 1940,
                                                    "texto": "por edital."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "1º-B",
                                            "rotulo": "§ 1º-B",
                                            "linha": 1942,
                                            "texto": "Na primeira oportunidade de falar nos autos, o réu citado nas formas previstas nos incisos I, II, III e IV do § 1º-A deste artigo deverá apresentar justa causa para a ausência de confirmação do recebimento da citação enviada eletronicamente."
                                        },
                                        {
                                            "numero": "1º-C",
                                            "rotulo": "§ 1º-C",
                                            "linha": 1944,
                                            "texto": "Considera-se ato atentatório à dignidade da justiça, passível de multa de até 5% (cinco por cento) do valor da causa, deixar de confirmar no prazo legal, sem justa causa, o recebimento da citação recebida por meio eletrônico."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1946,
                                            "texto": "O disposto no § 1º aplica-se à União, aos Estados, ao Distrito Federal, aos Municípios e às entidades da administração indireta."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1948,
                                            "texto": "Na ação de usucapião de imóvel, os confinantes serão citados pessoalmente, exceto quando tiver por objeto unidade autônoma de prédio em condomínio, caso em que tal citação é dispensada."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1950,
                                            "texto": "As citações por correio eletrônico serão acompanhadas das orientações para realização da confirmação de recebimento e de código identificador que permitirá a sua identificação na página eletrônica do órgão judicial citante."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 1952,
                                            "texto": "As microempresas e as pequenas empresas somente se sujeitam ao disposto no § 1º deste artigo quando não possuírem endereço eletrônico cadastrado no sistema integrado da Rede Nacional para a Simplificação do Registro e da Legalização de Empresas e Negócios (Redesim)."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 1954,
                                            "texto": "Para os fins do § 5º deste artigo, deverá haver compartilhamento de cadastro com o órgão do Poder Judiciário, incluído o endereço eletrônico constante do sistema integrado da Redesim, nos termos da legislação aplicável ao sigilo fiscal e ao tratamento de dados pessoais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "247º",
                                    "rotulo": "Art. 247º.",
                                    "linha": 1957,
                                    "caput": "A citação será feita por meio eletrônico ou pelo correio para qualquer comarca do País, exceto:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1959,
                                            "texto": "nas ações de estado, observado o disposto no art. 695, § 3º;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1961,
                                            "texto": "quando o citando for incapaz;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1963,
                                            "texto": "quando o citando for pessoa de direito público;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1965,
                                            "texto": "quando o citando residir em local não atendido pela entrega domiciliar de correspondência;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1967,
                                            "texto": "quando o autor, justificadamente, a requerer de outra forma."
                                        }
                                    ]
                                },
                                {
                                    "numero": "248º",
                                    "rotulo": "Art. 248º.",
                                    "linha": 1969,
                                    "caput": "Deferida a citação pelo correio, o escrivão ou o chefe de secretaria remeterá ao citando cópias da petição inicial e do despacho do juiz e comunicará o prazo para resposta, o endereço do juízo e o respectivo cartório.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 1971,
                                            "texto": "A carta será registrada para entrega ao citando, exigindo-lhe o carteiro, ao fazer a entrega, que assine o recibo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 1973,
                                            "texto": "Sendo o citando pessoa jurídica, será válida a entrega do mandado a pessoa com poderes de gerência geral ou de administração ou, ainda, a funcionário responsável pelo recebimento de correspondências."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 1975,
                                            "texto": "Da carta de citação no processo de conhecimento constarão os requisitos do art. 250.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 250",
                                                    "href": "#art250",
                                                    "inicio": 75,
                                                    "fim": 83
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 1977,
                                            "texto": "Nos condomínios edilícios ou nos loteamentos com controle de acesso, será válida a entrega do mandado a funcionário da portaria responsável pelo recebimento de correspondência, que, entretanto, poderá recusar o recebimento, se declarar, por escrito, sob as penas da lei, que o destinatário da correspondência está ausente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "249º",
                                    "rotulo": "Art. 249º.",
                                    "linha": 1979,
                                    "caput": "A citação será feita por meio de oficial de justiça nas hipóteses previstas neste Código ou em lei, ou quando frustrada a citação pelo correio."
                                },
                                {
                                    "numero": "250º",
                                    "rotulo": "Art. 250º.",
                                    "linha": 1981,
                                    "caput": "O mandado que o oficial de justiça tiver de cumprir conterá:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1983,
                                            "texto": "os nomes do autor e do citando e seus respectivos domicílios ou residências;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1985,
                                            "texto": "a finalidade da citação, com todas as especificações constantes da petição inicial, bem como a menção do prazo para contestar, sob pena de revelia, ou para embargar a execução;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 1987,
                                            "texto": "a aplicação de sanção para o caso de descumprimento da ordem, se houver;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 1989,
                                            "texto": "se for o caso, a intimação do citando para comparecer, acompanhado de advogado ou de defensor público, à audiência de conciliação ou de mediação, com a menção do dia, da hora e do lugar do comparecimento;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 1991,
                                            "texto": "a cópia da petição inicial, do despacho ou da decisão que deferir tutela provisória;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 1993,
                                            "texto": "a assinatura do escrivão ou do chefe de secretaria e a declaração de que o subscreve por ordem do juiz."
                                        }
                                    ]
                                },
                                {
                                    "numero": "251º",
                                    "rotulo": "Art. 251º.",
                                    "linha": 1995,
                                    "caput": "Incumbe ao oficial de justiça procurar o citando e, onde o encontrar, citá-lo:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 1997,
                                            "texto": "lendo-lhe o mandado e entregando-lhe a contrafé;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 1999,
                                            "texto": "portando por fé se recebeu ou recusou a contrafé;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2001,
                                            "texto": "obtendo a nota de ciente ou certificando que o citando não a apôs no mandado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "252º",
                                    "rotulo": "Art. 252º.",
                                    "linha": 2003,
                                    "caput": "Quando, por 2 (duas) vezes, o oficial de justiça houver procurado o citando em seu domicílio ou residência sem o encontrar, deverá, havendo suspeita de ocultação, intimar qualquer pessoa da família ou, em sua falta, qualquer vizinho de que, no dia útil imediato, voltará a fim de efetuar a citação, na hora que designar.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2005,
                                            "texto": "Nos condomínios edilícios ou nos loteamentos com controle de acesso, será válida a intimação a que se refere o caput feita a funcionário da portaria responsável pelo recebimento de correspondência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "253º",
                                    "rotulo": "Art. 253º.",
                                    "linha": 2007,
                                    "caput": "No dia e na hora designados, o oficial de justiça, independentemente de novo despacho, comparecerá ao domicílio ou à residência do citando a fim de realizar a diligência.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2009,
                                            "texto": "Se o citando não estiver presente, o oficial de justiça procurará informar-se das razões da ausência, dando por feita a citação, ainda que o citando se tenha ocultado em outra comarca, seção ou subseção judiciárias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2011,
                                            "texto": "A citação com hora certa será efetivada mesmo que a pessoa da família ou o vizinho que houver sido intimado esteja ausente, ou se, embora presente, a pessoa da família ou o vizinho se recusar a receber o mandado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2013,
                                            "texto": "Da certidão da ocorrência, o oficial de justiça deixará contrafé com qualquer pessoa da família ou vizinho, conforme o caso, declarando-lhe o nome."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2015,
                                            "texto": "O oficial de justiça fará constar do mandado a advertência de que será nomeado curador especial se houver revelia."
                                        }
                                    ]
                                },
                                {
                                    "numero": "254º",
                                    "rotulo": "Art. 254º.",
                                    "linha": 2017,
                                    "caput": "Feita a citação com hora certa, o escrivão ou chefe de secretaria enviará ao réu, executado ou interessado, no prazo de 10 (dez) dias, contado da data da juntada do mandado aos autos, carta, telegrama ou correspondência eletrônica, dando-lhe de tudo ciência."
                                },
                                {
                                    "numero": "255º",
                                    "rotulo": "Art. 255º.",
                                    "linha": 2019,
                                    "caput": "Nas comarcas contíguas de fácil comunicação e nas que se situem na mesma região metropolitana, o oficial de justiça poderá efetuar, em qualquer delas, citações, intimações, notificações, penhoras e quaisquer outros atos executivos."
                                },
                                {
                                    "numero": "256º",
                                    "rotulo": "Art. 256º.",
                                    "linha": 2021,
                                    "caput": "A citação por edital será feita:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2029,
                                            "texto": "Considera-se inacessível, para efeito de citação por edital, o país que recusar o cumprimento de carta rogatória."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2031,
                                            "texto": "No caso de ser inacessível o lugar em que se encontrar o réu, a notícia de sua citação será divulgada também pelo rádio, se na comarca houver emissora de radiodifusão."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2033,
                                            "texto": "O réu será considerado em local ignorado ou incerto se infrutíferas as tentativas de sua localização, inclusive mediante requisição pelo juízo de informações sobre seu endereço nos cadastros de órgãos públicos ou de concessionárias de serviços públicos."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2023,
                                            "texto": "quando desconhecido ou incerto o citando;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2025,
                                            "texto": "quando ignorado, incerto ou inacessível o lugar em que se encontrar o citando;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2027,
                                            "texto": "nos casos expressos em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "257º",
                                    "rotulo": "Art. 257º.",
                                    "linha": 2035,
                                    "caput": "São requisitos da citação por edital:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2045,
                                            "texto": "O juiz poderá determinar que a publicação do edital seja feita também em jornal local de ampla circulação ou por outros meios, considerando as peculiaridades da comarca, da seção ou da subseção judiciárias."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2037,
                                            "texto": "a afirmação do autor ou a certidão do oficial informando a presença das circunstâncias autorizadoras;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2039,
                                            "texto": "a publicação do edital na rede mundial de computadores, no sítio do respectivo tribunal e na plataforma de editais do Conselho Nacional de Justiça, que deve ser certificada nos autos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2041,
                                            "texto": "a determinação, pelo juiz, do prazo, que variará entre 20 (vinte) e 60 (sessenta) dias, fluindo da data da publicação única ou, havendo mais de uma, da primeira;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2043,
                                            "texto": "a advertência de que será nomeado curador especial em caso de revelia."
                                        }
                                    ]
                                },
                                {
                                    "numero": "258º",
                                    "rotulo": "Art. 258º.",
                                    "linha": 2047,
                                    "caput": "A parte que requerer a citação por edital, alegando dolosamente a ocorrência das circunstâncias autorizadoras para sua realização, incorrerá em multa de 5 (cinco) vezes o salário-mínimo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2049,
                                            "texto": "A multa reverterá em benefício do citando."
                                        }
                                    ]
                                },
                                {
                                    "numero": "259º",
                                    "rotulo": "Art. 259º.",
                                    "linha": 2051,
                                    "caput": "Serão publicados editais:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2053,
                                            "texto": "na ação de usucapião de imóvel;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2055,
                                            "texto": "na ação de recuperação ou substituição de título ao portador;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2057,
                                            "texto": "em qualquer ação em que seja necessária, por determinação legal, a provocação, para participação no processo, de interessados incertos ou desconhecidos."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA CITAÇÃO",
                            "linhaTitulo": 1864
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 2059,
                            "artigos": [
                                {
                                    "numero": "260º",
                                    "rotulo": "Art. 260º.",
                                    "linha": 2062,
                                    "caput": "São requisitos das cartas de ordem, precatória e rogatória:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2072,
                                            "texto": "O juiz mandará trasladar para a carta quaisquer outras peças, bem como instruí-la com mapa, desenho ou gráfico, sempre que esses documentos devam ser examinados, na diligência, pelas partes, pelos peritos ou pelas testemunhas."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2074,
                                            "texto": "Quando o objeto da carta for exame pericial sobre documento, este será remetido em original, ficando nos autos reprodução fotográfica."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2076,
                                            "texto": "A carta arbitral atenderá, no que couber, aos requisitos a que se refere o caput e será instruída com a convenção de arbitragem e com as provas da nomeação do árbitro e de sua aceitação da função."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2064,
                                            "texto": "a indicação dos juízes de origem e de cumprimento do ato;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2066,
                                            "texto": "o inteiro teor da petição, do despacho judicial e do instrumento do mandato conferido ao advogado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2068,
                                            "texto": "a menção do ato processual que lhe constitui o objeto;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2070,
                                            "texto": "o encerramento com a assinatura do juiz."
                                        }
                                    ]
                                },
                                {
                                    "numero": "261º",
                                    "rotulo": "Art. 261º.",
                                    "linha": 2078,
                                    "caput": "Em todas as cartas o juiz fixará o prazo para cumprimento, atendendo à facilidade das comunicações e à natureza da diligência.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2080,
                                            "texto": "As partes deverão ser intimadas pelo juiz do ato de expedição da carta."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2082,
                                            "texto": "Expedida a carta, as partes acompanharão o cumprimento da diligência perante o juízo destinatário, ao qual compete a prática dos atos de comunicação."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2084,
                                            "texto": "A parte a quem interessar o cumprimento da diligência cooperará para que o prazo a que se refere o caput seja cumprido."
                                        }
                                    ]
                                },
                                {
                                    "numero": "262º",
                                    "rotulo": "Art. 262º.",
                                    "linha": 2086,
                                    "caput": "A carta tem caráter itinerante, podendo, antes ou depois de lhe ser ordenado o cumprimento, ser encaminhada a juízo diverso do que dela consta, a fim de se praticar o ato.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2088,
                                            "texto": "O encaminhamento da carta a outro juízo será imediatamente comunicado ao órgão expedidor, que intimará as partes."
                                        }
                                    ]
                                },
                                {
                                    "numero": "263º",
                                    "rotulo": "Art. 263º.",
                                    "linha": 2090,
                                    "caput": "As cartas deverão, preferencialmente, ser expedidas por meio eletrônico, caso em que a assinatura do juiz deverá ser eletrônica, na forma da lei."
                                },
                                {
                                    "numero": "264º",
                                    "rotulo": "Art. 264º.",
                                    "linha": 2092,
                                    "caput": "A carta de ordem e a carta precatória por meio eletrônico, por telefone ou por telegrama conterão, em resumo substancial, os requisitos mencionados no art. 250, especialmente no que se refere à aferição da autenticidade.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 250",
                                            "href": "#art250",
                                            "inicio": 151,
                                            "fim": 159
                                        }
                                    ]
                                },
                                {
                                    "numero": "265º",
                                    "rotulo": "Art. 265º.",
                                    "linha": 2094,
                                    "caput": "O secretário do tribunal, o escrivão ou o chefe de secretaria do juízo deprecante transmitirá, por telefone, a carta de ordem ou a carta precatória ao juízo em que houver de se cumprir o ato, por intermédio do escrivão do primeiro ofício da primeira vara, se houver na comarca mais de um ofício ou de uma vara, observando-se, quanto aos requisitos, o disposto no art. 264.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2096,
                                            "texto": "O escrivão ou o chefe de secretaria, no mesmo dia ou no dia útil imediato, telefonará ou enviará mensagem eletrônica ao secretário do tribunal, ao escrivão ou ao chefe de secretaria do juízo deprecante, lendo-lhe os termos da carta e solicitando-lhe que os confirme."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2098,
                                            "texto": "Sendo confirmada, o escrivão ou o chefe de secretaria submeterá a carta a despacho."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 264",
                                            "href": "#art264",
                                            "inicio": 363,
                                            "fim": 371
                                        }
                                    ]
                                },
                                {
                                    "numero": "266º",
                                    "rotulo": "Art. 266º.",
                                    "linha": 2100,
                                    "caput": "Serão praticados de ofício os atos requisitados por meio eletrônico e de telegrama, devendo a parte depositar, contudo, na secretaria do tribunal ou no cartório do juízo deprecante, a importância correspondente às despesas que serão feitas no juízo em que houver de praticar-se o ato."
                                },
                                {
                                    "numero": "267º",
                                    "rotulo": "Art. 267º.",
                                    "linha": 2102,
                                    "caput": "O juiz recusará cumprimento a carta precatória ou arbitral, devolvendo-a com decisão motivada quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2110,
                                            "texto": "No caso de incompetência em razão da matéria ou da hierarquia, o juiz deprecado, conforme o ato a ser praticado, poderá remeter a carta ao juiz ou ao tribunal competente."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2104,
                                            "texto": "a carta não estiver revestida dos requisitos legais;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2106,
                                            "texto": "faltar ao juiz competência em razão da matéria ou da hierarquia;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2108,
                                            "texto": "o juiz tiver dúvida acerca de sua autenticidade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "268º",
                                    "rotulo": "Art. 268º.",
                                    "linha": 2112,
                                    "caput": "Cumprida a carta, será devolvida ao juízo de origem no prazo de 10 (dez) dias, independentemente de traslado, pagas as custas pela parte."
                                }
                            ],
                            "titulo": "DAS CARTAS",
                            "linhaTitulo": 2060
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 2114,
                            "artigos": [
                                {
                                    "numero": "269º",
                                    "rotulo": "Art. 269º.",
                                    "linha": 2117,
                                    "caput": "Intimação é o ato pelo qual se dá ciência a alguém dos atos e dos termos do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2119,
                                            "texto": "É facultado aos advogados promover a intimação do advogado da outra parte por meio do correio, juntando aos autos, a seguir, cópia do ofício de intimação e do aviso de recebimento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2121,
                                            "texto": "O ofício de intimação deverá ser instruído com cópia do despacho, da decisão ou da sentença."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2123,
                                            "texto": "A intimação da União, dos Estados, do Distrito Federal, dos Municípios e de suas respectivas autarquias e fundações de direito público será realizada perante o órgão de Advocacia Pública responsável por sua representação judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "270º",
                                    "rotulo": "Art. 270º.",
                                    "linha": 2125,
                                    "caput": "As intimações realizam-se, sempre que possível, por meio eletrônico, na forma da lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2127,
                                            "texto": "Aplica-se ao Ministério Público, à Defensoria Pública e à Advocacia Pública o disposto no § 1º do art. 246."
                                        }
                                    ]
                                },
                                {
                                    "numero": "271º",
                                    "rotulo": "Art. 271º.",
                                    "linha": 2129,
                                    "caput": "O juiz determinará de ofício as intimações em processos pendentes, salvo disposição em contrário."
                                },
                                {
                                    "numero": "272º",
                                    "rotulo": "Art. 272º.",
                                    "linha": 2131,
                                    "caput": "Quando não realizadas por meio eletrônico, consideram-se feitas as intimações pela publicação dos atos no órgão oficial.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2133,
                                            "texto": "Os advogados poderão requerer que, na intimação a eles dirigida, figure apenas o nome da sociedade a que pertençam, desde que devidamente registrada na Ordem dos Advogados do Brasil."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2135,
                                            "texto": "Sob pena de nulidade, é indispensável que da publicação constem os nomes das partes e de seus advogados, com o respectivo número de inscrição na Ordem dos Advogados do Brasil, ou, se assim requerido, da sociedade de advogados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2137,
                                            "texto": "A grafia dos nomes das partes não deve conter abreviaturas."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2139,
                                            "texto": "A grafia dos nomes dos advogados deve corresponder ao nome completo e ser a mesma que constar da procuração ou que estiver registrada na Ordem dos Advogados do Brasil."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2141,
                                            "texto": "Constando dos autos pedido expresso para que as comunicações dos atos processuais sejam feitas em nome dos advogados indicados, o seu desatendimento implicará nulidade."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2143,
                                            "texto": "A retirada dos autos do cartório ou da secretaria em carga pelo advogado, por pessoa credenciada a pedido do advogado ou da sociedade de advogados, pela Advocacia Pública, pela Defensoria Pública ou pelo Ministério Público implicará intimação de qualquer decisão contida no processo retirado, ainda que pendente de publicação."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 2145,
                                            "texto": "O advogado e a sociedade de advogados deverão requerer o respectivo credenciamento para a retirada de autos por preposto."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 2147,
                                            "texto": "A parte arguirá a nulidade da intimação em capítulo preliminar do próprio ato que lhe caiba praticar, o qual será tido por tempestivo se o vício for reconhecido."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 2149,
                                            "texto": "Não sendo possível a prática imediata do ato diante da necessidade de acesso prévio aos autos, a parte limitar-se-á a arguir a nulidade da intimação, caso em que o prazo será contado da intimação da decisão que a reconheça."
                                        }
                                    ]
                                },
                                {
                                    "numero": "273º",
                                    "rotulo": "Art. 273º.",
                                    "linha": 2151,
                                    "caput": "Se inviável a intimação por meio eletrônico e não houver na localidade publicação em órgão oficial, incumbirá ao escrivão ou chefe de secretaria intimar de todos os atos do processo os advogados das partes:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2153,
                                            "texto": "pessoalmente, se tiverem domicílio na sede do juízo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2155,
                                            "texto": "por carta registrada, com aviso de recebimento, quando forem domiciliados fora do juízo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "274º",
                                    "rotulo": "Art. 274º.",
                                    "linha": 2157,
                                    "caput": "Não dispondo a lei de outro modo, as intimações serão feitas às partes, aos seus representantes legais, aos advogados e aos demais sujeitos do processo pelo correio ou, se presentes em cartório, diretamente pelo escrivão ou chefe de secretaria.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2159,
                                            "texto": "Presumem-se válidas as intimações dirigidas ao endereço constante dos autos, ainda que não recebidas pessoalmente pelo interessado, se a modificação temporária ou definitiva não tiver sido devidamente comunicada ao juízo, fluindo os prazos a partir da juntada aos autos do comprovante de entrega da correspondência no primitivo endereço."
                                        }
                                    ]
                                },
                                {
                                    "numero": "275º",
                                    "rotulo": "Art. 275º.",
                                    "linha": 2161,
                                    "caput": "A intimação será feita por oficial de justiça quando frustrada a realização por meio eletrônico ou pelo correio.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2163,
                                            "texto": "A certidão de intimação deve conter:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 2165,
                                                    "texto": "a indicação do lugar e a descrição da pessoa intimada, mencionando, quando possível, o número de seu documento de identidade e o órgão que o expediu;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 2167,
                                                    "texto": "a declaração de entrega da contrafé;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 2169,
                                                    "texto": "a nota de ciente ou a certidão de que o interessado não a apôs no mandado."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2171,
                                            "texto": "Caso necessário, a intimação poderá ser efetuada com hora certa ou por edital."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DAS INTIMAÇÕES",
                            "linhaTitulo": 2115
                        }
                    ],
                    "titulo": "DA COMUNICAÇÃO DOS ATOS PROCESSUAIS",
                    "linhaTitulo": 1838
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 2173,
                    "artigos": [
                        {
                            "numero": "276º",
                            "rotulo": "Art. 276º.",
                            "linha": 2176,
                            "caput": "Quando a lei prescrever determinada forma sob pena de nulidade, a decretação desta não pode ser requerida pela parte que lhe deu causa."
                        },
                        {
                            "numero": "277º",
                            "rotulo": "Art. 277º.",
                            "linha": 2178,
                            "caput": "Quando a lei prescrever determinada forma, o juiz considerará válido o ato se, realizado de outro modo, lhe alcançar a finalidade."
                        },
                        {
                            "numero": "278º",
                            "rotulo": "Art. 278º.",
                            "linha": 2180,
                            "caput": "A nulidade dos atos deve ser alegada na primeira oportunidade em que couber à parte falar nos autos, sob pena de preclusão.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2182,
                                    "texto": "Não se aplica o disposto no caput às nulidades que o juiz deva decretar de ofício, nem prevalece a preclusão provando a parte legítimo impedimento."
                                }
                            ]
                        },
                        {
                            "numero": "279º",
                            "rotulo": "Art. 279º.",
                            "linha": 2184,
                            "caput": "É nulo o processo quando o membro do Ministério Público não for intimado a acompanhar o feito em que deva intervir.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 2186,
                                    "texto": "Se o processo tiver tramitado sem conhecimento do membro do Ministério Público, o juiz invalidará os atos praticados a partir do momento em que ele deveria ter sido intimado."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 2188,
                                    "texto": "A nulidade só pode ser decretada após a intimação do Ministério Público, que se manifestará sobre a existência ou a inexistência de prejuízo."
                                }
                            ]
                        },
                        {
                            "numero": "280º",
                            "rotulo": "Art. 280º.",
                            "linha": 2190,
                            "caput": "As citações e as intimações serão nulas quando feitas sem observância das prescrições legais."
                        },
                        {
                            "numero": "281º",
                            "rotulo": "Art. 281º.",
                            "linha": 2192,
                            "caput": "Anulado o ato, consideram-se de nenhum efeito todos os subsequentes que dele dependam, todavia, a nulidade de uma parte do ato não prejudicará as outras que dela sejam independentes."
                        },
                        {
                            "numero": "282º",
                            "rotulo": "Art. 282º.",
                            "linha": 2194,
                            "caput": "Ao pronunciar a nulidade, o juiz declarará que atos são atingidos e ordenará as providências necessárias a fim de que sejam repetidos ou retificados.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 2196,
                                    "texto": "O ato não será repetido nem sua falta será suprida quando não prejudicar a parte."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 2198,
                                    "texto": "Quando puder decidir o mérito a favor da parte a quem aproveite a decretação da nulidade, o juiz não a pronunciará nem mandará repetir o ato ou suprir-lhe a falta."
                                }
                            ]
                        },
                        {
                            "numero": "283º",
                            "rotulo": "Art. 283º.",
                            "linha": 2200,
                            "caput": "O erro de forma do processo acarreta unicamente a anulação dos atos que não possam ser aproveitados, devendo ser praticados os que forem necessários a fim de se observarem as prescrições legais.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2202,
                                    "texto": "Dar-se-á o aproveitamento dos atos praticados desde que não resulte prejuízo à defesa de qualquer parte."
                                }
                            ]
                        }
                    ],
                    "titulo": "DAS NULIDADES",
                    "linhaTitulo": 2174
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO IV",
                    "linha": 2204,
                    "artigos": [
                        {
                            "numero": "284º",
                            "rotulo": "Art. 284º.",
                            "linha": 2207,
                            "caput": "Todos os processos estão sujeitos a registro, devendo ser distribuídos onde houver mais de um juiz."
                        },
                        {
                            "numero": "285º",
                            "rotulo": "Art. 285º.",
                            "linha": 2209,
                            "caput": "A distribuição, que poderá ser eletrônica, será alternada e aleatória, obedecendo-se rigorosa igualdade.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2211,
                                    "texto": "A lista de distribuição deverá ser publicada no Diário de Justiça."
                                }
                            ]
                        },
                        {
                            "numero": "286º",
                            "rotulo": "Art. 286º.",
                            "linha": 2213,
                            "caput": "Serão distribuídas por dependência as causas de qualquer natureza:",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2221,
                                    "texto": "Havendo intervenção de terceiro, reconvenção ou outra hipótese de ampliação objetiva do processo, o juiz, de ofício, mandará proceder à respectiva anotação pelo distribuidor."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 2215,
                                    "texto": "quando se relacionarem, por conexão ou continência, com outra já ajuizada;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 2217,
                                    "texto": "quando, tendo sido extinto o processo sem resolução de mérito, for reiterado o pedido, ainda que em litisconsórcio com outros autores ou que sejam parcialmente alterados os réus da demanda;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 2219,
                                    "texto": "quando houver ajuizamento de ações nos termos do art. 55, § 3º, ao juízo prevento."
                                }
                            ]
                        },
                        {
                            "numero": "287º",
                            "rotulo": "Art. 287º.",
                            "linha": 2223,
                            "caput": "A petição inicial deve vir acompanhada de procuração, que conterá os endereços do advogado, eletrônico e não eletrônico.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2225,
                                    "texto": "Dispensa-se a juntada da procuração:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2227,
                                            "texto": "no caso previsto no art. 104;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 104",
                                                    "href": "#art104",
                                                    "inicio": 20,
                                                    "fim": 28
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 10",
                                                    "href": "#art10",
                                                    "inicio": 20,
                                                    "fim": 27
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2229,
                                            "texto": "se a parte estiver representada pela Defensoria Pública;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2231,
                                            "texto": "se a representação decorrer diretamente de norma prevista na Constituição Federal ou em lei."
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "numero": "288º",
                            "rotulo": "Art. 288º.",
                            "linha": 2233,
                            "caput": "O juiz, de ofício ou a requerimento do interessado, corrigirá o erro ou compensará a falta de distribuição."
                        },
                        {
                            "numero": "289º",
                            "rotulo": "Art. 289º.",
                            "linha": 2235,
                            "caput": "A distribuição poderá ser fiscalizada pela parte, por seu procurador, pelo Ministério Público e pela Defensoria Pública."
                        },
                        {
                            "numero": "290º",
                            "rotulo": "Art. 290º.",
                            "linha": 2237,
                            "caput": "Será cancelada a distribuição do feito se a parte, intimada na pessoa de seu advogado, não realizar o pagamento das custas e despesas de ingresso em 15 (quinze) dias."
                        }
                    ],
                    "titulo": "DA DISTRIBUIÇÃO E DO REGISTRO",
                    "linhaTitulo": 2205
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO V",
                    "linha": 2239,
                    "artigos": [
                        {
                            "numero": "291º",
                            "rotulo": "Art. 291º.",
                            "linha": 2242,
                            "caput": "A toda causa será atribuído valor certo, ainda que não tenha conteúdo econômico imediatamente aferível."
                        },
                        {
                            "numero": "292º",
                            "rotulo": "Art. 292º.",
                            "linha": 2244,
                            "caput": "O valor da causa constará da petição inicial ou da reconvenção e será:",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 2262,
                                    "texto": "Quando se pedirem prestações vencidas e vincendas, considerar-se-á o valor de umas e outras."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 2264,
                                    "texto": "O valor das prestações vincendas será igual a uma prestação anual, se a obrigação for por tempo indeterminado ou por tempo superior a 1 (um) ano, e, se por tempo inferior, será igual à soma das prestações."
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 2266,
                                    "texto": "O juiz corrigirá, de ofício e por arbitramento, o valor da causa quando verificar que não corresponde ao conteúdo patrimonial em discussão ou ao proveito econômico perseguido pelo autor, caso em que se procederá ao recolhimento das custas correspondentes."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 2246,
                                    "texto": "na ação de cobrança de dívida, a soma monetariamente corrigida do principal, dos juros de mora vencidos e de outras penalidades, se houver, até a data de propositura da ação;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 2248,
                                    "texto": "na ação que tiver por objeto a existência, a validade, o cumprimento, a modificação, a resolução, a resilição ou a rescisão de ato jurídico, o valor do ato ou o de sua parte controvertida;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 2250,
                                    "texto": "na ação de alimentos, a soma de 12 (doze) prestações mensais pedidas pelo autor;",
                                    "links": [
                                        {
                                            "campo": "texto",
                                            "texto": "12",
                                            "href": "../../../LEIS/L1060.htm#art12",
                                            "inicio": 32,
                                            "fim": 34
                                        }
                                    ]
                                },
                                {
                                    "numero": "IV",
                                    "rotulo": "IV",
                                    "linha": 2252,
                                    "texto": "na ação de divisão, de demarcação e de reivindicação, o valor de avaliação da área ou do bem objeto do pedido;"
                                },
                                {
                                    "numero": "V",
                                    "rotulo": "V",
                                    "linha": 2254,
                                    "texto": "na ação indenizatória, inclusive a fundada em dano moral, o valor pretendido;"
                                },
                                {
                                    "numero": "VI",
                                    "rotulo": "VI",
                                    "linha": 2256,
                                    "texto": "na ação em que há cumulação de pedidos, a quantia correspondente à soma dos valores de todos eles;"
                                },
                                {
                                    "numero": "VII",
                                    "rotulo": "VII",
                                    "linha": 2258,
                                    "texto": "na ação em que os pedidos são alternativos, o de maior valor;"
                                },
                                {
                                    "numero": "VIII",
                                    "rotulo": "VIII",
                                    "linha": 2260,
                                    "texto": "na ação em que houver pedido subsidiário, o valor do pedido principal."
                                }
                            ]
                        },
                        {
                            "numero": "293º",
                            "rotulo": "Art. 293º.",
                            "linha": 2268,
                            "caput": "O réu poderá impugnar, em preliminar da contestação, o valor atribuído à causa pelo autor, sob pena de preclusão, e o juiz decidirá a respeito, impondo, se for o caso, a complementação das custas."
                        }
                    ],
                    "titulo": "DO VALOR DA CAUSA",
                    "linhaTitulo": 2240
                }
            ],
            "titulo": "DOS ATOS PROCESSUAIS",
            "linhaTitulo": 1539
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO V",
            "linha": 2270,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 2273,
                    "artigos": [
                        {
                            "numero": "294º",
                            "rotulo": "Art. 294º.",
                            "linha": 2276,
                            "caput": "A tutela provisória pode fundamentar-se em urgência ou evidência.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2278,
                                    "texto": "A tutela provisória de urgência, cautelar ou antecipada, pode ser concedida em caráter antecedente ou incidental."
                                }
                            ]
                        },
                        {
                            "numero": "295º",
                            "rotulo": "Art. 295º.",
                            "linha": 2280,
                            "caput": "A tutela provisória requerida em caráter incidental independe do pagamento de custas."
                        },
                        {
                            "numero": "296º",
                            "rotulo": "Art. 296º.",
                            "linha": 2282,
                            "caput": "A tutela provisória conserva sua eficácia na pendência do processo, mas pode, a qualquer tempo, ser revogada ou modificada.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2284,
                                    "texto": "Salvo decisão judicial em contrário, a tutela provisória conservará a eficácia durante o período de suspensão do processo."
                                }
                            ]
                        },
                        {
                            "numero": "297º",
                            "rotulo": "Art. 297º.",
                            "linha": 2286,
                            "caput": "O juiz poderá determinar as medidas que considerar adequadas para efetivação da tutela provisória.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2288,
                                    "texto": "A efetivação da tutela provisória observará as normas referentes ao cumprimento provisório da sentença, no que couber."
                                }
                            ]
                        },
                        {
                            "numero": "298º",
                            "rotulo": "Art. 298º.",
                            "linha": 2290,
                            "caput": "Na decisão que conceder, negar, modificar ou revogar a tutela provisória, o juiz motivará seu convencimento de modo claro e preciso."
                        },
                        {
                            "numero": "299º",
                            "rotulo": "Art. 299º.",
                            "linha": 2292,
                            "caput": "A tutela provisória será requerida ao juízo da causa e, quando antecedente, ao juízo competente para conhecer do pedido principal.",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2294,
                                    "texto": "Ressalvada disposição especial, na ação de competência originária de tribunal e nos recursos a tutela provisória será requerida ao órgão jurisdicional competente para apreciar o mérito."
                                }
                            ]
                        }
                    ],
                    "titulo": "DISPOSIÇÕES GERAIS",
                    "linhaTitulo": 2274
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 2296,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 2299,
                            "artigos": [
                                {
                                    "numero": "300º",
                                    "rotulo": "Art. 300º.",
                                    "linha": 2302,
                                    "caput": "A tutela de urgência será concedida quando houver elementos que evidenciem a probabilidade do direito e o perigo de dano ou o risco ao resultado útil do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2304,
                                            "texto": "Para a concessão da tutela de urgência, o juiz pode, conforme o caso, exigir caução real ou fidejussória idônea para ressarcir os danos que a outra parte possa vir a sofrer, podendo a caução ser dispensada se a parte economicamente hipossuficiente não puder oferecê-la."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2306,
                                            "texto": "A tutela de urgência pode ser concedida liminarmente ou após justificação prévia."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2308,
                                            "texto": "A tutela de urgência de natureza antecipada não será concedida quando houver perigo de irreversibilidade dos efeitos da decisão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "301º",
                                    "rotulo": "Art. 301º.",
                                    "linha": 2310,
                                    "caput": "A tutela de urgência de natureza cautelar pode ser efetivada mediante arresto, sequestro, arrolamento de bens, registro de protesto contra alienação de bem e qualquer outra medida idônea para asseguração do direito."
                                },
                                {
                                    "numero": "302º",
                                    "rotulo": "Art. 302º.",
                                    "linha": 2312,
                                    "caput": "Independentemente da reparação por dano processual, a parte responde pelo prejuízo que a efetivação da tutela de urgência causar à parte adversa, se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2322,
                                            "texto": "A indenização será liquidada nos autos em que a medida tiver sido concedida, sempre que possível."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2314,
                                            "texto": "a sentença lhe for desfavorável;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2316,
                                            "texto": "obtida liminarmente a tutela em caráter antecedente, não fornecer os meios necessários para a citação do requerido no prazo de 5 (cinco) dias;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2318,
                                            "texto": "ocorrer a cessação da eficácia da medida em qualquer hipótese legal;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2320,
                                            "texto": "o juiz acolher a alegação de decadência ou prescrição da pretensão do autor."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 2300
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 2324,
                            "artigos": [
                                {
                                    "numero": "303º",
                                    "rotulo": "Art. 303º.",
                                    "linha": 2327,
                                    "caput": "Nos casos em que a urgência for contemporânea à propositura da ação, a petição inicial pode limitar-se ao requerimento da tutela antecipada e à indicação do pedido de tutela final, com a exposição da lide, do direito que se busca realizar e do perigo de dano ou do risco ao resultado útil do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2329,
                                            "texto": "Concedida a tutela antecipada a que se refere o caput deste artigo:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 2331,
                                                    "texto": "o autor deverá aditar a petição inicial, com a complementação de sua argumentação, a juntada de novos documentos e a confirmação do pedido de tutela final, em 15 (quinze) dias ou em outro prazo maior que o juiz fixar;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 2333,
                                                    "texto": "o réu será citado e intimado para a audiência de conciliação ou de mediação na forma do art. 334;",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 334",
                                                            "href": "#art334",
                                                            "inicio": 88,
                                                            "fim": 96
                                                        }
                                                    ]
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 2335,
                                                    "texto": "não havendo autocomposição, o prazo para contestação será contado na forma do art. 335.",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 335",
                                                            "href": "#art335",
                                                            "inicio": 78,
                                                            "fim": 86
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2337,
                                            "texto": "Não realizado o aditamento a que se refere o inciso I do § 1º deste artigo, o processo será extinto sem resolução do mérito."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2339,
                                            "texto": "O aditamento a que se refere o inciso I do § 1º deste artigo dar-se-á nos mesmos autos, sem incidência de novas custas processuais."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2341,
                                            "texto": "Na petição inicial a que se refere o caput deste artigo, o autor terá de indicar o valor da causa, que deve levar em consideração o pedido de tutela final."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2343,
                                            "texto": "O autor indicará na petição inicial, ainda, que pretende valer-se do benefício previsto no caput deste artigo."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2345,
                                            "texto": "Caso entenda que não há elementos para a concessão de tutela antecipada, o órgão jurisdicional determinará a emenda da petição inicial em até 5 (cinco) dias, sob pena de ser indeferida e de o processo ser extinto sem resolução de mérito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "304º",
                                    "rotulo": "Art. 304º.",
                                    "linha": 2347,
                                    "caput": "A tutela antecipada, concedida nos termos do art. 303, torna-se estável se da decisão que a conceder não for interposto o respectivo recurso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2349,
                                            "texto": "No caso previsto no caput , o processo será extinto."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2351,
                                            "texto": "Qualquer das partes poderá demandar a outra com o intuito de rever, reformar ou invalidar a tutela antecipada estabilizada nos termos do caput ."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2353,
                                            "texto": "A tutela antecipada conservará seus efeitos enquanto não revista, reformada ou invalidada por decisão de mérito proferida na ação de que trata o § 2º."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2355,
                                            "texto": "Qualquer das partes poderá requerer o desarquivamento dos autos em que foi concedida a medida, para instruir a petição inicial da ação a que se refere o § 2º, prevento o juízo em que a tutela antecipada foi concedida."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2357,
                                            "texto": "O direito de rever, reformar ou invalidar a tutela antecipada, previsto no § 2º deste artigo, extingue-se após 2 (dois) anos, contados da ciência da decisão que extinguiu o processo, nos termos do § 1º."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2359,
                                            "texto": "A decisão que concede a tutela não fará coisa julgada, mas a estabilidade dos respectivos efeitos só será afastada por decisão que a revir, reformar ou invalidar, proferida em ação ajuizada por uma das partes, nos termos do § 2º deste artigo."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 303",
                                            "href": "#art303",
                                            "inicio": 45,
                                            "fim": 53
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO PROCEDIMENTO DA TUTELA ANTECIPADA REQUERIDA EM CARÁTER ANTECEDENTE",
                            "linhaTitulo": 2325
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 2361,
                            "artigos": [
                                {
                                    "numero": "305º",
                                    "rotulo": "Art. 305º.",
                                    "linha": 2364,
                                    "caput": "A petição inicial da ação que visa à prestação de tutela cautelar em caráter antecedente indicará a lide e seu fundamento, a exposição sumária do direito que se objetiva assegurar e o perigo de dano ou o risco ao resultado útil do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2366,
                                            "texto": "Caso entenda que o pedido a que se refere o caput tem natureza antecipada, o juiz observará o disposto no art. 303.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 303",
                                                    "href": "#art303",
                                                    "inicio": 106,
                                                    "fim": 114
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "306º",
                                    "rotulo": "Art. 306º.",
                                    "linha": 2368,
                                    "caput": "O réu será citado para, no prazo de 5 (cinco) dias, contestar o pedido e indicar as provas que pretende produzir."
                                },
                                {
                                    "numero": "307º",
                                    "rotulo": "Art. 307º.",
                                    "linha": 2370,
                                    "caput": "Não sendo contestado o pedido, os fatos alegados pelo autor presumir-se-ão aceitos pelo réu como ocorridos, caso em que o juiz decidirá dentro de 5 (cinco) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2372,
                                            "texto": "Contestado o pedido no prazo legal, observar-se-á o procedimento comum."
                                        }
                                    ]
                                },
                                {
                                    "numero": "308º",
                                    "rotulo": "Art. 308º.",
                                    "linha": 2374,
                                    "caput": "Efetivada a tutela cautelar, o pedido principal terá de ser formulado pelo autor no prazo de 30 (trinta) dias, caso em que será apresentado nos mesmos autos em que deduzido o pedido de tutela cautelar, não dependendo do adiantamento de novas custas processuais.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2376,
                                            "texto": "O pedido principal pode ser formulado conjuntamente com o pedido de tutela cautelar."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2378,
                                            "texto": "A causa de pedir poderá ser aditada no momento de formulação do pedido principal."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2380,
                                            "texto": "Apresentado o pedido principal, as partes serão intimadas para a audiência de conciliação ou de mediação, na forma do art. 334, por seus advogados ou pessoalmente, sem necessidade de nova citação do réu.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 334",
                                                    "href": "#art334",
                                                    "inicio": 118,
                                                    "fim": 126
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2382,
                                            "texto": "Não havendo autocomposição, o prazo para contestação será contado na forma do art. 335.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 335",
                                                    "href": "#art335",
                                                    "inicio": 78,
                                                    "fim": 86
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "309º",
                                    "rotulo": "Art. 309º.",
                                    "linha": 2384,
                                    "caput": "Cessa a eficácia da tutela concedida em caráter antecedente, se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2392,
                                            "texto": "Se por qualquer motivo cessar a eficácia da tutela cautelar, é vedado à parte renovar o pedido, salvo sob novo fundamento."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2386,
                                            "texto": "o autor não deduzir o pedido principal no prazo legal;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2388,
                                            "texto": "não for efetivada dentro de 30 (trinta) dias;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2390,
                                            "texto": "o juiz julgar improcedente o pedido principal formulado pelo autor ou extinguir o processo sem resolução de mérito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "310º",
                                    "rotulo": "Art. 310º.",
                                    "linha": 2394,
                                    "caput": "O indeferimento da tutela cautelar não obsta a que a parte formule o pedido principal, nem influi no julgamento desse, salvo se o motivo do indeferimento for o reconhecimento de decadência ou de prescrição."
                                }
                            ],
                            "titulo": "DO PROCEDIMENTO DA TUTELA CAUTELAR REQUERIDA EM CARÁTER ANTECEDENTE",
                            "linhaTitulo": 2362
                        }
                    ],
                    "titulo": "DA TUTELA DE URGÊNCIA",
                    "linhaTitulo": 2297
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 2396,
                    "artigos": [
                        {
                            "numero": "311º",
                            "rotulo": "Art. 311º.",
                            "linha": 2399,
                            "caput": "A tutela da evidência será concedida, independentemente da demonstração de perigo de dano ou de risco ao resultado útil do processo, quando:",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 2409,
                                    "texto": "Nas hipóteses dos incisos II e III, o juiz poderá decidir liminarmente."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 2401,
                                    "texto": "ficar caracterizado o abuso do direito de defesa ou o manifesto propósito protelatório da parte;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 2403,
                                    "texto": "as alegações de fato puderem ser comprovadas apenas documentalmente e houver tese firmada em julgamento de casos repetitivos ou em súmula vinculante;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 2405,
                                    "texto": "se tratar de pedido reipersecutório fundado em prova documental adequada do contrato de depósito, caso em que será decretada a ordem de entrega do objeto custodiado, sob cominação de multa;"
                                },
                                {
                                    "numero": "IV",
                                    "rotulo": "IV",
                                    "linha": 2407,
                                    "texto": "a petição inicial for instruída com prova documental suficiente dos fatos constitutivos do direito do autor, a que o réu não oponha prova capaz de gerar dúvida razoável."
                                }
                            ]
                        }
                    ],
                    "titulo": "DA TUTELA DA EVIDÊNCIA",
                    "linhaTitulo": 2397
                }
            ],
            "titulo": "DA TUTELA PROVISÓRIA",
            "linhaTitulo": 2271
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO VI",
            "linha": 2411,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 2414,
                    "artigos": [
                        {
                            "numero": "312º",
                            "rotulo": "Art. 312º.",
                            "linha": 2417,
                            "caput": "Considera-se proposta a ação quando a petição inicial for protocolada, todavia, a propositura da ação só produz quanto ao réu os efeitos mencionados no art. 240 depois que for validamente citado.",
                            "links": [
                                {
                                    "campo": "caput",
                                    "texto": "art. 240",
                                    "href": "#art240",
                                    "inicio": 152,
                                    "fim": 160
                                }
                            ]
                        }
                    ],
                    "titulo": "DA FORMAÇÃO DO PROCESSO",
                    "linhaTitulo": 2415
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 2419,
                    "artigos": [
                        {
                            "numero": "313º",
                            "rotulo": "Art. 313º.",
                            "linha": 2422,
                            "caput": "Suspende-se o processo:",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 2448,
                                    "texto": "Na hipótese do inciso I, o juiz suspenderá o processo, nos termos do art. 689.",
                                    "links": [
                                        {
                                            "campo": "texto",
                                            "texto": "art. 689",
                                            "href": "#art689",
                                            "inicio": 69,
                                            "fim": 77
                                        }
                                    ]
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 2450,
                                    "texto": "Não ajuizada ação de habilitação, ao tomar conhecimento da morte, o juiz determinará a suspensão do processo e observará o seguinte:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2452,
                                            "texto": "falecido o réu, ordenará a intimação do autor para que promova a citação do respectivo espólio, de quem for o sucessor ou, se for o caso, dos herdeiros, no prazo que designar, de no mínimo 2 (dois) e no máximo 6 (seis) meses;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2454,
                                            "texto": "falecido o autor e sendo transmissível o direito em litígio, determinará a intimação de seu espólio, de quem for o sucessor ou, se for o caso, dos herdeiros, pelos meios de divulgação que reputar mais adequados, para que manifestem interesse na sucessão processual e promovam a respectiva habilitação no prazo designado, sob pena de extinção do processo sem resolução de mérito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 2456,
                                    "texto": "No caso de morte do procurador de qualquer das partes, ainda que iniciada a audiência de instrução e julgamento, o juiz determinará que a parte constitua novo mandatário, no prazo de 15 (quinze) dias, ao final do qual extinguirá o processo sem resolução de mérito, se o autor não nomear novo mandatário, ou ordenará o prosseguimento do processo à revelia do réu, se falecido o procurador deste."
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 2458,
                                    "texto": "O prazo de suspensão do processo nunca poderá exceder 1 (um) ano nas hipóteses do inciso V e 6 (seis) meses naquela prevista no inciso II."
                                },
                                {
                                    "numero": "5º",
                                    "rotulo": "§ 5º",
                                    "linha": 2460,
                                    "texto": "O juiz determinará o prosseguimento do processo assim que esgotados os prazos previstos no § 4º."
                                },
                                {
                                    "numero": "6º",
                                    "rotulo": "§ 6º",
                                    "linha": 2462,
                                    "texto": "No caso do inciso IX, o período de suspensão será de 30 (trinta) dias, contado a partir da data do parto ou da concessão da adoção, mediante apresentação de certidão de nascimento ou documento similar que comprove a realização do parto, ou de termo judicial que tenha concedido a adoção, desde que haja notificação ao cliente."
                                },
                                {
                                    "numero": "7º",
                                    "rotulo": "§ 7º",
                                    "linha": 2464,
                                    "texto": "No caso do inciso X, o período de suspensão será de 8 (oito) dias, contado a partir da data do parto ou da concessão da adoção, mediante apresentação de certidão de nascimento ou documento similar que comprove a realização do parto, ou de termo judicial que tenha concedido a adoção, desde que haja notificação ao cliente."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 2424,
                                    "texto": "pela morte ou pela perda da capacidade processual de qualquer das partes, de seu representante legal ou de seu procurador;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 2426,
                                    "texto": "pela convenção das partes;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 2428,
                                    "texto": "pela arguição de impedimento ou de suspeição;"
                                },
                                {
                                    "numero": "IV",
                                    "rotulo": "IV",
                                    "linha": 2430,
                                    "texto": "pela admissão de incidente de resolução de demandas repetitivas;"
                                },
                                {
                                    "numero": "V",
                                    "rotulo": "V",
                                    "linha": 2432,
                                    "texto": "quando a sentença de mérito:",
                                    "alineas": [
                                        {
                                            "letra": "a",
                                            "rotulo": "a)",
                                            "linha": 2434,
                                            "texto": "depender do julgamento de outra causa ou da declaração de existência ou de inexistência de relação jurídica que constitua o objeto principal de outro processo pendente;"
                                        },
                                        {
                                            "letra": "b",
                                            "rotulo": "b)",
                                            "linha": 2436,
                                            "texto": "tiver de ser proferida somente após a verificação de determinado fato ou a produção de certa prova, requisitada a outro juízo;"
                                        }
                                    ]
                                },
                                {
                                    "numero": "VI",
                                    "rotulo": "VI",
                                    "linha": 2438,
                                    "texto": "por motivo de força maior;"
                                },
                                {
                                    "numero": "VII",
                                    "rotulo": "VII",
                                    "linha": 2440,
                                    "texto": "quando se discutir em juízo questão decorrente de acidentes e fatos da navegação de competência do Tribunal Marítimo;"
                                },
                                {
                                    "numero": "VIII",
                                    "rotulo": "VIII",
                                    "linha": 2442,
                                    "texto": "nos demais casos que este Código regula."
                                },
                                {
                                    "numero": "IX",
                                    "rotulo": "IX",
                                    "linha": 2444,
                                    "texto": "pelo parto ou pela concessão de adoção, quando a advogada responsável pelo processo constituir a única patrona da causa;"
                                },
                                {
                                    "numero": "X",
                                    "rotulo": "X",
                                    "linha": 2446,
                                    "texto": "quando o advogado responsável pelo processo constituir o único patrono da causa e tornar-se pai."
                                }
                            ]
                        },
                        {
                            "numero": "314º",
                            "rotulo": "Art. 314º.",
                            "linha": 2466,
                            "caput": "Durante a suspensão é vedado praticar qualquer ato processual, podendo o juiz, todavia, determinar a realização de atos urgentes a fim de evitar dano irreparável, salvo no caso de arguição de impedimento e de suspeição."
                        },
                        {
                            "numero": "315º",
                            "rotulo": "Art. 315º.",
                            "linha": 2468,
                            "caput": "Se o conhecimento do mérito depender de verificação da existência de fato delituoso, o juiz pode determinar a suspensão do processo até que se pronuncie a justiça criminal.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 2470,
                                    "texto": "Se a ação penal não for proposta no prazo de 3 (três) meses, contado da intimação do ato de suspensão, cessará o efeito desse, incumbindo ao juiz cível examinar incidentemente a questão prévia."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 2472,
                                    "texto": "Proposta a ação penal, o processo ficará suspenso pelo prazo máximo de 1 (um) ano, ao final do qual aplicar-se-á o disposto na parte final do § 1º."
                                }
                            ]
                        }
                    ],
                    "titulo": "DA SUSPENSÃO DO PROCESSO",
                    "linhaTitulo": 2420
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 2474,
                    "divisoes": [
                        {
                            "tipo": "parte",
                            "rotulo": "PARTE ESPECIAL",
                            "linha": 2481
                        }
                    ],
                    "artigos": [
                        {
                            "numero": "316º",
                            "rotulo": "Art. 316º.",
                            "linha": 2477,
                            "caput": "A extinção do processo dar-se-á por sentença."
                        },
                        {
                            "numero": "317º",
                            "rotulo": "Art. 317º.",
                            "linha": 2479,
                            "caput": "Antes de proferir decisão sem resolução de mérito, o juiz deverá conceder à parte oportunidade para, se possível, corrigir o vício."
                        }
                    ],
                    "titulo": "DA EXTINÇÃO DO PROCESSO",
                    "linhaTitulo": 2475
                }
            ],
            "titulo": "DA FORMAÇÃO, DA SUSPENSÃO E DA EXTINÇÃO DO PROCESSO",
            "linhaTitulo": 2412
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO I",
            "linha": 2483,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 2486,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 2489,
                            "artigos": [
                                {
                                    "numero": "318º",
                                    "rotulo": "Art. 318º.",
                                    "linha": 2492,
                                    "caput": "Aplica-se a todas as causas o procedimento comum, salvo disposição em contrário deste Código ou de lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2494,
                                            "texto": "O procedimento comum aplica-se subsidiariamente aos demais procedimentos especiais e ao processo de execução."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 2490
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 2496,
                            "artigos": [
                                {
                                    "numero": "319º",
                                    "rotulo": "Art. 319º.",
                                    "linha": 2502,
                                    "caput": "A petição inicial indicará:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2518,
                                            "texto": "Caso não disponha das informações previstas no inciso II, poderá o autor, na petição inicial, requerer ao juiz diligências necessárias a sua obtenção."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2520,
                                            "texto": "A petição inicial não será indeferida se, a despeito da falta de informações a que se refere o inciso II, for possível a citação do réu."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2522,
                                            "texto": "A petição inicial não será indeferida pelo não atendimento ao disposto no inciso II deste artigo se a obtenção de tais informações tornar impossível ou excessivamente oneroso o acesso à justiça."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2504,
                                            "texto": "o juízo a que é dirigida;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2506,
                                            "texto": "os nomes, os prenomes, o estado civil, a existência de união estável, a profissão, o número de inscrição no Cadastro de Pessoas Físicas ou no Cadastro Nacional da Pessoa Jurídica, o endereço eletrônico, o domicílio e a residência do autor e do réu;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2508,
                                            "texto": "o fato e os fundamentos jurídicos do pedido;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2510,
                                            "texto": "o pedido com as suas especificações;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 2512,
                                            "texto": "o valor da causa;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 2514,
                                            "texto": "as provas com que o autor pretende demonstrar a verdade dos fatos alegados;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 2516,
                                            "texto": "a opção do autor pela realização ou não de audiência de conciliação ou de mediação."
                                        }
                                    ],
                                    "rubrica": "Dos Requisitos da Petição Inicial",
                                    "linhaRubrica": 2500
                                },
                                {
                                    "numero": "320º",
                                    "rotulo": "Art. 320º.",
                                    "linha": 2524,
                                    "caput": "A petição inicial será instruída com os documentos indispensáveis à propositura da ação."
                                },
                                {
                                    "numero": "321º",
                                    "rotulo": "Art. 321º.",
                                    "linha": 2526,
                                    "caput": "O juiz, ao verificar que a petição inicial não preenche os requisitos dos arts. 319 e 320 ou que apresenta defeitos e irregularidades capazes de dificultar o julgamento de mérito, determinará que o autor, no prazo de 15 (quinze) dias, a emende ou a complete, indicando com precisão o que deve ser corrigido ou completado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2528,
                                            "texto": "Se o autor não cumprir a diligência, o juiz indeferirá a petição inicial. Seção II"
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 319 e 320",
                                            "href": "#art319",
                                            "inicio": 74,
                                            "fim": 89
                                        }
                                    ]
                                },
                                {
                                    "numero": "322º",
                                    "rotulo": "Art. 322º.",
                                    "linha": 2533,
                                    "caput": "O pedido deve ser certo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2535,
                                            "texto": "Compreendem-se no principal os juros legais, a correção monetária e as verbas de sucumbência, inclusive os honorários advocatícios."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2537,
                                            "texto": "A interpretação do pedido considerará o conjunto da postulação e observará o princípio da boa-fé."
                                        }
                                    ],
                                    "rubrica": "Do Pedido",
                                    "linhaRubrica": 2531
                                },
                                {
                                    "numero": "323º",
                                    "rotulo": "Art. 323º.",
                                    "linha": 2539,
                                    "caput": "Na ação que tiver por objeto cumprimento de obrigação em prestações sucessivas, essas serão consideradas incluídas no pedido, independentemente de declaração expressa do autor, e serão incluídas na condenação, enquanto durar a obrigação, se o devedor, no curso do processo, deixar de pagá-las ou de consigná-las."
                                },
                                {
                                    "numero": "324º",
                                    "rotulo": "Art. 324º.",
                                    "linha": 2541,
                                    "caput": "O pedido deve ser determinado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2543,
                                            "texto": "É lícito, porém, formular pedido genérico:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 2545,
                                                    "texto": "nas ações universais, se o autor não puder individuar os bens demandados;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 2547,
                                                    "texto": "quando não for possível determinar, desde logo, as consequências do ato ou do fato;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 2549,
                                                    "texto": "quando a determinação do objeto ou do valor da condenação depender de ato que deva ser praticado pelo réu."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2551,
                                            "texto": "O disposto neste artigo aplica-se à reconvenção."
                                        }
                                    ]
                                },
                                {
                                    "numero": "325º",
                                    "rotulo": "Art. 325º.",
                                    "linha": 2553,
                                    "caput": "O pedido será alternativo quando, pela natureza da obrigação, o devedor puder cumprir a prestação de mais de um modo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2555,
                                            "texto": "Quando, pela lei ou pelo contrato, a escolha couber ao devedor, o juiz lhe assegurará o direito de cumprir a prestação de um ou de outro modo, ainda que o autor não tenha formulado pedido alternativo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "326º",
                                    "rotulo": "Art. 326º.",
                                    "linha": 2557,
                                    "caput": "É lícito formular mais de um pedido em ordem subsidiária, a fim de que o juiz conheça do posterior, quando não acolher o anterior.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2559,
                                            "texto": "É lícito formular mais de um pedido, alternativamente, para que o juiz acolha um deles."
                                        }
                                    ]
                                },
                                {
                                    "numero": "327º",
                                    "rotulo": "Art. 327º.",
                                    "linha": 2561,
                                    "caput": "É lícita a cumulação, em um único processo, contra o mesmo réu, de vários pedidos, ainda que entre eles não haja conexão.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2563,
                                            "texto": "São requisitos de admissibilidade da cumulação que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 2565,
                                                    "texto": "os pedidos sejam compatíveis entre si;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 2567,
                                                    "texto": "seja competente para conhecer deles o mesmo juízo;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 2569,
                                                    "texto": "seja adequado para todos os pedidos o tipo de procedimento."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2571,
                                            "texto": "Quando, para cada pedido, corresponder tipo diverso de procedimento, será admitida a cumulação se o autor empregar o procedimento comum, sem prejuízo do emprego das técnicas processuais diferenciadas previstas nos procedimentos especiais a que se sujeitam um ou mais pedidos cumulados, que não forem incompatíveis com as disposições sobre o procedimento comum."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2573,
                                            "texto": "O inciso I do § 1º não se aplica às cumulações de pedidos de que trata o art. 326.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 326",
                                                    "href": "#art326",
                                                    "inicio": 73,
                                                    "fim": 81
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "328º",
                                    "rotulo": "Art. 328º.",
                                    "linha": 2575,
                                    "caput": "Na obrigação indivisível com pluralidade de credores, aquele que não participou do processo receberá sua parte, deduzidas as despesas na proporção de seu crédito."
                                },
                                {
                                    "numero": "329º",
                                    "rotulo": "Art. 329º.",
                                    "linha": 2577,
                                    "caput": "O autor poderá:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2583,
                                            "texto": "Aplica-se o disposto neste artigo à reconvenção e à respectiva causa de pedir. Seção III"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2579,
                                            "texto": "até a citação, aditar ou alterar o pedido ou a causa de pedir, independentemente de consentimento do réu;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2581,
                                            "texto": "até o saneamento do processo, aditar ou alterar o pedido e a causa de pedir, com consentimento do réu, assegurado o contraditório mediante a possibilidade de manifestação deste no prazo mínimo de 15 (quinze) dias, facultado o requerimento de prova suplementar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "330º",
                                    "rotulo": "Art. 330º.",
                                    "linha": 2588,
                                    "caput": "A petição inicial será indeferida quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2598,
                                            "texto": "Considera-se inepta a petição inicial quando:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 2600,
                                                    "texto": "lhe faltar pedido ou causa de pedir;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 2602,
                                                    "texto": "o pedido for indeterminado, ressalvadas as hipóteses legais em que se permite o pedido genérico;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 2604,
                                                    "texto": "da narração dos fatos não decorrer logicamente a conclusão;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 2606,
                                                    "texto": "contiver pedidos incompatíveis entre si."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2608,
                                            "texto": "Nas ações que tenham por objeto a revisão de obrigação decorrente de empréstimo, de financiamento ou de alienação de bens, o autor terá de, sob pena de inépcia, discriminar na petição inicial, dentre as obrigações contratuais, aquelas que pretende controverter, além de quantificar o valor incontroverso do débito."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2610,
                                            "texto": "Na hipótese do § 2º, o valor incontroverso deverá continuar a ser pago no tempo e modo contratados."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2590,
                                            "texto": "for inepta;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2592,
                                            "texto": "a parte for manifestamente ilegítima;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2594,
                                            "texto": "o autor carecer de interesse processual;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2596,
                                            "texto": "não atendidas as prescrições dos arts. 106 e 321.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 106",
                                                    "href": "#art106",
                                                    "inicio": 33,
                                                    "fim": 42
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "321",
                                                    "href": "#art321",
                                                    "inicio": 45,
                                                    "fim": 48
                                                }
                                            ]
                                        }
                                    ],
                                    "rubrica": "Do Indeferimento da Petição Inicial",
                                    "linhaRubrica": 2586
                                },
                                {
                                    "numero": "331º",
                                    "rotulo": "Art. 331º.",
                                    "linha": 2612,
                                    "caput": "Indeferida a petição inicial, o autor poderá apelar, facultado ao juiz, no prazo de 5 (cinco) dias, retratar-se.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2614,
                                            "texto": "Se não houver retratação, o juiz mandará citar o réu para responder ao recurso."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2616,
                                            "texto": "Sendo a sentença reformada pelo tribunal, o prazo para a contestação começará a correr da intimação do retorno dos autos, observado o disposto no art. 334.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 334",
                                                    "href": "#art334",
                                                    "inicio": 146,
                                                    "fim": 154
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2618,
                                            "texto": "Não interposta a apelação, o réu será intimado do trânsito em julgado da sentença."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA PETIÇÃO INICIAL",
                            "linhaTitulo": 2497
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 2620,
                            "artigos": [
                                {
                                    "numero": "332º",
                                    "rotulo": "Art. 332º.",
                                    "linha": 2623,
                                    "caput": "Nas causas que dispensem a fase instrutória, o juiz, independentemente da citação do réu, julgará liminarmente improcedente o pedido que contrariar:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2633,
                                            "texto": "O juiz também poderá julgar liminarmente improcedente o pedido se verificar, desde logo, a ocorrência de decadência ou de prescrição."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2635,
                                            "texto": "Não interposta a apelação, o réu será intimado do trânsito em julgado da sentença, nos termos do art. 241.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 241",
                                                    "href": "#art241",
                                                    "inicio": 97,
                                                    "fim": 105
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2637,
                                            "texto": "Interposta a apelação, o juiz poderá retratar-se em 5 (cinco) dias."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2639,
                                            "texto": "Se houver retratação, o juiz determinará o prosseguimento do processo, com a citação do réu, e, se não houver retratação, determinará a citação do réu para apresentar contrarrazões, no prazo de 15 (quinze) dias."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2625,
                                            "texto": "enunciado de súmula do Supremo Tribunal Federal ou do Superior Tribunal de Justiça;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2627,
                                            "texto": "acórdão proferido pelo Supremo Tribunal Federal ou pelo Superior Tribunal de Justiça em julgamento de recursos repetitivos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2629,
                                            "texto": "entendimento firmado em incidente de resolução de demandas repetitivas ou de assunção de competência;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2631,
                                            "texto": "enunciado de súmula de tribunal de justiça sobre direito local."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA IMPROCEDÊNCIA LIMINAR DO PEDIDO",
                            "linhaTitulo": 2621
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 2641,
                            "artigos": [
                                {
                                    "numero": "334º",
                                    "rotulo": "Art. 334º.",
                                    "linha": 2644,
                                    "caput": "Se a petição inicial preencher os requisitos essenciais e não for o caso de improcedência liminar do pedido, o juiz designará audiência de conciliação ou de mediação com antecedência mínima de 30 (trinta) dias, devendo ser citado o réu com pelo menos 20 (vinte) dias de antecedência.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2646,
                                            "texto": "O conciliador ou mediador, onde houver, atuará necessariamente na audiência de conciliação ou de mediação, observando o disposto neste Código, bem como as disposições da lei de organização judiciária."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2648,
                                            "texto": "Poderá haver mais de uma sessão destinada à conciliação e à mediação, não podendo exceder a 2 (dois) meses da data de realização da primeira sessão, desde que necessárias à composição das partes."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2650,
                                            "texto": "A intimação do autor para a audiência será feita na pessoa de seu advogado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2652,
                                            "texto": "A audiência não será realizada:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 2654,
                                                    "texto": "se ambas as partes manifestarem, expressamente, desinteresse na composição consensual;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 2656,
                                                    "texto": "quando não se admitir a autocomposição."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2658,
                                            "texto": "O autor deverá indicar, na petição inicial, seu desinteresse na autocomposição, e o réu deverá fazê-lo, por petição, apresentada com 10 (dez) dias de antecedência, contados da data da audiência."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2660,
                                            "texto": "Havendo litisconsórcio, o desinteresse na realização da audiência deve ser manifestado por todos os litisconsortes."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 2662,
                                            "texto": "A audiência de conciliação ou de mediação pode realizar-se por meio eletrônico, nos termos da lei."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 2664,
                                            "texto": "O não comparecimento injustificado do autor ou do réu à audiência de conciliação é considerado ato atentatório à dignidade da justiça e será sancionado com multa de até dois por cento da vantagem econômica pretendida ou do valor da causa, revertida em favor da União ou do Estado."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 2666,
                                            "texto": "As partes devem estar acompanhadas por seus advogados ou defensores públicos."
                                        },
                                        {
                                            "numero": "10º",
                                            "rotulo": "§ 10º",
                                            "linha": 2668,
                                            "texto": "A parte poderá constituir representante, por meio de procuração específica, com poderes para negociar e transigir."
                                        },
                                        {
                                            "numero": "11º",
                                            "rotulo": "§ 11º",
                                            "linha": 2670,
                                            "texto": "A autocomposição obtida será reduzida a termo e homologada por sentença."
                                        },
                                        {
                                            "numero": "12º",
                                            "rotulo": "§ 12º",
                                            "linha": 2672,
                                            "texto": "A pauta das audiências de conciliação ou de mediação será organizada de modo a respeitar o intervalo mínimo de 20 (vinte) minutos entre o início de uma e o início da seguinte."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA AUDIÊNCIA DE CONCILIAÇÃO OU DE MEDIAÇÃO",
                            "linhaTitulo": 2642
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VI",
                            "linha": 2674,
                            "artigos": [
                                {
                                    "numero": "335º",
                                    "rotulo": "Art. 335º.",
                                    "linha": 2677,
                                    "caput": "O réu poderá oferecer contestação, por petição, no prazo de 15 (quinze) dias, cujo termo inicial será a data:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2685,
                                            "texto": "No caso de litisconsórcio passivo, ocorrendo a hipótese do art. 334, § 6º, o termo inicial previsto no inciso II será, para cada um dos réus, a data de apresentação de seu respectivo pedido de cancelamento da audiência.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 334",
                                                    "href": "#art334",
                                                    "inicio": 59,
                                                    "fim": 67
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2687,
                                            "texto": "Quando ocorrer a hipótese do art. 334, § 4º, inciso II, havendo litisconsórcio passivo e o autor desistir da ação em relação a réu ainda não citado, o prazo para resposta correrá da data de intimação da decisão que homologar a desistência.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 334",
                                                    "href": "#art334",
                                                    "inicio": 29,
                                                    "fim": 37
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2679,
                                            "texto": "da audiência de conciliação ou de mediação, ou da última sessão de conciliação, quando qualquer parte não comparecer ou, comparecendo, não houver autocomposição;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2681,
                                            "texto": "do protocolo do pedido de cancelamento da audiência de conciliação ou de mediação apresentado pelo réu, quando ocorrer a hipótese do art. 334, § 4º, inciso I;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 334",
                                                    "href": "#art334",
                                                    "inicio": 133,
                                                    "fim": 141
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2683,
                                            "texto": "prevista no art. 231, de acordo com o modo como foi feita a citação, nos demais casos.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 231",
                                                    "href": "#art231",
                                                    "inicio": 12,
                                                    "fim": 20
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "336º",
                                    "rotulo": "Art. 336º.",
                                    "linha": 2689,
                                    "caput": "Incumbe ao réu alegar, na contestação, toda a matéria de defesa, expondo as razões de fato e de direito com que impugna o pedido do autor e especificando as provas que pretende produzir."
                                },
                                {
                                    "numero": "337º",
                                    "rotulo": "Art. 337º.",
                                    "linha": 2691,
                                    "caput": "Incumbe ao réu, antes de discutir o mérito, alegar:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2719,
                                            "texto": "Verifica-se a litispendência ou a coisa julgada quando se reproduz ação anteriormente ajuizada."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2721,
                                            "texto": "Uma ação é idêntica a outra quando possui as mesmas partes, a mesma causa de pedir e o mesmo pedido."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2723,
                                            "texto": "Há litispendência quando se repete ação que está em curso."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2725,
                                            "texto": "Há coisa julgada quando se repete ação que já foi decidida por decisão transitada em julgado."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2727,
                                            "texto": "Excetuadas a convenção de arbitragem e a incompetência relativa, o juiz conhecerá de ofício das matérias enumeradas neste artigo."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2729,
                                            "texto": "A ausência de alegação da existência de convenção de arbitragem, na forma prevista neste Capítulo, implica aceitação da jurisdição estatal e renúncia ao juízo arbitral."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2693,
                                            "texto": "inexistência ou nulidade da citação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2695,
                                            "texto": "incompetência absoluta e relativa;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2697,
                                            "texto": "incorreção do valor da causa;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2699,
                                            "texto": "inépcia da petição inicial;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 2701,
                                            "texto": "perempção;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 2703,
                                            "texto": "litispendência;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 2705,
                                            "texto": "coisa julgada;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 2707,
                                            "texto": "conexão;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 2709,
                                            "texto": "incapacidade da parte, defeito de representação ou falta de autorização;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 2711,
                                            "texto": "convenção de arbitragem;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 2713,
                                            "texto": "ausência de legitimidade ou de interesse processual;"
                                        },
                                        {
                                            "numero": "XII",
                                            "rotulo": "XII",
                                            "linha": 2715,
                                            "texto": "falta de caução ou de outra prestação que a lei exige como preliminar;"
                                        },
                                        {
                                            "numero": "XIII",
                                            "rotulo": "XIII",
                                            "linha": 2717,
                                            "texto": "indevida concessão do benefício de gratuidade de justiça."
                                        }
                                    ]
                                },
                                {
                                    "numero": "338º",
                                    "rotulo": "Art. 338º.",
                                    "linha": 2731,
                                    "caput": "Alegando o réu, na contestação, ser parte ilegítima ou não ser o responsável pelo prejuízo invocado, o juiz facultará ao autor, em 15 (quinze) dias, a alteração da petição inicial para substituição do réu.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2733,
                                            "texto": "Realizada a substituição, o autor reembolsará as despesas e pagará os honorários ao procurador do réu excluído, que serão fixados entre três e cinco por cento do valor da causa ou, sendo este irrisório, nos termos do art. 85, § 8º."
                                        }
                                    ]
                                },
                                {
                                    "numero": "339º",
                                    "rotulo": "Art. 339º.",
                                    "linha": 2735,
                                    "caput": "Quando alegar sua ilegitimidade, incumbe ao réu indicar o sujeito passivo da relação jurídica discutida sempre que tiver conhecimento, sob pena de arcar com as despesas processuais e de indenizar o autor pelos prejuízos decorrentes da falta de indicação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2737,
                                            "texto": "O autor, ao aceitar a indicação, procederá, no prazo de 15 (quinze) dias, à alteração da petição inicial para a substituição do réu, observando-se, ainda, o parágrafo único do art. 338.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 338",
                                                    "href": "#art338",
                                                    "inicio": 176,
                                                    "fim": 184
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2739,
                                            "texto": "No prazo de 15 (quinze) dias, o autor pode optar por alterar a petição inicial para incluir, como litisconsorte passivo, o sujeito indicado pelo réu."
                                        }
                                    ]
                                },
                                {
                                    "numero": "340º",
                                    "rotulo": "Art. 340º.",
                                    "linha": 2741,
                                    "caput": "Havendo alegação de incompetência relativa ou absoluta, a contestação poderá ser protocolada no foro de domicílio do réu, fato que será imediatamente comunicado ao juiz da causa, preferencialmente por meio eletrônico.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2743,
                                            "texto": "A contestação será submetida a livre distribuição ou, se o réu houver sido citado por meio de carta precatória, juntada aos autos dessa carta, seguindo-se a sua imediata remessa para o juízo da causa."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2745,
                                            "texto": "Reconhecida a competência do foro indicado pelo réu, o juízo para o qual for distribuída a contestação ou a carta precatória será considerado prevento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2747,
                                            "texto": "Alegada a incompetência nos termos do caput , será suspensa a realização da audiência de conciliação ou de mediação, se tiver sido designada."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2749,
                                            "texto": "Definida a competência, o juízo competente designará nova data para a audiência de conciliação ou de mediação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "341º",
                                    "rotulo": "Art. 341º.",
                                    "linha": 2751,
                                    "caput": "Incumbe também ao réu manifestar-se precisamente sobre as alegações de fato constantes da petição inicial, presumindo-se verdadeiras as não impugnadas, salvo se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2759,
                                            "texto": "O ônus da impugnação especificada dos fatos não se aplica ao defensor público, ao advogado dativo e ao curador especial."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2753,
                                            "texto": "não for admissível, a seu respeito, a confissão;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2755,
                                            "texto": "a petição inicial não estiver acompanhada de instrumento que a lei considerar da substância do ato;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2757,
                                            "texto": "estiverem em contradição com a defesa, considerada em seu conjunto."
                                        }
                                    ]
                                },
                                {
                                    "numero": "342º",
                                    "rotulo": "Art. 342º.",
                                    "linha": 2761,
                                    "caput": "Depois da contestação, só é lícito ao réu deduzir novas alegações quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2763,
                                            "texto": "relativas a direito ou a fato superveniente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2765,
                                            "texto": "competir ao juiz conhecer delas de ofício;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2767,
                                            "texto": "por expressa autorização legal, puderem ser formuladas em qualquer tempo e grau de jurisdição."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA CONTESTAÇÃO",
                            "linhaTitulo": 2675
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VII",
                            "linha": 2769,
                            "artigos": [
                                {
                                    "numero": "343º",
                                    "rotulo": "Art. 343º.",
                                    "linha": 2772,
                                    "caput": "Na contestação, é lícito ao réu propor reconvenção para manifestar pretensão própria, conexa com a ação principal ou com o fundamento da defesa.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2774,
                                            "texto": "Proposta a reconvenção, o autor será intimado, na pessoa de seu advogado, para apresentar resposta no prazo de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2776,
                                            "texto": "A desistência da ação ou a ocorrência de causa extintiva que impeça o exame de seu mérito não obsta ao prosseguimento do processo quanto à reconvenção."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2778,
                                            "texto": "A reconvenção pode ser proposta contra o autor e terceiro."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2780,
                                            "texto": "A reconvenção pode ser proposta pelo réu em litisconsórcio com terceiro."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2782,
                                            "texto": "Se o autor for substituto processual, o reconvinte deverá afirmar ser titular de direito em face do substituído, e a reconvenção deverá ser proposta em face do autor, também na qualidade de substituto processual."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2784,
                                            "texto": "O réu pode propor reconvenção independentemente de oferecer contestação."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA RECONVENÇÃO",
                            "linhaTitulo": 2770
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VIII",
                            "linha": 2786,
                            "artigos": [
                                {
                                    "numero": "344º",
                                    "rotulo": "Art. 344º.",
                                    "linha": 2789,
                                    "caput": "Se o réu não contestar a ação, será considerado revel e presumir-se-ão verdadeiras as alegações de fato formuladas pelo autor."
                                },
                                {
                                    "numero": "345º",
                                    "rotulo": "Art. 345º.",
                                    "linha": 2791,
                                    "caput": "A revelia não produz o efeito mencionado no art. 344 se:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2793,
                                            "texto": "havendo pluralidade de réus, algum deles contestar a ação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2795,
                                            "texto": "o litígio versar sobre direitos indisponíveis;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2797,
                                            "texto": "a petição inicial não estiver acompanhada de instrumento que a lei considere indispensável à prova do ato;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2799,
                                            "texto": "as alegações de fato formuladas pelo autor forem inverossímeis ou estiverem em contradição com prova constante dos autos."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 344",
                                            "href": "#art344",
                                            "inicio": 44,
                                            "fim": 52
                                        }
                                    ]
                                },
                                {
                                    "numero": "346º",
                                    "rotulo": "Art. 346º.",
                                    "linha": 2801,
                                    "caput": "Os prazos contra o revel que não tenha patrono nos autos fluirão da data de publicação do ato decisório no órgão oficial.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2803,
                                            "texto": "O revel poderá intervir no processo em qualquer fase, recebendo-o no estado em que se encontrar."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA REVELIA",
                            "linhaTitulo": 2787
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IX",
                            "linha": 2805,
                            "artigos": [
                                {
                                    "numero": "347º",
                                    "rotulo": "Art. 347º.",
                                    "linha": 2808,
                                    "caput": "Findo o prazo para a contestação, o juiz tomará, conforme o caso, as providências preliminares constantes das seções deste Capítulo. Seção I"
                                },
                                {
                                    "numero": "348º",
                                    "rotulo": "Art. 348º.",
                                    "linha": 2813,
                                    "caput": "Se o réu não contestar a ação, o juiz, verificando a inocorrência do efeito da revelia previsto no art. 344, ordenará que o autor especifique as provas que pretenda produzir, se ainda não as tiver indicado.",
                                    "rubrica": "Da Não Incidência dos Efeitos da Revelia",
                                    "linhaRubrica": 2811,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 344",
                                            "href": "#art344",
                                            "inicio": 99,
                                            "fim": 107
                                        }
                                    ]
                                },
                                {
                                    "numero": "349º",
                                    "rotulo": "Art. 349º.",
                                    "linha": 2815,
                                    "caput": "Ao réu revel será lícita a produção de provas, contrapostas às alegações do autor, desde que se faça representar nos autos a tempo de praticar os atos processuais indispensáveis a essa produção. Seção II"
                                },
                                {
                                    "numero": "350º",
                                    "rotulo": "Art. 350º.",
                                    "linha": 2820,
                                    "caput": "Se o réu alegar fato impeditivo, modificativo ou extintivo do direito do autor, este será ouvido no prazo de 15 (quinze) dias, permitindo-lhe o juiz a produção de prova. Seção III",
                                    "rubrica": "Do Fato Impeditivo, Modificativo ou Extintivo do Direito do Autor",
                                    "linhaRubrica": 2818
                                },
                                {
                                    "numero": "351º",
                                    "rotulo": "Art. 351º.",
                                    "linha": 2825,
                                    "caput": "Se o réu alegar qualquer das matérias enumeradas no art. 337, o juiz determinará a oitiva do autor no prazo de 15 (quinze) dias, permitindo-lhe a produção de prova.",
                                    "rubrica": "Das Alegações do Réu",
                                    "linhaRubrica": 2823,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 337",
                                            "href": "#art337",
                                            "inicio": 52,
                                            "fim": 60
                                        }
                                    ]
                                },
                                {
                                    "numero": "352º",
                                    "rotulo": "Art. 352º.",
                                    "linha": 2827,
                                    "caput": "Verificando a existência de irregularidades ou de vícios sanáveis, o juiz determinará sua correção em prazo nunca superior a 30 (trinta) dias."
                                },
                                {
                                    "numero": "353º",
                                    "rotulo": "Art. 353º.",
                                    "linha": 2829,
                                    "caput": "Cumpridas as providências preliminares ou não havendo necessidade delas, o juiz proferirá julgamento conforme o estado do processo, observando o que dispõe o Capítulo X."
                                }
                            ],
                            "titulo": "DAS PROVIDÊNCIAS PRELIMINARES E DO SANEAMENTO",
                            "linhaTitulo": 2806
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO X",
                            "linha": 2831,
                            "artigos": [
                                {
                                    "numero": "354º",
                                    "rotulo": "Art. 354º.",
                                    "linha": 2837,
                                    "caput": "Ocorrendo qualquer das hipóteses previstas nos arts. 485 e 487, incisos II e III, o juiz proferirá sentença.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2839,
                                            "texto": "A decisão a que se refere o caput pode dizer respeito a apenas parcela do processo, caso em que será impugnável por agravo de instrumento. Seção II"
                                        }
                                    ],
                                    "rubrica": "Da Extinção do Processo",
                                    "linhaRubrica": 2835,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 485",
                                            "href": "#art485",
                                            "inicio": 47,
                                            "fim": 56
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "487",
                                            "href": "#art487",
                                            "inicio": 59,
                                            "fim": 62
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "487, incisos II e III",
                                            "href": "#art487ii",
                                            "inicio": 59,
                                            "fim": 80
                                        }
                                    ]
                                },
                                {
                                    "numero": "355º",
                                    "rotulo": "Art. 355º.",
                                    "linha": 2844,
                                    "caput": "O juiz julgará antecipadamente o pedido, proferindo sentença com resolução de mérito, quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2846,
                                            "texto": "não houver necessidade de produção de outras provas;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2848,
                                            "texto": "o réu for revel, ocorrer o efeito previsto no art. 344 e não houver requerimento de prova, na forma do art. 349. Seção III",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 344",
                                                    "href": "#art344",
                                                    "inicio": 46,
                                                    "fim": 54
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 349",
                                                    "href": "#art349",
                                                    "inicio": 103,
                                                    "fim": 111
                                                }
                                            ]
                                        }
                                    ],
                                    "rubrica": "Do Julgamento Antecipado do Mérito",
                                    "linhaRubrica": 2842
                                },
                                {
                                    "numero": "356º",
                                    "rotulo": "Art. 356º.",
                                    "linha": 2853,
                                    "caput": "O juiz decidirá parcialmente o mérito quando um ou mais dos pedidos formulados ou parcela deles:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2859,
                                            "texto": "A decisão que julgar parcialmente o mérito poderá reconhecer a existência de obrigação líquida ou ilíquida."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2861,
                                            "texto": "A parte poderá liquidar ou executar, desde logo, a obrigação reconhecida na decisão que julgar parcialmente o mérito, independentemente de caução, ainda que haja recurso contra essa interposto."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2863,
                                            "texto": "Na hipótese do § 2º, se houver trânsito em julgado da decisão, a execução será definitiva."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2865,
                                            "texto": "A liquidação e o cumprimento da decisão que julgar parcialmente o mérito poderão ser processados em autos suplementares, a requerimento da parte ou a critério do juiz."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2867,
                                            "texto": "A decisão proferida com base neste artigo é impugnável por agravo de instrumento. Seção IV"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2855,
                                            "texto": "mostrar-se incontroverso;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2857,
                                            "texto": "estiver em condições de imediato julgamento, nos termos do art. 355.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 355",
                                                    "href": "#art355",
                                                    "inicio": 59,
                                                    "fim": 67
                                                }
                                            ]
                                        }
                                    ],
                                    "rubrica": "Do Julgamento Antecipado Parcial do Mérito",
                                    "linhaRubrica": 2851
                                },
                                {
                                    "numero": "357º",
                                    "rotulo": "Art. 357º.",
                                    "linha": 2872,
                                    "caput": "Não ocorrendo nenhuma das hipóteses deste Capítulo, deverá o juiz, em decisão de saneamento e de organização do processo:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2884,
                                            "texto": "Realizado o saneamento, as partes têm o direito de pedir esclarecimentos ou solicitar ajustes, no prazo comum de 5 (cinco) dias, findo o qual a decisão se torna estável."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2886,
                                            "texto": "As partes podem apresentar ao juiz, para homologação, delimitação consensual das questões de fato e de direito a que se referem os incisos II e IV, a qual, se homologada, vincula as partes e o juiz."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2888,
                                            "texto": "Se a causa apresentar complexidade em matéria de fato ou de direito, deverá o juiz designar audiência para que o saneamento seja feito em cooperação com as partes, oportunidade em que o juiz, se for o caso, convidará as partes a integrar ou esclarecer suas alegações."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2890,
                                            "texto": "Caso tenha sido determinada a produção de prova testemunhal, o juiz fixará prazo comum não superior a 15 (quinze) dias para que as partes apresentem rol de testemunhas."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2892,
                                            "texto": "Na hipótese do § 3º, as partes devem levar, para a audiência prevista, o respectivo rol de testemunhas."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2894,
                                            "texto": "O número de testemunhas arroladas não pode ser superior a 10 (dez), sendo 3 (três), no máximo, para a prova de cada fato."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 2896,
                                            "texto": "O juiz poderá limitar o número de testemunhas levando em conta a complexidade da causa e dos fatos individualmente considerados."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 2898,
                                            "texto": "Caso tenha sido determinada a produção de prova pericial, o juiz deve observar o disposto no art. 465 e, se possível, estabelecer, desde logo, calendário para sua realização.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 465",
                                                    "href": "#art465",
                                                    "inicio": 93,
                                                    "fim": 101
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 2900,
                                            "texto": "As pautas deverão ser preparadas com intervalo mínimo de 1 (uma) hora entre as audiências."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2874,
                                            "texto": "resolver as questões processuais pendentes, se houver;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2876,
                                            "texto": "delimitar as questões de fato sobre as quais recairá a atividade probatória, especificando os meios de prova admitidos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2878,
                                            "texto": "definir a distribuição do ônus da prova, observado o art. 373;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 373",
                                                    "href": "#art373",
                                                    "inicio": 53,
                                                    "fim": 61
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2880,
                                            "texto": "delimitar as questões de direito relevantes para a decisão do mérito;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 2882,
                                            "texto": "designar, se necessário, audiência de instrução e julgamento."
                                        }
                                    ],
                                    "rubrica": "Do Saneamento e da Organização do Processo",
                                    "linhaRubrica": 2870
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DO JULGAMENTO CONFORME O ESTADO DO PROCESSO",
                            "linhaTitulo": 2832
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XI",
                            "linha": 2902,
                            "artigos": [
                                {
                                    "numero": "358º",
                                    "rotulo": "Art. 358º.",
                                    "linha": 2905,
                                    "caput": "No dia e na hora designados, o juiz declarará aberta a audiência de instrução e julgamento e mandará apregoar as partes e os respectivos advogados, bem como outras pessoas que dela devam participar."
                                },
                                {
                                    "numero": "359º",
                                    "rotulo": "Art. 359º.",
                                    "linha": 2907,
                                    "caput": "Instalada a audiência, o juiz tentará conciliar as partes, independentemente do emprego anterior de outros métodos de solução consensual de conflitos, como a mediação e a arbitragem."
                                },
                                {
                                    "numero": "360º",
                                    "rotulo": "Art. 360º.",
                                    "linha": 2909,
                                    "caput": "O juiz exerce o poder de polícia, incumbindo-lhe:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2911,
                                            "texto": "manter a ordem e o decoro na audiência;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2913,
                                            "texto": "ordenar que se retirem da sala de audiência os que se comportarem inconvenientemente;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2915,
                                            "texto": "requisitar, quando necessário, força policial;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 2917,
                                            "texto": "tratar com urbanidade as partes, os advogados, os membros do Ministério Público e da Defensoria Pública e qualquer pessoa que participe do processo;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 2919,
                                            "texto": "registrar em ata, com exatidão, todos os requerimentos apresentados em audiência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "361º",
                                    "rotulo": "Art. 361º.",
                                    "linha": 2921,
                                    "caput": "As provas orais serão produzidas em audiência, ouvindo-se nesta ordem, preferencialmente:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2929,
                                            "texto": "Enquanto depuserem o perito, os assistentes técnicos, as partes e as testemunhas, não poderão os advogados e o Ministério Público intervir ou apartear, sem licença do juiz."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2923,
                                            "texto": "o perito e os assistentes técnicos, que responderão aos quesitos de esclarecimentos requeridos no prazo e na forma do art. 477, caso não respondidos anteriormente por escrito;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 477",
                                                    "href": "#art477",
                                                    "inicio": 118,
                                                    "fim": 126
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2925,
                                            "texto": "o autor e, em seguida, o réu, que prestarão depoimentos pessoais;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2927,
                                            "texto": "as testemunhas arroladas pelo autor e pelo réu, que serão inquiridas."
                                        }
                                    ]
                                },
                                {
                                    "numero": "362º",
                                    "rotulo": "Art. 362º.",
                                    "linha": 2931,
                                    "caput": "A audiência poderá ser adiada:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2939,
                                            "texto": "O impedimento deverá ser comprovado até a abertura da audiência, e, não o sendo, o juiz procederá à instrução."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2941,
                                            "texto": "O juiz poderá dispensar a produção das provas requeridas pela parte cujo advogado ou defensor público não tenha comparecido à audiência, aplicando-se a mesma regra ao Ministério Público."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2943,
                                            "texto": "Quem der causa ao adiamento responderá pelas despesas acrescidas."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2933,
                                            "texto": "por convenção das partes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2935,
                                            "texto": "se não puder comparecer, por motivo justificado, qualquer pessoa que dela deva necessariamente participar;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 2937,
                                            "texto": "por atraso injustificado de seu início em tempo superior a 30 (trinta) minutos do horário marcado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "363º",
                                    "rotulo": "Art. 363º.",
                                    "linha": 2945,
                                    "caput": "Havendo antecipação ou adiamento da audiência, o juiz, de ofício ou a requerimento da parte, determinará a intimação dos advogados ou da sociedade de advogados para ciência da nova designação."
                                },
                                {
                                    "numero": "364º",
                                    "rotulo": "Art. 364º.",
                                    "linha": 2947,
                                    "caput": "Finda a instrução, o juiz dará a palavra ao advogado do autor e do réu, bem como ao membro do Ministério Público, se for o caso de sua intervenção, sucessivamente, pelo prazo de 20 (vinte) minutos para cada um, prorrogável por 10 (dez) minutos, a critério do juiz.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2949,
                                            "texto": "Havendo litisconsorte ou terceiro interveniente, o prazo, que formará com o da prorrogação um só todo, dividir-se-á entre os do mesmo grupo, se não convencionarem de modo diverso."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2951,
                                            "texto": "Quando a causa apresentar questões complexas de fato ou de direito, o debate oral poderá ser substituído por razões finais escritas, que serão apresentadas pelo autor e pelo réu, bem como pelo Ministério Público, se for o caso de sua intervenção, em prazos sucessivos de 15 (quinze) dias, assegurada vista dos autos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "365º",
                                    "rotulo": "Art. 365º.",
                                    "linha": 2953,
                                    "caput": "A audiência é una e contínua, podendo ser excepcional e justificadamente cindida na ausência de perito ou de testemunha, desde que haja concordância das partes.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2955,
                                            "texto": "Diante da impossibilidade de realização da instrução, do debate e do julgamento no mesmo dia, o juiz marcará seu prosseguimento para a data mais próxima possível, em pauta preferencial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "366º",
                                    "rotulo": "Art. 366º.",
                                    "linha": 2957,
                                    "caput": "Encerrado o debate ou oferecidas as razões finais, o juiz proferirá sentença em audiência ou no prazo de 30 (trinta) dias."
                                },
                                {
                                    "numero": "367º",
                                    "rotulo": "Art. 367º.",
                                    "linha": 2959,
                                    "caput": "O servidor lavrará, sob ditado do juiz, termo que conterá, em resumo, o ocorrido na audiência, bem como, por extenso, os despachos, as decisões e a sentença, se proferida no ato.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2961,
                                            "texto": "Quando o termo não for registrado em meio eletrônico, o juiz rubricar-lhe-á as folhas, que serão encadernadas em volume próprio."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2963,
                                            "texto": "Subscreverão o termo o juiz, os advogados, o membro do Ministério Público e o escrivão ou chefe de secretaria, dispensadas as partes, exceto quando houver ato de disposição para cuja prática os advogados não tenham poderes."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 2965,
                                            "texto": "O escrivão ou chefe de secretaria trasladará para os autos cópia autêntica do termo de audiência."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 2967,
                                            "texto": "Tratando-se de autos eletrônicos, observar-se-á o disposto neste Código, em legislação específica e nas normas internas dos tribunais."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 2969,
                                            "texto": "A audiência poderá ser integralmente gravada em imagem e em áudio, em meio digital ou analógico, desde que assegure o rápido acesso das partes e dos órgãos julgadores, observada a legislação específica."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 2971,
                                            "texto": "A gravação a que se refere o § 5º também pode ser realizada diretamente por qualquer das partes, independentemente de autorização judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "368º",
                                    "rotulo": "Art. 368º.",
                                    "linha": 2973,
                                    "caput": "A audiência será pública, ressalvadas as exceções legais."
                                }
                            ],
                            "titulo": "DA AUDIÊNCIA DE INSTRUÇÃO E JULGAMENTO",
                            "linhaTitulo": 2903
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XII",
                            "linha": 2975,
                            "artigos": [
                                {
                                    "numero": "369º",
                                    "rotulo": "Art. 369º.",
                                    "linha": 2981,
                                    "caput": "As partes têm o direito de empregar todos os meios legais, bem como os moralmente legítimos, ainda que não especificados neste Código, para provar a verdade dos fatos em que se funda o pedido ou a defesa e influir eficazmente na convicção do juiz.",
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 2979
                                },
                                {
                                    "numero": "370º",
                                    "rotulo": "Art. 370º.",
                                    "linha": 2983,
                                    "caput": "Caberá ao juiz, de ofício ou a requerimento da parte, determinar as provas necessárias ao julgamento do mérito.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 2985,
                                            "texto": "O juiz indeferirá, em decisão fundamentada, as diligências inúteis ou meramente protelatórias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "371º",
                                    "rotulo": "Art. 371º.",
                                    "linha": 2987,
                                    "caput": "O juiz apreciará a prova constante dos autos, independentemente do sujeito que a tiver promovido, e indicará na decisão as razões da formação de seu convencimento."
                                },
                                {
                                    "numero": "372º",
                                    "rotulo": "Art. 372º.",
                                    "linha": 2989,
                                    "caput": "O juiz poderá admitir a utilização de prova produzida em outro processo, atribuindo-lhe o valor que considerar adequado, observado o contraditório."
                                },
                                {
                                    "numero": "373º",
                                    "rotulo": "Art. 373º.",
                                    "linha": 2991,
                                    "caput": "O ônus da prova incumbe:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 2997,
                                            "texto": "Nos casos previstos em lei ou diante de peculiaridades da causa relacionadas à impossibilidade ou à excessiva dificuldade de cumprir o encargo nos termos do caput ou à maior facilidade de obtenção da prova do fato contrário, poderá o juiz atribuir o ônus da prova de modo diverso, desde que o faça por decisão fundamentada, caso em que deverá dar à parte a oportunidade de se desincumbir do ônus que lhe foi atribuído."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 2999,
                                            "texto": "A decisão prevista no § 1º deste artigo não pode gerar situação em que a desincumbência do encargo pela parte seja impossível ou excessivamente difícil."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3001,
                                            "texto": "A distribuição diversa do ônus da prova também pode ocorrer por convenção das partes, salvo quando:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3003,
                                                    "texto": "recair sobre direito indisponível da parte;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3005,
                                                    "texto": "tornar excessivamente difícil a uma parte o exercício do direito."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3007,
                                            "texto": "A convenção de que trata o § 3º pode ser celebrada antes ou durante o processo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 2993,
                                            "texto": "ao autor, quanto ao fato constitutivo de seu direito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 2995,
                                            "texto": "ao réu, quanto à existência de fato impeditivo, modificativo ou extintivo do direito do autor."
                                        }
                                    ]
                                },
                                {
                                    "numero": "374º",
                                    "rotulo": "Art. 374º.",
                                    "linha": 3009,
                                    "caput": "Não dependem de prova os fatos:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3011,
                                            "texto": "notórios;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3013,
                                            "texto": "afirmados por uma parte e confessados pela parte contrária;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3015,
                                            "texto": "admitidos no processo como incontroversos;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3017,
                                            "texto": "em cujo favor milita presunção legal de existência ou de veracidade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "375º",
                                    "rotulo": "Art. 375º.",
                                    "linha": 3019,
                                    "caput": "O juiz aplicará as regras de experiência comum subministradas pela observação do que ordinariamente acontece e, ainda, as regras de experiência técnica, ressalvado, quanto a estas, o exame pericial."
                                },
                                {
                                    "numero": "376º",
                                    "rotulo": "Art. 376º.",
                                    "linha": 3021,
                                    "caput": "A parte que alegar direito municipal, estadual, estrangeiro ou consuetudinário provar-lhe-á o teor e a vigência, se assim o juiz determinar."
                                },
                                {
                                    "numero": "377º",
                                    "rotulo": "Art. 377º.",
                                    "linha": 3023,
                                    "caput": "A carta precatória, a carta rogatória e o auxílio direto suspenderão o julgamento da causa no caso previsto no art. 313, inciso V, alínea “b”, quando, tendo sido requeridos antes da decisão de saneamento, a prova neles solicitada for imprescindível.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3025,
                                            "texto": "A carta precatória e a carta rogatória não devolvidas no prazo ou concedidas sem efeito suspensivo poderão ser juntadas aos autos a qualquer momento."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 313",
                                            "href": "#art313",
                                            "inicio": 111,
                                            "fim": 119
                                        }
                                    ]
                                },
                                {
                                    "numero": "378º",
                                    "rotulo": "Art. 378º.",
                                    "linha": 3027,
                                    "caput": "Ninguém se exime do dever de colaborar com o Poder Judiciário para o descobrimento da verdade."
                                },
                                {
                                    "numero": "379º",
                                    "rotulo": "Art. 379º.",
                                    "linha": 3029,
                                    "caput": "Preservado o direito de não produzir prova contra si própria, incumbe à parte:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3031,
                                            "texto": "comparecer em juízo, respondendo ao que lhe for interrogado;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3033,
                                            "texto": "colaborar com o juízo na realização de inspeção judicial que for considerada necessária;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3035,
                                            "texto": "praticar o ato que lhe for determinado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "380º",
                                    "rotulo": "Art. 380º.",
                                    "linha": 3037,
                                    "caput": "Incumbe ao terceiro, em relação a qualquer causa:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3043,
                                            "texto": "Poderá o juiz, em caso de descumprimento, determinar, além da imposição de multa, outras medidas indutivas, coercitivas, mandamentais ou sub-rogatórias. Seção II"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3039,
                                            "texto": "informar ao juiz os fatos e as circunstâncias de que tenha conhecimento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3041,
                                            "texto": "exibir coisa ou documento que esteja em seu poder."
                                        }
                                    ]
                                },
                                {
                                    "numero": "381º",
                                    "rotulo": "Art. 381º.",
                                    "linha": 3048,
                                    "caput": "A produção antecipada da prova será admitida nos casos em que:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3056,
                                            "texto": "O arrolamento de bens observará o disposto nesta Seção quando tiver por finalidade apenas a realização de documentação e não a prática de atos de apreensão."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3058,
                                            "texto": "A produção antecipada da prova é da competência do juízo do foro onde esta deva ser produzida ou do foro de domicílio do réu."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3060,
                                            "texto": "A produção antecipada da prova não previne a competência do juízo para a ação que venha a ser proposta."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3062,
                                            "texto": "O juízo estadual tem competência para produção antecipada de prova requerida em face da União, de entidade autárquica ou de empresa pública federal se, na localidade, não houver vara federal."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 3064,
                                            "texto": "Aplica-se o disposto nesta Seção àquele que pretender justificar a existência de algum fato ou relação jurídica para simples documento e sem caráter contencioso, que exporá, em petição circunstanciada, a sua intenção."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3050,
                                            "texto": "haja fundado receio de que venha a tornar-se impossível ou muito difícil a verificação de certos fatos na pendência da ação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3052,
                                            "texto": "a prova a ser produzida seja suscetível de viabilizar a autocomposição ou outro meio adequado de solução de conflito;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3054,
                                            "texto": "o prévio conhecimento dos fatos possa justificar ou evitar o ajuizamento de ação."
                                        }
                                    ],
                                    "rubrica": "Da Produção Antecipada da Prova",
                                    "linhaRubrica": 3046
                                },
                                {
                                    "numero": "382º",
                                    "rotulo": "Art. 382º.",
                                    "linha": 3066,
                                    "caput": "Na petição, o requerente apresentará as razões que justificam a necessidade de antecipação da prova e mencionará com precisão os fatos sobre os quais a prova há de recair.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3068,
                                            "texto": "O juiz determinará, de ofício ou a requerimento da parte, a citação de interessados na produção da prova ou no fato a ser provado, salvo se inexistente caráter contencioso."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3070,
                                            "texto": "O juiz não se pronunciará sobre a ocorrência ou a inocorrência do fato, nem sobre as respectivas consequências jurídicas."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3072,
                                            "texto": "Os interessados poderão requerer a produção de qualquer prova no mesmo procedimento, desde que relacionada ao mesmo fato, salvo se a sua produção conjunta acarretar excessiva demora."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3074,
                                            "texto": "Neste procedimento, não se admitirá defesa ou recurso, salvo contra decisão que indeferir totalmente a produção da prova pleiteada pelo requerente originário."
                                        }
                                    ]
                                },
                                {
                                    "numero": "383º",
                                    "rotulo": "Art. 383º.",
                                    "linha": 3076,
                                    "caput": "Os autos permanecerão em cartório durante 1 (um) mês para extração de cópias e certidões pelos interessados.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3078,
                                            "texto": "Findo o prazo, os autos serão entregues ao promovente da medida. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "384º",
                                    "rotulo": "Art. 384º.",
                                    "linha": 3083,
                                    "caput": "A existência e o modo de existir de algum fato podem ser atestados ou documentados, a requerimento do interessado, mediante ata lavrada por tabelião.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3085,
                                            "texto": "Dados representados por imagem ou som gravados em arquivos eletrônicos poderão constar da ata notarial. Seção IV"
                                        }
                                    ],
                                    "rubrica": "Da Ata Notarial",
                                    "linhaRubrica": 3081
                                },
                                {
                                    "numero": "385º",
                                    "rotulo": "Art. 385º.",
                                    "linha": 3090,
                                    "caput": "Cabe à parte requerer o depoimento pessoal da outra parte, a fim de que esta seja interrogada na audiência de instrução e julgamento, sem prejuízo do poder do juiz de ordená-lo de ofício.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3092,
                                            "texto": "Se a parte, pessoalmente intimada para prestar depoimento pessoal e advertida da pena de confesso, não comparecer ou, comparecendo, se recusar a depor, o juiz aplicar-lhe-á a pena."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3094,
                                            "texto": "É vedado a quem ainda não depôs assistir ao interrogatório da outra parte."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3096,
                                            "texto": "O depoimento pessoal da parte que residir em comarca, seção ou subseção judiciária diversa daquela onde tramita o processo poderá ser colhido por meio de videoconferência ou outro recurso tecnológico de transmissão de sons e imagens em tempo real, o que poderá ocorrer, inclusive, durante a realização da audiência de instrução e julgamento."
                                        }
                                    ],
                                    "rubrica": "Do Depoimento Pessoal",
                                    "linhaRubrica": 3088
                                },
                                {
                                    "numero": "386º",
                                    "rotulo": "Art. 386º.",
                                    "linha": 3098,
                                    "caput": "Quando a parte, sem motivo justificado, deixar de responder ao que lhe for perguntado ou empregar evasivas, o juiz, apreciando as demais circunstâncias e os elementos de prova, declarará, na sentença, se houve recusa de depor."
                                },
                                {
                                    "numero": "387º",
                                    "rotulo": "Art. 387º.",
                                    "linha": 3100,
                                    "caput": "A parte responderá pessoalmente sobre os fatos articulados, não podendo servir-se de escritos anteriormente preparados, permitindo-lhe o juiz, todavia, a consulta a notas breves, desde que objetivem completar esclarecimentos."
                                },
                                {
                                    "numero": "388º",
                                    "rotulo": "Art. 388º.",
                                    "linha": 3102,
                                    "caput": "A parte não é obrigada a depor sobre fatos:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3112,
                                            "texto": "Esta disposição não se aplica às ações de estado e de família. Seção V"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3104,
                                            "texto": "criminosos ou torpes que lhe forem imputados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3106,
                                            "texto": "a cujo respeito, por estado ou profissão, deva guardar sigilo;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3108,
                                            "texto": "acerca dos quais não possa responder sem desonra própria, de seu cônjuge, de seu companheiro ou de parente em grau sucessível;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3110,
                                            "texto": "que coloquem em perigo a vida do depoente ou das pessoas referidas no inciso III."
                                        }
                                    ]
                                },
                                {
                                    "numero": "389º",
                                    "rotulo": "Art. 389º.",
                                    "linha": 3117,
                                    "caput": "Há confissão, judicial ou extrajudicial, quando a parte admite a verdade de fato contrário ao seu interesse e favorável ao do adversário.",
                                    "rubrica": "Da Confissão",
                                    "linhaRubrica": 3115
                                },
                                {
                                    "numero": "390º",
                                    "rotulo": "Art. 390º.",
                                    "linha": 3119,
                                    "caput": "A confissão judicial pode ser espontânea ou provocada.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3121,
                                            "texto": "A confissão espontânea pode ser feita pela própria parte ou por representante com poder especial."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3123,
                                            "texto": "A confissão provocada constará do termo de depoimento pessoal."
                                        }
                                    ]
                                },
                                {
                                    "numero": "391º",
                                    "rotulo": "Art. 391º.",
                                    "linha": 3125,
                                    "caput": "A confissão judicial faz prova contra o confitente, não prejudicando, todavia, os litisconsortes.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3127,
                                            "texto": "Nas ações que versarem sobre bens imóveis ou direitos reais sobre imóveis alheios, a confissão de um cônjuge ou companheiro não valerá sem a do outro, salvo se o regime de casamento for o de separação absoluta de bens."
                                        }
                                    ]
                                },
                                {
                                    "numero": "392º",
                                    "rotulo": "Art. 392º.",
                                    "linha": 3129,
                                    "caput": "Não vale como confissão a admissão, em juízo, de fatos relativos a direitos indisponíveis.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3131,
                                            "texto": "A confissão será ineficaz se feita por quem não for capaz de dispor do direito a que se referem os fatos confessados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3133,
                                            "texto": "A confissão feita por um representante somente é eficaz nos limites em que este pode vincular o representado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "393º",
                                    "rotulo": "Art. 393º.",
                                    "linha": 3135,
                                    "caput": "A confissão é irrevogável, mas pode ser anulada se decorreu de erro de fato ou de coação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3137,
                                            "texto": "A legitimidade para a ação prevista no caput é exclusiva do confitente e pode ser transferida a seus herdeiros se ele falecer após a propositura."
                                        }
                                    ]
                                },
                                {
                                    "numero": "394º",
                                    "rotulo": "Art. 394º.",
                                    "linha": 3139,
                                    "caput": "A confissão extrajudicial, quando feita oralmente, só terá eficácia nos casos em que a lei não exija prova literal."
                                },
                                {
                                    "numero": "395º",
                                    "rotulo": "Art. 395º.",
                                    "linha": 3141,
                                    "caput": "A confissão é, em regra, indivisível, não podendo a parte que a quiser invocar como prova aceitá-la no tópico que a beneficiar e rejeitá-la no que lhe for desfavorável, porém cindir-se-á quando o confitente a ela aduzir fatos novos, capazes de constituir fundamento de defesa de direito material ou de reconvenção. Seção VI"
                                },
                                {
                                    "numero": "396º",
                                    "rotulo": "Art. 396º.",
                                    "linha": 3146,
                                    "caput": "O juiz pode ordenar que a parte exiba documento ou coisa que se encontre em seu poder.",
                                    "rubrica": "Da Exibição de Documento ou Coisa",
                                    "linhaRubrica": 3144
                                },
                                {
                                    "numero": "397º",
                                    "rotulo": "Art. 397º.",
                                    "linha": 3148,
                                    "caput": "O pedido formulado pela parte conterá:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3151,
                                            "texto": "a descrição, tão completa quanto possível, do documento ou da coisa, ou das categorias de documentos ou de coisas buscados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3154,
                                            "texto": "a finalidade da prova, com indicação dos fatos que se relacionam com o documento ou com a coisa, ou com suas categorias;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3157,
                                            "texto": "as circunstâncias em que se funda o requerente para afirmar que o documento ou a coisa existe, ainda que a referência seja a categoria de documentos ou de coisas, e se acha em poder da parte contrária."
                                        }
                                    ]
                                },
                                {
                                    "numero": "398º",
                                    "rotulo": "Art. 398º.",
                                    "linha": 3159,
                                    "caput": "O requerido dará sua resposta nos 5 (cinco) dias subsequentes à sua intimação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3161,
                                            "texto": "Se o requerido afirmar que não possui o documento ou a coisa, o juiz permitirá que o requerente prove, por qualquer meio, que a declaração não corresponde à verdade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "399º",
                                    "rotulo": "Art. 399º.",
                                    "linha": 3163,
                                    "caput": "O juiz não admitirá a recusa se:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3165,
                                            "texto": "o requerido tiver obrigação legal de exibir;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3167,
                                            "texto": "o requerido tiver aludido ao documento ou à coisa, no processo, com o intuito de constituir prova;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3169,
                                            "texto": "o documento, por seu conteúdo, for comum às partes."
                                        }
                                    ]
                                },
                                {
                                    "numero": "400º",
                                    "rotulo": "Art. 400º.",
                                    "linha": 3171,
                                    "caput": "Ao decidir o pedido, o juiz admitirá como verdadeiros os fatos que, por meio do documento ou da coisa, a parte pretendia provar se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3177,
                                            "texto": "Sendo necessário, o juiz pode adotar medidas indutivas, coercitivas, mandamentais ou sub-rogatórias para que o documento seja exibido."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3173,
                                            "texto": "o requerido não efetuar a exibição nem fizer nenhuma declaração no prazo do art. 398;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 398",
                                                    "href": "#art398",
                                                    "inicio": 76,
                                                    "fim": 84
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3175,
                                            "texto": "a recusa for havida por ilegítima."
                                        }
                                    ]
                                },
                                {
                                    "numero": "401º",
                                    "rotulo": "Art. 401º.",
                                    "linha": 3179,
                                    "caput": "Quando o documento ou a coisa estiver em poder de terceiro, o juiz ordenará sua citação para responder no prazo de 15 (quinze) dias."
                                },
                                {
                                    "numero": "402º",
                                    "rotulo": "Art. 402º.",
                                    "linha": 3181,
                                    "caput": "Se o terceiro negar a obrigação de exibir ou a posse do documento ou da coisa, o juiz designará audiência especial, tomando-lhe o depoimento, bem como o das partes e, se necessário, o de testemunhas, e em seguida proferirá decisão."
                                },
                                {
                                    "numero": "403º",
                                    "rotulo": "Art. 403º.",
                                    "linha": 3183,
                                    "caput": "Se o terceiro, sem justo motivo, se recusar a efetuar a exibição, o juiz ordenar-lhe-á que proceda ao respectivo depósito em cartório ou em outro lugar designado, no prazo de 5 (cinco) dias, impondo ao requerente que o ressarça pelas despesas que tiver.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3185,
                                            "texto": "Se o terceiro descumprir a ordem, o juiz expedirá mandado de apreensão, requisitando, se necessário, força policial, sem prejuízo da responsabilidade por crime de desobediência, pagamento de multa e outras medidas indutivas, coercitivas, mandamentais ou sub-rogatórias necessárias para assegurar a efetivação da decisão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "404º",
                                    "rotulo": "Art. 404º.",
                                    "linha": 3187,
                                    "caput": "A parte e o terceiro se escusam de exibir, em juízo, o documento ou a coisa se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3201,
                                            "texto": "Se os motivos de que tratam os incisos I a VI do caput disserem respeito a apenas uma parcela do documento, a parte ou o terceiro exibirá a outra em cartório, para dela ser extraída cópia reprográfica, de tudo sendo lavrado auto circunstanciado. Seção VII Da Prova Documental Subseção I"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3189,
                                            "texto": "concernente a negócios da própria vida da família;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3191,
                                            "texto": "sua apresentação puder violar dever de honra;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3193,
                                            "texto": "sua publicidade redundar em desonra à parte ou ao terceiro, bem como a seus parentes consanguíneos ou afins até o terceiro grau, ou lhes representar perigo de ação penal;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3195,
                                            "texto": "sua exibição acarretar a divulgação de fatos a cujo respeito, por estado ou profissão, devam guardar segredo;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 3197,
                                            "texto": "subsistirem outros motivos graves que, segundo o prudente arbítrio do juiz, justifiquem a recusa da exibição;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 3199,
                                            "texto": "houver disposição legal que justifique a recusa da exibição."
                                        }
                                    ]
                                },
                                {
                                    "numero": "405º",
                                    "rotulo": "Art. 405º.",
                                    "linha": 3209,
                                    "caput": "O documento público faz prova não só da sua formação, mas também dos fatos que o escrivão, o chefe de secretaria, o tabelião ou o servidor declarar que ocorreram em sua presença.",
                                    "rubrica": "Da Força Probante dos Documentos",
                                    "linhaRubrica": 3207
                                },
                                {
                                    "numero": "406º",
                                    "rotulo": "Art. 406º.",
                                    "linha": 3211,
                                    "caput": "Quando a lei exigir instrumento público como da substância do ato, nenhuma outra prova, por mais especial que seja, pode suprir-lhe a falta."
                                },
                                {
                                    "numero": "407º",
                                    "rotulo": "Art. 407º.",
                                    "linha": 3213,
                                    "caput": "O documento feito por oficial público incompetente ou sem a observância das formalidades legais, sendo subscrito pelas partes, tem a mesma eficácia probatória do documento particular."
                                },
                                {
                                    "numero": "408º",
                                    "rotulo": "Art. 408º.",
                                    "linha": 3215,
                                    "caput": "As declarações constantes do documento particular escrito e assinado ou somente assinado presumem-se verdadeiras em relação ao signatário.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3217,
                                            "texto": "Quando, todavia, contiver declaração de ciência de determinado fato, o documento particular prova a ciência, mas não o fato em si, incumbindo o ônus de prová-lo ao interessado em sua veracidade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "409º",
                                    "rotulo": "Art. 409º.",
                                    "linha": 3219,
                                    "caput": "A data do documento particular, quando a seu respeito surgir dúvida ou impugnação entre os litigantes, provar-se-á por todos os meios de direito.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3221,
                                            "texto": "Em relação a terceiros, considerar-se-á datado o documento particular:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3223,
                                                    "texto": "no dia em que foi registrado;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3225,
                                                    "texto": "desde a morte de algum dos signatários;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3227,
                                                    "texto": "a partir da impossibilidade física que sobreveio a qualquer dos signatários;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 3229,
                                                    "texto": "da sua apresentação em repartição pública ou em juízo;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 3231,
                                                    "texto": "do ato ou do fato que estabeleça, de modo certo, a anterioridade da formação do documento."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "410º",
                                    "rotulo": "Art. 410º.",
                                    "linha": 3233,
                                    "caput": "Considera-se autor do documento particular:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3235,
                                            "texto": "aquele que o fez e o assinou;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3237,
                                            "texto": "aquele por conta de quem ele foi feito, estando assinado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3239,
                                            "texto": "aquele que, mandando compô-lo, não o firmou porque, conforme a experiência comum, não se costuma assinar, como livros empresariais e assentos domésticos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "411º",
                                    "rotulo": "Art. 411º.",
                                    "linha": 3241,
                                    "caput": "Considera-se autêntico o documento quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3243,
                                            "texto": "o tabelião reconhecer a firma do signatário;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3245,
                                            "texto": "a autoria estiver identificada por qualquer outro meio legal de certificação, inclusive eletrônico, nos termos da lei;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3247,
                                            "texto": "não houver impugnação da parte contra quem foi produzido o documento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "412º",
                                    "rotulo": "Art. 412º.",
                                    "linha": 3249,
                                    "caput": "O documento particular de cuja autenticidade não se duvida prova que o seu autor fez a declaração que lhe é atribuída.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3251,
                                            "texto": "O documento particular admitido expressa ou tacitamente é indivisível, sendo vedado à parte que pretende utilizar-se dele aceitar os fatos que lhe são favoráveis e recusar os que são contrários ao seu interesse, salvo se provar que estes não ocorreram."
                                        }
                                    ]
                                },
                                {
                                    "numero": "413º",
                                    "rotulo": "Art. 413º.",
                                    "linha": 3253,
                                    "caput": "O telegrama, o radiograma ou qualquer outro meio de transmissão tem a mesma força probatória do documento particular se o original constante da estação expedidora tiver sido assinado pelo remetente.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3255,
                                            "texto": "A firma do remetente poderá ser reconhecida pelo tabelião, declarando-se essa circunstância no original depositado na estação expedidora."
                                        }
                                    ]
                                },
                                {
                                    "numero": "414º",
                                    "rotulo": "Art. 414º.",
                                    "linha": 3257,
                                    "caput": "O telegrama ou o radiograma presume-se conforme com o original, provando as datas de sua expedição e de seu recebimento pelo destinatário."
                                },
                                {
                                    "numero": "415º",
                                    "rotulo": "Art. 415º.",
                                    "linha": 3259,
                                    "caput": "As cartas e os registros domésticos provam contra quem os escreveu quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3261,
                                            "texto": "enunciam o recebimento de um crédito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3263,
                                            "texto": "contêm anotação que visa a suprir a falta de título em favor de quem é apontado como credor;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3265,
                                            "texto": "expressam conhecimento de fatos para os quais não se exija determinada prova."
                                        }
                                    ]
                                },
                                {
                                    "numero": "416º",
                                    "rotulo": "Art. 416º.",
                                    "linha": 3267,
                                    "caput": "A nota escrita pelo credor em qualquer parte de documento representativo de obrigação, ainda que não assinada, faz prova em benefício do devedor.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3269,
                                            "texto": "Aplica-se essa regra tanto para o documento que o credor conservar em seu poder quanto para aquele que se achar em poder do devedor ou de terceiro."
                                        }
                                    ]
                                },
                                {
                                    "numero": "417º",
                                    "rotulo": "Art. 417º.",
                                    "linha": 3271,
                                    "caput": "Os livros empresariais provam contra seu autor, sendo lícito ao empresário, todavia, demonstrar, por todos os meios permitidos em direito, que os lançamentos não correspondem à verdade dos fatos."
                                },
                                {
                                    "numero": "418º",
                                    "rotulo": "Art. 418º.",
                                    "linha": 3273,
                                    "caput": "Os livros empresariais que preencham os requisitos exigidos por lei provam a favor de seu autor no litígio entre empresários."
                                },
                                {
                                    "numero": "419º",
                                    "rotulo": "Art. 419º.",
                                    "linha": 3275,
                                    "caput": "A escrituração contábil é indivisível, e, se dos fatos que resultam dos lançamentos, uns são favoráveis ao interesse de seu autor e outros lhe são contrários, ambos serão considerados em conjunto, como unidade."
                                },
                                {
                                    "numero": "420º",
                                    "rotulo": "Art. 420º.",
                                    "linha": 3277,
                                    "caput": "O juiz pode ordenar, a requerimento da parte, a exibição integral dos livros empresariais e dos documentos do arquivo:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3279,
                                            "texto": "na liquidação de sociedade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3281,
                                            "texto": "na sucessão por morte de sócio;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3283,
                                            "texto": "quando e como determinar a lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "421º",
                                    "rotulo": "Art. 421º.",
                                    "linha": 3285,
                                    "caput": "O juiz pode, de ofício, ordenar à parte a exibição parcial dos livros e dos documentos, extraindo-se deles a suma que interessar ao litígio, bem como reproduções autenticadas."
                                },
                                {
                                    "numero": "422º",
                                    "rotulo": "Art. 422º.",
                                    "linha": 3287,
                                    "caput": "Qualquer reprodução mecânica, como a fotográfica, a cinematográfica, a fonográfica ou de outra espécie, tem aptidão para fazer prova dos fatos ou das coisas representadas, se a sua conformidade com o documento original não for impugnada por aquele contra quem foi produzida.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3289,
                                            "texto": "As fotografias digitais e as extraídas da rede mundial de computadores fazem prova das imagens que reproduzem, devendo, se impugnadas, ser apresentada a respectiva autenticação eletrônica ou, não sendo possível, realizada perícia."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3291,
                                            "texto": "Se se tratar de fotografia publicada em jornal ou revista, será exigido um exemplar original do periódico, caso impugnada a veracidade pela outra parte."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3293,
                                            "texto": "Aplica-se o disposto neste artigo à forma impressa de mensagem eletrônica."
                                        }
                                    ]
                                },
                                {
                                    "numero": "423º",
                                    "rotulo": "Art. 423º.",
                                    "linha": 3295,
                                    "caput": "As reproduções dos documentos particulares, fotográficas ou obtidas por outros processos de repetição, valem como certidões sempre que o escrivão ou o chefe de secretaria certificar sua conformidade com o original."
                                },
                                {
                                    "numero": "424º",
                                    "rotulo": "Art. 424º.",
                                    "linha": 3297,
                                    "caput": "A cópia de documento particular tem o mesmo valor probante que o original, cabendo ao escrivão, intimadas as partes, proceder à conferência e certificar a conformidade entre a cópia e o original."
                                },
                                {
                                    "numero": "425º",
                                    "rotulo": "Art. 425º.",
                                    "linha": 3299,
                                    "caput": "Fazem a mesma prova que os originais:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3313,
                                            "texto": "Os originais dos documentos digitalizados mencionados no inciso VI deverão ser preservados pelo seu detentor até o final do prazo para propositura de ação rescisória."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3315,
                                            "texto": "Tratando-se de cópia digital de título executivo extrajudicial ou de documento relevante à instrução do processo, o juiz poderá determinar seu depósito em cartório ou secretaria."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3301,
                                            "texto": "as certidões textuais de qualquer peça dos autos, do protocolo das audiências ou de outro livro a cargo do escrivão ou do chefe de secretaria, se extraídas por ele ou sob sua vigilância e por ele subscritas;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3303,
                                            "texto": "os traslados e as certidões extraídas por oficial público de instrumentos ou documentos lançados em suas notas;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3305,
                                            "texto": "as reproduções dos documentos públicos, desde que autenticadas por oficial público ou conferidas em cartório com os respectivos originais;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3307,
                                            "texto": "as cópias reprográficas de peças do próprio processo judicial declaradas autênticas pelo advogado, sob sua responsabilidade pessoal, se não lhes for impugnada a autenticidade;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 3309,
                                            "texto": "os extratos digitais de bancos de dados públicos e privados, desde que atestado pelo seu emitente, sob as penas da lei, que as informações conferem com o que consta na origem;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 3311,
                                            "texto": "as reproduções digitalizadas de qualquer documento público ou particular, quando juntadas aos autos pelos órgãos da justiça e seus auxiliares, pelo Ministério Público e seus auxiliares, pela Defensoria Pública e seus auxiliares, pelas procuradorias, pelas repartições públicas em geral e por advogados, ressalvada a alegação motivada e fundamentada de adulteração."
                                        }
                                    ]
                                },
                                {
                                    "numero": "426º",
                                    "rotulo": "Art. 426º.",
                                    "linha": 3317,
                                    "caput": "O juiz apreciará fundamentadamente a fé que deva merecer o documento, quando em ponto substancial e sem ressalva contiver entrelinha, emenda, borrão ou cancelamento."
                                },
                                {
                                    "numero": "427º",
                                    "rotulo": "Art. 427º.",
                                    "linha": 3319,
                                    "caput": "Cessa a fé do documento público ou particular sendo-lhe declarada judicialmente a falsidade.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3321,
                                            "texto": "A falsidade consiste em:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3323,
                                                    "texto": "formar documento não verdadeiro;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3325,
                                                    "texto": "alterar documento verdadeiro."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "428º",
                                    "rotulo": "Art. 428º.",
                                    "linha": 3327,
                                    "caput": "Cessa a fé do documento particular quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3333,
                                            "texto": "Dar-se-á abuso quando aquele que recebeu documento assinado com texto não escrito no todo ou em parte formá-lo ou completá-lo por si ou por meio de outrem, violando o pacto feito com o signatário."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3329,
                                            "texto": "for impugnada sua autenticidade e enquanto não se comprovar sua veracidade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3331,
                                            "texto": "assinado em branco, for impugnado seu conteúdo, por preenchimento abusivo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "429º",
                                    "rotulo": "Art. 429º.",
                                    "linha": 3335,
                                    "caput": "Incumbe o ônus da prova quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3337,
                                            "texto": "se tratar de falsidade de documento ou de preenchimento abusivo, à parte que a arguir;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3339,
                                            "texto": "se tratar de impugnação da autenticidade, à parte que produziu o documento. Subseção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "430º",
                                    "rotulo": "Art. 430º.",
                                    "linha": 3344,
                                    "caput": "A falsidade deve ser suscitada na contestação, na réplica ou no prazo de 15 (quinze) dias, contado a partir da intimação da juntada do documento aos autos.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3346,
                                            "texto": "Uma vez arguida, a falsidade será resolvida como questão incidental, salvo se a parte requerer que o juiz a decida como questão principal, nos termos do inciso II do art. 19.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "inciso II do art. 19",
                                                    "href": "#art19ii",
                                                    "inicio": 153,
                                                    "fim": 173
                                                }
                                            ]
                                        }
                                    ],
                                    "rubrica": "Da Arguição de Falsidade",
                                    "linhaRubrica": 3342
                                },
                                {
                                    "numero": "431º",
                                    "rotulo": "Art. 431º.",
                                    "linha": 3348,
                                    "caput": "A parte arguirá a falsidade expondo os motivos em que funda a sua pretensão e os meios com que provará o alegado."
                                },
                                {
                                    "numero": "432º",
                                    "rotulo": "Art. 432º.",
                                    "linha": 3350,
                                    "caput": "Depois de ouvida a outra parte no prazo de 15 (quinze) dias, será realizado o exame pericial.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3352,
                                            "texto": "Não se procederá ao exame pericial se a parte que produziu o documento concordar em retirá-lo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "433º",
                                    "rotulo": "Art. 433º.",
                                    "linha": 3354,
                                    "caput": "A declaração sobre a falsidade do documento, quando suscitada como questão principal, constará da parte dispositiva da sentença e sobre ela incidirá também a autoridade da coisa julgada. Subseção III"
                                },
                                {
                                    "numero": "434º",
                                    "rotulo": "Art. 434º.",
                                    "linha": 3359,
                                    "caput": "Incumbe à parte instruir a petição inicial ou a contestação com os documentos destinados a provar suas alegações.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3361,
                                            "texto": "Quando o documento consistir em reprodução cinematográfica ou fonográfica, a parte deverá trazê-lo nos termos do caput , mas sua exposição será realizada em audiência, intimando-se previamente as partes."
                                        }
                                    ],
                                    "rubrica": "Da Produção da Prova Documental",
                                    "linhaRubrica": 3357
                                },
                                {
                                    "numero": "435º",
                                    "rotulo": "Art. 435º.",
                                    "linha": 3363,
                                    "caput": "É lícito às partes, em qualquer tempo, juntar aos autos documentos novos, quando destinados a fazer prova de fatos ocorridos depois dos articulados ou para contrapô-los aos que foram produzidos nos autos.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3365,
                                            "texto": "Admite-se também a juntada posterior de documentos formados após a petição inicial ou a contestação, bem como dos que se tornaram conhecidos, acessíveis ou disponíveis após esses atos, cabendo à parte que os produzir comprovar o motivo que a impediu de juntá-los anteriormente e incumbindo ao juiz, em qualquer caso, avaliar a conduta da parte de acordo com o art. 5º."
                                        }
                                    ]
                                },
                                {
                                    "numero": "436º",
                                    "rotulo": "Art. 436º.",
                                    "linha": 3367,
                                    "caput": "A parte, intimada a falar sobre documento constante dos autos, poderá:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3377,
                                            "texto": "Nas hipóteses dos incisos II e III, a impugnação deverá basear-se em argumentação específica, não se admitindo alegação genérica de falsidade."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3369,
                                            "texto": "impugnar a admissibilidade da prova documental;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3371,
                                            "texto": "impugnar sua autenticidade;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3373,
                                            "texto": "suscitar sua falsidade, com ou sem deflagração do incidente de arguição de falsidade;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3375,
                                            "texto": "manifestar-se sobre seu conteúdo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "437º",
                                    "rotulo": "Art. 437º.",
                                    "linha": 3379,
                                    "caput": "O réu manifestar-se-á na contestação sobre os documentos anexados à inicial, e o autor manifestar-se-á na réplica sobre os documentos anexados à contestação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3381,
                                            "texto": "Sempre que uma das partes requerer a juntada de documento aos autos, o juiz ouvirá, a seu respeito, a outra parte, que disporá do prazo de 15 (quinze) dias para adotar qualquer das posturas indicadas no art. 436.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 436",
                                                    "href": "#art436",
                                                    "inicio": 203,
                                                    "fim": 211
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3383,
                                            "texto": "Poderá o juiz, a requerimento da parte, dilatar o prazo para manifestação sobre a prova documental produzida, levando em consideração a quantidade e a complexidade da documentação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "438º",
                                    "rotulo": "Art. 438º.",
                                    "linha": 3385,
                                    "caput": "O juiz requisitará às repartições públicas, em qualquer tempo ou grau de jurisdição:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3391,
                                            "texto": "Recebidos os autos, o juiz mandará extrair, no prazo máximo e improrrogável de 1 (um) mês, certidões ou reproduções fotográficas das peças que indicar e das que forem indicadas pelas partes, e, em seguida, devolverá os autos à repartição de origem."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3393,
                                            "texto": "As repartições públicas poderão fornecer todos os documentos em meio eletrônico, conforme disposto em lei, certificando, pelo mesmo meio, que se trata de extrato fiel do que consta em seu banco de dados ou no documento digitalizado. Seção VIII"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3387,
                                            "texto": "as certidões necessárias à prova das alegações das partes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3389,
                                            "texto": "os procedimentos administrativos nas causas em que forem interessados a União, os Estados, o Distrito Federal, os Municípios ou entidades da administração indireta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "439º",
                                    "rotulo": "Art. 439º.",
                                    "linha": 3398,
                                    "caput": "A utilização de documentos eletrônicos no processo convencional dependerá de sua conversão à forma impressa e da verificação de sua autenticidade, na forma da lei.",
                                    "rubrica": "Dos Documentos Eletrônicos",
                                    "linhaRubrica": 3396
                                },
                                {
                                    "numero": "440º",
                                    "rotulo": "Art. 440º.",
                                    "linha": 3400,
                                    "caput": "O juiz apreciará o valor probante do documento eletrônico não convertido, assegurado às partes o acesso ao seu teor."
                                },
                                {
                                    "numero": "441º",
                                    "rotulo": "Art. 441º.",
                                    "linha": 3402,
                                    "caput": "Serão admitidos documentos eletrônicos produzidos e conservados com a observância da legislação específica. Seção IX Da Prova Testemunhal Subseção I"
                                },
                                {
                                    "numero": "442º",
                                    "rotulo": "Art. 442º.",
                                    "linha": 3410,
                                    "caput": "A prova testemunhal é sempre admissível, não dispondo a lei de modo diverso.",
                                    "rubrica": "Da Admissibilidade e do Valor da Prova Testemunhal",
                                    "linhaRubrica": 3408
                                },
                                {
                                    "numero": "443º",
                                    "rotulo": "Art. 443º.",
                                    "linha": 3412,
                                    "caput": "O juiz indeferirá a inquirição de testemunhas sobre fatos:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3414,
                                            "texto": "já provados por documento ou confissão da parte;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3416,
                                            "texto": "que só por documento ou por exame pericial puderem ser provados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "444º",
                                    "rotulo": "Art. 444º.",
                                    "linha": 3418,
                                    "caput": "Nos casos em que a lei exigir prova escrita da obrigação, é admissível a prova testemunhal quando houver começo de prova por escrito, emanado da parte contra a qual se pretende produzir a prova."
                                },
                                {
                                    "numero": "445º",
                                    "rotulo": "Art. 445º.",
                                    "linha": 3420,
                                    "caput": "Também se admite a prova testemunhal quando o credor não pode ou não podia, moral ou materialmente, obter a prova escrita da obrigação, em casos como o de parentesco, de depósito necessário ou de hospedagem em hotel ou em razão das práticas comerciais do local onde contraída a obrigação."
                                },
                                {
                                    "numero": "446º",
                                    "rotulo": "Art. 446º.",
                                    "linha": 3422,
                                    "caput": "É lícito à parte provar com testemunhas:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3424,
                                            "texto": "nos contratos simulados, a divergência entre a vontade real e a vontade declarada;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3426,
                                            "texto": "nos contratos em geral, os vícios de consentimento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "447º",
                                    "rotulo": "Art. 447º.",
                                    "linha": 3428,
                                    "caput": "Podem depor como testemunhas todas as pessoas, exceto as incapazes, impedidas ou suspeitas.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3430,
                                            "texto": "São incapazes:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3432,
                                                    "texto": "o interdito por enfermidade ou deficiência mental;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3434,
                                                    "texto": "o que, acometido por enfermidade ou retardamento mental, ao tempo em que ocorreram os fatos, não podia discerni-los, ou, ao tempo em que deve depor, não está habilitado a transmitir as percepções;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3436,
                                                    "texto": "o que tiver menos de 16 (dezesseis) anos;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 3438,
                                                    "texto": "o cego e o surdo, quando a ciência do fato depender dos sentidos que lhes faltam."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3440,
                                            "texto": "São impedidos:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3442,
                                                    "texto": "o cônjuge, o companheiro, o ascendente e o descendente em qualquer grau e o colateral, até o terceiro grau, de alguma das partes, por consanguinidade ou afinidade, salvo se o exigir o interesse público ou, tratando-se de causa relativa ao estado da pessoa, não se puder obter de outro modo a prova que o juiz repute necessária ao julgamento do mérito;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3444,
                                                    "texto": "o que é parte na causa;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3446,
                                                    "texto": "o que intervém em nome de uma parte, como o tutor, o representante legal da pessoa jurídica, o juiz, o advogado e outros que assistam ou tenham assistido as partes."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3448,
                                            "texto": "São suspeitos:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3450,
                                                    "texto": "o inimigo da parte ou o seu amigo íntimo;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3452,
                                                    "texto": "o que tiver interesse no litígio."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3454,
                                            "texto": "Sendo necessário, pode o juiz admitir o depoimento das testemunhas menores, impedidas ou suspeitas."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 3456,
                                            "texto": "Os depoimentos referidos no § 4º serão prestados independentemente de compromisso, e o juiz lhes atribuirá o valor que possam merecer."
                                        }
                                    ]
                                },
                                {
                                    "numero": "448º",
                                    "rotulo": "Art. 448º.",
                                    "linha": 3458,
                                    "caput": "A testemunha não é obrigada a depor sobre fatos:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3460,
                                            "texto": "que lhe acarretem grave dano, bem como ao seu cônjuge ou companheiro e aos seus parentes consanguíneos ou afins, em linha reta ou colateral, até o terceiro grau;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3462,
                                            "texto": "a cujo respeito, por estado ou profissão, deva guardar sigilo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "449º",
                                    "rotulo": "Art. 449º.",
                                    "linha": 3464,
                                    "caput": "Salvo disposição especial em contrário, as testemunhas devem ser ouvidas na sede do juízo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3466,
                                            "texto": "Quando a parte ou a testemunha, por enfermidade ou por outro motivo relevante, estiver impossibilitada de comparecer, mas não de prestar depoimento, o juiz designará, conforme as circunstâncias, dia, hora e lugar para inquiri-la. Subseção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "450º",
                                    "rotulo": "Art. 450º.",
                                    "linha": 3471,
                                    "caput": "O rol de testemunhas conterá, sempre que possível, o nome, a profissão, o estado civil, a idade, o número de inscrição no Cadastro de Pessoas Físicas, o número de registro de identidade e o endereço completo da residência e do local de trabalho.",
                                    "rubrica": "Da Produção da Prova Testemunhal",
                                    "linhaRubrica": 3469
                                },
                                {
                                    "numero": "451º",
                                    "rotulo": "Art. 451º.",
                                    "linha": 3473,
                                    "caput": "Depois de apresentado o rol de que tratam os §§ 4º e 5º do art. 357, a parte só pode substituir a testemunha:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3475,
                                            "texto": "que falecer;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3477,
                                            "texto": "que, por enfermidade, não estiver em condições de depor;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3479,
                                            "texto": "que, tendo mudado de residência ou de local de trabalho, não for encontrada."
                                        }
                                    ]
                                },
                                {
                                    "numero": "452º",
                                    "rotulo": "Art. 452º.",
                                    "linha": 3481,
                                    "caput": "Quando for arrolado como testemunha, o juiz da causa:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3483,
                                            "texto": "declarar-se-á impedido, se tiver conhecimento de fatos que possam influir na decisão, caso em que será vedado à parte que o incluiu no rol desistir de seu depoimento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3485,
                                            "texto": "se nada souber, mandará excluir o seu nome."
                                        }
                                    ]
                                },
                                {
                                    "numero": "453º",
                                    "rotulo": "Art. 453º.",
                                    "linha": 3487,
                                    "caput": "As testemunhas depõem, na audiência de instrução e julgamento, perante o juiz da causa, exceto:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3493,
                                            "texto": "A oitiva de testemunha que residir em comarca, seção ou subseção judiciária diversa daquela onde tramita o processo poderá ser realizada por meio de videoconferência ou outro recurso tecnológico de transmissão e recepção de sons e imagens em tempo real, o que poderá ocorrer, inclusive, durante a audiência de instrução e julgamento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3495,
                                            "texto": "Os juízos deverão manter equipamento para a transmissão e recepção de sons e imagens a que se refere o § 1º."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3489,
                                            "texto": "as que prestam depoimento antecipadamente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3491,
                                            "texto": "as que são inquiridas por carta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "454º",
                                    "rotulo": "Art. 454º.",
                                    "linha": 3497,
                                    "caput": "São inquiridos em sua residência ou onde exercem sua função:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3523,
                                            "texto": "O juiz solicitará à autoridade que indique dia, hora e local a fim de ser inquirida, remetendo-lhe cópia da petição inicial ou da defesa oferecida pela parte que a arrolou como testemunha."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3525,
                                            "texto": "Passado 1 (um) mês sem manifestação da autoridade, o juiz designará dia, hora e local para o depoimento, preferencialmente na sede do juízo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3527,
                                            "texto": "O juiz também designará dia, hora e local para o depoimento, quando a autoridade não comparecer, injustificadamente, à sessão agendada para a colheita de seu testemunho no dia, hora e local por ela mesma indicados."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3499,
                                            "texto": "o presidente e o vice-presidente da República;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3501,
                                            "texto": "os ministros de Estado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3503,
                                            "texto": "os ministros do Supremo Tribunal Federal, os conselheiros do Conselho Nacional de Justiça e os ministros do Superior Tribunal de Justiça, do Superior Tribunal Militar, do Tribunal Superior Eleitoral, do Tribunal Superior do Trabalho e do Tribunal de Contas da União;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3505,
                                            "texto": "o procurador-geral da República e os conselheiros do Conselho Nacional do Ministério Público;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 3507,
                                            "texto": "o advogado-geral da União, o procurador-geral do Estado, o procurador-geral do Município, o defensor público-geral federal e o defensor público-geral do Estado;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 3509,
                                            "texto": "os senadores e os deputados federais;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 3511,
                                            "texto": "os governadores dos Estados e do Distrito Federal;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 3513,
                                            "texto": "o prefeito;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 3515,
                                            "texto": "os deputados estaduais e distritais;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 3517,
                                            "texto": "os desembargadores dos Tribunais de Justiça, dos Tribunais Regionais Federais, dos Tribunais Regionais do Trabalho e dos Tribunais Regionais Eleitorais e os conselheiros dos Tribunais de Contas dos Estados e do Distrito Federal;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 3519,
                                            "texto": "o procurador-geral de justiça;"
                                        },
                                        {
                                            "numero": "XII",
                                            "rotulo": "XII",
                                            "linha": 3521,
                                            "texto": "o embaixador de país que, por lei ou tratado, concede idêntica prerrogativa a agente diplomático do Brasil."
                                        }
                                    ]
                                },
                                {
                                    "numero": "455º",
                                    "rotulo": "Art. 455º.",
                                    "linha": 3529,
                                    "caput": "Cabe ao advogado da parte informar ou intimar a testemunha por ele arrolada do dia, da hora e do local da audiência designada, dispensando-se a intimação do juízo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3531,
                                            "texto": "A intimação deverá ser realizada por carta com aviso de recebimento, cumprindo ao advogado juntar aos autos, com antecedência de pelo menos 3 (três) dias da data da audiência, cópia da correspondência de intimação e do comprovante de recebimento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3533,
                                            "texto": "A parte pode comprometer-se a levar a testemunha à audiência, independentemente da intimação de que trata o § 1º, presumindo-se, caso a testemunha não compareça, que a parte desistiu de sua inquirição."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3535,
                                            "texto": "A inércia na realização da intimação a que se refere o § 1º importa desistência da inquirição da testemunha."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3537,
                                            "texto": "A intimação será feita pela via judicial quando:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3539,
                                                    "texto": "for frustrada a intimação prevista no § 1º deste artigo;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3541,
                                                    "texto": "sua necessidade for devidamente demonstrada pela parte ao juiz;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3543,
                                                    "texto": "figurar no rol de testemunhas servidor público ou militar, hipótese em que o juiz o requisitará ao chefe da repartição ou ao comando do corpo em que servir;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 3545,
                                                    "texto": "a testemunha houver sido arrolada pelo Ministério Público ou pela Defensoria Pública;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 3547,
                                                    "texto": "a testemunha for uma daquelas previstas no art. 454.",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 454",
                                                            "href": "#art454",
                                                            "inicio": 43,
                                                            "fim": 51
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 3549,
                                            "texto": "A testemunha que, intimada na forma do § 1º ou do § 4º, deixar de comparecer sem motivo justificado será conduzida e responderá pelas despesas do adiamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "456º",
                                    "rotulo": "Art. 456º.",
                                    "linha": 3551,
                                    "caput": "O juiz inquirirá as testemunhas separada e sucessivamente, primeiro as do autor e depois as do réu, e providenciará para que uma não ouça o depoimento das outras.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3553,
                                            "texto": "O juiz poderá alterar a ordem estabelecida no caput se as partes concordarem."
                                        }
                                    ]
                                },
                                {
                                    "numero": "457º",
                                    "rotulo": "Art. 457º.",
                                    "linha": 3555,
                                    "caput": "Antes de depor, a testemunha será qualificada, declarará ou confirmará seus dados e informará se tem relações de parentesco com a parte ou interesse no objeto do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3557,
                                            "texto": "É lícito à parte contraditar a testemunha, arguindo-lhe a incapacidade, o impedimento ou a suspeição, bem como, caso a testemunha negue os fatos que lhe são imputados, provar a contradita com documentos ou com testemunhas, até 3 (três), apresentadas no ato e inquiridas em separado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3559,
                                            "texto": "Sendo provados ou confessados os fatos a que se refere o § 1º, o juiz dispensará a testemunha ou lhe tomará o depoimento como informante."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3561,
                                            "texto": "A testemunha pode requerer ao juiz que a escuse de depor, alegando os motivos previstos neste Código, decidindo o juiz de plano após ouvidas as partes."
                                        }
                                    ]
                                },
                                {
                                    "numero": "458º",
                                    "rotulo": "Art. 458º.",
                                    "linha": 3563,
                                    "caput": "Ao início da inquirição, a testemunha prestará o compromisso de dizer a verdade do que souber e lhe for perguntado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3565,
                                            "texto": "O juiz advertirá à testemunha que incorre em sanção penal quem faz afirmação falsa, cala ou oculta a verdade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "459º",
                                    "rotulo": "Art. 459º.",
                                    "linha": 3567,
                                    "caput": "As perguntas serão formuladas pelas partes diretamente à testemunha, começando pela que a arrolou, não admitindo o juiz aquelas que puderem induzir a resposta, não tiverem relação com as questões de fato objeto da atividade probatória ou importarem repetição de outra já respondida.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3569,
                                            "texto": "O juiz poderá inquirir a testemunha tanto antes quanto depois da inquirição feita pelas partes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3571,
                                            "texto": "As testemunhas devem ser tratadas com urbanidade, não se lhes fazendo perguntas ou considerações impertinentes, capciosas ou vexatórias."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3573,
                                            "texto": "As perguntas que o juiz indeferir serão transcritas no termo, se a parte o requerer."
                                        }
                                    ]
                                },
                                {
                                    "numero": "460º",
                                    "rotulo": "Art. 460º.",
                                    "linha": 3575,
                                    "caput": "O depoimento poderá ser documentado por meio de gravação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3577,
                                            "texto": "Quando digitado ou registrado por taquigrafia, estenotipia ou outro método idôneo de documentação, o depoimento será assinado pelo juiz, pelo depoente e pelos procuradores."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3579,
                                            "texto": "Se houver recurso em processo em autos não eletrônicos, o depoimento somente será digitado quando for impossível o envio de sua documentação eletrônica."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3581,
                                            "texto": "Tratando-se de autos eletrônicos, observar-se-á o disposto neste Código e na legislação específica sobre a prática eletrônica de atos processuais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "461º",
                                    "rotulo": "Art. 461º.",
                                    "linha": 3583,
                                    "caput": "O juiz pode ordenar, de ofício ou a requerimento da parte:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3589,
                                            "texto": "Os acareados serão reperguntados para que expliquem os pontos de divergência, reduzindo-se a termo o ato de acareação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3591,
                                            "texto": "A acareação pode ser realizada por videoconferência ou por outro recurso tecnológico de transmissão de sons e imagens em tempo real."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3585,
                                            "texto": "a inquirição de testemunhas referidas nas declarações da parte ou das testemunhas;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3587,
                                            "texto": "a acareação de 2 (duas) ou mais testemunhas ou de alguma delas com a parte, quando, sobre fato determinado que possa influir na decisão da causa, divergirem as suas declarações."
                                        }
                                    ]
                                },
                                {
                                    "numero": "462º",
                                    "rotulo": "Art. 462º.",
                                    "linha": 3593,
                                    "caput": "A testemunha pode requerer ao juiz o pagamento da despesa que efetuou para comparecimento à audiência, devendo a parte pagá-la logo que arbitrada ou depositá-la em cartório dentro de 3 (três) dias."
                                },
                                {
                                    "numero": "463º",
                                    "rotulo": "Art. 463º.",
                                    "linha": 3595,
                                    "caput": "O depoimento prestado em juízo é considerado serviço público.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3597,
                                            "texto": "A testemunha, quando sujeita ao regime da legislação trabalhista, não sofre, por comparecer à audiência, perda de salário nem desconto no tempo de serviço. Seção X"
                                        }
                                    ]
                                },
                                {
                                    "numero": "464º",
                                    "rotulo": "Art. 464º.",
                                    "linha": 3602,
                                    "caput": "A prova pericial consiste em exame, vistoria ou avaliação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3604,
                                            "texto": "O juiz indeferirá a perícia quando:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3606,
                                                    "texto": "a prova do fato não depender de conhecimento especial de técnico;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3608,
                                                    "texto": "for desnecessária em vista de outras provas produzidas;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3610,
                                                    "texto": "a verificação for impraticável."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3612,
                                            "texto": "De ofício ou a requerimento das partes, o juiz poderá, em substituição à perícia, determinar a produção de prova técnica simplificada, quando o ponto controvertido for de menor complexidade."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3614,
                                            "texto": "A prova técnica simplificada consistirá apenas na inquirição de especialista, pelo juiz, sobre ponto controvertido da causa que demande especial conhecimento científico ou técnico."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3616,
                                            "texto": "Durante a arguição, o especialista, que deverá ter formação acadêmica específica na área objeto de seu depoimento, poderá valer-se de qualquer recurso tecnológico de transmissão de sons e imagens com o fim de esclarecer os pontos controvertidos da causa."
                                        }
                                    ],
                                    "rubrica": "Da Prova Pericial",
                                    "linhaRubrica": 3600
                                },
                                {
                                    "numero": "465º",
                                    "rotulo": "Art. 465º.",
                                    "linha": 3618,
                                    "caput": "O juiz nomeará perito especializado no objeto da perícia e fixará de imediato o prazo para a entrega do laudo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3620,
                                            "texto": "Incumbe às partes, dentro de 15 (quinze) dias contados da intimação do despacho de nomeação do perito:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3622,
                                                    "texto": "arguir o impedimento ou a suspeição do perito, se for o caso;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3624,
                                                    "texto": "indicar assistente técnico;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3626,
                                                    "texto": "apresentar quesitos."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3628,
                                            "texto": "Ciente da nomeação, o perito apresentará em 5 (cinco) dias:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3630,
                                                    "texto": "proposta de honorários;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3632,
                                                    "texto": "currículo, com comprovação de especialização;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3634,
                                                    "texto": "contatos profissionais, em especial o endereço eletrônico, para onde serão dirigidas as intimações pessoais."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3636,
                                            "texto": "As partes serão intimadas da proposta de honorários para, querendo, manifestar-se no prazo comum de 5 (cinco) dias, após o que o juiz arbitrará o valor, intimando-se as partes para os fins do art. 95.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 95",
                                                    "href": "#art95",
                                                    "inicio": 192,
                                                    "fim": 199
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3638,
                                            "texto": "O juiz poderá autorizar o pagamento de até cinquenta por cento dos honorários arbitrados a favor do perito no início dos trabalhos, devendo o remanescente ser pago apenas ao final, depois de entregue o laudo e prestados todos os esclarecimentos necessários."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 3640,
                                            "texto": "Quando a perícia for inconclusiva ou deficiente, o juiz poderá reduzir a remuneração inicialmente arbitrada para o trabalho."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 3642,
                                            "texto": "Quando tiver de realizar-se por carta, poder-se-á proceder à nomeação de perito e à indicação de assistentes técnicos no juízo ao qual se requisitar a perícia."
                                        }
                                    ]
                                },
                                {
                                    "numero": "466º",
                                    "rotulo": "Art. 466º.",
                                    "linha": 3644,
                                    "caput": "O perito cumprirá escrupulosamente o encargo que lhe foi cometido, independentemente de termo de compromisso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3646,
                                            "texto": "Os assistentes técnicos são de confiança da parte e não estão sujeitos a impedimento ou suspeição."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3648,
                                            "texto": "O perito deve assegurar aos assistentes das partes o acesso e o acompanhamento das diligências e dos exames que realizar, com prévia comunicação, comprovada nos autos, com antecedência mínima de 5 (cinco) dias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "467º",
                                    "rotulo": "Art. 467º.",
                                    "linha": 3650,
                                    "caput": "O perito pode escusar-se ou ser recusado por impedimento ou suspeição.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3652,
                                            "texto": "O juiz, ao aceitar a escusa ou ao julgar procedente a impugnação, nomeará novo perito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "468º",
                                    "rotulo": "Art. 468º.",
                                    "linha": 3654,
                                    "caput": "O perito pode ser substituído quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3660,
                                            "texto": "No caso previsto no inciso II, o juiz comunicará a ocorrência à corporação profissional respectiva, podendo, ainda, impor multa ao perito, fixada tendo em vista o valor da causa e o possível prejuízo decorrente do atraso no processo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3662,
                                            "texto": "O perito substituído restituirá, no prazo de 15 (quinze) dias, os valores recebidos pelo trabalho não realizado, sob pena de ficar impedido de atuar como perito judicial pelo prazo de 5 (cinco) anos."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3664,
                                            "texto": "Não ocorrendo a restituição voluntária de que trata o § 2º, a parte que tiver realizado o adiantamento dos honorários poderá promover execução contra o perito, na forma dos arts. 513 e seguintes deste Código, com fundamento na decisão que determinar a devolução do numerário."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3656,
                                            "texto": "faltar-lhe conhecimento técnico ou científico;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3658,
                                            "texto": "sem motivo legítimo, deixar de cumprir o encargo no prazo que lhe foi assinado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "469º",
                                    "rotulo": "Art. 469º.",
                                    "linha": 3666,
                                    "caput": "As partes poderão apresentar quesitos suplementares durante a diligência, que poderão ser respondidos pelo perito previamente ou na audiência de instrução e julgamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3668,
                                            "texto": "O escrivão dará à parte contrária ciência da juntada dos quesitos aos autos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "470º",
                                    "rotulo": "Art. 470º.",
                                    "linha": 3670,
                                    "caput": "Incumbe ao juiz:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3672,
                                            "texto": "indeferir quesitos impertinentes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3674,
                                            "texto": "formular os quesitos que entender necessários ao esclarecimento da causa."
                                        }
                                    ]
                                },
                                {
                                    "numero": "471º",
                                    "rotulo": "Art. 471º.",
                                    "linha": 3676,
                                    "caput": "As partes podem, de comum acordo, escolher o perito, indicando-o mediante requerimento, desde que:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3682,
                                            "texto": "As partes, ao escolher o perito, já devem indicar os respectivos assistentes técnicos para acompanhar a realização da perícia, que se realizará em data e local previamente anunciados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3684,
                                            "texto": "O perito e os assistentes técnicos devem entregar, respectivamente, laudo e pareceres em prazo fixado pelo juiz."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3686,
                                            "texto": "A perícia consensual substitui, para todos os efeitos, a que seria realizada por perito nomeado pelo juiz."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3678,
                                            "texto": "sejam plenamente capazes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3680,
                                            "texto": "a causa possa ser resolvida por autocomposição."
                                        }
                                    ]
                                },
                                {
                                    "numero": "472º",
                                    "rotulo": "Art. 472º.",
                                    "linha": 3688,
                                    "caput": "O juiz poderá dispensar prova pericial quando as partes, na inicial e na contestação, apresentarem, sobre as questões de fato, pareceres técnicos ou documentos elucidativos que considerar suficientes."
                                },
                                {
                                    "numero": "473º",
                                    "rotulo": "Art. 473º.",
                                    "linha": 3690,
                                    "caput": "O laudo pericial deverá conter:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3700,
                                            "texto": "No laudo, o perito deve apresentar sua fundamentação em linguagem simples e com coerência lógica, indicando como alcançou suas conclusões."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3702,
                                            "texto": "É vedado ao perito ultrapassar os limites de sua designação, bem como emitir opiniões pessoais que excedam o exame técnico ou científico do objeto da perícia."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3704,
                                            "texto": "Para o desempenho de sua função, o perito e os assistentes técnicos podem valer-se de todos os meios necessários, ouvindo testemunhas, obtendo informações, solicitando documentos que estejam em poder da parte, de terceiros ou em repartições públicas, bem como instruir o laudo com planilhas, mapas, plantas, desenhos, fotografias ou outros elementos necessários ao esclarecimento do objeto da perícia."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3692,
                                            "texto": "a exposição do objeto da perícia;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3694,
                                            "texto": "a análise técnica ou científica realizada pelo perito;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3696,
                                            "texto": "a indicação do método utilizado, esclarecendo-o e demonstrando ser predominantemente aceito pelos especialistas da área do conhecimento da qual se originou;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3698,
                                            "texto": "resposta conclusiva a todos os quesitos apresentados pelo juiz, pelas partes e pelo órgão do Ministério Público."
                                        }
                                    ]
                                },
                                {
                                    "numero": "474º",
                                    "rotulo": "Art. 474º.",
                                    "linha": 3706,
                                    "caput": "As partes terão ciência da data e do local designados pelo juiz ou indicados pelo perito para ter início a produção da prova."
                                },
                                {
                                    "numero": "475º",
                                    "rotulo": "Art. 475º.",
                                    "linha": 3708,
                                    "caput": "Tratando-se de perícia complexa que abranja mais de uma área de conhecimento especializado, o juiz poderá nomear mais de um perito, e a parte, indicar mais de um assistente técnico."
                                },
                                {
                                    "numero": "476º",
                                    "rotulo": "Art. 476º.",
                                    "linha": 3710,
                                    "caput": "Se o perito, por motivo justificado, não puder apresentar o laudo dentro do prazo, o juiz poderá conceder-lhe, por uma vez, prorrogação pela metade do prazo originalmente fixado."
                                },
                                {
                                    "numero": "477º",
                                    "rotulo": "Art. 477º.",
                                    "linha": 3712,
                                    "caput": "O perito protocolará o laudo em juízo, no prazo fixado pelo juiz, pelo menos 20 (vinte) dias antes da audiência de instrução e julgamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3714,
                                            "texto": "As partes serão intimadas para, querendo, manifestar-se sobre o laudo do perito do juízo no prazo comum de 15 (quinze) dias, podendo o assistente técnico de cada uma das partes, em igual prazo, apresentar seu respectivo parecer."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3716,
                                            "texto": "O perito do juízo tem o dever de, no prazo de 15 (quinze) dias, esclarecer ponto:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3718,
                                                    "texto": "sobre o qual exista divergência ou dúvida de qualquer das partes, do juiz ou do órgão do Ministério Público;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3720,
                                                    "texto": "divergente apresentado no parecer do assistente técnico da parte."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3722,
                                            "texto": "Se ainda houver necessidade de esclarecimentos, a parte requererá ao juiz que mande intimar o perito ou o assistente técnico a comparecer à audiência de instrução e julgamento, formulando, desde logo, as perguntas, sob forma de quesitos."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3724,
                                            "texto": "O perito ou o assistente técnico será intimado por meio eletrônico, com pelo menos 10 (dez) dias de antecedência da audiência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "478º",
                                    "rotulo": "Art. 478º.",
                                    "linha": 3726,
                                    "caput": "Quando o exame tiver por objeto a autenticidade ou a falsidade de documento ou for de natureza médico-legal, o perito será escolhido, de preferência, entre os técnicos dos estabelecimentos oficiais especializados, a cujos diretores o juiz autorizará a remessa dos autos, bem como do material sujeito a exame.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3728,
                                            "texto": "Nas hipóteses de gratuidade de justiça, os órgãos e as repartições oficiais deverão cumprir a determinação judicial com preferência, no prazo estabelecido."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3730,
                                            "texto": "A prorrogação do prazo referido no § 1º pode ser requerida motivadamente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3732,
                                            "texto": "Quando o exame tiver por objeto a autenticidade da letra e da firma, o perito poderá requisitar, para efeito de comparação, documentos existentes em repartições públicas e, na falta destes, poderá requerer ao juiz que a pessoa a quem se atribuir a autoria do documento lance em folha de papel, por cópia ou sob ditado, dizeres diferentes, para fins de comparação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "479º",
                                    "rotulo": "Art. 479º.",
                                    "linha": 3734,
                                    "caput": "O juiz apreciará a prova pericial de acordo com o disposto no art. 371, indicando na sentença os motivos que o levaram a considerar ou a deixar de considerar as conclusões do laudo, levando em conta o método utilizado pelo perito.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 371",
                                            "href": "#art371",
                                            "inicio": 62,
                                            "fim": 70
                                        }
                                    ]
                                },
                                {
                                    "numero": "480º",
                                    "rotulo": "Art. 480º.",
                                    "linha": 3736,
                                    "caput": "O juiz determinará, de ofício ou a requerimento da parte, a realização de nova perícia quando a matéria não estiver suficientemente esclarecida.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3738,
                                            "texto": "A segunda perícia tem por objeto os mesmos fatos sobre os quais recaiu a primeira e destina-se a corrigir eventual omissão ou inexatidão dos resultados a que esta conduziu."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3740,
                                            "texto": "A segunda perícia rege-se pelas disposições estabelecidas para a primeira."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3742,
                                            "texto": "A segunda perícia não substitui a primeira, cabendo ao juiz apreciar o valor de uma e de outra. Seção XI"
                                        }
                                    ]
                                },
                                {
                                    "numero": "481º",
                                    "rotulo": "Art. 481º.",
                                    "linha": 3747,
                                    "caput": "O juiz, de ofício ou a requerimento da parte, pode, em qualquer fase do processo, inspecionar pessoas ou coisas, a fim de se esclarecer sobre fato que interesse à decisão da causa.",
                                    "rubrica": "Da Inspeção Judicial",
                                    "linhaRubrica": 3745
                                },
                                {
                                    "numero": "482º",
                                    "rotulo": "Art. 482º.",
                                    "linha": 3749,
                                    "caput": "Ao realizar a inspeção, o juiz poderá ser assistido por um ou mais peritos."
                                },
                                {
                                    "numero": "483º",
                                    "rotulo": "Art. 483º.",
                                    "linha": 3751,
                                    "caput": "O juiz irá ao local onde se encontre a pessoa ou a coisa quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3759,
                                            "texto": "As partes têm sempre direito a assistir à inspeção, prestando esclarecimentos e fazendo observações que considerem de interesse para a causa."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3753,
                                            "texto": "julgar necessário para a melhor verificação ou interpretação dos fatos que deva observar;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3755,
                                            "texto": "a coisa não puder ser apresentada em juízo sem consideráveis despesas ou graves dificuldades;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3757,
                                            "texto": "determinar a reconstituição dos fatos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "484º",
                                    "rotulo": "Art. 484º.",
                                    "linha": 3761,
                                    "caput": "Concluída a diligência, o juiz mandará lavrar auto circunstanciado, mencionando nele tudo quanto for útil ao julgamento da causa.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3763,
                                            "texto": "O auto poderá ser instruído com desenho, gráfico ou fotografia."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DAS PROVAS",
                            "linhaTitulo": 2976
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XIII",
                            "linha": 3765,
                            "artigos": [
                                {
                                    "numero": "485º",
                                    "rotulo": "Art. 485º.",
                                    "linha": 3771,
                                    "caput": "O juiz não resolverá o mérito quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3793,
                                            "texto": "Nas hipóteses descritas nos incisos II e III, a parte será intimada pessoalmente para suprir a falta no prazo de 5 (cinco) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3795,
                                            "texto": "No caso do § 1º, quanto ao inciso II, as partes pagarão proporcionalmente as custas, e, quanto ao inciso III, o autor será condenado ao pagamento das despesas e dos honorários de advogado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3797,
                                            "texto": "O juiz conhecerá de ofício da matéria constante dos incisos IV, V, VI e IX, em qualquer tempo e grau de jurisdição, enquanto não ocorrer o trânsito em julgado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3799,
                                            "texto": "Oferecida a contestação, o autor não poderá, sem o consentimento do réu, desistir da ação."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 3801,
                                            "texto": "A desistência da ação pode ser apresentada até a sentença."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 3803,
                                            "texto": "Oferecida a contestação, a extinção do processo por abandono da causa pelo autor depende de requerimento do réu."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 3805,
                                            "texto": "Interposta a apelação em qualquer dos casos de que tratam os incisos deste artigo, o juiz terá 5 (cinco) dias para retratar-se."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3773,
                                            "texto": "indeferir a petição inicial;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3775,
                                            "texto": "o processo ficar parado durante mais de 1 (um) ano por negligência das partes;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3777,
                                            "texto": "por não promover os atos e as diligências que lhe incumbir, o autor abandonar a causa por mais de 30 (trinta) dias;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 3779,
                                            "texto": "verificar a ausência de pressupostos de constituição e de desenvolvimento válido e regular do processo;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 3781,
                                            "texto": "reconhecer a existência de perempção, de litispendência ou de coisa julgada;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 3783,
                                            "texto": "verificar ausência de legitimidade ou de interesse processual;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 3785,
                                            "texto": "acolher a alegação de existência de convenção de arbitragem ou quando o juízo arbitral reconhecer sua competência;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 3787,
                                            "texto": "homologar a desistência da ação;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 3789,
                                            "texto": "em caso de morte da parte, a ação for considerada intransmissível por disposição legal; e"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 3791,
                                            "texto": "nos demais casos prescritos neste Código."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 3769
                                },
                                {
                                    "numero": "486º",
                                    "rotulo": "Art. 486º.",
                                    "linha": 3807,
                                    "caput": "O pronunciamento judicial que não resolve o mérito não obsta a que a parte proponha de novo a ação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3809,
                                            "texto": "No caso de extinção em razão de litispendência e nos casos dos incisos I, IV, VI e VII do art. 485, a propositura da nova ação depende da correção do vício que levou à sentença sem resolução do mérito.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "incisos I, IV, VI e VII do art. 485",
                                                    "href": "#art485i",
                                                    "inicio": 63,
                                                    "fim": 98
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 485",
                                                    "href": "#art485",
                                                    "inicio": 90,
                                                    "fim": 98
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3811,
                                            "texto": "A petição inicial, todavia, não será despachada sem a prova do pagamento ou do depósito das custas e dos honorários de advogado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3813,
                                            "texto": "Se o autor der causa, por 3 (três) vezes, a sentença fundada em abandono da causa, não poderá propor nova ação contra o réu com o mesmo objeto, ficando-lhe ressalvada, entretanto, a possibilidade de alegar em defesa o seu direito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "487º",
                                    "rotulo": "Art. 487º.",
                                    "linha": 3815,
                                    "caput": "Haverá resolução de mérito quando o juiz:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3829,
                                            "texto": "Ressalvada a hipótese do § 1º do art. 332, a prescrição e a decadência não serão reconhecidas sem que antes seja dada às partes oportunidade de manifestar-se.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 332",
                                                    "href": "#art332",
                                                    "inicio": 33,
                                                    "fim": 41
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3817,
                                            "texto": "acolher ou rejeitar o pedido formulado na ação ou na reconvenção;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3819,
                                            "texto": "decidir, de ofício ou a requerimento, sobre a ocorrência de decadência ou prescrição;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3821,
                                            "texto": "homologar:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 3823,
                                                    "texto": "o reconhecimento da procedência do pedido formulado na ação ou na reconvenção;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 3825,
                                                    "texto": "a transação;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 3827,
                                                    "texto": "a renúncia à pretensão formulada na ação ou na reconvenção."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "488º",
                                    "rotulo": "Art. 488º.",
                                    "linha": 3831,
                                    "caput": "Desde que possível, o juiz resolverá o mérito sempre que a decisão for favorável à parte a quem aproveitaria eventual pronunciamento nos termos do art. 485. Seção II",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 485",
                                            "href": "#art485",
                                            "inicio": 147,
                                            "fim": 155
                                        }
                                    ]
                                },
                                {
                                    "numero": "489º",
                                    "rotulo": "Art. 489º.",
                                    "linha": 3836,
                                    "caput": "São elementos essenciais da sentença:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3844,
                                            "texto": "Não se considera fundamentada qualquer decisão judicial, seja ela interlocutória, sentença ou acórdão, que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3846,
                                                    "texto": "se limitar à indicação, à reprodução ou à paráfrase de ato normativo, sem explicar sua relação com a causa ou a questão decidida;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3848,
                                                    "texto": "empregar conceitos jurídicos indeterminados, sem explicar o motivo concreto de sua incidência no caso;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3850,
                                                    "texto": "invocar motivos que se prestariam a justificar qualquer outra decisão;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 3852,
                                                    "texto": "não enfrentar todos os argumentos deduzidos no processo capazes de, em tese, infirmar a conclusão adotada pelo julgador;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 3854,
                                                    "texto": "se limitar a invocar precedente ou enunciado de súmula, sem identificar seus fundamentos determinantes nem demonstrar que o caso sob julgamento se ajusta àqueles fundamentos;"
                                                },
                                                {
                                                    "numero": "VI",
                                                    "rotulo": "VI",
                                                    "linha": 3856,
                                                    "texto": "deixar de seguir enunciado de súmula, jurisprudência ou precedente invocado pela parte, sem demonstrar a existência de distinção no caso em julgamento ou a superação do entendimento."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3858,
                                            "texto": "No caso de colisão entre normas, o juiz deve justificar o objeto e os critérios gerais da ponderação efetuada, enunciando as razões que autorizam a interferência na norma afastada e as premissas fáticas que fundamentam a conclusão."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3860,
                                            "texto": "A decisão judicial deve ser interpretada a partir da conjugação de todos os seus elementos e em conformidade com o princípio da boa-fé."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3838,
                                            "texto": "o relatório, que conterá os nomes das partes, a identificação do caso, com a suma do pedido e da contestação, e o registro das principais ocorrências havidas no andamento do processo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3840,
                                            "texto": "os fundamentos, em que o juiz analisará as questões de fato e de direito;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 3842,
                                            "texto": "o dispositivo, em que o juiz resolverá as questões principais que as partes lhe submeterem."
                                        }
                                    ],
                                    "rubrica": "Dos Elementos e dos Efeitos da Sentença",
                                    "linhaRubrica": 3834
                                },
                                {
                                    "numero": "490º",
                                    "rotulo": "Art. 490º.",
                                    "linha": 3862,
                                    "caput": "O juiz resolverá o mérito acolhendo ou rejeitando, no todo ou em parte, os pedidos formulados pelas partes."
                                },
                                {
                                    "numero": "491º",
                                    "rotulo": "Art. 491º.",
                                    "linha": 3864,
                                    "caput": "Na ação relativa à obrigação de pagar quantia, ainda que formulado pedido genérico, a decisão definirá desde logo a extensão da obrigação, o índice de correção monetária, a taxa de juros, o termo inicial de ambos e a periodicidade da capitalização dos juros, se for o caso, salvo quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3870,
                                            "texto": "Nos casos previstos neste artigo, seguir-se-á a apuração do valor devido por liquidação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3872,
                                            "texto": "O disposto no caput também se aplica quando o acórdão alterar a sentença."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3866,
                                            "texto": "não for possível determinar, de modo definitivo, o montante devido;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3868,
                                            "texto": "a apuração do valor devido depender da produção de prova de realização demorada ou excessivamente dispendiosa, assim reconhecida na sentença."
                                        }
                                    ]
                                },
                                {
                                    "numero": "492º",
                                    "rotulo": "Art. 492º.",
                                    "linha": 3874,
                                    "caput": "É vedado ao juiz proferir decisão de natureza diversa da pedida, bem como condenar a parte em quantidade superior ou em objeto diverso do que lhe foi demandado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3876,
                                            "texto": "A decisão deve ser certa, ainda que resolva relação jurídica condicional."
                                        }
                                    ]
                                },
                                {
                                    "numero": "493º",
                                    "rotulo": "Art. 493º.",
                                    "linha": 3878,
                                    "caput": "Se, depois da propositura da ação, algum fato constitutivo, modificativo ou extintivo do direito influir no julgamento do mérito, caberá ao juiz tomá-lo em consideração, de ofício ou a requerimento da parte, no momento de proferir a decisão.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3880,
                                            "texto": "Se constatar de ofício o fato novo, o juiz ouvirá as partes sobre ele antes de decidir."
                                        }
                                    ]
                                },
                                {
                                    "numero": "494º",
                                    "rotulo": "Art. 494º.",
                                    "linha": 3882,
                                    "caput": "Publicada a sentença, o juiz só poderá alterá-la:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3884,
                                            "texto": "para corrigir-lhe, de ofício ou a requerimento da parte, inexatidões materiais ou erros de cálculo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3886,
                                            "texto": "por meio de embargos de declaração."
                                        }
                                    ]
                                },
                                {
                                    "numero": "495º",
                                    "rotulo": "Art. 495º.",
                                    "linha": 3888,
                                    "caput": "A decisão que condenar o réu ao pagamento de prestação consistente em dinheiro e a que determinar a conversão de prestação de fazer, de não fazer ou de dar coisa em prestação pecuniária valerão como título constitutivo de hipoteca judiciária.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3890,
                                            "texto": "A decisão produz a hipoteca judiciária:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3892,
                                                    "texto": "embora a condenação seja genérica;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3894,
                                                    "texto": "ainda que o credor possa promover o cumprimento provisório da sentença ou esteja pendente arresto sobre bem do devedor;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3896,
                                                    "texto": "mesmo que impugnada por recurso dotado de efeito suspensivo."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3898,
                                            "texto": "A hipoteca judiciária poderá ser realizada mediante apresentação de cópia da sentença perante o cartório de registro imobiliário, independentemente de ordem judicial, de declaração expressa do juiz ou de demonstração de urgência."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3900,
                                            "texto": "No prazo de até 15 (quinze) dias da data de realização da hipoteca, a parte informá-la-á ao juízo da causa, que determinará a intimação da outra parte para que tome ciência do ato."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3902,
                                            "texto": "A hipoteca judiciária, uma vez constituída, implicará, para o credor hipotecário, o direito de preferência, quanto ao pagamento, em relação a outros credores, observada a prioridade no registro."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 3904,
                                            "texto": "Sobrevindo a reforma ou a invalidação da decisão que impôs o pagamento de quantia, a parte responderá, independentemente de culpa, pelos danos que a outra parte tiver sofrido em razão da constituição da garantia, devendo o valor da indenização ser liquidado e executado nos próprios autos. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "496º",
                                    "rotulo": "Art. 496º.",
                                    "linha": 3909,
                                    "caput": "Está sujeita ao duplo grau de jurisdição, não produzindo efeito senão depois de confirmada pelo tribunal, a sentença:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3915,
                                            "texto": "Nos casos previstos neste artigo, não interposta a apelação no prazo legal, o juiz ordenará a remessa dos autos ao tribunal, e, se não o fizer, o presidente do respectivo tribunal avocá-los-á."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3917,
                                            "texto": "Em qualquer dos casos referidos no § 1º, o tribunal julgará a remessa necessária."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 3919,
                                            "texto": "Não se aplica o disposto neste artigo quando a condenação ou o proveito econômico obtido na causa for de valor certo e líquido inferior a:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3921,
                                                    "texto": "1.000 (mil) salários-mínimos para a União e as respectivas autarquias e fundações de direito público;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3923,
                                                    "texto": "500 (quinhentos) salários-mínimos para os Estados, o Distrito Federal, as respectivas autarquias e fundações de direito público e os Municípios que constituam capitais dos Estados;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3925,
                                                    "texto": "100 (cem) salários-mínimos para todos os demais Municípios e respectivas autarquias e fundações de direito público."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 3927,
                                            "texto": "Também não se aplica o disposto neste artigo quando a sentença estiver fundada em:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3929,
                                                    "texto": "súmula de tribunal superior;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3931,
                                                    "texto": "acórdão proferido pelo Supremo Tribunal Federal ou pelo Superior Tribunal de Justiça em julgamento de recursos repetitivos;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3933,
                                                    "texto": "entendimento firmado em incidente de resolução de demandas repetitivas ou de assunção de competência;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 3935,
                                                    "texto": "entendimento coincidente com orientação vinculante firmada no âmbito administrativo do próprio ente público, consolidada em manifestação, parecer ou súmula administrativa. Seção IV"
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3911,
                                            "texto": "proferida contra a União, os Estados, o Distrito Federal, os Municípios e suas respectivas autarquias e fundações de direito público;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3913,
                                            "texto": "que julgar procedentes, no todo ou em parte, os embargos à execução fiscal."
                                        }
                                    ],
                                    "rubrica": "Da Remessa Necessária",
                                    "linhaRubrica": 3907
                                },
                                {
                                    "numero": "497º",
                                    "rotulo": "Art. 497º.",
                                    "linha": 3940,
                                    "caput": "Na ação que tenha por objeto a prestação de fazer ou de não fazer, o juiz, se procedente o pedido, concederá a tutela específica ou determinará providências que assegurem a obtenção de tutela pelo resultado prático equivalente.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3942,
                                            "texto": "Para a concessão da tutela específica destinada a inibir a prática, a reiteração ou a continuação de um ilícito, ou a sua remoção, é irrelevante a demonstração da ocorrência de dano ou da existência de culpa ou dolo."
                                        }
                                    ],
                                    "rubrica": "Do Julgamento das Ações Relativas às Prestações de Fazer, de Não Fazer e de Entregar Coisa",
                                    "linhaRubrica": 3938
                                },
                                {
                                    "numero": "498º",
                                    "rotulo": "Art. 498º.",
                                    "linha": 3944,
                                    "caput": "Na ação que tenha por objeto a entrega de coisa, o juiz, ao conceder a tutela específica, fixará o prazo para o cumprimento da obrigação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3946,
                                            "texto": "Tratando-se de entrega de coisa determinada pelo gênero e pela quantidade, o autor individualizá-la-á na petição inicial, se lhe couber a escolha, ou, se a escolha couber ao réu, este a entregará individualizada, no prazo fixado pelo juiz."
                                        }
                                    ]
                                },
                                {
                                    "numero": "499º",
                                    "rotulo": "Art. 499º.",
                                    "linha": 3948,
                                    "caput": "A obrigação somente será convertida em perdas e danos se o autor o requerer ou se impossível a tutela específica ou a obtenção de tutela pelo resultado prático equivalente.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 3950,
                                            "texto": "Nas hipóteses de responsabilidade contratual previstas nos arts. 441, 618 e 757 da Lei nº 10.406, de 10 de janeiro de 2002 (Código Civil), e de responsabilidade subsidiária e solidária, se requerida a conversão da obrigação em perdas e danos, o juiz concederá, primeiramente, a faculdade para o cumprimento da tutela específica.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 441",
                                                    "href": "../../../LEIS/2002/L10406.htm#art441",
                                                    "inicio": 59,
                                                    "fim": 68
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "618",
                                                    "href": "../../../LEIS/2002/L10406.htm#art618",
                                                    "inicio": 70,
                                                    "fim": 73
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "500º",
                                    "rotulo": "Art. 500º.",
                                    "linha": 3952,
                                    "caput": "A indenização por perdas e danos dar-se-á sem prejuízo da multa fixada periodicamente para compelir o réu ao cumprimento específico da obrigação."
                                },
                                {
                                    "numero": "501º",
                                    "rotulo": "Art. 501º.",
                                    "linha": 3954,
                                    "caput": "Na ação que tenha por objeto a emissão de declaração de vontade, a sentença que julgar procedente o pedido, uma vez transitada em julgado, produzirá todos os efeitos da declaração não emitida. Seção V"
                                },
                                {
                                    "numero": "502º",
                                    "rotulo": "Art. 502º.",
                                    "linha": 3959,
                                    "caput": "Denomina-se coisa julgada material a autoridade que torna imutável e indiscutível a decisão de mérito não mais sujeita a recurso.",
                                    "rubrica": "Da Coisa Julgada",
                                    "linhaRubrica": 3957
                                },
                                {
                                    "numero": "503º",
                                    "rotulo": "Art. 503º.",
                                    "linha": 3961,
                                    "caput": "A decisão que julgar total ou parcialmente o mérito tem força de lei nos limites da questão principal expressamente decidida.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 3963,
                                            "texto": "O disposto no caput aplica-se à resolução de questão prejudicial, decidida expressa e incidentemente no processo, se:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 3965,
                                                    "texto": "dessa resolução depender o julgamento do mérito;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 3967,
                                                    "texto": "a seu respeito tiver havido contraditório prévio e efetivo, não se aplicando no caso de revelia;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 3969,
                                                    "texto": "o juízo tiver competência em razão da matéria e da pessoa para resolvê-la como questão principal."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 3971,
                                            "texto": "A hipótese do § 1º não se aplica se no processo houver restrições probatórias ou limitações à cognição que impeçam o aprofundamento da análise da questão prejudicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "504º",
                                    "rotulo": "Art. 504º.",
                                    "linha": 3973,
                                    "caput": "Não fazem coisa julgada:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3975,
                                            "texto": "os motivos, ainda que importantes para determinar o alcance da parte dispositiva da sentença;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3977,
                                            "texto": "a verdade dos fatos, estabelecida como fundamento da sentença."
                                        }
                                    ]
                                },
                                {
                                    "numero": "505º",
                                    "rotulo": "Art. 505º.",
                                    "linha": 3979,
                                    "caput": "Nenhum juiz decidirá novamente as questões já decididas relativas à mesma lide, salvo:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3981,
                                            "texto": "se, tratando-se de relação jurídica de trato continuado, sobreveio modificação no estado de fato ou de direito, caso em que poderá a parte pedir a revisão do que foi estatuído na sentença;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3983,
                                            "texto": "nos demais casos prescritos em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "506º",
                                    "rotulo": "Art. 506º.",
                                    "linha": 3985,
                                    "caput": "A sentença faz coisa julgada às partes entre as quais é dada, não prejudicando terceiros."
                                },
                                {
                                    "numero": "507º",
                                    "rotulo": "Art. 507º.",
                                    "linha": 3987,
                                    "caput": "É vedado à parte discutir no curso do processo as questões já decididas a cujo respeito se operou a preclusão."
                                },
                                {
                                    "numero": "508º",
                                    "rotulo": "Art. 508º.",
                                    "linha": 3989,
                                    "caput": "Transitada em julgado a decisão de mérito, considerar-se-ão deduzidas e repelidas todas as alegações e as defesas que a parte poderia opor tanto ao acolhimento quanto à rejeição do pedido."
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA SENTENÇA E DA COISA JULGADA",
                            "linhaTitulo": 3766
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XIV",
                            "linha": 3991,
                            "artigos": [
                                {
                                    "numero": "509º",
                                    "rotulo": "Art. 509º.",
                                    "linha": 3994,
                                    "caput": "Quando a sentença condenar ao pagamento de quantia ilíquida, proceder-se-á à sua liquidação, a requerimento do credor ou do devedor:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4000,
                                            "texto": "Quando na sentença houver uma parte líquida e outra ilíquida, ao credor é lícito promover simultaneamente a execução daquela e, em autos apartados, a liquidação desta."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4002,
                                            "texto": "Quando a apuração do valor depender apenas de cálculo aritmético, o credor poderá promover, desde logo, o cumprimento da sentença."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4004,
                                            "texto": "O Conselho Nacional de Justiça desenvolverá e colocará à disposição dos interessados programa de atualização financeira."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4006,
                                            "texto": "Na liquidação é vedado discutir de novo a lide ou modificar a sentença que a julgou."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 3996,
                                            "texto": "por arbitramento, quando determinado pela sentença, convencionado pelas partes ou exigido pela natureza do objeto da liquidação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 3998,
                                            "texto": "pelo procedimento comum, quando houver necessidade de alegar e provar fato novo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "510º",
                                    "rotulo": "Art. 510º.",
                                    "linha": 4008,
                                    "caput": "Na liquidação por arbitramento, o juiz intimará as partes para a apresentação de pareceres ou documentos elucidativos, no prazo que fixar, e, caso não possa decidir de plano, nomeará perito, observando-se, no que couber, o procedimento da prova pericial."
                                },
                                {
                                    "numero": "511º",
                                    "rotulo": "Art. 511º.",
                                    "linha": 4010,
                                    "caput": "Na liquidação pelo procedimento comum, o juiz determinará a intimação do requerido, na pessoa de seu advogado ou da sociedade de advogados a que estiver vinculado, para, querendo, apresentar contestação no prazo de 15 (quinze) dias, observando-se, a seguir, no que couber, o disposto no Livro I da Parte Especial deste Código ."
                                },
                                {
                                    "numero": "512º",
                                    "rotulo": "Art. 512º.",
                                    "linha": 4012,
                                    "caput": "A liquidação poderá ser realizada na pendência de recurso, processando-se em autos apartados no juízo de origem, cumprindo ao liquidante instruir o pedido com cópias das peças processuais pertinentes."
                                }
                            ],
                            "titulo": "DA LIQUIDAÇÃO DE SENTENÇA",
                            "linhaTitulo": 3992
                        }
                    ],
                    "titulo": "DO PROCEDIMENTO COMUM",
                    "linhaTitulo": 2487
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 4014,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 4017,
                            "artigos": [
                                {
                                    "numero": "513º",
                                    "rotulo": "Art. 513º.",
                                    "linha": 4020,
                                    "caput": "O cumprimento da sentença será feito segundo as regras deste Título, observando-se, no que couber e conforme a natureza da obrigação, o disposto no Livro II da Parte Especial deste Código.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4022,
                                            "texto": "O cumprimento da sentença que reconhece o dever de pagar quantia, provisório ou definitivo, far-se-á a requerimento do exequente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4024,
                                            "texto": "O devedor será intimado para cumprir a sentença:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4026,
                                                    "texto": "pelo Diário da Justiça, na pessoa de seu advogado constituído nos autos;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4028,
                                                    "texto": "por carta com aviso de recebimento, quando representado pela Defensoria Pública ou quando não tiver procurador constituído nos autos, ressalvada a hipótese do inciso IV;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 4030,
                                                    "texto": "por meio eletrônico, quando, no caso do § 1º do art. 246, não tiver procurador constituído nos autos"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 4032,
                                                    "texto": "por edital, quando, citado na forma do art. 256, tiver sido revel na fase de conhecimento.",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 256",
                                                            "href": "#art256",
                                                            "inicio": 39,
                                                            "fim": 47
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4034,
                                            "texto": "Na hipótese do § 2º, incisos II e III, considera-se realizada a intimação quando o devedor houver mudado de endereço sem prévia comunicação ao juízo, observado o disposto no parágrafo único do art. 274.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 274",
                                                    "href": "#art274",
                                                    "inicio": 193,
                                                    "fim": 201
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4036,
                                            "texto": "Se o requerimento a que alude o § 1º for formulado após 1 (um) ano do trânsito em julgado da sentença, a intimação será feita na pessoa do devedor, por meio de carta com aviso de recebimento encaminhada ao endereço constante dos autos, observado o disposto no parágrafo único do art. 274 e no § 3º deste artigo.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 274",
                                                    "href": "#art274",
                                                    "inicio": 279,
                                                    "fim": 287
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4038,
                                            "texto": "O cumprimento da sentença não poderá ser promovido em face do fiador, do coobrigado ou do corresponsável que não tiver participado da fase de conhecimento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "514º",
                                    "rotulo": "Art. 514º.",
                                    "linha": 4040,
                                    "caput": "Quando o juiz decidir relação jurídica sujeita a condição ou termo, o cumprimento da sentença dependerá de demonstração de que se realizou a condição ou de que ocorreu o termo."
                                },
                                {
                                    "numero": "515º",
                                    "rotulo": "Art. 515º.",
                                    "linha": 4042,
                                    "caput": "São títulos executivos judiciais, cujo cumprimento dar-se-á de acordo com os artigos previstos neste Título:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4062,
                                            "texto": "Nos casos dos incisos VI a IX, o devedor será citado no juízo cível para o cumprimento da sentença ou para a liquidação no prazo de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4064,
                                            "texto": "A autocomposição judicial pode envolver sujeito estranho ao processo e versar sobre relação jurídica que não tenha sido deduzida em juízo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4044,
                                            "texto": "as decisões proferidas no processo civil que reconheçam a exigibilidade de obrigação de pagar quantia, de fazer, de não fazer ou de entregar coisa;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4046,
                                            "texto": "a decisão homologatória de autocomposição judicial;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4048,
                                            "texto": "a decisão homologatória de autocomposição extrajudicial de qualquer natureza;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4050,
                                            "texto": "o formal e a certidão de partilha, exclusivamente em relação ao inventariante, aos herdeiros e aos sucessores a título singular ou universal;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4052,
                                            "texto": "o crédito de auxiliar da justiça, quando as custas, emolumentos ou honorários tiverem sido aprovados por decisão judicial;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4054,
                                            "texto": "a sentença penal condenatória transitada em julgado;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 4056,
                                            "texto": "a sentença arbitral;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 4058,
                                            "texto": "a sentença estrangeira homologada pelo Superior Tribunal de Justiça;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 4060,
                                            "texto": "a decisão interlocutória estrangeira, após a concessão do exequatur à carta rogatória pelo Superior Tribunal de Justiça;"
                                        }
                                    ]
                                },
                                {
                                    "numero": "516º",
                                    "rotulo": "Art. 516º.",
                                    "linha": 4066,
                                    "caput": "O cumprimento da sentença efetuar-se-á perante:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4074,
                                            "texto": "Nas hipóteses dos incisos II e III, o exequente poderá optar pelo juízo do atual domicílio do executado, pelo juízo do local onde se encontrem os bens sujeitos à execução ou pelo juízo do local onde deva ser executada a obrigação de fazer ou de não fazer, casos em que a remessa dos autos do processo será solicitada ao juízo de origem."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4068,
                                            "texto": "os tribunais, nas causas de sua competência originária;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4070,
                                            "texto": "o juízo que decidiu a causa no primeiro grau de jurisdição;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4072,
                                            "texto": "o juízo cível competente, quando se tratar de sentença penal condenatória, de sentença arbitral, de sentença estrangeira ou de acórdão proferido pelo Tribunal Marítimo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "517º",
                                    "rotulo": "Art. 517º.",
                                    "linha": 4076,
                                    "caput": "A decisão judicial transitada em julgado poderá ser levada a protesto, nos termos da lei, depois de transcorrido o prazo para pagamento voluntário previsto no art. 523.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4078,
                                            "texto": "Para efetivar o protesto, incumbe ao exequente apresentar certidão de teor da decisão."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4080,
                                            "texto": "A certidão de teor da decisão deverá ser fornecida no prazo de 3 (três) dias e indicará o nome e a qualificação do exequente e do executado, o número do processo, o valor da dívida e a data de decurso do prazo para pagamento voluntário."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4082,
                                            "texto": "O executado que tiver proposto ação rescisória para impugnar a decisão exequenda pode requerer, a suas expensas e sob sua responsabilidade, a anotação da propositura da ação à margem do título protestado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4084,
                                            "texto": "A requerimento do executado, o protesto será cancelado por determinação do juiz, mediante ofício a ser expedido ao cartório, no prazo de 3 (três) dias, contado da data de protocolo do requerimento, desde que comprovada a satisfação integral da obrigação."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 523.",
                                            "href": "#art523",
                                            "inicio": 159,
                                            "fim": 168
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "art. 523",
                                            "href": "#art523",
                                            "inicio": 159,
                                            "fim": 167
                                        }
                                    ]
                                },
                                {
                                    "numero": "518º",
                                    "rotulo": "Art. 518º.",
                                    "linha": 4086,
                                    "caput": "Todas as questões relativas à validade do procedimento de cumprimento da sentença e dos atos executivos subsequentes poderão ser arguidas pelo executado nos próprios autos e nestes serão decididas pelo juiz."
                                },
                                {
                                    "numero": "519º",
                                    "rotulo": "Art. 519º.",
                                    "linha": 4088,
                                    "caput": "Aplicam-se as disposições relativas ao cumprimento da sentença, provisório ou definitivo, e à liquidação, no que couber, às decisões que concederem tutela provisória."
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 4018
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 4090,
                            "artigos": [
                                {
                                    "numero": "520º",
                                    "rotulo": "Art. 520º.",
                                    "linha": 4093,
                                    "caput": "O cumprimento provisório da sentença impugnada por recurso desprovido de efeito suspensivo será realizado da mesma forma que o cumprimento definitivo, sujeitando-se ao seguinte regime:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4103,
                                            "texto": "No cumprimento provisório da sentença, o executado poderá apresentar impugnação, se quiser, nos termos do art. 525.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 525",
                                                    "href": "#art525",
                                                    "inicio": 106,
                                                    "fim": 114
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4105,
                                            "texto": "A multa e os honorários a que se refere o § 1º do art. 523 são devidos no cumprimento provisório de sentença condenatória ao pagamento de quantia certa.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 523",
                                                    "href": "#art523",
                                                    "inicio": 50,
                                                    "fim": 58
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4107,
                                            "texto": "Se o executado comparecer tempestivamente e depositar o valor, com a finalidade de isentar-se da multa, o ato não será havido como incompatível com o recurso por ele interposto."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4109,
                                            "texto": "A restituição ao estado anterior a que se refere o inciso II não implica o desfazimento da transferência de posse ou da alienação de propriedade ou de outro direito real eventualmente já realizada, ressalvado, sempre, o direito à reparação dos prejuízos causados ao executado."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4111,
                                            "texto": "Ao cumprimento provisório de sentença que reconheça obrigação de fazer, de não fazer ou de dar coisa aplica-se, no que couber, o disposto neste Capítulo."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4095,
                                            "texto": "corre por iniciativa e responsabilidade do exequente, que se obriga, se a sentença for reformada, a reparar os danos que o executado haja sofrido;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4097,
                                            "texto": "fica sem efeito, sobrevindo decisão que modifique ou anule a sentença objeto da execução, restituindo-se as partes ao estado anterior e liquidando-se eventuais prejuízos nos mesmos autos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4099,
                                            "texto": "se a sentença objeto de cumprimento provisório for modificada ou anulada apenas em parte, somente nesta ficará sem efeito a execução;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4101,
                                            "texto": "o levantamento de depósito em dinheiro e a prática de atos que importem transferência de posse ou alienação de propriedade ou de outro direito real, ou dos quais possa resultar grave dano ao executado, dependem de caução suficiente e idônea, arbitrada de plano pelo juiz e prestada nos próprios autos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "521º",
                                    "rotulo": "Art. 521º.",
                                    "linha": 4113,
                                    "caput": "A caução prevista no inciso IV do art. 520 poderá ser dispensada nos casos em que:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4124,
                                            "texto": "A exigência de caução será mantida quando da dispensa possa resultar manifesto risco de grave dano de difícil ou incerta reparação."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4115,
                                            "texto": "o crédito for de natureza alimentar, independentemente de sua origem;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4117,
                                            "texto": "o credor demonstrar situação de necessidade;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4120,
                                            "texto": "pender o agravo do art. 1.042;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4122,
                                            "texto": "a sentença a ser provisoriamente cumprida estiver em consonância com súmula da jurisprudência do Supremo Tribunal Federal ou do Superior Tribunal de Justiça ou em conformidade com acórdão proferido no julgamento de casos repetitivos."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "inciso IV do art. 520",
                                            "href": "#art520iv",
                                            "inicio": 21,
                                            "fim": 42
                                        }
                                    ]
                                },
                                {
                                    "numero": "522º",
                                    "rotulo": "Art. 522º.",
                                    "linha": 4126,
                                    "caput": "O cumprimento provisório da sentença será requerido por petição dirigida ao juízo competente.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4128,
                                            "texto": "Não sendo eletrônicos os autos, a petição será acompanhada de cópias das seguintes peças do processo, cuja autenticidade poderá ser certificada pelo próprio advogado, sob sua responsabilidade pessoal:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4130,
                                                    "texto": "decisão exequenda;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4132,
                                                    "texto": "certidão de interposição do recurso não dotado de efeito suspensivo;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 4134,
                                                    "texto": "procurações outorgadas pelas partes;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 4136,
                                                    "texto": "decisão de habilitação, se for o caso;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 4138,
                                                    "texto": "facultativamente, outras peças processuais consideradas necessárias para demonstrar a existência do crédito."
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO CUMPRIMENTO PROVISÓRIO DA SENTENÇA QUE RECONHECE A EXIGIBILIDADE DE OBRIGAÇÃO DE PAGAR QUANTIA CERTA",
                            "linhaTitulo": 4091
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 4140,
                            "artigos": [
                                {
                                    "numero": "523º",
                                    "rotulo": "Art. 523º.",
                                    "linha": 4143,
                                    "caput": "No caso de condenação em quantia certa, ou já fixada em liquidação, e no caso de decisão sobre parcela incontroversa, o cumprimento definitivo da sentença far-se-á a requerimento do exequente, sendo o executado intimado para pagar o débito, no prazo de 15 (quinze) dias, acrescido de custas, se houver.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4145,
                                            "texto": "Não ocorrendo pagamento voluntário no prazo do caput , o débito será acrescido de multa de dez por cento e, também, de honorários de advogado de dez por cento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4147,
                                            "texto": "Efetuado o pagamento parcial no prazo previsto no caput , a multa e os honorários previstos no § 1º incidirão sobre o restante."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4149,
                                            "texto": "Não efetuado tempestivamente o pagamento voluntário, será expedido, desde logo, mandado de penhora e avaliação, seguindo-se os atos de expropriação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "524º",
                                    "rotulo": "Art. 524º.",
                                    "linha": 4151,
                                    "caput": "O requerimento previsto no art. 523 será instruído com demonstrativo discriminado e atualizado do crédito, devendo a petição conter:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4167,
                                            "texto": "Quando o valor apontado no demonstrativo aparentemente exceder os limites da condenação, a execução será iniciada pelo valor pretendido, mas a penhora terá por base a importância que o juiz entender adequada."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4169,
                                            "texto": "Para a verificação dos cálculos, o juiz poderá valer-se de contabilista do juízo, que terá o prazo máximo de 30 (trinta) dias para efetuá-la, exceto se outro lhe for determinado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4171,
                                            "texto": "Quando a elaboração do demonstrativo depender de dados em poder de terceiros ou do executado, o juiz poderá requisitá-los, sob cominação do crime de desobediência."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4173,
                                            "texto": "Quando a complementação do demonstrativo depender de dados adicionais em poder do executado, o juiz poderá, a requerimento do exequente, requisitá-los, fixando prazo de até 30 (trinta) dias para o cumprimento da diligência."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4175,
                                            "texto": "Se os dados adicionais a que se refere o § 4º não forem apresentados pelo executado, sem justificativa, no prazo designado, reputar-se-ão corretos os cálculos apresentados pelo exequente apenas com base nos dados de que dispõe."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4153,
                                            "texto": "o nome completo, o número de inscrição no Cadastro de Pessoas Físicas ou no Cadastro Nacional da Pessoa Jurídica do exequente e do executado, observado o disposto no art. 319, §§ 1º a 3º;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 319",
                                                    "href": "#art319",
                                                    "inicio": 166,
                                                    "fim": 174
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4155,
                                            "texto": "o índice de correção monetária adotado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4157,
                                            "texto": "os juros aplicados e as respectivas taxas;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4159,
                                            "texto": "o termo inicial e o termo final dos juros e da correção monetária utilizados;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4161,
                                            "texto": "a periodicidade da capitalização dos juros, se for o caso;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4163,
                                            "texto": "especificação dos eventuais descontos obrigatórios realizados;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 4165,
                                            "texto": "indicação dos bens passíveis de penhora, sempre que possível."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 523",
                                            "href": "#art523",
                                            "inicio": 27,
                                            "fim": 35
                                        }
                                    ]
                                },
                                {
                                    "numero": "525º",
                                    "rotulo": "Art. 525º.",
                                    "linha": 4177,
                                    "caput": "Transcorrido o prazo previsto no art. 523 sem o pagamento voluntário, inicia-se o prazo de 15 (quinze) dias para que o executado, independentemente de penhora ou nova intimação, apresente, nos próprios autos, sua impugnação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4179,
                                            "texto": "Na impugnação, o executado poderá alegar:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4181,
                                                    "texto": "falta ou nulidade da citação se, na fase de conhecimento, o processo correu à revelia;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4183,
                                                    "texto": "ilegitimidade de parte;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 4185,
                                                    "texto": "inexequibilidade do título ou inexigibilidade da obrigação;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 4187,
                                                    "texto": "penhora incorreta ou avaliação errônea;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 4189,
                                                    "texto": "excesso de execução ou cumulação indevida de execuções;"
                                                },
                                                {
                                                    "numero": "VI",
                                                    "rotulo": "VI",
                                                    "linha": 4191,
                                                    "texto": "incompetência absoluta ou relativa do juízo da execução;"
                                                },
                                                {
                                                    "numero": "VII",
                                                    "rotulo": "VII",
                                                    "linha": 4193,
                                                    "texto": "qualquer causa modificativa ou extintiva da obrigação, como pagamento, novação, compensação, transação ou prescrição, desde que supervenientes à sentença."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4195,
                                            "texto": "A alegação de impedimento ou suspeição observará o disposto nos arts. 146 e 148.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 146",
                                                    "href": "#art146",
                                                    "inicio": 64,
                                                    "fim": 73
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "148",
                                                    "href": "#art148",
                                                    "inicio": 76,
                                                    "fim": 79
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 146 e 148",
                                                    "href": "#art146",
                                                    "inicio": 64,
                                                    "fim": 79
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4197,
                                            "texto": "Aplica-se à impugnação o disposto no art. 229.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 229.",
                                                    "href": "#art229",
                                                    "inicio": 37,
                                                    "fim": 46
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 229",
                                                    "href": "#art229",
                                                    "inicio": 37,
                                                    "fim": 45
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "229",
                                                    "href": "../../../LEIS/2002/L10406.htm#art229",
                                                    "inicio": 42,
                                                    "fim": 45
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4199,
                                            "texto": "Quando o executado alegar que o exequente, em excesso de execução, pleiteia quantia superior à resultante da sentença, cumprir-lhe-á declarar de imediato o valor que entende correto, apresentando demonstrativo discriminado e atualizado de seu cálculo."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4201,
                                            "texto": "Na hipótese do § 4º, não apontado o valor correto ou não apresentado o demonstrativo, a impugnação será liminarmente rejeitada, se o excesso de execução for o seu único fundamento, ou, se houver outro, a impugnação será processada, mas o juiz não examinará a alegação de excesso de execução."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 4203,
                                            "texto": "A apresentação de impugnação não impede a prática dos atos executivos, inclusive os de expropriação, podendo o juiz, a requerimento do executado e desde que garantido o juízo com penhora, caução ou depósito suficientes, atribuir-lhe efeito suspensivo, se seus fundamentos forem relevantes e se o prosseguimento da execução for manifestamente suscetível de causar ao executado grave dano de difícil ou incerta reparação."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 4205,
                                            "texto": "A concessão de efeito suspensivo a que se refere o § 6º não impedirá a efetivação dos atos de substituição, de reforço ou de redução da penhora e de avaliação dos bens"
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 4207,
                                            "texto": "Quando o efeito suspensivo atribuído à impugnação disser respeito apenas a parte do objeto da execução, esta prosseguirá quanto à parte restante."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 4209,
                                            "texto": "A concessão de efeito suspensivo à impugnação deduzida por um dos executados não suspenderá a execução contra os que não impugnaram, quando o respectivo fundamento disser respeito exclusivamente ao impugnante."
                                        },
                                        {
                                            "numero": "10º",
                                            "rotulo": "§ 10º",
                                            "linha": 4211,
                                            "texto": "Ainda que atribuído efeito suspensivo à impugnação, é lícito ao exequente requerer o prosseguimento da execução, oferecendo e prestando, nos próprios autos, caução suficiente e idônea a ser arbitrada pelo juiz."
                                        },
                                        {
                                            "numero": "11º",
                                            "rotulo": "§ 11º",
                                            "linha": 4213,
                                            "texto": "As questões relativas a fato superveniente ao término do prazo para apresentação da impugnação, assim como aquelas relativas à validade e à adequação da penhora, da avaliação e dos atos executivos subsequentes, podem ser arguidas por simples petição, tendo o executado, em qualquer dos casos, o prazo de 15 (quinze) dias para formular esta arguição, contado da comprovada ciência do fato ou da intimação do ato."
                                        },
                                        {
                                            "numero": "12º",
                                            "rotulo": "§ 12º",
                                            "linha": 4215,
                                            "texto": "Para efeito do disposto no inciso III do § 1º deste artigo, considera-se também inexigível a obrigação reconhecida em título executivo judicial fundado em lei ou ato normativo considerado inconstitucional pelo Supremo Tribunal Federal, ou fundado em aplicação ou interpretação da lei ou do ato normativo tido pelo Supremo Tribunal Federal como incompatível com a Constituição Federal, em controle de constitucionalidade concentrado ou difuso."
                                        },
                                        {
                                            "numero": "13º",
                                            "rotulo": "§ 13º",
                                            "linha": 4217,
                                            "texto": "No caso do § 12, os efeitos da decisão do Supremo Tribunal Federal poderão ser modulados no tempo, em atenção à segurança jurídica.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "12",
                                                    "href": "../../../LEIS/L1060.htm#art12",
                                                    "inicio": 13,
                                                    "fim": 15
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "14º",
                                            "rotulo": "§ 14º",
                                            "linha": 4219,
                                            "texto": "A decisão do Supremo Tribunal Federal referida no § 12 deve ser anterior ao trânsito em julgado da decisão exequenda.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "12",
                                                    "href": "../../../LEIS/L1060.htm#art12",
                                                    "inicio": 52,
                                                    "fim": 54
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "15º",
                                            "rotulo": "§ 15º",
                                            "linha": 4221,
                                            "texto": "Se a decisão referida no § 12 for proferida após o trânsito em julgado da decisão exequenda, caberá ação rescisória, cujo prazo será contado do trânsito em julgado da decisão proferida pelo Supremo Tribunal Federal.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "12",
                                                    "href": "../../../LEIS/L1060.htm#art12",
                                                    "inicio": 27,
                                                    "fim": 29
                                                }
                                            ]
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 523",
                                            "href": "#art523",
                                            "inicio": 33,
                                            "fim": 41
                                        }
                                    ]
                                },
                                {
                                    "numero": "526º",
                                    "rotulo": "Art. 526º.",
                                    "linha": 4223,
                                    "caput": "É lícito ao réu, antes de ser intimado para o cumprimento da sentença, comparecer em juízo e oferecer em pagamento o valor que entender devido, apresentando memória discriminada do cálculo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4225,
                                            "texto": "O autor será ouvido no prazo de 5 (cinco) dias, podendo impugnar o valor depositado, sem prejuízo do levantamento do depósito a título de parcela incontroversa."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4227,
                                            "texto": "Concluindo o juiz pela insuficiência do depósito, sobre a diferença incidirão multa de dez por cento e honorários advocatícios, também fixados em dez por cento, seguindo-se a execução com penhora e atos subsequentes."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4229,
                                            "texto": "Se o autor não se opuser, o juiz declarará satisfeita a obrigação e extinguirá o processo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "527º",
                                    "rotulo": "Art. 527º.",
                                    "linha": 4231,
                                    "caput": "Aplicam-se as disposições deste Capítulo ao cumprimento provisório da sentença, no que couber."
                                }
                            ],
                            "titulo": "DO CUMPRIMENTO DEFINITIVO DA SENTENÇA QUE RECONHECE A EXIGIBILIDADE DE OBRIGAÇÃO DE PAGAR QUANTIA CERTA",
                            "linhaTitulo": 4141
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 4233,
                            "artigos": [
                                {
                                    "numero": "528º",
                                    "rotulo": "Art. 528º.",
                                    "linha": 4236,
                                    "caput": "No cumprimento de sentença que condene ao pagamento de prestação alimentícia ou de decisão interlocutória que fixe alimentos, o juiz, a requerimento do exequente, mandará intimar o executado pessoalmente para, em 3 (três) dias, pagar o débito, provar que o fez ou justificar a impossibilidade de efetuá-lo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4238,
                                            "texto": "Caso o executado, no prazo referido no caput , não efetue o pagamento, não prove que o efetuou ou não apresente justificativa da impossibilidade de efetuá-lo, o juiz mandará protestar o pronunciamento judicial, aplicando-se, no que couber, o disposto no art. 517 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 517",
                                                    "href": "#art517",
                                                    "inicio": 254,
                                                    "fim": 262
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4240,
                                            "texto": "Somente a comprovação de fato que gere a impossibilidade absoluta de pagar justificará o inadimplemento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4242,
                                            "texto": "Se o executado não pagar ou se a justificativa apresentada não for aceita, o juiz, além de mandar protestar o pronunciamento judicial na forma do § 1º, decretar-lhe-á a prisão pelo prazo de 1 (um) a 3 (três) meses."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4244,
                                            "texto": "A prisão será cumprida em regime fechado, devendo o preso ficar separado dos presos comuns."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4246,
                                            "texto": "O cumprimento da pena não exime o executado do pagamento das prestações vencidas e vincendas."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 4248,
                                            "texto": "Paga a prestação alimentícia, o juiz suspenderá o cumprimento da ordem de prisão."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 4250,
                                            "texto": "O débito alimentar que autoriza a prisão civil do alimentante é o que compreende até as 3 (três) prestações anteriores ao ajuizamento da execução e as que se vencerem no curso do processo."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 4252,
                                            "texto": "O exequente pode optar por promover o cumprimento da sentença ou decisão desde logo, nos termos do disposto neste Livro, Título II, Capítulo III, caso em que não será admissível a prisão do executado, e, recaindo a penhora em dinheiro, a concessão de efeito suspensivo à impugnação não obsta a que o exequente levante mensalmente a importância da prestação."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 4254,
                                            "texto": "Além das opções previstas no art. 516, parágrafo único, o exequente pode promover o cumprimento da sentença ou decisão que condena ao pagamento de prestação alimentícia no juízo de seu domicílio.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 516",
                                                    "href": "#art516",
                                                    "inicio": 29,
                                                    "fim": 37
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "529º",
                                    "rotulo": "Art. 529º.",
                                    "linha": 4256,
                                    "caput": "Quando o executado for funcionário público, militar, diretor ou gerente de empresa ou empregado sujeito à legislação do trabalho, o exequente poderá requerer o desconto em folha de pagamento da importância da prestação alimentícia.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4258,
                                            "texto": "Ao proferir a decisão, o juiz oficiará à autoridade, à empresa ou ao empregador, determinando, sob pena de crime de desobediência, o desconto a partir da primeira remuneração posterior do executado, a contar do protocolo do ofício."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4260,
                                            "texto": "O ofício conterá o nome e o número de inscrição no Cadastro de Pessoas Físicas do exequente e do executado, a importância a ser descontada mensalmente, o tempo de sua duração e a conta na qual deve ser feito o depósito."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4262,
                                            "texto": "Sem prejuízo do pagamento dos alimentos vincendos, o débito objeto de execução pode ser descontado dos rendimentos ou rendas do executado, de forma parcelada, nos termos do caput deste artigo, contanto que, somado à parcela devida, não ultrapasse cinquenta por cento de seus ganhos líquidos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "530º",
                                    "rotulo": "Art. 530º.",
                                    "linha": 4264,
                                    "caput": "Não cumprida a obrigação, observar-se-á o disposto nos arts. 831 e seguintes.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 831 e seguintes",
                                            "href": "#art831",
                                            "inicio": 55,
                                            "fim": 76
                                        }
                                    ]
                                },
                                {
                                    "numero": "531º",
                                    "rotulo": "Art. 531º.",
                                    "linha": 4266,
                                    "caput": "O disposto neste Capítulo aplica-se aos alimentos definitivos ou provisórios.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4268,
                                            "texto": "A execução dos alimentos provisórios, bem como a dos alimentos fixados em sentença ainda não transitada em julgado, se processa em autos apartados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4270,
                                            "texto": "O cumprimento definitivo da obrigação de prestar alimentos será processado nos mesmos autos em que tenha sido proferida a sentença."
                                        }
                                    ]
                                },
                                {
                                    "numero": "532º",
                                    "rotulo": "Art. 532º.",
                                    "linha": 4272,
                                    "caput": "Verificada a conduta procrastinatória do executado, o juiz deverá, se for o caso, dar ciência ao Ministério Público dos indícios da prática do crime de abandono material."
                                },
                                {
                                    "numero": "533º",
                                    "rotulo": "Art. 533º.",
                                    "linha": 4274,
                                    "caput": "Quando a indenização por ato ilícito incluir prestação de alimentos, caberá ao executado, a requerimento do exequente, constituir capital cuja renda assegure o pagamento do valor mensal da pensão.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4276,
                                            "texto": "O capital a que se refere o caput , representado por imóveis ou por direitos reais sobre imóveis suscetíveis de alienação, títulos da dívida pública ou aplicações financeiras em banco oficial, será inalienável e impenhorável enquanto durar a obrigação do executado, além de constituir-se em patrimônio de afetação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4278,
                                            "texto": "O juiz poderá substituir a constituição do capital pela inclusão do exequente em folha de pagamento de pessoa jurídica de notória capacidade econômica ou, a requerimento do executado, por fiança bancária ou garantia real, em valor a ser arbitrado de imediato pelo juiz."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4280,
                                            "texto": "Se sobrevier modificação nas condições econômicas, poderá a parte requerer, conforme as circunstâncias, redução ou aumento da prestação."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4282,
                                            "texto": "A prestação alimentícia poderá ser fixada tomando por base o salário-mínimo."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4284,
                                            "texto": "Finda a obrigação de prestar alimentos, o juiz mandará liberar o capital, cessar o desconto em folha ou cancelar as garantias prestadas."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO CUMPRIMENTO DE SENTENÇA QUE RECONHEÇA A EXIGIBILIDADE DE OBRIGAÇÃO DE PRESTAR ALIMENTOS",
                            "linhaTitulo": 4234
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 4286,
                            "artigos": [
                                {
                                    "numero": "534º",
                                    "rotulo": "Art. 534º.",
                                    "linha": 4289,
                                    "caput": "No cumprimento de sentença que impuser à Fazenda Pública o dever de pagar quantia certa, o exequente apresentará demonstrativo discriminado e atualizado do crédito contendo:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4303,
                                            "texto": "Havendo pluralidade de exequentes, cada um deverá apresentar o seu próprio demonstrativo, aplicando-se à hipótese, se for o caso, o disposto nos §§ 1º e 2º do art. 113."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4305,
                                            "texto": "A multa prevista no § 1º do art. 523 não se aplica à Fazenda Pública.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 523",
                                                    "href": "#art523",
                                                    "inicio": 28,
                                                    "fim": 36
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4291,
                                            "texto": "o nome completo e o número de inscrição no Cadastro de Pessoas Físicas ou no Cadastro Nacional da Pessoa Jurídica do exequente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4293,
                                            "texto": "o índice de correção monetária adotado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4295,
                                            "texto": "os juros aplicados e as respectivas taxas;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4297,
                                            "texto": "o termo inicial e o termo final dos juros e da correção monetária utilizados;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4299,
                                            "texto": "a periodicidade da capitalização dos juros, se for o caso;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4301,
                                            "texto": "a especificação dos eventuais descontos obrigatórios realizados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "535º",
                                    "rotulo": "Art. 535º.",
                                    "linha": 4307,
                                    "caput": "A Fazenda Pública será intimada na pessoa de seu representante judicial, por carga, remessa ou meio eletrônico, para, querendo, no prazo de 30 (trinta) dias e nos próprios autos, impugnar a execução, podendo arguir:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4321,
                                            "texto": "A alegação de impedimento ou suspeição observará o disposto nos arts. 146 e 148.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 146",
                                                    "href": "#art146",
                                                    "inicio": 64,
                                                    "fim": 73
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "148",
                                                    "href": "#art148",
                                                    "inicio": 76,
                                                    "fim": 79
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 146 e 148",
                                                    "href": "#art146",
                                                    "inicio": 64,
                                                    "fim": 79
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4323,
                                            "texto": "Quando se alegar que o exequente, em excesso de execução, pleiteia quantia superior à resultante do título, cumprirá à executada declarar de imediato o valor que entende correto, sob pena de não conhecimento da arguição."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4325,
                                            "texto": "Não impugnada a execução ou rejeitadas as arguições da executada:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4327,
                                                    "texto": "expedir-se-á, por intermédio do presidente do tribunal competente, precatório em favor do exequente, observando-se o disposto na Constituição Federal;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4329,
                                                    "texto": "por ordem do juiz, dirigida à autoridade na pessoa de quem o ente público foi citado para o processo, o pagamento de obrigação de pequeno valor será realizado no prazo de 2 (dois) meses contado da entrega da requisição, mediante depósito na agência de banco oficial mais próxima da residência do exequente."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4331,
                                            "texto": "Tratando-se de impugnação parcial, a parte não questionada pela executada será, desde logo, objeto de cumprimento."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4333,
                                            "texto": "Para efeito do disposto no inciso III do caput deste artigo, considera-se também inexigível a obrigação reconhecida em título executivo judicial fundado em lei ou ato normativo considerado inconstitucional pelo Supremo Tribunal Federal, ou fundado em aplicação ou interpretação da lei ou do ato normativo tido pelo Supremo Tribunal Federal como incompatível com a Constituição Federal, em controle de constitucionalidade concentrado ou difuso."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 4335,
                                            "texto": "No caso do § 5º, os efeitos da decisão do Supremo Tribunal Federal poderão ser modulados no tempo, de modo a favorecer a segurança jurídica."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 4337,
                                            "texto": "A decisão do Supremo Tribunal Federal referida no § 5º deve ter sido proferida antes do trânsito em julgado da decisão exequenda."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 4339,
                                            "texto": "Se a decisão referida no § 5º for proferida após o trânsito em julgado da decisão exequenda, caberá ação rescisória, cujo prazo será contado do trânsito em julgado da decisão proferida pelo Supremo Tribunal Federal."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4309,
                                            "texto": "falta ou nulidade da citação se, na fase de conhecimento, o processo correu à revelia;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4311,
                                            "texto": "ilegitimidade de parte;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4313,
                                            "texto": "inexequibilidade do título ou inexigibilidade da obrigação;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4315,
                                            "texto": "excesso de execução ou cumulação indevida de execuções;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4317,
                                            "texto": "incompetência absoluta ou relativa do juízo da execução;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4319,
                                            "texto": "qualquer causa modificativa ou extintiva da obrigação, como pagamento, novação, compensação, transação ou prescrição, desde que supervenientes ao trânsito em julgado da sentença."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO CUMPRIMENTO DE SENTENÇA QUE RECONHEÇA A EXIGIBILIDADE DE OBRIGAÇÃO DE PAGAR QUANTIA CERTA PELA FAZENDA PÚBLICA",
                            "linhaTitulo": 4287
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VI",
                            "linha": 4341,
                            "artigos": [
                                {
                                    "numero": "536º",
                                    "rotulo": "Art. 536º.",
                                    "linha": 4347,
                                    "caput": "No cumprimento de sentença que reconheça a exigibilidade de obrigação de fazer ou de não fazer, o juiz poderá, de ofício ou a requerimento, para a efetivação da tutela específica ou a obtenção de tutela pelo resultado prático equivalente, determinar as medidas necessárias à satisfação do exequente.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4349,
                                            "texto": "Para atender ao disposto no caput , o juiz poderá determinar, entre outras medidas, a imposição de multa, a busca e apreensão, a remoção de pessoas e coisas, o desfazimento de obras e o impedimento de atividade nociva, podendo, caso necessário, requisitar o auxílio de força policial."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4351,
                                            "texto": "O mandado de busca e apreensão de pessoas e coisas será cumprido por 2 (dois) oficiais de justiça, observando-se o disposto no art. 846, §§ 1º a 4º, se houver necessidade de arrombamento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4353,
                                            "texto": "O executado incidirá nas penas de litigância de má-fé quando injustificadamente descumprir a ordem judicial, sem prejuízo de sua responsabilização por crime de desobediência."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4355,
                                            "texto": "No cumprimento de sentença que reconheça a exigibilidade de obrigação de fazer ou de não fazer, aplica-se o art. 525, no que couber.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 525",
                                                    "href": "#art525",
                                                    "inicio": 108,
                                                    "fim": 116
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4357,
                                            "texto": "O disposto neste artigo aplica-se, no que couber, ao cumprimento de sentença que reconheça deveres de fazer e de não fazer de natureza não obrigacional."
                                        }
                                    ],
                                    "rubrica": "Do Cumprimento de Sentença que Reconheça a Exigibilidade de Obrigação de Fazer ou de Não Fazer",
                                    "linhaRubrica": 4345
                                },
                                {
                                    "numero": "537º",
                                    "rotulo": "Art. 537º.",
                                    "linha": 4359,
                                    "caput": "A multa independe de requerimento da parte e poderá ser aplicada na fase de conhecimento, em tutela provisória ou na sentença, ou na fase de execução, desde que seja suficiente e compatível com a obrigação e que se determine prazo razoável para cumprimento do preceito.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4361,
                                            "texto": "O juiz poderá, de ofício ou a requerimento, modificar o valor ou a periodicidade da multa vincenda ou excluí-la, caso verifique que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4363,
                                                    "texto": "se tornou insuficiente ou excessiva;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4365,
                                                    "texto": "o obrigado demonstrou cumprimento parcial superveniente da obrigação ou justa causa para o descumprimento."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4367,
                                            "texto": "O valor da multa será devido ao exequente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4370,
                                            "texto": "A decisão que fixa a multa é passível de cumprimento provisório, devendo ser depositada em juízo, permitido o levantamento do valor após o trânsito em julgado da sentença favorável à parte."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4372,
                                            "texto": "A multa será devida desde o dia em que se configurar o descumprimento da decisão e incidirá enquanto não for cumprida a decisão que a tiver cominado."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4374,
                                            "texto": "O disposto neste artigo aplica-se, no que couber, ao cumprimento de sentença que reconheça deveres de fazer e de não fazer de natureza não obrigacional. Seção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "538º",
                                    "rotulo": "Art. 538º.",
                                    "linha": 4379,
                                    "caput": "Não cumprida a obrigação de entregar coisa no prazo estabelecido na sentença, será expedido mandado de busca e apreensão ou de imissão na posse em favor do credor, conforme se tratar de coisa móvel ou imóvel.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4381,
                                            "texto": "A existência de benfeitorias deve ser alegada na fase de conhecimento, em contestação, de forma discriminada e com atribuição, sempre que possível e justificadamente, do respectivo valor."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4383,
                                            "texto": "O direito de retenção por benfeitorias deve ser exercido na contestação, na fase de conhecimento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4385,
                                            "texto": "Aplicam-se ao procedimento previsto neste artigo, no que couber, as disposições sobre o cumprimento de obrigação de fazer ou de não fazer."
                                        }
                                    ],
                                    "rubrica": "Do Cumprimento de Sentença que Reconheça a Exigibilidade de Obrigação de Entregar Coisa",
                                    "linhaRubrica": 4377
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DO CUMPRIMENTO DE SENTENÇA QUE RECONHEÇA A EXIGIBILIDADE DE OBRIGAÇÃO DE FAZER, DE NÃO FAZER OU DE ENTREGAR COISA",
                            "linhaTitulo": 4342
                        }
                    ],
                    "titulo": "DO CUMPRIMENTO DA SENTENÇA",
                    "linhaTitulo": 4015
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 4387,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 4390,
                            "artigos": [
                                {
                                    "numero": "539º",
                                    "rotulo": "Art. 539º.",
                                    "linha": 4393,
                                    "caput": "Nos casos previstos em lei, poderá o devedor ou terceiro requerer, com efeito de pagamento, a consignação da quantia ou da coisa devida.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4395,
                                            "texto": "Tratando-se de obrigação em dinheiro, poderá o valor ser depositado em estabelecimento bancário, oficial onde houver, situado no lugar do pagamento, cientificando-se o credor por carta com aviso de recebimento, assinado o prazo de 10 (dez) dias para a manifestação de recusa."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4397,
                                            "texto": "Decorrido o prazo do § 1º, contado do retorno do aviso de recebimento, sem a manifestação de recusa, considerar-se-á o devedor liberado da obrigação, ficando à disposição do credor a quantia depositada."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4399,
                                            "texto": "Ocorrendo a recusa, manifestada por escrito ao estabelecimento bancário, poderá ser proposta, dentro de 1 (um) mês, a ação de consignação, instruindo-se a inicial com a prova do depósito e da recusa."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4401,
                                            "texto": "Não proposta a ação no prazo do § 3º, ficará sem efeito o depósito, podendo levantá-lo o depositante."
                                        }
                                    ]
                                },
                                {
                                    "numero": "540º",
                                    "rotulo": "Art. 540º.",
                                    "linha": 4403,
                                    "caput": "Requerer-se-á a consignação no lugar do pagamento, cessando para o devedor, à data do depósito, os juros e os riscos, salvo se a demanda for julgada improcedente."
                                },
                                {
                                    "numero": "541º",
                                    "rotulo": "Art. 541º.",
                                    "linha": 4405,
                                    "caput": "Tratando-se de prestações sucessivas, consignada uma delas, pode o devedor continuar a depositar, no mesmo processo e sem mais formalidades, as que se forem vencendo, desde que o faça em até 5 (cinco) dias contados da data do respectivo vencimento."
                                },
                                {
                                    "numero": "542º",
                                    "rotulo": "Art. 542º.",
                                    "linha": 4407,
                                    "caput": "Na petição inicial, o autor requererá:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4413,
                                            "texto": "Não realizado o depósito no prazo do inciso I, o processo será extinto sem resolução do mérito."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4409,
                                            "texto": "o depósito da quantia ou da coisa devida, a ser efetivado no prazo de 5 (cinco) dias contados do deferimento, ressalvada a hipótese do art. 539, § 3º;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4411,
                                            "texto": "a citação do réu para levantar o depósito ou oferecer contestação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "543º",
                                    "rotulo": "Art. 543º.",
                                    "linha": 4415,
                                    "caput": "Se o objeto da prestação for coisa indeterminada e a escolha couber ao credor, será este citado para exercer o direito dentro de 5 (cinco) dias, se outro prazo não constar de lei ou do contrato, ou para aceitar que o devedor a faça, devendo o juiz, ao despachar a petição inicial, fixar lugar, dia e hora em que se fará a entrega, sob pena de depósito."
                                },
                                {
                                    "numero": "544º",
                                    "rotulo": "Art. 544º.",
                                    "linha": 4417,
                                    "caput": "Na contestação, o réu poderá alegar que:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4427,
                                            "texto": "No caso do inciso IV, a alegação somente será admissível se o réu indicar o montante que entende devido."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4419,
                                            "texto": "não houve recusa ou mora em receber a quantia ou a coisa devida;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4421,
                                            "texto": "foi justa a recusa;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4423,
                                            "texto": "o depósito não se efetuou no prazo ou no lugar do pagamento;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4425,
                                            "texto": "o depósito não é integral."
                                        }
                                    ]
                                },
                                {
                                    "numero": "545º",
                                    "rotulo": "Art. 545º.",
                                    "linha": 4429,
                                    "caput": "Alegada a insuficiência do depósito, é lícito ao autor completá-lo, em 10 (dez) dias, salvo se corresponder a prestação cujo inadimplemento acarrete a rescisão do contrato.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4431,
                                            "texto": "No caso do caput , poderá o réu levantar, desde logo, a quantia ou a coisa depositada, com a consequente liberação parcial do autor, prosseguindo o processo quanto à parcela controvertida."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4433,
                                            "texto": "A sentença que concluir pela insuficiência do depósito determinará, sempre que possível, o montante devido e valerá como título executivo, facultado ao credor promover-lhe o cumprimento nos mesmos autos, após liquidação, se necessária."
                                        }
                                    ]
                                },
                                {
                                    "numero": "546º",
                                    "rotulo": "Art. 546º.",
                                    "linha": 4435,
                                    "caput": "Julgado procedente o pedido, o juiz declarará extinta a obrigação e condenará o réu ao pagamento de custas e honorários advocatícios.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4437,
                                            "texto": "Proceder-se-á do mesmo modo se o credor receber e der quitação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "547º",
                                    "rotulo": "Art. 547º.",
                                    "linha": 4439,
                                    "caput": "Se ocorrer dúvida sobre quem deva legitimamente receber o pagamento, o autor requererá o depósito e a citação dos possíveis titulares do crédito para provarem o seu direito."
                                },
                                {
                                    "numero": "548º",
                                    "rotulo": "Art. 548º.",
                                    "linha": 4441,
                                    "caput": "No caso do art. 547:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4443,
                                            "texto": "não comparecendo pretendente algum, converter-se-á o depósito em arrecadação de coisas vagas;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4445,
                                            "texto": "comparecendo apenas um, o juiz decidirá de plano;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4447,
                                            "texto": "comparecendo mais de um, o juiz declarará efetuado o depósito e extinta a obrigação, continuando o processo a correr unicamente entre os presuntivos credores, observado o procedimento comum."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 547",
                                            "href": "#art547",
                                            "inicio": 11,
                                            "fim": 19
                                        }
                                    ]
                                },
                                {
                                    "numero": "549º",
                                    "rotulo": "Art. 549º.",
                                    "linha": 4449,
                                    "caput": "Aplica-se o procedimento estabelecido neste Capítulo, no que couber, ao resgate do aforamento."
                                }
                            ],
                            "titulo": "DA AÇÃO DE CONSIGNAÇÃO EM PAGAMENTO",
                            "linhaTitulo": 4391
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 4451,
                            "artigos": [
                                {
                                    "numero": "550º",
                                    "rotulo": "Art. 550º.",
                                    "linha": 4454,
                                    "caput": "Aquele que afirmar ser titular do direito de exigir contas requererá a citação do réu para que as preste ou ofereça contestação no prazo de 15 (quinze) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4456,
                                            "texto": "Na petição inicial, o autor especificará, detalhadamente, as razões pelas quais exige as contas, instruindo-a com documentos comprobatórios dessa necessidade, se existirem."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4458,
                                            "texto": "Prestadas as contas, o autor terá 15 (quinze) dias para se manifestar, prosseguindo-se o processo na forma do Capítulo X do Título I deste Livro."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4460,
                                            "texto": "A impugnação das contas apresentadas pelo réu deverá ser fundamentada e específica, com referência expressa ao lançamento questionado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4462,
                                            "texto": "Se o réu não contestar o pedido, observar-se-á o disposto no art. 355.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 355",
                                                    "href": "#art355",
                                                    "inicio": 61,
                                                    "fim": 69
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4464,
                                            "texto": "A decisão que julgar procedente o pedido condenará o réu a prestar as contas no prazo de 15 (quinze) dias, sob pena de não lhe ser lícito impugnar as que o autor apresentar."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 4466,
                                            "texto": "Se o réu apresentar as contas no prazo previsto no § 5º, seguir-se-á o procedimento do § 2º, caso contrário, o autor apresentá-las-á no prazo de 15 (quinze) dias, podendo o juiz determinar a realização de exame pericial, se necessário."
                                        }
                                    ]
                                },
                                {
                                    "numero": "551º",
                                    "rotulo": "Art. 551º.",
                                    "linha": 4468,
                                    "caput": "As contas do réu serão apresentadas na forma adequada, especificando-se as receitas, a aplicação das despesas e os investimentos, se houver.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4470,
                                            "texto": "Havendo impugnação específica e fundamentada pelo autor, o juiz estabelecerá prazo razoável para que o réu apresente os documentos justificativos dos lançamentos individualmente impugnados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4472,
                                            "texto": "As contas do autor, para os fins do art. 550, § 5º, serão apresentadas na forma adequada, já instruídas com os documentos justificativos, especificando-se as receitas, a aplicação das despesas e os investimentos, se houver, bem como o respectivo saldo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "552º",
                                    "rotulo": "Art. 552º.",
                                    "linha": 4474,
                                    "caput": "A sentença apurará o saldo e constituirá título executivo judicial."
                                },
                                {
                                    "numero": "553º",
                                    "rotulo": "Art. 553º.",
                                    "linha": 4476,
                                    "caput": "As contas do inventariante, do tutor, do curador, do depositário e de qualquer outro administrador serão prestadas em apenso aos autos do processo em que tiver sido nomeado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4478,
                                            "texto": "Se qualquer dos referidos no caput for condenado a pagar o saldo e não o fizer no prazo legal, o juiz poderá destituí-lo, sequestrar os bens sob sua guarda, glosar o prêmio ou a gratificação a que teria direito e determinar as medidas executivas necessárias à recomposição do prejuízo."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA AÇÃO DE EXIGIR CONTAS",
                            "linhaTitulo": 4452
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 4480,
                            "artigos": [
                                {
                                    "numero": "554º",
                                    "rotulo": "Art. 554º.",
                                    "linha": 4486,
                                    "caput": "A propositura de uma ação possessória em vez de outra não obstará a que o juiz conheça do pedido e outorgue a proteção legal correspondente àquela cujos pressupostos estejam provados.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4488,
                                            "texto": "No caso de ação possessória em que figure no polo passivo grande número de pessoas, serão feitas a citação pessoal dos ocupantes que forem encontrados no local e a citação por edital dos demais, determinando-se, ainda, a intimação do Ministério Público e, se envolver pessoas em situação de hipossuficiência econômica, da Defensoria Pública."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4490,
                                            "texto": "Para fim da citação pessoal prevista no § 1º, o oficial de justiça procurará os ocupantes no local por uma vez, citando-se por edital os que não forem encontrados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4492,
                                            "texto": "O juiz deverá determinar que se dê ampla publicidade da existência da ação prevista no § 1º e dos respectivos prazos processuais, podendo, para tanto, valer-se de anúncios em jornal ou rádio locais, da publicação de cartazes na região do conflito e de outros meios."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 4484
                                },
                                {
                                    "numero": "555º",
                                    "rotulo": "Art. 555º.",
                                    "linha": 4494,
                                    "caput": "É lícito ao autor cumular ao pedido possessório o de:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4500,
                                            "texto": "Pode o autor requerer, ainda, imposição de medida necessária e adequada para:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4502,
                                                    "texto": "evitar nova turbação ou esbulho;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4504,
                                                    "texto": "cumprir-se a tutela provisória ou final."
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4496,
                                            "texto": "condenação em perdas e danos;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4498,
                                            "texto": "indenização dos frutos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "556º",
                                    "rotulo": "Art. 556º.",
                                    "linha": 4506,
                                    "caput": "É lícito ao réu, na contestação, alegando que foi o ofendido em sua posse, demandar a proteção possessória e a indenização pelos prejuízos resultantes da turbação ou do esbulho cometido pelo autor."
                                },
                                {
                                    "numero": "557º",
                                    "rotulo": "Art. 557º.",
                                    "linha": 4508,
                                    "caput": "Na pendência de ação possessória é vedado, tanto ao autor quanto ao réu, propor ação de reconhecimento do domínio, exceto se a pretensão for deduzida em face de terceira pessoa.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4510,
                                            "texto": "Não obsta à manutenção ou à reintegração de posse a alegação de propriedade ou de outro direito sobre a coisa."
                                        }
                                    ]
                                },
                                {
                                    "numero": "558º",
                                    "rotulo": "Art. 558º.",
                                    "linha": 4512,
                                    "caput": "Regem o procedimento de manutenção e de reintegração de posse as normas da Seção II deste Capítulo quando a ação for proposta dentro de ano e dia da turbação ou do esbulho afirmado na petição inicial.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4514,
                                            "texto": "Passado o prazo referido no caput , será comum o procedimento, não perdendo, contudo, o caráter possessório."
                                        }
                                    ]
                                },
                                {
                                    "numero": "559º",
                                    "rotulo": "Art. 559º.",
                                    "linha": 4516,
                                    "caput": "Se o réu provar, em qualquer tempo, que o autor provisoriamente mantido ou reintegrado na posse carece de idoneidade financeira para, no caso de sucumbência, responder por perdas e danos, o juiz designar-lhe-á o prazo de 5 (cinco) dias para requerer caução, real ou fidejussória, sob pena de ser depositada a coisa litigiosa, ressalvada a impossibilidade da parte economicamente hipossuficiente. Seção II"
                                },
                                {
                                    "numero": "560º",
                                    "rotulo": "Art. 560º.",
                                    "linha": 4521,
                                    "caput": "O possuidor tem direito a ser mantido na posse em caso de turbação e reintegrado em caso de esbulho.",
                                    "rubrica": "Da Manutenção e da Reintegração de Posse",
                                    "linhaRubrica": 4519
                                },
                                {
                                    "numero": "561º",
                                    "rotulo": "Art. 561º.",
                                    "linha": 4523,
                                    "caput": "Incumbe ao autor provar:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4525,
                                            "texto": "a sua posse;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4527,
                                            "texto": "a turbação ou o esbulho praticado pelo réu;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4529,
                                            "texto": "a data da turbação ou do esbulho;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4531,
                                            "texto": "a continuação da posse, embora turbada, na ação de manutenção, ou a perda da posse, na ação de reintegração."
                                        }
                                    ]
                                },
                                {
                                    "numero": "562º",
                                    "rotulo": "Art. 562º.",
                                    "linha": 4533,
                                    "caput": "Estando a petição inicial devidamente instruída, o juiz deferirá, sem ouvir o réu, a expedição do mandado liminar de manutenção ou de reintegração, caso contrário, determinará que o autor justifique previamente o alegado, citando-se o réu para comparecer à audiência que for designada.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4535,
                                            "texto": "Contra as pessoas jurídicas de direito público não será deferida a manutenção ou a reintegração liminar sem prévia audiência dos respectivos representantes judiciais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "563º",
                                    "rotulo": "Art. 563º.",
                                    "linha": 4537,
                                    "caput": "Considerada suficiente a justificação, o juiz fará logo expedir mandado de manutenção ou de reintegração."
                                },
                                {
                                    "numero": "564º",
                                    "rotulo": "Art. 564º.",
                                    "linha": 4539,
                                    "caput": "Concedido ou não o mandado liminar de manutenção ou de reintegração, o autor promoverá, nos 5 (cinco) dias subsequentes, a citação do réu para, querendo, contestar a ação no prazo de 15 (quinze) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4541,
                                            "texto": "Quando for ordenada a justificação prévia, o prazo para contestar será contado da intimação da decisão que deferir ou não a medida liminar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "565º",
                                    "rotulo": "Art. 565º.",
                                    "linha": 4543,
                                    "caput": "No litígio coletivo pela posse de imóvel, quando o esbulho ou a turbação afirmado na petição inicial houver ocorrido há mais de ano e dia, o juiz, antes de apreciar o pedido de concessão da medida liminar, deverá designar audiência de mediação, a realizar-se em até 30 (trinta) dias, que observará o disposto nos §§ 2º e 4º.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4545,
                                            "texto": "Concedida a liminar, se essa não for executada no prazo de 1 (um) ano, a contar da data de distribuição, caberá ao juiz designar audiência de mediação, nos termos dos §§ 2º a 4º deste artigo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4547,
                                            "texto": "O Ministério Público será intimado para comparecer à audiência, e a Defensoria Pública será intimada sempre que houver parte beneficiária de gratuidade da justiça."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4549,
                                            "texto": "O juiz poderá comparecer à área objeto do litígio quando sua presença se fizer necessária à efetivação da tutela jurisdicional."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4551,
                                            "texto": "Os órgãos responsáveis pela política agrária e pela política urbana da União, de Estado ou do Distrito Federal e de Município onde se situe a área objeto do litígio poderão ser intimados para a audiência, a fim de se manifestarem sobre seu interesse no processo e sobre a existência de possibilidade de solução para o conflito possessório."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 4553,
                                            "texto": "Aplica-se o disposto neste artigo ao litígio sobre propriedade de imóvel."
                                        }
                                    ]
                                },
                                {
                                    "numero": "566º",
                                    "rotulo": "Art. 566º.",
                                    "linha": 4555,
                                    "caput": "Aplica-se, quanto ao mais, o procedimento comum. Seção III"
                                },
                                {
                                    "numero": "567º",
                                    "rotulo": "Art. 567º.",
                                    "linha": 4560,
                                    "caput": "O possuidor direto ou indireto que tenha justo receio de ser molestado na posse poderá requerer ao juiz que o segure da turbação ou esbulho iminente, mediante mandado proibitório em que se comine ao réu determinada pena pecuniária caso transgrida o preceito.",
                                    "rubrica": "Do Interdito Proibitório",
                                    "linhaRubrica": 4558
                                },
                                {
                                    "numero": "568º",
                                    "rotulo": "Art. 568º.",
                                    "linha": 4562,
                                    "caput": "Aplica-se ao interdito proibitório o disposto na Seção II deste Capítulo."
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DAS AÇÕES POSSESSÓRIAS",
                            "linhaTitulo": 4481
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 4564,
                            "artigos": [
                                {
                                    "numero": "569º",
                                    "rotulo": "Art. 569º.",
                                    "linha": 4570,
                                    "caput": "Cabe:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4572,
                                            "texto": "ao proprietário a ação de demarcação, para obrigar o seu confinante a estremar os respectivos prédios, fixando-se novos limites entre eles ou aviventando-se os já apagados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4574,
                                            "texto": "ao condômino a ação de divisão, para obrigar os demais consortes a estremar os quinhões."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 4568
                                },
                                {
                                    "numero": "570º",
                                    "rotulo": "Art. 570º.",
                                    "linha": 4576,
                                    "caput": "É lícita a cumulação dessas ações, caso em que deverá processar-se primeiramente a demarcação total ou parcial da coisa comum, citando-se os confinantes e os condôminos."
                                },
                                {
                                    "numero": "571º",
                                    "rotulo": "Art. 571º.",
                                    "linha": 4578,
                                    "caput": "A demarcação e a divisão poderão ser realizadas por escritura pública, desde que maiores, capazes e concordes todos os interessados, observando-se, no que couber, os dispositivos deste Capítulo."
                                },
                                {
                                    "numero": "572º",
                                    "rotulo": "Art. 572º.",
                                    "linha": 4580,
                                    "caput": "Fixados os marcos da linha de demarcação, os confinantes considerar-se-ão terceiros quanto ao processo divisório, ficando-lhes, porém, ressalvado o direito de vindicar os terrenos de que se julguem despojados por invasão das linhas limítrofes constitutivas do perímetro ou de reclamar indenização correspondente ao seu valor.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4582,
                                            "texto": "No caso do caput , serão citados para a ação todos os condôminos, se a sentença homologatória da divisão ainda não houver transitado em julgado, e todos os quinhoeiros dos terrenos vindicados, se a ação for proposta posteriormente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4584,
                                            "texto": "Neste último caso, a sentença que julga procedente a ação, condenando a restituir os terrenos ou a pagar a indenização, valerá como título executivo em favor dos quinhoeiros para haverem dos outros condôminos que forem parte na divisão ou de seus sucessores a título universal, na proporção que lhes tocar, a composição pecuniária do desfalque sofrido."
                                        }
                                    ]
                                },
                                {
                                    "numero": "573º",
                                    "rotulo": "Art. 573º.",
                                    "linha": 4586,
                                    "caput": "Tratando-se de imóvel georreferenciado, com averbação no registro de imóveis, pode o juiz dispensar a realização de prova pericial. Seção II"
                                },
                                {
                                    "numero": "574º",
                                    "rotulo": "Art. 574º.",
                                    "linha": 4591,
                                    "caput": "Na petição inicial, instruída com os títulos da propriedade, designar-se-á o imóvel pela situação e pela denominação, descrever-se-ão os limites por constituir, aviventar ou renovar e nomear-se-ão todos os confinantes da linha demarcanda.",
                                    "rubrica": "Da Demarcação",
                                    "linhaRubrica": 4589
                                },
                                {
                                    "numero": "575º",
                                    "rotulo": "Art. 575º.",
                                    "linha": 4593,
                                    "caput": "Qualquer condômino é parte legítima para promover a demarcação do imóvel comum, requerendo a intimação dos demais para, querendo, intervir no processo."
                                },
                                {
                                    "numero": "576º",
                                    "rotulo": "Art. 576º.",
                                    "linha": 4595,
                                    "caput": "A citação dos réus será feita por correio, observado o disposto no art. 247.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4597,
                                            "texto": "Será publicado edital, nos termos do inciso III do art. 259.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "inciso III do art. 259",
                                                    "href": "#art259ii",
                                                    "inicio": 37,
                                                    "fim": 59
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "inciso III do art. 259",
                                                    "href": "#art259iii",
                                                    "inicio": 37,
                                                    "fim": 59
                                                }
                                            ]
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 247",
                                            "href": "#art247",
                                            "inicio": 67,
                                            "fim": 75
                                        }
                                    ]
                                },
                                {
                                    "numero": "577º",
                                    "rotulo": "Art. 577º.",
                                    "linha": 4599,
                                    "caput": "Feitas as citações, terão os réus o prazo comum de 15 (quinze) dias para contestar."
                                },
                                {
                                    "numero": "578º",
                                    "rotulo": "Art. 578º.",
                                    "linha": 4601,
                                    "caput": "Após o prazo de resposta do réu, observar-se-á o procedimento comum."
                                },
                                {
                                    "numero": "579º",
                                    "rotulo": "Art. 579º.",
                                    "linha": 4603,
                                    "caput": "Antes de proferir a sentença, o juiz nomeará um ou mais peritos para levantar o traçado da linha demarcanda."
                                },
                                {
                                    "numero": "580º",
                                    "rotulo": "Art. 580º.",
                                    "linha": 4605,
                                    "caput": "Concluídos os estudos, os peritos apresentarão minucioso laudo sobre o traçado da linha demarcanda, considerando os títulos, os marcos, os rumos, a fama da vizinhança, as informações de antigos moradores do lugar e outros elementos que coligirem."
                                },
                                {
                                    "numero": "581º",
                                    "rotulo": "Art. 581º.",
                                    "linha": 4607,
                                    "caput": "A sentença que julgar procedente o pedido determinará o traçado da linha demarcanda.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4609,
                                            "texto": "A sentença proferida na ação demarcatória determinará a restituição da área invadida, se houver, declarando o domínio ou a posse do prejudicado, ou ambos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "582º",
                                    "rotulo": "Art. 582º.",
                                    "linha": 4611,
                                    "caput": "Transitada em julgado a sentença, o perito efetuará a demarcação e colocará os marcos necessários.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4613,
                                            "texto": "Todas as operações serão consignadas em planta e memorial descritivo com as referências convenientes para a identificação, em qualquer tempo, dos pontos assinalados, observada a legislação especial que dispõe sobre a identificação do imóvel rural."
                                        }
                                    ]
                                },
                                {
                                    "numero": "583º",
                                    "rotulo": "Art. 583º.",
                                    "linha": 4615,
                                    "caput": "As plantas serão acompanhadas das cadernetas de operações de campo e do memorial descritivo, que conterá:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4617,
                                            "texto": "o ponto de partida, os rumos seguidos e a aviventação dos antigos com os respectivos cálculos;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4619,
                                            "texto": "os acidentes encontrados, as cercas, os valos, os marcos antigos, os córregos, os rios, as lagoas e outros;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4621,
                                            "texto": "a indicação minuciosa dos novos marcos cravados, dos antigos aproveitados, das culturas existentes e da sua produção anual;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4623,
                                            "texto": "a composição geológica dos terrenos, bem como a qualidade e a extensão dos campos, das matas e das capoeiras;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4625,
                                            "texto": "as vias de comunicação;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4627,
                                            "texto": "as distâncias a pontos de referência, tais como rodovias federais e estaduais, ferrovias, portos, aglomerações urbanas e polos comerciais;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 4629,
                                            "texto": "a indicação de tudo o mais que for útil para o levantamento da linha ou para a identificação da linha já levantada."
                                        }
                                    ]
                                },
                                {
                                    "numero": "584º",
                                    "rotulo": "Art. 584º.",
                                    "linha": 4631,
                                    "caput": "É obrigatória a colocação de marcos tanto na estação inicial, dita marco primordial, quanto nos vértices dos ângulos, salvo se algum desses últimos pontos for assinalado por acidentes naturais de difícil remoção ou destruição."
                                },
                                {
                                    "numero": "585º",
                                    "rotulo": "Art. 585º.",
                                    "linha": 4633,
                                    "caput": "A linha será percorrida pelos peritos, que examinarão os marcos e os rumos, consignando em relatório escrito a exatidão do memorial e da planta apresentados pelo agrimensor ou as divergências porventura encontradas."
                                },
                                {
                                    "numero": "586º",
                                    "rotulo": "Art. 586º.",
                                    "linha": 4635,
                                    "caput": "Juntado aos autos o relatório dos peritos, o juiz determinará que as partes se manifestem sobre ele no prazo comum de 15 (quinze) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4637,
                                            "texto": "Executadas as correções e as retificações que o juiz determinar, lavrar-se-á, em seguida, o auto de demarcação em que os limites demarcandos serão minuciosamente descritos de acordo com o memorial e a planta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "587º",
                                    "rotulo": "Art. 587º.",
                                    "linha": 4639,
                                    "caput": "Assinado o auto pelo juiz e pelos peritos, será proferida a sentença homologatória da demarcação. Seção III"
                                },
                                {
                                    "numero": "588º",
                                    "rotulo": "Art. 588º.",
                                    "linha": 4644,
                                    "caput": "A petição inicial será instruída com os títulos de domínio do promovente e conterá:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4646,
                                            "texto": "a indicação da origem da comunhão e a denominação, a situação, os limites e as características do imóvel;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4648,
                                            "texto": "o nome, o estado civil, a profissão e a residência de todos os condôminos, especificando-se os estabelecidos no imóvel com benfeitorias e culturas;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4650,
                                            "texto": "as benfeitorias comuns."
                                        }
                                    ],
                                    "rubrica": "Da Divisão",
                                    "linhaRubrica": 4642
                                },
                                {
                                    "numero": "589º",
                                    "rotulo": "Art. 589º.",
                                    "linha": 4652,
                                    "caput": "Feitas as citações como preceitua o art. 576, prosseguir-se-á na forma dos arts. 577 e 578.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 576",
                                            "href": "#art576",
                                            "inicio": 36,
                                            "fim": 44
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 577 e 578",
                                            "href": "#art577",
                                            "inicio": 75,
                                            "fim": 90
                                        }
                                    ]
                                },
                                {
                                    "numero": "590º",
                                    "rotulo": "Art. 590º.",
                                    "linha": 4654,
                                    "caput": "O juiz nomeará um ou mais peritos para promover a medição do imóvel e as operações de divisão, observada a legislação especial que dispõe sobre a identificação do imóvel rural.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4656,
                                            "texto": "O perito deverá indicar as vias de comunicação existentes, as construções e as benfeitorias, com a indicação dos seus valores e dos respectivos proprietários e ocupantes, as águas principais que banham o imóvel e quaisquer outras informações que possam concorrer para facilitar a partilha."
                                        }
                                    ]
                                },
                                {
                                    "numero": "591º",
                                    "rotulo": "Art. 591º.",
                                    "linha": 4658,
                                    "caput": "Todos os condôminos serão intimados a apresentar, dentro de 10 (dez) dias, os seus títulos, se ainda não o tiverem feito, e a formular os seus pedidos sobre a constituição dos quinhões."
                                },
                                {
                                    "numero": "592º",
                                    "rotulo": "Art. 592º.",
                                    "linha": 4660,
                                    "caput": "O juiz ouvirá as partes no prazo comum de 15 (quinze) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4662,
                                            "texto": "Não havendo impugnação, o juiz determinará a divisão geodésica do imóvel."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4664,
                                            "texto": "Havendo impugnação, o juiz proferirá, no prazo de 10 (dez) dias, decisão sobre os pedidos e os títulos que devam ser atendidos na formação dos quinhões."
                                        }
                                    ]
                                },
                                {
                                    "numero": "593º",
                                    "rotulo": "Art. 593º.",
                                    "linha": 4666,
                                    "caput": "Se qualquer linha do perímetro atingir benfeitorias permanentes dos confinantes feitas há mais de 1 (um) ano, serão elas respeitadas, bem como os terrenos onde estiverem, os quais não se computarão na área dividenda."
                                },
                                {
                                    "numero": "594º",
                                    "rotulo": "Art. 594º.",
                                    "linha": 4668,
                                    "caput": "Os confinantes do imóvel dividendo podem demandar a restituição dos terrenos que lhes tenham sido usurpados.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4670,
                                            "texto": "Serão citados para a ação todos os condôminos, se a sentença homologatória da divisão ainda não houver transitado em julgado, e todos os quinhoeiros dos terrenos vindicados, se a ação for proposta posteriormente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4672,
                                            "texto": "Nesse último caso terão os quinhoeiros o direito, pela mesma sentença que os obrigar à restituição, a haver dos outros condôminos do processo divisório ou de seus sucessores a título universal a composição pecuniária proporcional ao desfalque sofrido."
                                        }
                                    ]
                                },
                                {
                                    "numero": "595º",
                                    "rotulo": "Art. 595º.",
                                    "linha": 4674,
                                    "caput": "Os peritos proporão, em laudo fundamentado, a forma da divisão, devendo consultar, quanto possível, a comodidade das partes, respeitar, para adjudicação a cada condômino, a preferência dos terrenos contíguos às suas residências e benfeitorias e evitar o retalhamento dos quinhões em glebas separadas."
                                },
                                {
                                    "numero": "596º",
                                    "rotulo": "Art. 596º.",
                                    "linha": 4676,
                                    "caput": "Ouvidas as partes, no prazo comum de 15 (quinze) dias, sobre o cálculo e o plano da divisão, o juiz deliberará a partilha.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4678,
                                            "texto": "Em cumprimento dessa decisão, o perito procederá à demarcação dos quinhões, observando, além do disposto nos arts. 584 e 585, as seguintes regras:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4680,
                                                    "texto": "as benfeitorias comuns que não comportarem divisão cômoda serão adjudicadas a um dos condôminos mediante compensação;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4682,
                                                    "texto": "instituir-se-ão as servidões que forem indispensáveis em favor de uns quinhões sobre os outros, incluindo o respectivo valor no orçamento para que, não se tratando de servidões naturais, seja compensado o condômino aquinhoado com o prédio serviente;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 4684,
                                                    "texto": "as benfeitorias particulares dos condôminos que excederem à área a que têm direito serão adjudicadas ao quinhoeiro vizinho mediante reposição;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 4686,
                                                    "texto": "se outra coisa não acordarem as partes, as compensações e as reposições serão feitas em dinheiro."
                                                }
                                            ],
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 584 e 585",
                                                    "href": "#art584",
                                                    "inicio": 109,
                                                    "fim": 124
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "597º",
                                    "rotulo": "Art. 597º.",
                                    "linha": 4688,
                                    "caput": "Terminados os trabalhos e desenhados na planta os quinhões e as servidões aparentes, o perito organizará o memorial descritivo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4690,
                                            "texto": "Cumprido o disposto no art. 586, o escrivão, em seguida, lavrará o auto de divisão, acompanhado de uma folha de pagamento para cada condômino.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 586",
                                                    "href": "#art586",
                                                    "inicio": 23,
                                                    "fim": 31
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4692,
                                            "texto": "Assinado o auto pelo juiz e pelo perito, será proferida sentença homologatória da divisão."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4694,
                                            "texto": "O auto conterá:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4696,
                                                    "texto": "a confinação e a extensão superficial do imóvel;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4698,
                                                    "texto": "a classificação das terras com o cálculo das áreas de cada consorte e com a respectiva avaliação ou, quando a homogeneidade das terras não determinar diversidade de valores, a avaliação do imóvel na sua integridade;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 4700,
                                                    "texto": "o valor e a quantidade geométrica que couber a cada condômino, declarando-se as reduções e as compensações resultantes da diversidade de valores das glebas componentes de cada quinhão."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4702,
                                            "texto": "Cada folha de pagamento conterá:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4704,
                                                    "texto": "a descrição das linhas divisórias do quinhão, mencionadas as confinantes;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4706,
                                                    "texto": "a relação das benfeitorias e das culturas do próprio quinhoeiro e das que lhe foram adjudicadas por serem comuns ou mediante compensação;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 4708,
                                                    "texto": "a declaração das servidões instituídas, especificados os lugares, a extensão e o modo de exercício."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "598º",
                                    "rotulo": "Art. 598º.",
                                    "linha": 4710,
                                    "caput": "Aplica-se às divisões o disposto nos arts. 575 a 578.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 575 a 578",
                                            "href": "#art575",
                                            "inicio": 37,
                                            "fim": 52
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA AÇÃO DE DIVISÃO E DA DEMARCAÇÃO DE TERRAS PARTICULARES",
                            "linhaTitulo": 4565
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 4712,
                            "artigos": [
                                {
                                    "numero": "599º",
                                    "rotulo": "Art. 599º.",
                                    "linha": 4715,
                                    "caput": "A ação de dissolução parcial de sociedade pode ter por objeto:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4723,
                                            "texto": "A petição inicial será necessariamente instruída com o contrato social consolidado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4725,
                                            "texto": "A ação de dissolução parcial de sociedade pode ter também por objeto a sociedade anônima de capital fechado quando demonstrado, por acionista ou acionistas que representem cinco por cento ou mais do capital social, que não pode preencher o seu fim."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4717,
                                            "texto": "a resolução da sociedade empresária contratual ou simples em relação ao sócio falecido, excluído ou que exerceu o direito de retirada ou recesso; e"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4719,
                                            "texto": "a apuração dos haveres do sócio falecido, excluído ou que exerceu o direito de retirada ou recesso; ou"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4721,
                                            "texto": "somente a resolução ou a apuração de haveres."
                                        }
                                    ]
                                },
                                {
                                    "numero": "600º",
                                    "rotulo": "Art. 600º.",
                                    "linha": 4727,
                                    "caput": "A ação pode ser proposta:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4741,
                                            "texto": "O cônjuge ou companheiro do sócio cujo casamento, união estável ou convivência terminou poderá requerer a apuração de seus haveres na sociedade, que serão pagos à conta da quota social titulada por este sócio."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4729,
                                            "texto": "pelo espólio do sócio falecido, quando a totalidade dos sucessores não ingressar na sociedade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4731,
                                            "texto": "pelos sucessores, após concluída a partilha do sócio falecido;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4733,
                                            "texto": "pela sociedade, se os sócios sobreviventes não admitirem o ingresso do espólio ou dos sucessores do falecido na sociedade, quando esse direito decorrer do contrato social;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4735,
                                            "texto": "pelo sócio que exerceu o direito de retirada ou recesso, se não tiver sido providenciada, pelos demais sócios, a alteração contratual consensual formalizando o desligamento, depois de transcorridos 10 (dez) dias do exercício do direito;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4737,
                                            "texto": "pela sociedade, nos casos em que a lei não autoriza a exclusão extrajudicial; ou"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4739,
                                            "texto": "pelo sócio excluído."
                                        }
                                    ]
                                },
                                {
                                    "numero": "601º",
                                    "rotulo": "Art. 601º.",
                                    "linha": 4743,
                                    "caput": "Os sócios e a sociedade serão citados para, no prazo de 15 (quinze) dias, concordar com o pedido ou apresentar contestação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4745,
                                            "texto": "A sociedade não será citada se todos os seus sócios o forem, mas ficará sujeita aos efeitos da decisão e à coisa julgada."
                                        }
                                    ]
                                },
                                {
                                    "numero": "602º",
                                    "rotulo": "Art. 602º.",
                                    "linha": 4747,
                                    "caput": "A sociedade poderá formular pedido de indenização compensável com o valor dos haveres a apurar."
                                },
                                {
                                    "numero": "603º",
                                    "rotulo": "Art. 603º.",
                                    "linha": 4749,
                                    "caput": "Havendo manifestação expressa e unânime pela concordância da dissolução, o juiz a decretará, passando-se imediatamente à fase de liquidação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4751,
                                            "texto": "Na hipótese prevista no caput , não haverá condenação em honorários advocatícios de nenhuma das partes, e as custas serão rateadas segundo a participação das partes no capital social."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4753,
                                            "texto": "Havendo contestação, observar-se-á o procedimento comum, mas a liquidação da sentença seguirá o disposto neste Capítulo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "604º",
                                    "rotulo": "Art. 604º.",
                                    "linha": 4755,
                                    "caput": "Para apuração dos haveres, o juiz:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4763,
                                            "texto": "O juiz determinará à sociedade ou aos sócios que nela permanecerem que depositem em juízo a parte incontroversa dos haveres devidos."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4765,
                                            "texto": "O depósito poderá ser, desde logo, levantando pelo ex-sócio, pelo espólio ou pelos sucessores."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4767,
                                            "texto": "Se o contrato social estabelecer o pagamento dos haveres, será observado o que nele se dispôs no depósito judicial da parte incontroversa."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4757,
                                            "texto": "fixará a data da resolução da sociedade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4759,
                                            "texto": "definirá o critério de apuração dos haveres à vista do disposto no contrato social; e"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4761,
                                            "texto": "nomeará o perito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "605º",
                                    "rotulo": "Art. 605º.",
                                    "linha": 4769,
                                    "caput": "A data da resolução da sociedade será:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4771,
                                            "texto": "no caso de falecimento do sócio, a do óbito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4773,
                                            "texto": "na retirada imotivada, o sexagésimo dia seguinte ao do recebimento, pela sociedade, da notificação do sócio retirante;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4775,
                                            "texto": "no recesso, o dia do recebimento, pela sociedade, da notificação do sócio dissidente;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4777,
                                            "texto": "na retirada por justa causa de sociedade por prazo determinado e na exclusão judicial de sócio, a do trânsito em julgado da decisão que dissolver a sociedade; e"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4779,
                                            "texto": "na exclusão extrajudicial, a data da assembleia ou da reunião de sócios que a tiver deliberado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "606º",
                                    "rotulo": "Art. 606º.",
                                    "linha": 4781,
                                    "caput": "Em caso de omissão do contrato social, o juiz definirá, como critério de apuração de haveres, o valor patrimonial apurado em balanço de determinação, tomando-se por referência a data da resolução e avaliando-se bens e direitos do ativo, tangíveis e intangíveis, a preço de saída, além do passivo também a ser apurado de igual forma.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4783,
                                            "texto": "Em todos os casos em que seja necessária a realização de perícia, a nomeação do perito recairá preferencialmente sobre especialista em avaliação de sociedades."
                                        }
                                    ]
                                },
                                {
                                    "numero": "607º",
                                    "rotulo": "Art. 607º.",
                                    "linha": 4785,
                                    "caput": "A data da resolução e o critério de apuração de haveres podem ser revistos pelo juiz, a pedido da parte, a qualquer tempo antes do início da perícia."
                                },
                                {
                                    "numero": "608º",
                                    "rotulo": "Art. 608º.",
                                    "linha": 4787,
                                    "caput": "Até a data da resolução, integram o valor devido ao ex-sócio, ao espólio ou aos sucessores a participação nos lucros ou os juros sobre o capital próprio declarados pela sociedade e, se for o caso, a remuneração como administrador.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4789,
                                            "texto": "Após a data da resolução, o ex-sócio, o espólio ou os sucessores terão direito apenas à correção monetária dos valores apurados e aos juros contratuais ou legais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "609º",
                                    "rotulo": "Art. 609º.",
                                    "linha": 4791,
                                    "caput": "Uma vez apurados, os haveres do sócio retirante serão pagos conforme disciplinar o contrato social e, no silêncio deste, nos termos do § 2º do art. 1.031 da Lei nº 10.406, de 10 de janeiro de 2002 (Código Civil)."
                                }
                            ],
                            "titulo": "DA AÇÃO DE DISSOLUÇÃO PARCIAL DE SOCIEDADE",
                            "linhaTitulo": 4713
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VI",
                            "linha": 4793,
                            "artigos": [
                                {
                                    "numero": "610º",
                                    "rotulo": "Art. 610º.",
                                    "linha": 4799,
                                    "caput": "Havendo testamento ou interessado incapaz, proceder-se-á ao inventário judicial.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4801,
                                            "texto": "Se todos forem capazes e concordes, o inventário e a partilha poderão ser feitos por escritura pública, a qual constituirá documento hábil para qualquer ato de registro, bem como para levantamento de importância depositada em instituições financeiras."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4803,
                                            "texto": "O tabelião somente lavrará a escritura pública se todas as partes interessadas estiverem assistidas por advogado ou por defensor público, cuja qualificação e assinatura constarão do ato notarial."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 4797
                                },
                                {
                                    "numero": "611º",
                                    "rotulo": "Art. 611º.",
                                    "linha": 4805,
                                    "caput": "O processo de inventário e de partilha deve ser instaurado dentro de 2 (dois) meses, a contar da abertura da sucessão, ultimando-se nos 12 (doze) meses subsequentes, podendo o juiz prorrogar esses prazos, de ofício ou a requerimento de parte.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "12",
                                            "href": "../../../LEIS/L1060.htm#art12",
                                            "inicio": 136,
                                            "fim": 138
                                        }
                                    ]
                                },
                                {
                                    "numero": "612º",
                                    "rotulo": "Art. 612º.",
                                    "linha": 4807,
                                    "caput": "O juiz decidirá todas as questões de direito desde que os fatos relevantes estejam provados por documento, só remetendo para as vias ordinárias as questões que dependerem de outras provas."
                                },
                                {
                                    "numero": "613º",
                                    "rotulo": "Art. 613º.",
                                    "linha": 4809,
                                    "caput": "Até que o inventariante preste o compromisso, continuará o espólio na posse do administrador provisório."
                                },
                                {
                                    "numero": "614º",
                                    "rotulo": "Art. 614º.",
                                    "linha": 4811,
                                    "caput": "O administrador provisório representa ativa e passivamente o espólio, é obrigado a trazer ao acervo os frutos que desde a abertura da sucessão percebeu, tem direito ao reembolso das despesas necessárias e úteis que fez e responde pelo dano a que, por dolo ou culpa, der causa. Seção II"
                                },
                                {
                                    "numero": "615º",
                                    "rotulo": "Art. 615º.",
                                    "linha": 4816,
                                    "caput": "O requerimento de inventário e de partilha incumbe a quem estiver na posse e na administração do espólio, no prazo estabelecido no art. 611.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4818,
                                            "texto": "O requerimento será instruído com a certidão de óbito do autor da herança."
                                        }
                                    ],
                                    "rubrica": "Da Legitimidade para Requerer o Inventário",
                                    "linhaRubrica": 4814,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 611",
                                            "href": "#art611",
                                            "inicio": 131,
                                            "fim": 139
                                        }
                                    ]
                                },
                                {
                                    "numero": "616º",
                                    "rotulo": "Art. 616º.",
                                    "linha": 4820,
                                    "caput": "Têm, contudo, legitimidade concorrente:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4822,
                                            "texto": "o cônjuge ou companheiro supérstite;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4824,
                                            "texto": "o herdeiro;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4826,
                                            "texto": "o legatário;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4828,
                                            "texto": "o testamenteiro;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4830,
                                            "texto": "o cessionário do herdeiro ou do legatário;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4832,
                                            "texto": "o credor do herdeiro, do legatário ou do autor da herança;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 4834,
                                            "texto": "o Ministério Público, havendo herdeiros incapazes;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 4836,
                                            "texto": "a Fazenda Pública, quando tiver interesse;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 4838,
                                            "texto": "o administrador judicial da falência do herdeiro, do legatário, do autor da herança ou do cônjuge ou companheiro supérstite. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "617º",
                                    "rotulo": "Art. 617º.",
                                    "linha": 4843,
                                    "caput": "O juiz nomeará inventariante na seguinte ordem:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4861,
                                            "texto": "O inventariante, intimado da nomeação, prestará, dentro de 5 (cinco) dias, o compromisso de bem e fielmente desempenhar a função."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4845,
                                            "texto": "o cônjuge ou companheiro sobrevivente, desde que estivesse convivendo com o outro ao tempo da morte deste;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4847,
                                            "texto": "o herdeiro que se achar na posse e na administração do espólio, se não houver cônjuge ou companheiro sobrevivente ou se estes não puderem ser nomeados;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4849,
                                            "texto": "qualquer herdeiro, quando nenhum deles estiver na posse e na administração do espólio;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4851,
                                            "texto": "o herdeiro menor, por seu representante legal;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4853,
                                            "texto": "o testamenteiro, se lhe tiver sido confiada a administração do espólio ou se toda a herança estiver distribuída em legados;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4855,
                                            "texto": "o cessionário do herdeiro ou do legatário;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 4857,
                                            "texto": "o inventariante judicial, se houver;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 4859,
                                            "texto": "pessoa estranha idônea, quando não houver inventariante judicial."
                                        }
                                    ],
                                    "rubrica": "Do Inventariante e das Primeiras Declarações",
                                    "linhaRubrica": 4841
                                },
                                {
                                    "numero": "618º",
                                    "rotulo": "Art. 618º.",
                                    "linha": 4863,
                                    "caput": "Incumbe ao inventariante:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4865,
                                            "texto": "representar o espólio ativa e passivamente, em juízo ou fora dele, observando-se, quanto ao dativo, o disposto no art. 75, § 1º;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4867,
                                            "texto": "administrar o espólio, velando-lhe os bens com a mesma diligência que teria se seus fossem;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4869,
                                            "texto": "prestar as primeiras e as últimas declarações pessoalmente ou por procurador com poderes especiais;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4871,
                                            "texto": "exibir em cartório, a qualquer tempo, para exame das partes, os documentos relativos ao espólio;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4873,
                                            "texto": "juntar aos autos certidão do testamento, se houver;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4875,
                                            "texto": "trazer à colação os bens recebidos pelo herdeiro ausente, renunciante ou excluído;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 4877,
                                            "texto": "prestar contas de sua gestão ao deixar o cargo ou sempre que o juiz lhe determinar;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 4879,
                                            "texto": "requerer a declaração de insolvência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "619º",
                                    "rotulo": "Art. 619º.",
                                    "linha": 4881,
                                    "caput": "Incumbe ainda ao inventariante, ouvidos os interessados e com autorização do juiz:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4883,
                                            "texto": "alienar bens de qualquer espécie;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4885,
                                            "texto": "transigir em juízo ou fora dele;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4887,
                                            "texto": "pagar dívidas do espólio;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4889,
                                            "texto": "fazer as despesas necessárias para a conservação e o melhoramento dos bens do espólio."
                                        }
                                    ]
                                },
                                {
                                    "numero": "620º",
                                    "rotulo": "Art. 620º.",
                                    "linha": 4891,
                                    "caput": "Dentro de 20 (vinte) dias contados da data em que prestou o compromisso, o inventariante fará as primeiras declarações, das quais se lavrará termo circunstanciado, assinado pelo juiz, pelo escrivão e pelo inventariante, no qual serão exarados:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4917,
                                            "texto": "O juiz determinará que se proceda:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 4919,
                                                    "texto": "ao balanço do estabelecimento, se o autor da herança era empresário individual;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 4921,
                                                    "texto": "à apuração de haveres, se o autor da herança era sócio de sociedade que não anônima."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4923,
                                            "texto": "As declarações podem ser prestadas mediante petição, firmada por procurador com poderes especiais, à qual o termo se reportará."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4893,
                                            "texto": "o nome, o estado, a idade e o domicílio do autor da herança, o dia e o lugar em que faleceu e se deixou testamento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4895,
                                            "texto": "o nome, o estado, a idade, o endereço eletrônico e a residência dos herdeiros e, havendo cônjuge ou companheiro supérstite, além dos respectivos dados pessoais, o regime de bens do casamento ou da união estável;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4897,
                                            "texto": "a qualidade dos herdeiros e o grau de parentesco com o inventariado;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4899,
                                            "texto": "a relação completa e individualizada de todos os bens do espólio, inclusive aqueles que devem ser conferidos à colação, e dos bens alheios que nele forem encontrados, descrevendo-se:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 4901,
                                                    "texto": "os imóveis, com as suas especificações, nomeadamente local em que se encontram, extensão da área, limites, confrontações, benfeitorias, origem dos títulos, números das matrículas e ônus que os gravam;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 4903,
                                                    "texto": "os móveis, com os sinais característicos;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 4905,
                                                    "texto": "os semoventes, seu número, suas espécies, suas marcas e seus sinais distintivos;"
                                                },
                                                {
                                                    "letra": "d",
                                                    "rotulo": "d)",
                                                    "linha": 4907,
                                                    "texto": "o dinheiro, as joias, os objetos de ouro e prata e as pedras preciosas, declarando-se-lhes especificadamente a qualidade, o peso e a importância;"
                                                },
                                                {
                                                    "letra": "e",
                                                    "rotulo": "e)",
                                                    "linha": 4909,
                                                    "texto": "os títulos da dívida pública, bem como as ações, as quotas e os títulos de sociedade, mencionando-se-lhes o número, o valor e a data;"
                                                },
                                                {
                                                    "letra": "f",
                                                    "rotulo": "f)",
                                                    "linha": 4911,
                                                    "texto": "as dívidas ativas e passivas, indicando-se-lhes as datas, os títulos, a origem da obrigação e os nomes dos credores e dos devedores;"
                                                },
                                                {
                                                    "letra": "g",
                                                    "rotulo": "g)",
                                                    "linha": 4913,
                                                    "texto": "direitos e ações;"
                                                },
                                                {
                                                    "letra": "h",
                                                    "rotulo": "h)",
                                                    "linha": 4915,
                                                    "texto": "o valor corrente de cada um dos bens do espólio."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "621º",
                                    "rotulo": "Art. 621º.",
                                    "linha": 4925,
                                    "caput": "Só se pode arguir sonegação ao inventariante depois de encerrada a descrição dos bens, com a declaração, por ele feita, de não existirem outros por inventariar."
                                },
                                {
                                    "numero": "622º",
                                    "rotulo": "Art. 622º.",
                                    "linha": 4927,
                                    "caput": "O inventariante será removido de ofício ou a requerimento:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4929,
                                            "texto": "se não prestar, no prazo legal, as primeiras ou as últimas declarações;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4931,
                                            "texto": "se não der ao inventário andamento regular, se suscitar dúvidas infundadas ou se praticar atos meramente protelatórios;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4933,
                                            "texto": "se, por culpa sua, bens do espólio se deteriorarem, forem dilapidados ou sofrerem dano;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 4935,
                                            "texto": "se não defender o espólio nas ações em que for citado, se deixar de cobrar dívidas ativas ou se não promover as medidas necessárias para evitar o perecimento de direitos;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 4937,
                                            "texto": "se não prestar contas ou se as que prestar não forem julgadas boas;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 4939,
                                            "texto": "se sonegar, ocultar ou desviar bens do espólio."
                                        }
                                    ]
                                },
                                {
                                    "numero": "623º",
                                    "rotulo": "Art. 623º.",
                                    "linha": 4941,
                                    "caput": "Requerida a remoção com fundamento em qualquer dos incisos do art. 622, será intimado o inventariante para, no prazo de 15 (quinze) dias, defender-se e produzir provas.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4943,
                                            "texto": "O incidente da remoção correrá em apenso aos autos do inventário."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 622",
                                            "href": "#art622",
                                            "inicio": 62,
                                            "fim": 70
                                        }
                                    ]
                                },
                                {
                                    "numero": "624º",
                                    "rotulo": "Art. 624º.",
                                    "linha": 4945,
                                    "caput": "Decorrido o prazo, com a defesa do inventariante ou sem ela, o juiz decidirá.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4947,
                                            "texto": "Se remover o inventariante, o juiz nomeará outro, observada a ordem estabelecida no art. 617.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 617",
                                                    "href": "#art617",
                                                    "inicio": 84,
                                                    "fim": 92
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "625º",
                                    "rotulo": "Art. 625º.",
                                    "linha": 4949,
                                    "caput": "O inventariante removido entregará imediatamente ao substituto os bens do espólio e, caso deixe de fazê-lo, será compelido mediante mandado de busca e apreensão ou de imissão na posse, conforme se tratar de bem móvel ou imóvel, sem prejuízo da multa a ser fixada pelo juiz em montante não superior a três por cento do valor dos bens inventariados. Seção IV"
                                },
                                {
                                    "numero": "626º",
                                    "rotulo": "Art. 626º.",
                                    "linha": 4954,
                                    "caput": "Feitas as primeiras declarações, o juiz mandará citar, para os termos do inventário e da partilha, o cônjuge, o companheiro, os herdeiros e os legatários e intimar a Fazenda Pública, o Ministério Público, se houver herdeiro incapaz ou ausente, e o testamenteiro, se houver testamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4956,
                                            "texto": "O cônjuge ou o companheiro, os herdeiros e os legatários serão citados pelo correio, observado o disposto no art. 247, sendo, ainda, publicado edital, nos termos do inciso III do art. 259.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 247",
                                                    "href": "#art247",
                                                    "inicio": 109,
                                                    "fim": 117
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "inciso III do art. 259",
                                                    "href": "#art259ii",
                                                    "inicio": 165,
                                                    "fim": 187
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "inciso III do art. 259",
                                                    "href": "#art259iii",
                                                    "inicio": 165,
                                                    "fim": 187
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4958,
                                            "texto": "Das primeiras declarações extrair-se-ão tantas cópias quantas forem as partes."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4960,
                                            "texto": "A citação será acompanhada de cópia das primeiras declarações."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 4962,
                                            "texto": "Incumbe ao escrivão remeter cópias à Fazenda Pública, ao Ministério Público, ao testamenteiro, se houver, e ao advogado, se a parte já estiver representada nos autos."
                                        }
                                    ],
                                    "rubrica": "Das Citações e das Impugnações",
                                    "linhaRubrica": 4952
                                },
                                {
                                    "numero": "627º",
                                    "rotulo": "Art. 627º.",
                                    "linha": 4964,
                                    "caput": "Concluídas as citações, abrir-se-á vista às partes, em cartório e pelo prazo comum de 15 (quinze) dias, para que se manifestem sobre as primeiras declarações, incumbindo às partes:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4972,
                                            "texto": "Julgando procedente a impugnação referida no inciso I, o juiz mandará retificar as primeiras declarações."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4974,
                                            "texto": "Se acolher o pedido de que trata o inciso II, o juiz nomeará outro inventariante, observada a preferência legal."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 4976,
                                            "texto": "Verificando que a disputa sobre a qualidade de herdeiro a que alude o inciso III demanda produção de provas que não a documental, o juiz remeterá a parte às vias ordinárias e sobrestará, até o julgamento da ação, a entrega do quinhão que na partilha couber ao herdeiro admitido."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 4966,
                                            "texto": "arguir erros, omissões e sonegação de bens;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 4968,
                                            "texto": "reclamar contra a nomeação de inventariante"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 4970,
                                            "texto": "contestar a qualidade de quem foi incluído no título de herdeiro."
                                        }
                                    ]
                                },
                                {
                                    "numero": "628º",
                                    "rotulo": "Art. 628º.",
                                    "linha": 4978,
                                    "caput": "Aquele que se julgar preterido poderá demandar sua admissão no inventário, requerendo-a antes da partilha.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 4980,
                                            "texto": "Ouvidas as partes no prazo de 15 (quinze) dias, o juiz decidirá."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 4982,
                                            "texto": "Se para solução da questão for necessária a produção de provas que não a documental, o juiz remeterá o requerente às vias ordinárias, mandando reservar, em poder do inventariante, o quinhão do herdeiro excluído até que se decida o litígio."
                                        }
                                    ]
                                },
                                {
                                    "numero": "629º",
                                    "rotulo": "Art. 629º.",
                                    "linha": 4984,
                                    "caput": "A Fazenda Pública, no prazo de 15 (quinze) dias, após a vista de que trata o art. 627, informará ao juízo, de acordo com os dados que constam de seu cadastro imobiliário, o valor dos bens de raiz descritos nas primeiras declarações. Seção V",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 627",
                                            "href": "#art627",
                                            "inicio": 77,
                                            "fim": 85
                                        }
                                    ]
                                },
                                {
                                    "numero": "630º",
                                    "rotulo": "Art. 630º.",
                                    "linha": 4989,
                                    "caput": "Findo o prazo previsto no art. 627 sem impugnação ou decidida a impugnação que houver sido oposta, o juiz nomeará, se for o caso, perito para avaliar os bens do espólio, se não houver na comarca avaliador judicial.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 4991,
                                            "texto": "Na hipótese prevista no art. 620, § 1º, o juiz nomeará perito para avaliação das quotas sociais ou apuração dos haveres."
                                        }
                                    ],
                                    "rubrica": "Da Avaliação e do Cálculo do Imposto",
                                    "linhaRubrica": 4987,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 627",
                                            "href": "#art627",
                                            "inicio": 26,
                                            "fim": 34
                                        }
                                    ]
                                },
                                {
                                    "numero": "631º",
                                    "rotulo": "Art. 631º.",
                                    "linha": 4993,
                                    "caput": "Ao avaliar os bens do espólio, o perito observará, no que for aplicável, o disposto nos arts. 872 e 873.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 872 e 873",
                                            "href": "#art872",
                                            "inicio": 88,
                                            "fim": 103
                                        }
                                    ]
                                },
                                {
                                    "numero": "632º",
                                    "rotulo": "Art. 632º.",
                                    "linha": 4995,
                                    "caput": "Não se expedirá carta precatória para a avaliação de bens situados fora da comarca onde corre o inventário se eles forem de pequeno valor ou perfeitamente conhecidos do perito nomeado."
                                },
                                {
                                    "numero": "633º",
                                    "rotulo": "Art. 633º.",
                                    "linha": 4997,
                                    "caput": "Sendo capazes todas as partes, não se procederá à avaliação se a Fazenda Pública, intimada pessoalmente, concordar de forma expressa com o valor atribuído, nas primeiras declarações, aos bens do espólio."
                                },
                                {
                                    "numero": "634º",
                                    "rotulo": "Art. 634º.",
                                    "linha": 4999,
                                    "caput": "Se os herdeiros concordarem com o valor dos bens declarados pela Fazenda Pública, a avaliação cingir-se-á aos demais."
                                },
                                {
                                    "numero": "635º",
                                    "rotulo": "Art. 635º.",
                                    "linha": 5001,
                                    "caput": "Entregue o laudo de avaliação, o juiz mandará que as partes se manifestem no prazo de 15 (quinze) dias, que correrá em cartório.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5003,
                                            "texto": "Versando a impugnação sobre o valor dado pelo perito, o juiz a decidirá de plano, à vista do que constar dos autos."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5005,
                                            "texto": "Julgando procedente a impugnação, o juiz determinará que o perito retifique a avaliação, observando os fundamentos da decisão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "636º",
                                    "rotulo": "Art. 636º.",
                                    "linha": 5007,
                                    "caput": "Aceito o laudo ou resolvidas as impugnações suscitadas a seu respeito, lavrar-se-á em seguida o termo de últimas declarações, no qual o inventariante poderá emendar, aditar ou completar as primeiras."
                                },
                                {
                                    "numero": "637º",
                                    "rotulo": "Art. 637º.",
                                    "linha": 5009,
                                    "caput": "Ouvidas as partes sobre as últimas declarações no prazo comum de 15 (quinze) dias, proceder-se-á ao cálculo do tributo."
                                },
                                {
                                    "numero": "638º",
                                    "rotulo": "Art. 638º.",
                                    "linha": 5011,
                                    "caput": "Feito o cálculo, sobre ele serão ouvidas todas as partes no prazo comum de 5 (cinco) dias, que correrá em cartório, e, em seguida, a Fazenda Pública.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5013,
                                            "texto": "Se acolher eventual impugnação, o juiz ordenará nova remessa dos autos ao contabilista, determinando as alterações que devam ser feitas no cálculo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5015,
                                            "texto": "Cumprido o despacho, o juiz julgará o cálculo do tributo. Seção VI"
                                        }
                                    ]
                                },
                                {
                                    "numero": "639º",
                                    "rotulo": "Art. 639º.",
                                    "linha": 5020,
                                    "caput": "No prazo estabelecido no art. 627, o herdeiro obrigado à colação conferirá por termo nos autos ou por petição à qual o termo se reportará os bens que recebeu ou, se já não os possuir, trar-lhes-á o valor.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5022,
                                            "texto": "Os bens a serem conferidos na partilha, assim como as acessões e as benfeitorias que o donatário fez, calcular-se-ão pelo valor que tiverem ao tempo da abertura da sucessão."
                                        }
                                    ],
                                    "rubrica": "Das Colações",
                                    "linhaRubrica": 5018,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 627",
                                            "href": "#art627",
                                            "inicio": 25,
                                            "fim": 33
                                        }
                                    ]
                                },
                                {
                                    "numero": "640º",
                                    "rotulo": "Art. 640º.",
                                    "linha": 5024,
                                    "caput": "O herdeiro que renunciou à herança ou o que dela foi excluído não se exime, pelo fato da renúncia ou da exclusão, de conferir, para o efeito de repor a parte inoficiosa, as liberalidades que obteve do doador.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5026,
                                            "texto": "É lícito ao donatário escolher, dentre os bens doados, tantos quantos bastem para perfazer a legítima e a metade disponível, entrando na partilha o excedente para ser dividido entre os demais herdeiros."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5028,
                                            "texto": "Se a parte inoficiosa da doação recair sobre bem imóvel que não comporte divisão cômoda, o juiz determinará que sobre ela se proceda a licitação entre os herdeiros."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5030,
                                            "texto": "O donatário poderá concorrer na licitação referida no § 2º e, em igualdade de condições, terá preferência sobre os herdeiros."
                                        }
                                    ]
                                },
                                {
                                    "numero": "641º",
                                    "rotulo": "Art. 641º.",
                                    "linha": 5032,
                                    "caput": "Se o herdeiro negar o recebimento dos bens ou a obrigação de os conferir, o juiz, ouvidas as partes no prazo comum de 15 (quinze) dias, decidirá à vista das alegações e das provas produzidas.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5034,
                                            "texto": "Declarada improcedente a oposição, se o herdeiro, no prazo improrrogável de 15 (quinze) dias, não proceder à conferência, o juiz mandará sequestrar-lhe, para serem inventariados e partilhados, os bens sujeitos à colação ou imputar ao seu quinhão hereditário o valor deles, se já não os possuir."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5036,
                                            "texto": "Se a matéria exigir dilação probatória diversa da documental, o juiz remeterá as partes às vias ordinárias, não podendo o herdeiro receber o seu quinhão hereditário, enquanto pender a demanda, sem prestar caução correspondente ao valor dos bens sobre os quais versar a conferência. Seção VII"
                                        }
                                    ]
                                },
                                {
                                    "numero": "642º",
                                    "rotulo": "Art. 642º.",
                                    "linha": 5041,
                                    "caput": "Antes da partilha, poderão os credores do espólio requerer ao juízo do inventário o pagamento das dívidas vencidas e exigíveis.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5043,
                                            "texto": "A petição, acompanhada de prova literal da dívida, será distribuída por dependência e autuada em apenso aos autos do processo de inventário."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5045,
                                            "texto": "Concordando as partes com o pedido, o juiz, ao declarar habilitado o credor, mandará que se faça a separação de dinheiro ou, em sua falta, de bens suficientes para o pagamento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5047,
                                            "texto": "Separados os bens, tantos quantos forem necessários para o pagamento dos credores habilitados, o juiz mandará aliená-los, observando-se as disposições deste Código relativas à expropriação."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5049,
                                            "texto": "Se o credor requerer que, em vez de dinheiro, lhe sejam adjudicados, para o seu pagamento, os bens já reservados, o juiz deferir-lhe-á o pedido, concordando todas as partes."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5051,
                                            "texto": "Os donatários serão chamados a pronunciar-se sobre a aprovação das dívidas, sempre que haja possibilidade de resultar delas a redução das liberalidades."
                                        }
                                    ],
                                    "rubrica": "Do Pagamento das Dívidas",
                                    "linhaRubrica": 5039
                                },
                                {
                                    "numero": "643º",
                                    "rotulo": "Art. 643º.",
                                    "linha": 5053,
                                    "caput": "Não havendo concordância de todas as partes sobre o pedido de pagamento feito pelo credor, será o pedido remetido às vias ordinárias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5055,
                                            "texto": "O juiz mandará, porém, reservar, em poder do inventariante, bens suficientes para pagar o credor quando a dívida constar de documento que comprove suficientemente a obrigação e a impugnação não se fundar em quitação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "644º",
                                    "rotulo": "Art. 644º.",
                                    "linha": 5057,
                                    "caput": "O credor de dívida líquida e certa, ainda não vencida, pode requerer habilitação no inventário.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5059,
                                            "texto": "Concordando as partes com o pedido referido no caput , o juiz, ao julgar habilitado o crédito, mandará que se faça separação de bens para o futuro pagamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "645º",
                                    "rotulo": "Art. 645º.",
                                    "linha": 5061,
                                    "caput": "O legatário é parte legítima para manifestar-se sobre as dívidas do espólio:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5063,
                                            "texto": "quando toda a herança for dividida em legados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5065,
                                            "texto": "quando o reconhecimento das dívidas importar redução dos legados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "646º",
                                    "rotulo": "Art. 646º.",
                                    "linha": 5067,
                                    "caput": "Sem prejuízo do disposto no art. 860, é lícito aos herdeiros, ao separarem bens para o pagamento de dívidas, autorizar que o inventariante os indique à penhora no processo em que o espólio for executado. Seção VIII",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 860",
                                            "href": "#art860",
                                            "inicio": 28,
                                            "fim": 36
                                        }
                                    ]
                                },
                                {
                                    "numero": "647º",
                                    "rotulo": "Art. 647º.",
                                    "linha": 5072,
                                    "caput": "Cumprido o disposto no art. 642, § 3º, o juiz facultará às partes que, no prazo comum de 15 (quinze) dias, formulem o pedido de quinhão e, em seguida, proferirá a decisão de deliberação da partilha, resolvendo os pedidos das partes e designando os bens que devam constituir quinhão de cada herdeiro e legatário.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5074,
                                            "texto": "O juiz poderá, em decisão fundamentada, deferir antecipadamente a qualquer dos herdeiros o exercício dos direitos de usar e de fruir de determinado bem, com a condição de que, ao término do inventário, tal bem integre a cota desse herdeiro, cabendo a este, desde o deferimento, todos os ônus e bônus decorrentes do exercício daqueles direitos."
                                        }
                                    ],
                                    "rubrica": "Da Partilha",
                                    "linhaRubrica": 5070
                                },
                                {
                                    "numero": "648º",
                                    "rotulo": "Art. 648º.",
                                    "linha": 5076,
                                    "caput": "Na partilha, serão observadas as seguintes regras:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5078,
                                            "texto": "a máxima igualdade possível quanto ao valor, à natureza e à qualidade dos bens;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5080,
                                            "texto": "a prevenção de litígios futuros;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5082,
                                            "texto": "a máxima comodidade dos coerdeiros, do cônjuge ou do companheiro, se for o caso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "649º",
                                    "rotulo": "Art. 649º.",
                                    "linha": 5084,
                                    "caput": "Os bens insuscetíveis de divisão cômoda que não couberem na parte do cônjuge ou companheiro supérstite ou no quinhão de um só herdeiro serão licitados entre os interessados ou vendidos judicialmente, partilhando-se o valor apurado, salvo se houver acordo para que sejam adjudicados a todos."
                                },
                                {
                                    "numero": "650º",
                                    "rotulo": "Art. 650º.",
                                    "linha": 5086,
                                    "caput": "Se um dos interessados for nascituro, o quinhão que lhe caberá será reservado em poder do inventariante até o seu nascimento."
                                },
                                {
                                    "numero": "651º",
                                    "rotulo": "Art. 651º.",
                                    "linha": 5088,
                                    "caput": "O partidor organizará o esboço da partilha de acordo com a decisão judicial, observando nos pagamentos a seguinte ordem:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5090,
                                            "texto": "dívidas atendidas;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5092,
                                            "texto": "meação do cônjuge;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5094,
                                            "texto": "meação disponível;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5096,
                                            "texto": "quinhões hereditários, a começar pelo coerdeiro mais velho."
                                        }
                                    ]
                                },
                                {
                                    "numero": "652º",
                                    "rotulo": "Art. 652º.",
                                    "linha": 5098,
                                    "caput": "Feito o esboço, as partes manifestar-se-ão sobre esse no prazo comum de 15 (quinze) dias, e, resolvidas as reclamações, a partilha será lançada nos autos."
                                },
                                {
                                    "numero": "653º",
                                    "rotulo": "Art. 653º.",
                                    "linha": 5100,
                                    "caput": "A partilha constará:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5112,
                                            "texto": "O auto e cada uma das folhas serão assinados pelo juiz e pelo escrivão."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5102,
                                            "texto": "de auto de orçamento, que mencionará:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 5104,
                                                    "texto": "os nomes do autor da herança, do inventariante, do cônjuge ou companheiro supérstite, dos herdeiros, dos legatários e dos credores admitidos;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 5106,
                                                    "texto": "o ativo, o passivo e o líquido partível, com as necessárias especificações;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 5108,
                                                    "texto": "o valor de cada quinhão;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5110,
                                            "texto": "de folha de pagamento para cada parte, declarando a quota a pagar-lhe, a razão do pagamento e a relação dos bens que lhe compõem o quinhão, as características que os individualizam e os ônus que os gravam."
                                        }
                                    ]
                                },
                                {
                                    "numero": "654º",
                                    "rotulo": "Art. 654º.",
                                    "linha": 5114,
                                    "caput": "Pago o imposto de transmissão a título de morte e juntada aos autos certidão ou informação negativa de dívida para com a Fazenda Pública, o juiz julgará por sentença a partilha.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5116,
                                            "texto": "A existência de dívida para com a Fazenda Pública não impedirá o julgamento da partilha, desde que o seu pagamento esteja devidamente garantido."
                                        }
                                    ]
                                },
                                {
                                    "numero": "655º",
                                    "rotulo": "Art. 655º.",
                                    "linha": 5118,
                                    "caput": "Transitada em julgado a sentença mencionada no art. 654, receberá o herdeiro os bens que lhe tocarem e um formal de partilha, do qual constarão as seguintes peças:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5130,
                                            "texto": "O formal de partilha poderá ser substituído por certidão de pagamento do quinhão hereditário quando esse não exceder a 5 (cinco) vezes o salário-mínimo, caso em que se transcreverá nela a sentença de partilha transitada em julgado."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5120,
                                            "texto": "termo de inventariante e título de herdeiros;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5122,
                                            "texto": "avaliação dos bens que constituíram o quinhão do herdeiro;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5124,
                                            "texto": "pagamento do quinhão hereditário;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5126,
                                            "texto": "quitação dos impostos;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 5128,
                                            "texto": "sentença."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 654",
                                            "href": "#art654",
                                            "inicio": 47,
                                            "fim": 55
                                        }
                                    ]
                                },
                                {
                                    "numero": "656º",
                                    "rotulo": "Art. 656º.",
                                    "linha": 5132,
                                    "caput": "A partilha, mesmo depois de transitada em julgado a sentença, pode ser emendada nos mesmos autos do inventário, convindo todas as partes, quando tenha havido erro de fato na descrição dos bens, podendo o juiz, de ofício ou a requerimento da parte, a qualquer tempo, corrigir-lhe as inexatidões materiais."
                                },
                                {
                                    "numero": "657º",
                                    "rotulo": "Art. 657º.",
                                    "linha": 5134,
                                    "caput": "A partilha amigável, lavrada em instrumento público, reduzida a termo nos autos do inventário ou constante de escrito particular homologado pelo juiz, pode ser anulada por dolo, coação, erro essencial ou intervenção de incapaz, observado o disposto no § 4º do art. 966 .",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5136,
                                            "texto": "O direito à anulação de partilha amigável extingue-se em 1 (um) ano, contado esse prazo:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 5138,
                                                    "texto": "no caso de coação, do dia em que ela cessou;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 5140,
                                                    "texto": "no caso de erro ou dolo, do dia em que se realizou o ato;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 5142,
                                                    "texto": "quanto ao incapaz, do dia em que cessar a incapacidade."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "658º",
                                    "rotulo": "Art. 658º.",
                                    "linha": 5144,
                                    "caput": "É rescindível a partilha julgada por sentença:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5146,
                                            "texto": "nos casos mencionados no art. 657;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 657",
                                                    "href": "#art657",
                                                    "inicio": 25,
                                                    "fim": 33
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5148,
                                            "texto": "se feita com preterição de formalidades legais;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5150,
                                            "texto": "se preteriu herdeiro ou incluiu quem não o seja. Seção IX"
                                        }
                                    ]
                                },
                                {
                                    "numero": "659º",
                                    "rotulo": "Art. 659º.",
                                    "linha": 5155,
                                    "caput": "A partilha amigável, celebrada entre partes capazes, nos termos da lei, será homologada de plano pelo juiz, com observância dos arts. 660 a 663.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5157,
                                            "texto": "O disposto neste artigo aplica-se, também, ao pedido de adjudicação, quando houver herdeiro único."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5159,
                                            "texto": "Transitada em julgado a sentença de homologação de partilha ou de adjudicação, será lavrado o formal de partilha ou elaborada a carta de adjudicação e, em seguida, serão expedidos os alvarás referentes aos bens e às rendas por ele abrangidos, intimando-se o fisco para lançamento administrativo do imposto de transmissão e de outros tributos porventura incidentes, conforme dispuser a legislação tributária, nos termos do § 2º do art. 662."
                                        }
                                    ],
                                    "rubrica": "Do Arrolamento",
                                    "linhaRubrica": 5153,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 660 a 663",
                                            "href": "#art660",
                                            "inicio": 128,
                                            "fim": 143
                                        }
                                    ]
                                },
                                {
                                    "numero": "660º",
                                    "rotulo": "Art. 660º.",
                                    "linha": 5161,
                                    "caput": "Na petição de inventário, que se processará na forma de arrolamento sumário, independentemente da lavratura de termos de qualquer espécie, os herdeiros:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5163,
                                            "texto": "requererão ao juiz a nomeação do inventariante que designarem;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5165,
                                            "texto": "declararão os títulos dos herdeiros e os bens do espólio, observado o disposto no art. 630;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 630",
                                                    "href": "#art630",
                                                    "inicio": 82,
                                                    "fim": 90
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5167,
                                            "texto": "atribuirão valor aos bens do espólio, para fins de partilha."
                                        }
                                    ]
                                },
                                {
                                    "numero": "661º",
                                    "rotulo": "Art. 661º.",
                                    "linha": 5169,
                                    "caput": "Ressalvada a hipótese prevista no parágrafo único do art. 663, não se procederá à avaliação dos bens do espólio para nenhuma finalidade.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 663",
                                            "href": "#art663",
                                            "inicio": 53,
                                            "fim": 61
                                        }
                                    ]
                                },
                                {
                                    "numero": "662º",
                                    "rotulo": "Art. 662º.",
                                    "linha": 5171,
                                    "caput": "No arrolamento, não serão conhecidas ou apreciadas questões relativas ao lançamento, ao pagamento ou à quitação de taxas judiciárias e de tributos incidentes sobre a transmissão da propriedade dos bens do espólio.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5173,
                                            "texto": "A taxa judiciária, se devida, será calculada com base no valor atribuído pelos herdeiros, cabendo ao fisco, se apurar em processo administrativo valor diverso do estimado, exigir a eventual diferença pelos meios adequados ao lançamento de créditos tributários em geral."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5175,
                                            "texto": "O imposto de transmissão será objeto de lançamento administrativo, conforme dispuser a legislação tributária, não ficando as autoridades fazendárias adstritas aos valores dos bens do espólio atribuídos pelos herdeiros."
                                        }
                                    ]
                                },
                                {
                                    "numero": "663º",
                                    "rotulo": "Art. 663º.",
                                    "linha": 5177,
                                    "caput": "A existência de credores do espólio não impedirá a homologação da partilha ou da adjudicação, se forem reservados bens suficientes para o pagamento da dívida.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5179,
                                            "texto": "A reserva de bens será realizada pelo valor estimado pelas partes, salvo se o credor, regularmente notificado, impugnar a estimativa, caso em que se promoverá a avaliação dos bens a serem reservados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "664º",
                                    "rotulo": "Art. 664º.",
                                    "linha": 5181,
                                    "caput": "Quando o valor dos bens do espólio for igual ou inferior a 1.000 (mil) salários-mínimos, o inventário processar-se-á na forma de arrolamento, cabendo ao inventariante nomeado, independentemente de assinatura de termo de compromisso, apresentar, com suas declarações, a atribuição de valor aos bens do espólio e o plano da partilha.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5183,
                                            "texto": "Se qualquer das partes ou o Ministério Público impugnar a estimativa, o juiz nomeará avaliador, que oferecerá laudo em 10 (dez) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5185,
                                            "texto": "Apresentado o laudo, o juiz, em audiência que designar, deliberará sobre a partilha, decidindo de plano todas as reclamações e mandando pagar as dívidas não impugnadas."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5187,
                                            "texto": "Lavrar-se-á de tudo um só termo, assinado pelo juiz, pelo inventariante e pelas partes presentes ou por seus advogados."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5189,
                                            "texto": "Aplicam-se a essa espécie de arrolamento, no que couber, as disposições do art. 672 , relativamente ao lançamento, ao pagamento e à quitação da taxa judiciária e do imposto sobre a transmissão da propriedade dos bens do espólio.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 672",
                                                    "href": "#art672",
                                                    "inicio": 75,
                                                    "fim": 83
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5191,
                                            "texto": "Provada a quitação dos tributos relativos aos bens do espólio e às suas rendas, o juiz julgará a partilha."
                                        }
                                    ]
                                },
                                {
                                    "numero": "665º",
                                    "rotulo": "Art. 665º.",
                                    "linha": 5193,
                                    "caput": "O inventário processar-se-á também na forma do art. 664 , ainda que haja interessado incapaz, desde que concordem todas as partes e o Ministério Público.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 664",
                                            "href": "#art664",
                                            "inicio": 47,
                                            "fim": 55
                                        }
                                    ]
                                },
                                {
                                    "numero": "666º",
                                    "rotulo": "Art. 666º.",
                                    "linha": 5195,
                                    "caput": "Independerá de inventário ou de arrolamento o pagamento dos valores previstos na Lei nº 6.858, de 24 de novembro de 1980 ."
                                },
                                {
                                    "numero": "667º",
                                    "rotulo": "Art. 667º.",
                                    "linha": 5197,
                                    "caput": "Aplicam-se subsidiariamente a esta Seção as disposições das Seções VII e VIII deste Capítulo. Seção X"
                                },
                                {
                                    "numero": "668º",
                                    "rotulo": "Art. 668º.",
                                    "linha": 5202,
                                    "caput": "Cessa a eficácia da tutela provisória prevista nas Seções deste Capítulo:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5204,
                                            "texto": "se a ação não for proposta em 30 (trinta) dias contados da data em que da decisão foi intimado o impugnante, o herdeiro excluído ou o credor não admitido;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5206,
                                            "texto": "se o juiz extinguir o processo de inventário com ou sem resolução de mérito."
                                        }
                                    ],
                                    "rubrica": "Disposições Comuns a Todas as Seções",
                                    "linhaRubrica": 5200
                                },
                                {
                                    "numero": "669º",
                                    "rotulo": "Art. 669º.",
                                    "linha": 5208,
                                    "caput": "São sujeitos à sobrepartilha os bens:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5218,
                                            "texto": "Os bens mencionados nos incisos III e IV serão reservados à sobrepartilha sob a guarda e a administração do mesmo ou de diverso inventariante, a consentimento da maioria dos herdeiros."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5210,
                                            "texto": "sonegados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5212,
                                            "texto": "da herança descobertos após a partilha;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5214,
                                            "texto": "litigiosos, assim como os de liquidação difícil ou morosa;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5216,
                                            "texto": "situados em lugar remoto da sede do juízo onde se processa o inventário."
                                        }
                                    ]
                                },
                                {
                                    "numero": "670º",
                                    "rotulo": "Art. 670º.",
                                    "linha": 5220,
                                    "caput": "Na sobrepartilha dos bens, observar-se-á o processo de inventário e de partilha.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5222,
                                            "texto": "A sobrepartilha correrá nos autos do inventário do autor da herança."
                                        }
                                    ]
                                },
                                {
                                    "numero": "671º",
                                    "rotulo": "Art. 671º.",
                                    "linha": 5224,
                                    "caput": "O juiz nomeará curador especial:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5226,
                                            "texto": "ao ausente, se não o tiver;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5228,
                                            "texto": "ao incapaz, se concorrer na partilha com o seu representante, desde que exista colisão de interesses."
                                        }
                                    ]
                                },
                                {
                                    "numero": "672º",
                                    "rotulo": "Art. 672º.",
                                    "linha": 5230,
                                    "caput": "É lícita a cumulação de inventários para a partilha de heranças de pessoas diversas quando houver:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5238,
                                            "texto": "No caso previsto no inciso III, se a dependência for parcial, por haver outros bens, o juiz pode ordenar a tramitação separada, se melhor convier ao interesse das partes ou à celeridade processual."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5232,
                                            "texto": "identidade de pessoas entre as quais devam ser repartidos os bens;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5234,
                                            "texto": "heranças deixadas pelos dois cônjuges ou companheiros;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5236,
                                            "texto": "dependência de uma das partilhas em relação à outra."
                                        }
                                    ]
                                },
                                {
                                    "numero": "673º",
                                    "rotulo": "Art. 673º.",
                                    "linha": 5240,
                                    "caput": "No caso previsto no art. 672 , inciso II, prevalecerão as primeiras declarações, assim como o laudo de avaliação, salvo se alterado o valor dos bens.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 672",
                                            "href": "#art672",
                                            "inicio": 20,
                                            "fim": 28
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DO INVENTÁRIO E DA PARTILHA",
                            "linhaTitulo": 4794
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VII",
                            "linha": 5242,
                            "artigos": [
                                {
                                    "numero": "674º",
                                    "rotulo": "Art. 674º.",
                                    "linha": 5245,
                                    "caput": "Quem, não sendo parte no processo, sofrer constrição ou ameaça de constrição sobre bens que possua ou sobre os quais tenha direito incompatível com o ato constritivo, poderá requerer seu desfazimento ou sua inibição por meio de embargos de terceiro.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5247,
                                            "texto": "Os embargos podem ser de terceiro proprietário, inclusive fiduciário, ou possuidor."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5249,
                                            "texto": "Considera-se terceiro, para ajuizamento dos embargos:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 5251,
                                                    "texto": "o cônjuge ou companheiro, quando defende a posse de bens próprios ou de sua meação, ressalvado o disposto no art. 843 ;",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 843",
                                                            "href": "#art843",
                                                            "inicio": 109,
                                                            "fim": 117
                                                        }
                                                    ]
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 5253,
                                                    "texto": "o adquirente de bens cuja constrição decorreu de decisão que declara a ineficácia da alienação realizada em fraude à execução;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 5255,
                                                    "texto": "quem sofre constrição judicial de seus bens por força de desconsideração da personalidade jurídica, de cujo incidente não fez parte;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 5257,
                                                    "texto": "o credor com garantia real para obstar expropriação judicial do objeto de direito real de garantia, caso não tenha sido intimado, nos termos legais dos atos expropriatórios respectivos."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "675º",
                                    "rotulo": "Art. 675º.",
                                    "linha": 5259,
                                    "caput": "Os embargos podem ser opostos a qualquer tempo no processo de conhecimento enquanto não transitada em julgado a sentença e, no cumprimento de sentença ou no processo de execução, até 5 (cinco) dias depois da adjudicação, da alienação por iniciativa particular ou da arrematação, mas sempre antes da assinatura da respectiva carta.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5261,
                                            "texto": "Caso identifique a existência de terceiro titular de interesse em embargar o ato, o juiz mandará intimá-lo pessoalmente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "676º",
                                    "rotulo": "Art. 676º.",
                                    "linha": 5263,
                                    "caput": "Os embargos serão distribuídos por dependência ao juízo que ordenou a constrição e autuados em apartado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5265,
                                            "texto": "Nos casos de ato de constrição realizado por carta, os embargos serão oferecidos no juízo deprecado, salvo se indicado pelo juízo deprecante o bem constrito ou se já devolvida a carta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "677º",
                                    "rotulo": "Art. 677º.",
                                    "linha": 5267,
                                    "caput": "Na petição inicial, o embargante fará a prova sumária de sua posse ou de seu domínio e da qualidade de terceiro, oferecendo documentos e rol de testemunhas.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5269,
                                            "texto": "É facultada a prova da posse em audiência preliminar designada pelo juiz."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5271,
                                            "texto": "O possuidor direto pode alegar, além da sua posse, o domínio alheio."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5273,
                                            "texto": "A citação será pessoal, se o embargado não tiver procurador constituído nos autos da ação principal."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5275,
                                            "texto": "Será legitimado passivo o sujeito a quem o ato de constrição aproveita, assim como o será seu adversário no processo principal quando for sua a indicação do bem para a constrição judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "678º",
                                    "rotulo": "Art. 678º.",
                                    "linha": 5277,
                                    "caput": "A decisão que reconhecer suficientemente provado o domínio ou a posse determinará a suspensão das medidas constritivas sobre os bens litigiosos objeto dos embargos, bem como a manutenção ou a reintegração provisória da posse, se o embargante a houver requerido.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5279,
                                            "texto": "O juiz poderá condicionar a ordem de manutenção ou de reintegração provisória de posse à prestação de caução pelo requerente, ressalvada a impossibilidade da parte economicamente hipossuficiente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "679º",
                                    "rotulo": "Art. 679º.",
                                    "linha": 5281,
                                    "caput": "Os embargos poderão ser contestados no prazo de 15 (quinze) dias, findo o qual se seguirá o procedimento comum."
                                },
                                {
                                    "numero": "680º",
                                    "rotulo": "Art. 680º.",
                                    "linha": 5283,
                                    "caput": "Contra os embargos do credor com garantia real, o embargado somente poderá alegar que:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5285,
                                            "texto": "o devedor comum é insolvente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5287,
                                            "texto": "o título é nulo ou não obriga a terceiro;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5289,
                                            "texto": "outra é a coisa dada em garantia."
                                        }
                                    ]
                                },
                                {
                                    "numero": "681º",
                                    "rotulo": "Art. 681º.",
                                    "linha": 5291,
                                    "caput": "Acolhido o pedido inicial, o ato de constrição judicial indevida será cancelado, com o reconhecimento do domínio, da manutenção da posse ou da reintegração definitiva do bem ou do direito ao embargante."
                                }
                            ],
                            "titulo": "DOS EMBARGOS DE TERCEIRO",
                            "linhaTitulo": 5243
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VIII",
                            "linha": 5293,
                            "artigos": [
                                {
                                    "numero": "682º",
                                    "rotulo": "Art. 682º.",
                                    "linha": 5296,
                                    "caput": "Quem pretender, no todo ou em parte, a coisa ou o direito sobre que controvertem autor e réu poderá, até ser proferida a sentença, oferecer oposição contra ambos."
                                },
                                {
                                    "numero": "683º",
                                    "rotulo": "Art. 683º.",
                                    "linha": 5298,
                                    "caput": "O opoente deduzirá o pedido em observação aos requisitos exigidos para propositura da ação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5300,
                                            "texto": "Distribuída a oposição por dependência, serão os opostos citados, na pessoa de seus respectivos advogados, para contestar o pedido no prazo comum de 15 (quinze) dias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "684º",
                                    "rotulo": "Art. 684º.",
                                    "linha": 5302,
                                    "caput": "Se um dos opostos reconhecer a procedência do pedido, contra o outro prosseguirá o opoente."
                                },
                                {
                                    "numero": "685º",
                                    "rotulo": "Art. 685º.",
                                    "linha": 5304,
                                    "caput": "Admitido o processamento, a oposição será apensada aos autos e tramitará simultaneamente à ação originária, sendo ambas julgadas pela mesma sentença.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5306,
                                            "texto": "Se a oposição for proposta após o início da audiência de instrução, o juiz suspenderá o curso do processo ao fim da produção das provas, salvo se concluir que a unidade da instrução atende melhor ao princípio da duração razoável do processo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "686º",
                                    "rotulo": "Art. 686º.",
                                    "linha": 5308,
                                    "caput": "Cabendo ao juiz decidir simultaneamente a ação originária e a oposição, desta conhecerá em primeiro lugar."
                                }
                            ],
                            "titulo": "DA OPOSIÇÃO",
                            "linhaTitulo": 5294
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IX",
                            "linha": 5310,
                            "artigos": [
                                {
                                    "numero": "687º",
                                    "rotulo": "Art. 687º.",
                                    "linha": 5313,
                                    "caput": "A habilitação ocorre quando, por falecimento de qualquer das partes, os interessados houverem de suceder-lhe no processo."
                                },
                                {
                                    "numero": "688º",
                                    "rotulo": "Art. 688º.",
                                    "linha": 5315,
                                    "caput": "A habilitação pode ser requerida:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5317,
                                            "texto": "pela parte, em relação aos sucessores do falecido;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5319,
                                            "texto": "pelos sucessores do falecido, em relação à parte."
                                        }
                                    ]
                                },
                                {
                                    "numero": "689º",
                                    "rotulo": "Art. 689º.",
                                    "linha": 5321,
                                    "caput": "Proceder-se-á à habilitação nos autos do processo principal, na instância em que estiver, suspendendo-se, a partir de então, o processo."
                                },
                                {
                                    "numero": "690º",
                                    "rotulo": "Art. 690º.",
                                    "linha": 5323,
                                    "caput": "Recebida a petição, o juiz ordenará a citação dos requeridos para se pronunciarem no prazo de 5 (cinco) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5325,
                                            "texto": "A citação será pessoal, se a parte não tiver procurador constituído nos autos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "691º",
                                    "rotulo": "Art. 691º.",
                                    "linha": 5327,
                                    "caput": "O juiz decidirá o pedido de habilitação imediatamente, salvo se este for impugnado e houver necessidade de dilação probatória diversa da documental, caso em que determinará que o pedido seja autuado em apartado e disporá sobre a instrução."
                                },
                                {
                                    "numero": "692º",
                                    "rotulo": "Art. 692º.",
                                    "linha": 5329,
                                    "caput": "Transitada em julgado a sentença de habilitação, o processo principal retomará o seu curso, e cópia da sentença será juntada aos autos respectivos."
                                }
                            ],
                            "titulo": "DA HABILITAÇÃO",
                            "linhaTitulo": 5311
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO X",
                            "linha": 5331,
                            "artigos": [
                                {
                                    "numero": "693º",
                                    "rotulo": "Art. 693º.",
                                    "linha": 5334,
                                    "caput": "As normas deste Capítulo aplicam-se aos processos contenciosos de divórcio, separação, reconhecimento e extinção de união estável, guarda, visitação e filiação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5336,
                                            "texto": "A ação de alimentos e a que versar sobre interesse de criança ou de adolescente observarão o procedimento previsto em legislação específica, aplicando-se, no que couber, as disposições deste Capítulo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "694º",
                                    "rotulo": "Art. 694º.",
                                    "linha": 5338,
                                    "caput": "Nas ações de família, todos os esforços serão empreendidos para a solução consensual da controvérsia, devendo o juiz dispor do auxílio de profissionais de outras áreas de conhecimento para a mediação e conciliação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5340,
                                            "texto": "A requerimento das partes, o juiz pode determinar a suspensão do processo enquanto os litigantes se submetem a mediação extrajudicial ou a atendimento multidisciplinar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "695º",
                                    "rotulo": "Art. 695º.",
                                    "linha": 5342,
                                    "caput": "Recebida a petição inicial e, se for o caso, tomadas as providências referentes à tutela provisória, o juiz ordenará a citação do réu para comparecer à audiência de mediação e conciliação, observado o disposto no art. 694.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5344,
                                            "texto": "O mandado de citação conterá apenas os dados necessários à audiência e deverá estar desacompanhado de cópia da petição inicial, assegurado ao réu o direito de examinar seu conteúdo a qualquer tempo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5346,
                                            "texto": "A citação ocorrerá com antecedência mínima de 15 (quinze) dias da data designada para a audiência."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5348,
                                            "texto": "A citação será feita na pessoa do réu."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5350,
                                            "texto": "Na audiência, as partes deverão estar acompanhadas de seus advogados ou de defensores públicos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "696º",
                                    "rotulo": "Art. 696º.",
                                    "linha": 5352,
                                    "caput": "A audiência de mediação e conciliação poderá dividir-se em tantas sessões quantas sejam necessárias para viabilizar a solução consensual, sem prejuízo de providências jurisdicionais para evitar o perecimento do direito."
                                },
                                {
                                    "numero": "697º",
                                    "rotulo": "Art. 697º.",
                                    "linha": 5354,
                                    "caput": "Não realizado o acordo, passarão a incidir, a partir de então, as normas do procedimento comum, observado o art. 335 .",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 335",
                                            "href": "#art335",
                                            "inicio": 108,
                                            "fim": 116
                                        }
                                    ]
                                },
                                {
                                    "numero": "698º",
                                    "rotulo": "Art. 698º.",
                                    "linha": 5356,
                                    "caput": "Nas ações de família, o Ministério Público somente intervirá quando houver interesse de incapaz e deverá ser ouvido previamente à homologação de acordo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5358,
                                            "texto": "O Ministério Público intervirá, quando não for parte, nas ações de família em que figure como parte vítima de violência doméstica e familiar, nos termos da Lei nº 11.340, de 7 de agosto de 2006 (Lei Maria da Penha).",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "11",
                                                    "href": "../../../LEIS/L1060.htm#art11",
                                                    "inicio": 163,
                                                    "fim": 165
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "699º",
                                    "rotulo": "Art. 699º.",
                                    "linha": 5360,
                                    "caput": "Quando o processo envolver discussão sobre fato relacionado a abuso ou a alienação parental, o juiz, ao tomar o depoimento do incapaz, deverá estar acompanhado por especialista."
                                },
                                {
                                    "numero": "699º-A",
                                    "rotulo": "Art. 699º-A.",
                                    "linha": 5362,
                                    "caput": "Nas ações de guarda, antes de iniciada a audiência de mediação e conciliação de que trata o art. 695 deste Código, o juiz indagará às partes e ao Ministério Público se há risco de violência doméstica ou familiar, fixando o prazo de 5 (cinco) dias para a apresentação de prova ou de indícios pertinentes."
                                }
                            ],
                            "titulo": "DAS AÇÕES DE FAMÍLIA",
                            "linhaTitulo": 5332
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XI",
                            "linha": 5364,
                            "artigos": [
                                {
                                    "numero": "700º",
                                    "rotulo": "Art. 700º.",
                                    "linha": 5367,
                                    "caput": "A ação monitória pode ser proposta por aquele que afirmar, com base em prova escrita sem eficácia de título executivo, ter direito de exigir do devedor capaz:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5375,
                                            "texto": "A prova escrita pode consistir em prova oral documentada, produzida antecipadamente nos termos do art. 381 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 381",
                                                    "href": "#art381",
                                                    "inicio": 98,
                                                    "fim": 106
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5377,
                                            "texto": "Na petição inicial, incumbe ao autor explicitar, conforme o caso:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 5379,
                                                    "texto": "a importância devida, instruindo-a com memória de cálculo;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 5381,
                                                    "texto": "o valor atual da coisa reclamada;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 5383,
                                                    "texto": "o conteúdo patrimonial em discussão ou o proveito econômico perseguido."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5385,
                                            "texto": "O valor da causa deverá corresponder à importância prevista no § 2º, incisos I a III."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5387,
                                            "texto": "Além das hipóteses do art. 330 , a petição inicial será indeferida quando não atendido o disposto no § 2º deste artigo.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 330",
                                                    "href": "#art330",
                                                    "inicio": 22,
                                                    "fim": 30
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5389,
                                            "texto": "Havendo dúvida quanto à idoneidade de prova documental apresentada pelo autor, o juiz intimá-lo-á para, querendo, emendar a petição inicial, adaptando-a ao procedimento comum."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 5391,
                                            "texto": "É admissível ação monitória em face da Fazenda Pública."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 5393,
                                            "texto": "Na ação monitória, admite-se citação por qualquer dos meios permitidos para o procedimento comum."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5369,
                                            "texto": "o pagamento de quantia em dinheiro;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5371,
                                            "texto": "a entrega de coisa fungível ou infungível ou de bem móvel ou imóvel;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5373,
                                            "texto": "o adimplemento de obrigação de fazer ou de não fazer."
                                        }
                                    ]
                                },
                                {
                                    "numero": "701º",
                                    "rotulo": "Art. 701º.",
                                    "linha": 5395,
                                    "caput": "Sendo evidente o direito do autor, o juiz deferirá a expedição de mandado de pagamento, de entrega de coisa ou para execução de obrigação de fazer ou de não fazer, concedendo ao réu prazo de 15 (quinze) dias para o cumprimento e o pagamento de honorários advocatícios de cinco por cento do valor atribuído à causa.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5397,
                                            "texto": "O réu será isento do pagamento de custas processuais se cumprir o mandado no prazo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5399,
                                            "texto": "Constituir-se-á de pleno direito o título executivo judicial, independentemente de qualquer formalidade, se não realizado o pagamento e não apresentados os embargos previstos no art. 702 , observando-se, no que couber, o Título II do Livro I da Parte Especial .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 702",
                                                    "href": "#art702",
                                                    "inicio": 178,
                                                    "fim": 186
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5401,
                                            "texto": "É cabível ação rescisória da decisão prevista no caput quando ocorrer a hipótese do § 2º."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5403,
                                            "texto": "Sendo a ré Fazenda Pública, não apresentados os embargos previstos no art. 702 , aplicar-se-á o disposto no art. 496 , observando-se, a seguir, no que couber, o Título II do Livro I da Parte Especial.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 702",
                                                    "href": "#art702",
                                                    "inicio": 70,
                                                    "fim": 78
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 496",
                                                    "href": "#art496",
                                                    "inicio": 108,
                                                    "fim": 116
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5405,
                                            "texto": "Aplica-se à ação monitória, no que couber, o art. 916 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 916",
                                                    "href": "#art916",
                                                    "inicio": 45,
                                                    "fim": 53
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "702º",
                                    "rotulo": "Art. 702º.",
                                    "linha": 5407,
                                    "caput": "Independentemente de prévia segurança do juízo, o réu poderá opor, nos próprios autos, no prazo previsto no art. 701 , embargos à ação monitória.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5409,
                                            "texto": "Os embargos podem se fundar em matéria passível de alegação como defesa no procedimento comum."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5411,
                                            "texto": "Quando o réu alegar que o autor pleiteia quantia superior à devida, cumprir-lhe-á declarar de imediato o valor que entende correto, apresentando demonstrativo discriminado e atualizado da dívida."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5413,
                                            "texto": "Não apontado o valor correto ou não apresentado o demonstrativo, os embargos serão liminarmente rejeitados, se esse for o seu único fundamento, e, se houver outro fundamento, os embargos serão processados, mas o juiz deixará de examinar a alegação de excesso."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5415,
                                            "texto": "A oposição dos embargos suspende a eficácia da decisão referida no caput do art. 701 até o julgamento em primeiro grau.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 701",
                                                    "href": "#art701",
                                                    "inicio": 76,
                                                    "fim": 84
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5417,
                                            "texto": "O autor será intimado para responder aos embargos no prazo de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 5419,
                                            "texto": "Na ação monitória admite-se a reconvenção, sendo vedado o oferecimento de reconvenção à reconvenção."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 5421,
                                            "texto": "A critério do juiz, os embargos serão autuados em apartado, se parciais, constituindo-se de pleno direito o título executivo judicial em relação à parcela incontroversa."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 5423,
                                            "texto": "Rejeitados os embargos, constituir-se-á de pleno direito o título executivo judicial, prosseguindo-se o processo em observância ao disposto no Título II do Livro I da Parte Especial , no que for cabível."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 5425,
                                            "texto": "Cabe apelação contra a sentença que acolhe ou rejeita os embargos."
                                        },
                                        {
                                            "numero": "10º",
                                            "rotulo": "§ 10º",
                                            "linha": 5427,
                                            "texto": "O juiz condenará o autor de ação monitória proposta indevidamente e de má-fé ao pagamento, em favor do réu, de multa de até dez por cento sobre o valor da causa."
                                        },
                                        {
                                            "numero": "11º",
                                            "rotulo": "§ 11º",
                                            "linha": 5429,
                                            "texto": "O juiz condenará o réu que de má-fé opuser embargos à ação monitória ao pagamento de multa de até dez por cento sobre o valor atribuído à causa, em favor do autor."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 701",
                                            "href": "#art701",
                                            "inicio": 108,
                                            "fim": 116
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA AÇÃO MONITÓRIA",
                            "linhaTitulo": 5365
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XII",
                            "linha": 5431,
                            "artigos": [
                                {
                                    "numero": "703º",
                                    "rotulo": "Art. 703º.",
                                    "linha": 5434,
                                    "caput": "Tomado o penhor legal nos casos previstos em lei, requererá o credor, ato contínuo, a homologação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5436,
                                            "texto": "Na petição inicial, instruída com o contrato de locação ou a conta pormenorizada das despesas, a tabela dos preços e a relação dos objetos retidos, o credor pedirá a citação do devedor para pagar ou contestar na audiência preliminar que for designada."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5438,
                                            "texto": "A homologação do penhor legal poderá ser promovida pela via extrajudicial mediante requerimento, que conterá os requisitos previstos no § 1º deste artigo, do credor a notário de sua livre escolha."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5440,
                                            "texto": "Recebido o requerimento, o notário promoverá a notificação extrajudicial do devedor para, no prazo de 5 (cinco) dias, pagar o débito ou impugnar sua cobrança, alegando por escrito uma das causas previstas no art. 704 , hipótese em que o procedimento será encaminhado ao juízo competente para decisão.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 704",
                                                    "href": "#art704",
                                                    "inicio": 208,
                                                    "fim": 216
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5442,
                                            "texto": "Transcorrido o prazo sem manifestação do devedor, o notário formalizará a homologação do penhor legal por escritura pública."
                                        }
                                    ]
                                },
                                {
                                    "numero": "704º",
                                    "rotulo": "Art. 704º.",
                                    "linha": 5444,
                                    "caput": "A defesa só pode consistir em:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5446,
                                            "texto": "nulidade do processo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5448,
                                            "texto": "extinção da obrigação;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5450,
                                            "texto": "não estar a dívida compreendida entre as previstas em lei ou não estarem os bens sujeitos a penhor legal;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5452,
                                            "texto": "alegação de haver sido ofertada caução idônea, rejeitada pelo credor."
                                        }
                                    ]
                                },
                                {
                                    "numero": "705º",
                                    "rotulo": "Art. 705º.",
                                    "linha": 5454,
                                    "caput": "A partir da audiência preliminar, observar-se-á o procedimento comum."
                                },
                                {
                                    "numero": "706º",
                                    "rotulo": "Art. 706º.",
                                    "linha": 5456,
                                    "caput": "Homologado judicialmente o penhor legal, consolidar-se-á a posse do autor sobre o objeto.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5458,
                                            "texto": "Negada a homologação, o objeto será entregue ao réu, ressalvado ao autor o direito de cobrar a dívida pelo procedimento comum, salvo se acolhida a alegação de extinção da obrigação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5460,
                                            "texto": "Contra a sentença caberá apelação, e, na pendência de recurso, poderá o relator ordenar que a coisa permaneça depositada ou em poder do autor."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA HOMOLOGAÇÃO DO PENHOR LEGAL",
                            "linhaTitulo": 5432
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XIII",
                            "linha": 5462,
                            "artigos": [
                                {
                                    "numero": "707º",
                                    "rotulo": "Art. 707º.",
                                    "linha": 5465,
                                    "caput": "Quando inexistir consenso acerca da nomeação de um regulador de avarias, o juiz de direito da comarca do primeiro porto onde o navio houver chegado, provocado por qualquer parte interessada, nomeará um de notório conhecimento."
                                },
                                {
                                    "numero": "708º",
                                    "rotulo": "Art. 708º.",
                                    "linha": 5467,
                                    "caput": "O regulador declarará justificadamente se os danos são passíveis de rateio na forma de avaria grossa e exigirá das partes envolvidas a apresentação de garantias idôneas para que possam ser liberadas as cargas aos consignatários.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5469,
                                            "texto": "A parte que não concordar com o regulador quanto à declaração de abertura da avaria grossa deverá justificar suas razões ao juiz, que decidirá no prazo de 10 (dez) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5471,
                                            "texto": "Se o consignatário não apresentar garantia idônea a critério do regulador, este fixará o valor da contribuição provisória com base nos fatos narrados e nos documentos que instruírem a petição inicial, que deverá ser caucionado sob a forma de depósito judicial ou de garantia bancária."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5473,
                                            "texto": "Recusando-se o consignatário a prestar caução, o regulador requererá ao juiz a alienação judicial de sua carga na forma dos arts. 879 a 903 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 879",
                                                    "href": "#art879",
                                                    "inicio": 124,
                                                    "fim": 133
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "903",
                                                    "href": "#art903",
                                                    "inicio": 136,
                                                    "fim": 139
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5475,
                                            "texto": "É permitido o levantamento, por alvará, das quantias necessárias ao pagamento das despesas da alienação a serem arcadas pelo consignatário, mantendo-se o saldo remanescente em depósito judicial até o encerramento da regulação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "709º",
                                    "rotulo": "Art. 709º.",
                                    "linha": 5477,
                                    "caput": "As partes deverão apresentar nos autos os documentos necessários à regulação da avaria grossa em prazo razoável a ser fixado pelo regulador."
                                },
                                {
                                    "numero": "710º",
                                    "rotulo": "Art. 710º.",
                                    "linha": 5479,
                                    "caput": "O regulador apresentará o regulamento da avaria grossa no prazo de até 12 (doze) meses, contado da data da entrega dos documentos nos autos pelas partes, podendo o prazo ser estendido a critério do juiz.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5481,
                                            "texto": "Oferecido o regulamento da avaria grossa, dele terão vista as partes pelo prazo comum de 15 (quinze) dias, e, não havendo impugnação, o regulamento será homologado por sentença."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5483,
                                            "texto": "Havendo impugnação ao regulamento, o juiz decidirá no prazo de 10 (dez) dias, após a oitiva do regulador."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "12",
                                            "href": "../../../LEIS/L1060.htm#art12",
                                            "inicio": 71,
                                            "fim": 73
                                        }
                                    ]
                                },
                                {
                                    "numero": "711º",
                                    "rotulo": "Art. 711º.",
                                    "linha": 5485,
                                    "caput": "Aplicam-se ao regulador de avarias os arts. 156 a 158 , no que couber.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 156 a 158",
                                            "href": "#art156",
                                            "inicio": 38,
                                            "fim": 53
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA REGULAÇÃO DE AVARIA GROSSA",
                            "linhaTitulo": 5463
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XIV",
                            "linha": 5487,
                            "artigos": [
                                {
                                    "numero": "712º",
                                    "rotulo": "Art. 712º.",
                                    "linha": 5490,
                                    "caput": "Verificado o desaparecimento dos autos, eletrônicos ou não, pode o juiz, de ofício, qualquer das partes ou o Ministério Público, se for o caso, promover-lhes a restauração.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5492,
                                            "texto": "Havendo autos suplementares, nesses prosseguirá o processo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "713º",
                                    "rotulo": "Art. 713º.",
                                    "linha": 5494,
                                    "caput": "Na petição inicial, declarará a parte o estado do processo ao tempo do desaparecimento dos autos, oferecendo:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5496,
                                            "texto": "certidões dos atos constantes do protocolo de audiências do cartório por onde haja corrido o processo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5498,
                                            "texto": "cópia das peças que tenha em seu poder;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5500,
                                            "texto": "qualquer outro documento que facilite a restauração."
                                        }
                                    ]
                                },
                                {
                                    "numero": "714º",
                                    "rotulo": "Art. 714º.",
                                    "linha": 5502,
                                    "caput": "A parte contrária será citada para contestar o pedido no prazo de 5 (cinco) dias, cabendo-lhe exibir as cópias, as contrafés e as reproduções dos atos e dos documentos que estiverem em seu poder.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5504,
                                            "texto": "Se a parte concordar com a restauração, lavrar-se-á o auto que, assinado pelas partes e homologado pelo juiz, suprirá o processo desaparecido."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5506,
                                            "texto": "Se a parte não contestar ou se a concordância for parcial, observar-se-á o procedimento comum."
                                        }
                                    ]
                                },
                                {
                                    "numero": "715º",
                                    "rotulo": "Art. 715º.",
                                    "linha": 5508,
                                    "caput": "Se a perda dos autos tiver ocorrido depois da produção das provas em audiência, o juiz, se necessário, mandará repeti-las.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5510,
                                            "texto": "Serão reinquiridas as mesmas testemunhas, que, em caso de impossibilidade, poderão ser substituídas de ofício ou a requerimento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5512,
                                            "texto": "Não havendo certidão ou cópia do laudo, far-se-á nova perícia, sempre que possível pelo mesmo perito."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5514,
                                            "texto": "Não havendo certidão de documentos, esses serão reconstituídos mediante cópias ou, na falta dessas, pelos meios ordinários de prova."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5516,
                                            "texto": "Os serventuários e os auxiliares da justiça não podem eximir-se de depor como testemunhas a respeito de atos que tenham praticado ou assistido."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5518,
                                            "texto": "Se o juiz houver proferido sentença da qual ele próprio ou o escrivão possua cópia, esta será juntada aos autos e terá a mesma autoridade da original."
                                        }
                                    ]
                                },
                                {
                                    "numero": "716º",
                                    "rotulo": "Art. 716º.",
                                    "linha": 5520,
                                    "caput": "Julgada a restauração, seguirá o processo os seus termos.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5522,
                                            "texto": "Aparecendo os autos originais, neles se prosseguirá, sendo-lhes apensados os autos da restauração."
                                        }
                                    ]
                                },
                                {
                                    "numero": "717º",
                                    "rotulo": "Art. 717º.",
                                    "linha": 5524,
                                    "caput": "Se o desaparecimento dos autos tiver ocorrido no tribunal, o processo de restauração será distribuído, sempre que possível, ao relator do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5526,
                                            "texto": "A restauração far-se-á no juízo de origem quanto aos atos nele realizados."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5528,
                                            "texto": "Remetidos os autos ao tribunal, nele completar-se-á a restauração e proceder-se-á ao julgamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "718º",
                                    "rotulo": "Art. 718º.",
                                    "linha": 5530,
                                    "caput": "Quem houver dado causa ao desaparecimento dos autos responderá pelas custas da restauração e pelos honorários de advogado, sem prejuízo da responsabilidade civil ou penal em que incorrer."
                                }
                            ],
                            "titulo": "DA RESTAURAÇÃO DE AUTOS",
                            "linhaTitulo": 5488
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO XV",
                            "linha": 5532,
                            "artigos": [
                                {
                                    "numero": "719º",
                                    "rotulo": "Art. 719º.",
                                    "linha": 5538,
                                    "caput": "Quando este Código não estabelecer procedimento especial, regem os procedimentos de jurisdição voluntária as disposições constantes desta Seção.",
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 5536
                                },
                                {
                                    "numero": "720º",
                                    "rotulo": "Art. 720º.",
                                    "linha": 5540,
                                    "caput": "O procedimento terá início por provocação do interessado, do Ministério Público ou da Defensoria Pública, cabendo-lhes formular o pedido devidamente instruído com os documentos necessários e com a indicação da providência judicial."
                                },
                                {
                                    "numero": "721º",
                                    "rotulo": "Art. 721º.",
                                    "linha": 5542,
                                    "caput": "Serão citados todos os interessados, bem como intimado o Ministério Público, nos casos do art. 178 , para que se manifestem, querendo, no prazo de 15 (quinze) dias.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 178",
                                            "href": "#art178",
                                            "inicio": 90,
                                            "fim": 98
                                        }
                                    ]
                                },
                                {
                                    "numero": "722º",
                                    "rotulo": "Art. 722º.",
                                    "linha": 5544,
                                    "caput": "A Fazenda Pública será sempre ouvida nos casos em que tiver interesse."
                                },
                                {
                                    "numero": "723º",
                                    "rotulo": "Art. 723º.",
                                    "linha": 5546,
                                    "caput": "O juiz decidirá o pedido no prazo de 10 (dez) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5548,
                                            "texto": "O juiz não é obrigado a observar critério de legalidade estrita, podendo adotar em cada caso a solução que considerar mais conveniente ou oportuna."
                                        }
                                    ]
                                },
                                {
                                    "numero": "724º",
                                    "rotulo": "Art. 724º.",
                                    "linha": 5550,
                                    "caput": "Da sentença caberá apelação."
                                },
                                {
                                    "numero": "725º",
                                    "rotulo": "Art. 725º.",
                                    "linha": 5552,
                                    "caput": "Processar-se-á na forma estabelecida nesta Seção o pedido de:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5570,
                                            "texto": "As normas desta Seção aplicam-se, no que couber, aos procedimentos regulados nas seções seguintes. Seção II"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5554,
                                            "texto": "emancipação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5556,
                                            "texto": "sub-rogação;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5558,
                                            "texto": "alienação, arrendamento ou oneração de bens de crianças ou adolescentes, de órfãos e de interditos;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5560,
                                            "texto": "alienação, locação e administração da coisa comum;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 5562,
                                            "texto": "alienação de quinhão em coisa comum;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 5564,
                                            "texto": "extinção de usufruto, quando não decorrer da morte do usufrutuário, do termo da sua duração ou da consolidação, e de fideicomisso, quando decorrer de renúncia ou quando ocorrer antes do evento que caracterizar a condição resolutória;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 5566,
                                            "texto": "expedição de alvará judicial;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 5568,
                                            "texto": "homologação de autocomposição extrajudicial, de qualquer natureza ou valor."
                                        }
                                    ]
                                },
                                {
                                    "numero": "726º",
                                    "rotulo": "Art. 726º.",
                                    "linha": 5575,
                                    "caput": "Quem tiver interesse em manifestar formalmente sua vontade a outrem sobre assunto juridicamente relevante poderá notificar pessoas participantes da mesma relação jurídica para dar-lhes ciência de seu propósito.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5577,
                                            "texto": "Se a pretensão for a de dar conhecimento geral ao público, mediante edital, o juiz só a deferirá se a tiver por fundada e necessária ao resguardo de direito."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5579,
                                            "texto": "Aplica-se o disposto nesta Seção, no que couber, ao protesto judicial."
                                        }
                                    ],
                                    "rubrica": "Da Notificação e da Interpelação",
                                    "linhaRubrica": 5573
                                },
                                {
                                    "numero": "727º",
                                    "rotulo": "Art. 727º.",
                                    "linha": 5581,
                                    "caput": "Também poderá o interessado interpelar o requerido, no caso do art. 726 , para que faça ou deixe de fazer o que o requerente entenda ser de seu direito.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 726",
                                            "href": "#art726",
                                            "inicio": 63,
                                            "fim": 71
                                        }
                                    ]
                                },
                                {
                                    "numero": "728º",
                                    "rotulo": "Art. 728º.",
                                    "linha": 5583,
                                    "caput": "O requerido será previamente ouvido antes do deferimento da notificação ou do respectivo edital:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5585,
                                            "texto": "se houver suspeita de que o requerente, por meio da notificação ou do edital, pretende alcançar fim ilícito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5587,
                                            "texto": "se tiver sido requerida a averbação da notificação em registro público."
                                        }
                                    ]
                                },
                                {
                                    "numero": "729º",
                                    "rotulo": "Art. 729º.",
                                    "linha": 5589,
                                    "caput": "Deferida e realizada a notificação ou interpelação, os autos serão entregues ao requerente. Seção III"
                                },
                                {
                                    "numero": "730º",
                                    "rotulo": "Art. 730º.",
                                    "linha": 5594,
                                    "caput": "Nos casos expressos em lei, não havendo acordo entre os interessados sobre o modo como se deve realizar a alienação do bem, o juiz, de ofício ou a requerimento dos interessados ou do depositário, mandará aliená-lo em leilão, observando-se o disposto na Seção I deste Capítulo e, no que couber, o disposto nos arts. 879 a 903 . Seção IV",
                                    "rubrica": "Da Alienação Judicial",
                                    "linhaRubrica": 5592,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "arts. 879",
                                            "href": "#art879",
                                            "inicio": 309,
                                            "fim": 318
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "903",
                                            "href": "#art903",
                                            "inicio": 321,
                                            "fim": 324
                                        }
                                    ]
                                },
                                {
                                    "numero": "731º",
                                    "rotulo": "Art. 731º.",
                                    "linha": 5599,
                                    "caput": "A homologação do divórcio ou da separação consensuais, observados os requisitos legais, poderá ser requerida em petição assinada por ambos os cônjuges, da qual constarão:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5609,
                                            "texto": "Se os cônjuges não acordarem sobre a partilha dos bens, far-se-á esta depois de homologado o divórcio, na forma estabelecida nos arts. 647 a 658 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 647",
                                                    "href": "#art647",
                                                    "inicio": 129,
                                                    "fim": 138
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "658",
                                                    "href": "#art658",
                                                    "inicio": 141,
                                                    "fim": 144
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5601,
                                            "texto": "as disposições relativas à descrição e à partilha dos bens comuns;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5603,
                                            "texto": "as disposições relativas à pensão alimentícia entre os cônjuges;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5605,
                                            "texto": "o acordo relativo à guarda dos filhos incapazes e ao regime de visitas; e"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5607,
                                            "texto": "o valor da contribuição para criar e educar os filhos."
                                        }
                                    ],
                                    "rubrica": "Do Divórcio e da Separação Consensuais, da Extinção Consensual de União Estável e da Alteração do Regime de Bens do Matrimônio",
                                    "linhaRubrica": 5597
                                },
                                {
                                    "numero": "732º",
                                    "rotulo": "Art. 732º.",
                                    "linha": 5611,
                                    "caput": "As disposições relativas ao processo de homologação judicial de divórcio ou de separação consensuais aplicam-se, no que couber, ao processo de homologação da extinção consensual de união estável."
                                },
                                {
                                    "numero": "733º",
                                    "rotulo": "Art. 733º.",
                                    "linha": 5613,
                                    "caput": "O divórcio consensual, a separação consensual e a extinção consensual de união estável, não havendo nascituro ou filhos incapazes e observados os requisitos legais, poderão ser realizados por escritura pública, da qual constarão as disposições de que trata o art. 731 .",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5615,
                                            "texto": "A escritura não depende de homologação judicial e constitui título hábil para qualquer ato de registro, bem como para levantamento de importância depositada em instituições financeiras."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5617,
                                            "texto": "O tabelião somente lavrará a escritura se os interessados estiverem assistidos por advogado ou por defensor público, cuja qualificação e assinatura constarão do ato notarial."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 73",
                                            "href": "#art73",
                                            "inicio": 259,
                                            "fim": 266
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "art. 731",
                                            "href": "#art731",
                                            "inicio": 259,
                                            "fim": 267
                                        }
                                    ]
                                },
                                {
                                    "numero": "734º",
                                    "rotulo": "Art. 734º.",
                                    "linha": 5619,
                                    "caput": "A alteração do regime de bens do casamento, observados os requisitos legais, poderá ser requerida, motivadamente, em petição assinada por ambos os cônjuges, na qual serão expostas as razões que justificam a alteração, ressalvados os direitos de terceiros.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5621,
                                            "texto": "Ao receber a petição inicial, o juiz determinará a intimação do Ministério Público e a publicação de edital que divulgue a pretendida alteração de bens, somente podendo decidir depois de decorrido o prazo de 30 (trinta) dias da publicação do edital."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5623,
                                            "texto": "Os cônjuges, na petição inicial ou em petição avulsa, podem propor ao juiz meio alternativo de divulgação da alteração do regime de bens, a fim de resguardar direitos de terceiros."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5625,
                                            "texto": "Após o trânsito em julgado da sentença, serão expedidos mandados de averbação aos cartórios de registro civil e de imóveis e, caso qualquer dos cônjuges seja empresário, ao Registro Público de Empresas Mercantis e Atividades Afins. Seção V"
                                        }
                                    ]
                                },
                                {
                                    "numero": "735º",
                                    "rotulo": "Art. 735º.",
                                    "linha": 5630,
                                    "caput": "Recebendo testamento cerrado, o juiz, se não achar vício externo que o torne suspeito de nulidade ou falsidade, o abrirá e mandará que o escrivão o leia em presença do apresentante.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5632,
                                            "texto": "Do termo de abertura constarão o nome do apresentante e como ele obteve o testamento, a data e o lugar do falecimento do testador, com as respectivas provas, e qualquer circunstância digna de nota."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5634,
                                            "texto": "Depois de ouvido o Ministério Público, não havendo dúvidas a serem esclarecidas, o juiz mandará registrar, arquivar e cumprir o testamento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5636,
                                            "texto": "Feito o registro, será intimado o testamenteiro para assinar o termo da testamentária."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5638,
                                            "texto": "Se não houver testamenteiro nomeado ou se ele estiver ausente ou não aceitar o encargo, o juiz nomeará testamenteiro dativo, observando-se a preferência legal."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5640,
                                            "texto": "O testamenteiro deverá cumprir as disposições testamentárias e prestar contas em juízo do que recebeu e despendeu, observando-se o disposto em lei."
                                        }
                                    ],
                                    "rubrica": "Dos Testamentos e dos Codicilos",
                                    "linhaRubrica": 5628
                                },
                                {
                                    "numero": "736º",
                                    "rotulo": "Art. 736º.",
                                    "linha": 5642,
                                    "caput": "Qualquer interessado, exibindo o traslado ou a certidão de testamento público, poderá requerer ao juiz que ordene o seu cumprimento, observando-se, no que couber, o disposto nos parágrafos do art. 735 .",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 73",
                                            "href": "#art73",
                                            "inicio": 192,
                                            "fim": 199
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "art. 735",
                                            "href": "#art735",
                                            "inicio": 192,
                                            "fim": 200
                                        }
                                    ]
                                },
                                {
                                    "numero": "737º",
                                    "rotulo": "Art. 737º.",
                                    "linha": 5644,
                                    "caput": "A publicação do testamento particular poderá ser requerida, depois da morte do testador, pelo herdeiro, pelo legatário ou pelo testamenteiro, bem como pelo terceiro detentor do testamento, se impossibilitado de entregá-lo a algum dos outros legitimados para requerê-la.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5646,
                                            "texto": "Serão intimados os herdeiros que não tiverem requerido a publicação do testamento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5648,
                                            "texto": "Verificando a presença dos requisitos da lei, ouvido o Ministério Público, o juiz confirmará o testamento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5650,
                                            "texto": "Aplica-se o disposto neste artigo ao codicilo e aos testamentos marítimo, aeronáutico, militar e nuncupativo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5652,
                                            "texto": "Observar-se-á, no cumprimento do testamento, o disposto nos parágrafos do art. 735 . Seção VI",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 73",
                                                    "href": "#art73",
                                                    "inicio": 74,
                                                    "fim": 81
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 735",
                                                    "href": "#art735",
                                                    "inicio": 74,
                                                    "fim": 82
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "738º",
                                    "rotulo": "Art. 738º.",
                                    "linha": 5657,
                                    "caput": "Nos casos em que a lei considere jacente a herança, o juiz em cuja comarca tiver domicílio o falecido procederá imediatamente à arrecadação dos respectivos bens.",
                                    "rubrica": "Da Herança Jacente",
                                    "linhaRubrica": 5655
                                },
                                {
                                    "numero": "739º",
                                    "rotulo": "Art. 739º.",
                                    "linha": 5659,
                                    "caput": "A herança jacente ficará sob a guarda, a conservação e a administração de um curador até a respectiva entrega ao sucessor legalmente habilitado ou até a declaração de vacância.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5661,
                                            "texto": "Incumbe ao curador:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 5663,
                                                    "texto": "representar a herança em juízo ou fora dele, com intervenção do Ministério Público;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 5665,
                                                    "texto": "ter em boa guarda e conservação os bens arrecadados e promover a arrecadação de outros porventura existentes;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 5667,
                                                    "texto": "executar as medidas conservatórias dos direitos da herança;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 5669,
                                                    "texto": "apresentar mensalmente ao juiz balancete da receita e da despesa;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 5671,
                                                    "texto": "prestar contas ao final de sua gestão."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5673,
                                            "texto": "Aplica-se ao curador o disposto nos arts. 159 a 161 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 159 a 161",
                                                    "href": "#art159",
                                                    "inicio": 36,
                                                    "fim": 51
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "740º",
                                    "rotulo": "Art. 740º.",
                                    "linha": 5675,
                                    "caput": "O juiz ordenará que o oficial de justiça, acompanhado do escrivão ou do chefe de secretaria e do curador, arrole os bens e descreva-os em auto circunstanciado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5677,
                                            "texto": "Não podendo comparecer ao local, o juiz requisitará à autoridade policial que proceda à arrecadação e ao arrolamento dos bens, com 2 (duas) testemunhas, que assistirão às diligências."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5679,
                                            "texto": "Não estando ainda nomeado o curador, o juiz designará depositário e lhe entregará os bens, mediante simples termo nos autos, depois de compromissado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5681,
                                            "texto": "Durante a arrecadação, o juiz ou a autoridade policial inquirirá os moradores da casa e da vizinhança sobre a qualificação do falecido, o paradeiro de seus sucessores e a existência de outros bens, lavrando-se de tudo auto de inquirição e informação."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5683,
                                            "texto": "O juiz examinará reservadamente os papéis, as cartas missivas e os livros domésticos e, verificando que não apresentam interesse, mandará empacotá-los e lacrá-los para serem assim entregues aos sucessores do falecido ou queimados quando os bens forem declarados vacantes."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 5685,
                                            "texto": "Se constar ao juiz a existência de bens em outra comarca, mandará expedir carta precatória a fim de serem arrecadados."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 5687,
                                            "texto": "Não se fará a arrecadação, ou essa será suspensa, quando, iniciada, apresentarem-se para reclamar os bens o cônjuge ou companheiro, o herdeiro ou o testamenteiro notoriamente reconhecido e não houver oposição motivada do curador, de qualquer interessado, do Ministério Público ou do representante da Fazenda Pública."
                                        }
                                    ]
                                },
                                {
                                    "numero": "741º",
                                    "rotulo": "Art. 741º.",
                                    "linha": 5689,
                                    "caput": "Ultimada a arrecadação, o juiz mandará expedir edital, que será publicado na rede mundial de computadores, no sítio do tribunal a que estiver vinculado o juízo e na plataforma de editais do Conselho Nacional de Justiça, onde permanecerá por 3 (três) meses, ou, não havendo sítio, no órgão oficial e na imprensa da comarca, por 3 (três) vezes com intervalos de 1 (um) mês, para que os sucessores do falecido venham a habilitar-se no prazo de 6 (seis) meses contado da primeira publicação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5691,
                                            "texto": "Verificada a existência de sucessor ou de testamenteiro em lugar certo, far-se-á a sua citação, sem prejuízo do edital."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5693,
                                            "texto": "Quando o falecido for estrangeiro, será também comunicado o fato à autoridade consular."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5695,
                                            "texto": "Julgada a habilitação do herdeiro, reconhecida a qualidade do testamenteiro ou provada a identidade do cônjuge ou companheiro, a arrecadação converter-se-á em inventário."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5697,
                                            "texto": "Os credores da herança poderão habilitar-se como nos inventários ou propor a ação de cobrança."
                                        }
                                    ]
                                },
                                {
                                    "numero": "742º",
                                    "rotulo": "Art. 742º.",
                                    "linha": 5699,
                                    "caput": "O juiz poderá autorizar a alienação:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5715,
                                            "texto": "Não se procederá, entretanto, à venda se a Fazenda Pública ou o habilitando adiantar a importância para as despesas."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5717,
                                            "texto": "Os bens com valor de afeição, como retratos, objetos de uso pessoal, livros e obras de arte, só serão alienados depois de declarada a vacância da herança."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5701,
                                            "texto": "de bens móveis, se forem de conservação difícil ou dispendiosa;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5703,
                                            "texto": "de semoventes, quando não empregados na exploração de alguma indústria;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5705,
                                            "texto": "de títulos e papéis de crédito, havendo fundado receio de depreciação;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5707,
                                            "texto": "de ações de sociedade quando, reclamada a integralização, não dispuser a herança de dinheiro para o pagamento;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 5709,
                                            "texto": "de bens imóveis:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 5711,
                                                    "texto": "se ameaçarem ruína, não convindo a reparação;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 5713,
                                                    "texto": "se estiverem hipotecados e vencer-se a dívida, não havendo dinheiro para o pagamento."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "743º",
                                    "rotulo": "Art. 743º.",
                                    "linha": 5719,
                                    "caput": "Passado 1 (um) ano da primeira publicação do edital e não havendo herdeiro habilitado nem habilitação pendente, será a herança declarada vacante.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5721,
                                            "texto": "Pendendo habilitação, a vacância será declarada pela mesma sentença que a julgar improcedente, aguardando-se, no caso de serem diversas as habilitações, o julgamento da última."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5723,
                                            "texto": "Transitada em julgado a sentença que declarou a vacância, o cônjuge, o companheiro, os herdeiros e os credores só poderão reclamar o seu direito por ação direta. Seção VII"
                                        }
                                    ]
                                },
                                {
                                    "numero": "744º",
                                    "rotulo": "Art. 744º.",
                                    "linha": 5728,
                                    "caput": "Declarada a ausência nos casos previstos em lei, o juiz mandará arrecadar os bens do ausente e nomear-lhes-á curador na forma estabelecida na Seção VI, observando-se o disposto em lei.",
                                    "rubrica": "Dos Bens dos Ausentes",
                                    "linhaRubrica": 5726
                                },
                                {
                                    "numero": "745º",
                                    "rotulo": "Art. 745º.",
                                    "linha": 5730,
                                    "caput": "Feita a arrecadação, o juiz mandará publicar editais na rede mundial de computadores, no sítio do tribunal a que estiver vinculado e na plataforma de editais do Conselho Nacional de Justiça, onde permanecerá por 1 (um) ano, ou, não havendo sítio, no órgão oficial e na imprensa da comarca, durante 1 (um) ano, reproduzida de 2 (dois) em 2 (dois) meses, anunciando a arrecadação e chamando o ausente a entrar na posse de seus bens.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5732,
                                            "texto": "Findo o prazo previsto no edital, poderão os interessados requerer a abertura da sucessão provisória, observando-se o disposto em lei."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5734,
                                            "texto": "O interessado, ao requerer a abertura da sucessão provisória, pedirá a citação pessoal dos herdeiros presentes e do curador e, por editais, a dos ausentes para requererem habilitação, na forma dos arts. 689 a 692 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 689",
                                                    "href": "#art689",
                                                    "inicio": 197,
                                                    "fim": 206
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "692",
                                                    "href": "#art692",
                                                    "inicio": 209,
                                                    "fim": 212
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5736,
                                            "texto": "Presentes os requisitos legais, poderá ser requerida a conversão da sucessão provisória em definitiva."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5738,
                                            "texto": "Regressando o ausente ou algum de seus descendentes ou ascendentes para requerer ao juiz a entrega de bens, serão citados para contestar o pedido os sucessores provisórios ou definitivos, o Ministério Público e o representante da Fazenda Pública, seguindo-se o procedimento comum. Seção VIII"
                                        }
                                    ]
                                },
                                {
                                    "numero": "746º",
                                    "rotulo": "Art. 746º.",
                                    "linha": 5743,
                                    "caput": "Recebendo do descobridor coisa alheia perdida, o juiz mandará lavrar o respectivo auto, do qual constará a descrição do bem e as declarações do descobridor.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5745,
                                            "texto": "Recebida a coisa por autoridade policial, esta a remeterá em seguida ao juízo competente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5747,
                                            "texto": "Depositada a coisa, o juiz mandará publicar edital na rede mundial de computadores, no sítio do tribunal a que estiver vinculado e na plataforma de editais do Conselho Nacional de Justiça ou, não havendo sítio, no órgão oficial e na imprensa da comarca, para que o dono ou o legítimo possuidor a reclame, salvo se se tratar de coisa de pequeno valor e não for possível a publicação no sítio do tribunal, caso em que o edital será apenas afixado no átrio do edifício do fórum."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5749,
                                            "texto": "Observar-se-á, quanto ao mais, o disposto em lei. Seção IX"
                                        }
                                    ],
                                    "rubrica": "Das Coisas Vagas",
                                    "linhaRubrica": 5741
                                },
                                {
                                    "numero": "747º",
                                    "rotulo": "Art. 747º.",
                                    "linha": 5754,
                                    "caput": "A interdição pode ser promovida:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5764,
                                            "texto": "A legitimidade deverá ser comprovada por documentação que acompanhe a petição inicial."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5756,
                                            "texto": "pelo cônjuge ou companheiro;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5758,
                                            "texto": "pelos parentes ou tutores;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5760,
                                            "texto": "pelo representante da entidade em que se encontra abrigado o interditando;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5762,
                                            "texto": "pelo Ministério Público."
                                        }
                                    ],
                                    "rubrica": "Da Interdição",
                                    "linhaRubrica": 5752
                                },
                                {
                                    "numero": "748º",
                                    "rotulo": "Art. 748º.",
                                    "linha": 5766,
                                    "caput": "O Ministério Público só promoverá interdição em caso de doença mental grave:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5768,
                                            "texto": "se as pessoas designadas nos incisos I, II e III do art. 747 não existirem ou não promoverem a interdição;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "incisos I, II e III do art. 747",
                                                    "href": "#art747i",
                                                    "inicio": 29,
                                                    "fim": 60
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5770,
                                            "texto": "se, existindo, forem incapazes as pessoas mencionadas nos incisos I e II do art. 747 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "incisos I e II do art. 747",
                                                    "href": "#art747i",
                                                    "inicio": 58,
                                                    "fim": 84
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "749º",
                                    "rotulo": "Art. 749º.",
                                    "linha": 5772,
                                    "caput": "Incumbe ao autor, na petição inicial, especificar os fatos que demonstram a incapacidade do interditando para administrar seus bens e, se for o caso, para praticar atos da vida civil, bem como o momento em que a incapacidade se revelou.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5774,
                                            "texto": "Justificada a urgência, o juiz pode nomear curador provisório ao interditando para a prática de determinados atos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "750º",
                                    "rotulo": "Art. 750º.",
                                    "linha": 5776,
                                    "caput": "O requerente deverá juntar laudo médico para fazer prova de suas alegações ou informar a impossibilidade de fazê-lo."
                                },
                                {
                                    "numero": "751º",
                                    "rotulo": "Art. 751º.",
                                    "linha": 5778,
                                    "caput": "O interditando será citado para, em dia designado, comparecer perante o juiz, que o entrevistará minuciosamente acerca de sua vida, negócios, bens, vontades, preferências e laços familiares e afetivos e sobre o que mais lhe parecer necessário para convencimento quanto à sua capacidade para praticar atos da vida civil, devendo ser reduzidas a termo as perguntas e respostas.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5780,
                                            "texto": "Não podendo o interditando deslocar-se, o juiz o ouvirá no local onde estiver."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5782,
                                            "texto": "A entrevista poderá ser acompanhada por especialista."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5784,
                                            "texto": "Durante a entrevista, é assegurado o emprego de recursos tecnológicos capazes de permitir ou de auxiliar o interditando a expressar suas vontades e preferências e a responder às perguntas formuladas."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5786,
                                            "texto": "A critério do juiz, poderá ser requisitada a oitiva de parentes e de pessoas próximas."
                                        }
                                    ]
                                },
                                {
                                    "numero": "752º",
                                    "rotulo": "Art. 752º.",
                                    "linha": 5788,
                                    "caput": "Dentro do prazo de 15 (quinze) dias contado da entrevista, o interditando poderá impugnar o pedido.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5790,
                                            "texto": "O Ministério Público intervirá como fiscal da ordem jurídica."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5792,
                                            "texto": "O interditando poderá constituir advogado, e, caso não o faça, deverá ser nomeado curador especial."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5794,
                                            "texto": "Caso o interditando não constitua advogado, o seu cônjuge, companheiro ou qualquer parente sucessível poderá intervir como assistente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "753º",
                                    "rotulo": "Art. 753º.",
                                    "linha": 5796,
                                    "caput": "Decorrido o prazo previsto no art. 752 , o juiz determinará a produção de prova pericial para avaliação da capacidade do interditando para praticar atos da vida civil.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5798,
                                            "texto": "A perícia pode ser realizada por equipe composta por expertos com formação multidisciplinar."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5800,
                                            "texto": "O laudo pericial indicará especificadamente, se for o caso, os atos para os quais haverá necessidade de curatela."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 752",
                                            "href": "#art752",
                                            "inicio": 30,
                                            "fim": 38
                                        }
                                    ]
                                },
                                {
                                    "numero": "754º",
                                    "rotulo": "Art. 754º.",
                                    "linha": 5802,
                                    "caput": "Apresentado o laudo, produzidas as demais provas e ouvidos os interessados, o juiz proferirá sentença."
                                },
                                {
                                    "numero": "755º",
                                    "rotulo": "Art. 755º.",
                                    "linha": 5804,
                                    "caput": "Na sentença que decretar a interdição, o juiz:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5810,
                                            "texto": "A curatela deve ser atribuída a quem melhor possa atender aos interesses do curatelado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5812,
                                            "texto": "Havendo, ao tempo da interdição, pessoa incapaz sob a guarda e a responsabilidade do interdito, o juiz atribuirá a curatela a quem melhor puder atender aos interesses do interdito e do incapaz."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5814,
                                            "texto": "A sentença de interdição será inscrita no registro de pessoas naturais e imediatamente publicada na rede mundial de computadores, no sítio do tribunal a que estiver vinculado o juízo e na plataforma de editais do Conselho Nacional de Justiça, onde permanecerá por 6 (seis) meses, na imprensa local, 1 (uma) vez, e no órgão oficial, por 3 (três) vezes, com intervalo de 10 (dez) dias, constando do edital os nomes do interdito e do curador, a causa da interdição, os limites da curatela e, não sendo total a interdição, os atos que o interdito poderá praticar autonomamente."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5806,
                                            "texto": "nomeará curador, que poderá ser o requerente da interdição, e fixará os limites da curatela, segundo o estado e o desenvolvimento mental do interdito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5808,
                                            "texto": "considerará as características pessoais do interdito, observando suas potencialidades, habilidades, vontades e preferências."
                                        }
                                    ]
                                },
                                {
                                    "numero": "756º",
                                    "rotulo": "Art. 756º.",
                                    "linha": 5816,
                                    "caput": "Levantar-se-á a curatela quando cessar a causa que a determinou.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5818,
                                            "texto": "O pedido de levantamento da curatela poderá ser feito pelo interdito, pelo curador ou pelo Ministério Público e será apensado aos autos da interdição."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5820,
                                            "texto": "O juiz nomeará perito ou equipe multidisciplinar para proceder ao exame do interdito e designará audiência de instrução e julgamento após a apresentação do laudo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 5822,
                                            "texto": "Acolhido o pedido, o juiz decretará o levantamento da interdição e determinará a publicação da sentença, após o trânsito em julgado, na forma do art. 755, § 3º , ou, não sendo possível, na imprensa local e no órgão oficial, por 3 (três) vezes, com intervalo de 10 (dez) dias, seguindo-se a averbação no registro de pessoas naturais."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 5824,
                                            "texto": "A interdição poderá ser levantada parcialmente quando demonstrada a capacidade do interdito para praticar alguns atos da vida civil."
                                        }
                                    ]
                                },
                                {
                                    "numero": "757º",
                                    "rotulo": "Art. 757º.",
                                    "linha": 5826,
                                    "caput": "A autoridade do curador estende-se à pessoa e aos bens do incapaz que se encontrar sob a guarda e a responsabilidade do curatelado ao tempo da interdição, salvo se o juiz considerar outra solução como mais conveniente aos interesses do incapaz."
                                },
                                {
                                    "numero": "758º",
                                    "rotulo": "Art. 758º.",
                                    "linha": 5828,
                                    "caput": "O curador deverá buscar tratamento e apoio apropriados à conquista da autonomia pelo interdito. Seção X"
                                },
                                {
                                    "numero": "759º",
                                    "rotulo": "Art. 759º.",
                                    "linha": 5833,
                                    "caput": "O tutor ou o curador será intimado a prestar compromisso no prazo de 5 (cinco) dias contado da:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5839,
                                            "texto": "O tutor ou o curador prestará o compromisso por termo em livro rubricado pelo juiz."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5841,
                                            "texto": "Prestado o compromisso, o tutor ou o curador assume a administração dos bens do tutelado ou do interditado."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5835,
                                            "texto": "nomeação feita em conformidade com a lei;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5837,
                                            "texto": "intimação do despacho que mandar cumprir o testamento ou o instrumento público que o houver instituído."
                                        }
                                    ],
                                    "rubrica": "Disposições Comuns à Tutela e à Curatela",
                                    "linhaRubrica": 5831
                                },
                                {
                                    "numero": "760º",
                                    "rotulo": "Art. 760º.",
                                    "linha": 5843,
                                    "caput": "O tutor ou o curador poderá eximir-se do encargo apresentando escusa ao juiz no prazo de 5 (cinco) dias contado:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5849,
                                            "texto": "Não sendo requerida a escusa no prazo estabelecido neste artigo, considerar-se-á renunciado o direito de alegá-la."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5851,
                                            "texto": "O juiz decidirá de plano o pedido de escusa, e, não o admitindo, exercerá o nomeado a tutela ou a curatela enquanto não for dispensado por sentença transitada em julgado."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5845,
                                            "texto": "antes de aceitar o encargo, da intimação para prestar compromisso;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5847,
                                            "texto": "depois de entrar em exercício, do dia em que sobrevier o motivo da escusa."
                                        }
                                    ]
                                },
                                {
                                    "numero": "761º",
                                    "rotulo": "Art. 761º.",
                                    "linha": 5853,
                                    "caput": "Incumbe ao Ministério Público ou a quem tenha legítimo interesse requerer, nos casos previstos em lei, a remoção do tutor ou do curador.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5855,
                                            "texto": "O tutor ou o curador será citado para contestar a arguição no prazo de 5 (cinco) dias, findo o qual observar-se-á o procedimento comum."
                                        }
                                    ]
                                },
                                {
                                    "numero": "762º",
                                    "rotulo": "Art. 762º.",
                                    "linha": 5857,
                                    "caput": "Em caso de extrema gravidade, o juiz poderá suspender o tutor ou o curador do exercício de suas funções, nomeando substituto interino."
                                },
                                {
                                    "numero": "763º",
                                    "rotulo": "Art. 763º.",
                                    "linha": 5859,
                                    "caput": "Cessando as funções do tutor ou do curador pelo decurso do prazo em que era obrigado a servir, ser-lhe-á lícito requerer a exoneração do encargo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5861,
                                            "texto": "Caso o tutor ou o curador não requeira a exoneração do encargo dentro dos 10 (dez) dias seguintes à expiração do termo, entender-se-á reconduzido, salvo se o juiz o dispensar."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5863,
                                            "texto": "Cessada a tutela ou a curatela, é indispensável a prestação de contas pelo tutor ou pelo curador, na forma da lei civil. Seção XI"
                                        }
                                    ]
                                },
                                {
                                    "numero": "764º",
                                    "rotulo": "Art. 764º.",
                                    "linha": 5868,
                                    "caput": "O juiz decidirá sobre a aprovação do estatuto das fundações e de suas alterações sempre que o requeira o interessado, quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5874,
                                            "texto": "O estatuto das fundações deve observar o disposto na Lei nº 10.406, de 10 de janeiro de 2002 (Código Civil) ."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5876,
                                            "texto": "Antes de suprir a aprovação, o juiz poderá mandar fazer no estatuto modificações a fim de adaptá-lo ao objetivo do instituidor."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5870,
                                            "texto": "ela for negada previamente pelo Ministério Público ou por este forem exigidas modificações com as quais o interessado não concorde;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5872,
                                            "texto": "o interessado discordar do estatuto elaborado pelo Ministério Público."
                                        }
                                    ],
                                    "rubrica": "Da Organização e da Fiscalização das Fundações",
                                    "linhaRubrica": 5866
                                },
                                {
                                    "numero": "765º",
                                    "rotulo": "Art. 765º.",
                                    "linha": 5878,
                                    "caput": "Qualquer interessado ou o Ministério Público promoverá em juízo a extinção da fundação quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5880,
                                            "texto": "se tornar ilícito o seu objeto;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5882,
                                            "texto": "for impossível a sua manutenção;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5884,
                                            "texto": "vencer o prazo de sua existência. Seção XII"
                                        }
                                    ]
                                },
                                {
                                    "numero": "766º",
                                    "rotulo": "Art. 766º.",
                                    "linha": 5889,
                                    "caput": "Todos os protestos e os processos testemunháveis formados a bordo e lançados no livro Diário da Navegação deverão ser apresentados pelo comandante ao juiz de direito do primeiro porto, nas primeiras 24 (vinte e quatro) horas de chegada da embarcação, para sua ratificação judicial.",
                                    "rubrica": "Da Ratificação dos Protestos Marítimos e dos Processos Testemunháveis Formados a Bordo",
                                    "linhaRubrica": 5887
                                },
                                {
                                    "numero": "767º",
                                    "rotulo": "Art. 767º.",
                                    "linha": 5891,
                                    "caput": "A petição inicial conterá a transcrição dos termos lançados no livro Diário da Navegação e deverá ser instruída com cópias das páginas que contenham os termos que serão ratificados, dos documentos de identificação do comandante e das testemunhas arroladas, do rol de tripulantes, do documento de registro da embarcação e, quando for o caso, do manifesto das cargas sinistradas e a qualificação de seus consignatários, traduzidos, quando for o caso, de forma livre para o português."
                                },
                                {
                                    "numero": "768º",
                                    "rotulo": "Art. 768º.",
                                    "linha": 5893,
                                    "caput": "A petição inicial deverá ser distribuída com urgência e encaminhada ao juiz, que ouvirá, sob compromisso a ser prestado no mesmo dia, o comandante e as testemunhas em número mínimo de 2 (duas) e máximo de 4 (quatro), que deverão comparecer ao ato independentemente de intimação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5895,
                                            "texto": "Tratando-se de estrangeiros que não dominem a língua portuguesa, o autor deverá fazer-se acompanhar por tradutor, que prestará compromisso em audiência."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5897,
                                            "texto": "Caso o autor não se faça acompanhar por tradutor, o juiz deverá nomear outro que preste compromisso em audiência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "769º",
                                    "rotulo": "Art. 769º.",
                                    "linha": 5899,
                                    "caput": "Aberta a audiência, o juiz mandará apregoar os consignatários das cargas indicados na petição inicial e outros eventuais interessados, nomeando para os ausentes curador para o ato."
                                },
                                {
                                    "numero": "770º",
                                    "rotulo": "Art. 770º.",
                                    "linha": 5901,
                                    "caput": "Inquiridos o comandante e as testemunhas, o juiz, convencido da veracidade dos termos lançados no Diário da Navegação, em audiência, ratificará por sentença o protesto ou o processo testemunhável lavrado a bordo, dispensado o relatório.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5903,
                                            "texto": "Independentemente do trânsito em julgado, o juiz determinará a entrega dos autos ao autor ou ao seu advogado, mediante a apresentação de traslado."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DOS PROCEDIMENTOS DE JURISDIÇÃO VOLUNTÁRIA",
                            "linhaTitulo": 5533
                        }
                    ],
                    "titulo": "DOS PROCEDIMENTOS ESPECIAIS",
                    "linhaTitulo": 4388
                }
            ],
            "titulo": "DO PROCESSO DE CONHECIMENTO E DO CUMPRIMENTO DE SENTENÇA",
            "linhaTitulo": 2484
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO II",
            "linha": 5905,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 5908,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 5911,
                            "artigos": [
                                {
                                    "numero": "771º",
                                    "rotulo": "Art. 771º.",
                                    "linha": 5914,
                                    "caput": "Este Livro regula o procedimento da execução fundada em título extrajudicial, e suas disposições aplicam-se, também, no que couber, aos procedimentos especiais de execução, aos atos executivos realizados no procedimento de cumprimento de sentença, bem como aos efeitos de atos ou fatos processuais a que a lei atribuir força executiva.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5916,
                                            "texto": "Aplicam-se subsidiariamente à execução as disposições do Livro I da Parte Especial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "772º",
                                    "rotulo": "Art. 772º.",
                                    "linha": 5918,
                                    "caput": "O juiz pode, em qualquer momento do processo:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5920,
                                            "texto": "ordenar o comparecimento das partes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5922,
                                            "texto": "advertir o executado de que seu procedimento constitui ato atentatório à dignidade da justiça;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5924,
                                            "texto": "determinar que sujeitos indicados pelo exequente forneçam informações em geral relacionadas ao objeto da execução, tais como documentos e dados que tenham em seu poder, assinando-lhes prazo razoável."
                                        }
                                    ]
                                },
                                {
                                    "numero": "773º",
                                    "rotulo": "Art. 773º.",
                                    "linha": 5926,
                                    "caput": "O juiz poderá, de ofício ou a requerimento, determinar as medidas necessárias ao cumprimento da ordem de entrega de documentos e dados.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5928,
                                            "texto": "Quando, em decorrência do disposto neste artigo, o juízo receber dados sigilosos para os fins da execução, o juiz adotará as medidas necessárias para assegurar a confidencialidade."
                                        }
                                    ]
                                },
                                {
                                    "numero": "774º",
                                    "rotulo": "Art. 774º.",
                                    "linha": 5930,
                                    "caput": "Considera-se atentatória à dignidade da justiça a conduta comissiva ou omissiva do executado que:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5942,
                                            "texto": "Nos casos previstos neste artigo, o juiz fixará multa em montante não superior a vinte por cento do valor atualizado do débito em execução, a qual será revertida em proveito do exequente, exigível nos próprios autos do processo, sem prejuízo de outras sanções de natureza processual ou material."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5932,
                                            "texto": "frauda a execução;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5934,
                                            "texto": "se opõe maliciosamente à execução, empregando ardis e meios artificiosos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5936,
                                            "texto": "dificulta ou embaraça a realização da penhora;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5938,
                                            "texto": "resiste injustificadamente às ordens judiciais;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 5940,
                                            "texto": "intimado, não indica ao juiz quais são e onde estão os bens sujeitos à penhora e os respectivos valores, nem exibe prova de sua propriedade e, se for o caso, certidão negativa de ônus."
                                        }
                                    ]
                                },
                                {
                                    "numero": "775º",
                                    "rotulo": "Art. 775º.",
                                    "linha": 5944,
                                    "caput": "O exequente tem o direito de desistir de toda a execução ou de apenas alguma medida executiva.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 5946,
                                            "texto": "Na desistência da execução, observar-se-á o seguinte:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 5948,
                                                    "texto": "serão extintos a impugnação e os embargos que versarem apenas sobre questões processuais, pagando o exequente as custas processuais e os honorários advocatícios;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 5950,
                                                    "texto": "nos demais casos, a extinção dependerá da concordância do impugnante ou do embargante."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "776º",
                                    "rotulo": "Art. 776º.",
                                    "linha": 5952,
                                    "caput": "O exequente ressarcirá ao executado os danos que este sofreu, quando a sentença, transitada em julgado, declarar inexistente, no todo ou em parte, a obrigação que ensejou a execução."
                                },
                                {
                                    "numero": "777º",
                                    "rotulo": "Art. 777º.",
                                    "linha": 5954,
                                    "caput": "A cobrança de multas ou de indenizações decorrentes de litigância de má-fé ou de prática de ato atentatório à dignidade da justiça será promovida nos próprios autos do processo."
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 5912
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 5956,
                            "artigos": [
                                {
                                    "numero": "778º",
                                    "rotulo": "Art. 778º.",
                                    "linha": 5959,
                                    "caput": "Pode promover a execução forçada o credor a quem a lei confere título executivo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 5961,
                                            "texto": "Podem promover a execução forçada ou nela prosseguir, em sucessão ao exequente originário:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 5963,
                                                    "texto": "o Ministério Público, nos casos previstos em lei;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 5965,
                                                    "texto": "o espólio, os herdeiros ou os sucessores do credor, sempre que, por morte deste, lhes for transmitido o direito resultante do título executivo;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 5967,
                                                    "texto": "o cessionário, quando o direito resultante do título executivo lhe for transferido por ato entre vivos;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 5969,
                                                    "texto": "o sub-rogado, nos casos de sub-rogação legal ou convencional."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 5971,
                                            "texto": "A sucessão prevista no § 1º independe de consentimento do executado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "779º",
                                    "rotulo": "Art. 779º.",
                                    "linha": 5973,
                                    "caput": "A execução pode ser promovida contra:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5975,
                                            "texto": "o devedor, reconhecido como tal no título executivo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5977,
                                            "texto": "o espólio, os herdeiros ou os sucessores do devedor;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5979,
                                            "texto": "o novo devedor que assumiu, com o consentimento do credor, a obrigação resultante do título executivo;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 5981,
                                            "texto": "o fiador do débito constante em título extrajudicial;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 5983,
                                            "texto": "o responsável titular do bem vinculado por garantia real ao pagamento do débito;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 5985,
                                            "texto": "o responsável tributário, assim definido em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "780º",
                                    "rotulo": "Art. 780º.",
                                    "linha": 5987,
                                    "caput": "O exequente pode cumular várias execuções, ainda que fundadas em títulos diferentes, quando o executado for o mesmo e desde que para todas elas seja competente o mesmo juízo e idêntico o procedimento."
                                }
                            ],
                            "titulo": "DAS PARTES",
                            "linhaTitulo": 5957
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 5989,
                            "artigos": [
                                {
                                    "numero": "781º",
                                    "rotulo": "Art. 781º.",
                                    "linha": 5992,
                                    "caput": "A execução fundada em título extrajudicial será processada perante o juízo competente, observando-se o seguinte:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 5994,
                                            "texto": "a execução poderá ser proposta no foro de domicílio do executado, de eleição constante do título ou, ainda, de situação dos bens a ela sujeitos;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 5996,
                                            "texto": "tendo mais de um domicílio, o executado poderá ser demandado no foro de qualquer deles;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 5998,
                                            "texto": "sendo incerto ou desconhecido o domicílio do executado, a execução poderá ser proposta no lugar onde for encontrado ou no foro de domicílio do exequente;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6000,
                                            "texto": "havendo mais de um devedor, com diferentes domicílios, a execução será proposta no foro de qualquer deles, à escolha do exequente;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6002,
                                            "texto": "a execução poderá ser proposta no foro do lugar em que se praticou o ato ou em que ocorreu o fato que deu origem ao título, mesmo que nele não mais resida o executado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "782º",
                                    "rotulo": "Art. 782º.",
                                    "linha": 6004,
                                    "caput": "Não dispondo a lei de modo diverso, o juiz determinará os atos executivos, e o oficial de justiça os cumprirá.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6006,
                                            "texto": "O oficial de justiça poderá cumprir os atos executivos determinados pelo juiz também nas comarcas contíguas, de fácil comunicação, e nas que se situem na mesma região metropolitana."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6008,
                                            "texto": "Sempre que, para efetivar a execução, for necessário o emprego de força policial, o juiz a requisitará."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6010,
                                            "texto": "A requerimento da parte, o juiz pode determinar a inclusão do nome do executado em cadastros de inadimplentes."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6012,
                                            "texto": "A inscrição será cancelada imediatamente se for efetuado o pagamento, se for garantida a execução ou se a execução for extinta por qualquer outro motivo."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6014,
                                            "texto": "O disposto nos §§ 3º e 4º aplica-se à execução definitiva de título judicial."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA COMPETÊNCIA",
                            "linhaTitulo": 5990
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 6016,
                            "artigos": [
                                {
                                    "numero": "783º",
                                    "rotulo": "Art. 783º.",
                                    "linha": 6022,
                                    "caput": "A execução para cobrança de crédito fundar-se-á sempre em título de obrigação certa, líquida e exigível.",
                                    "rubrica": "Do Título Executivo",
                                    "linhaRubrica": 6020
                                },
                                {
                                    "numero": "784º",
                                    "rotulo": "Art. 784º.",
                                    "linha": 6024,
                                    "caput": "São títulos executivos extrajudiciais:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6052,
                                            "texto": "A propositura de qualquer ação relativa a débito constante de título executivo não inibe o credor de promover-lhe a execução."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6054,
                                            "texto": "Os títulos executivos extrajudiciais oriundos de país estrangeiro não dependem de homologação para serem executados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6056,
                                            "texto": "O título estrangeiro só terá eficácia executiva quando satisfeitos os requisitos de formação exigidos pela lei do lugar de sua celebração e quando o Brasil for indicado como o lugar de cumprimento da obrigação."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6058,
                                            "texto": "Nos títulos executivos constituídos ou atestados por meio eletrônico, é admitida qualquer modalidade de assinatura eletrônica prevista em lei, dispensada a assinatura de testemunhas quando sua integridade for conferida por provedor de assinatura."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6026,
                                            "texto": "a letra de câmbio, a nota promissória, a duplicata, a debênture e o cheque;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6028,
                                            "texto": "a escritura pública ou outro documento público assinado pelo devedor;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6030,
                                            "texto": "o documento particular assinado pelo devedor e por 2 (duas) testemunhas;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6032,
                                            "texto": "o instrumento de transação referendado pelo Ministério Público, pela Defensoria Pública, pela Advocacia Pública, pelos advogados dos transatores ou por conciliador ou mediador credenciado por tribunal;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6034,
                                            "texto": "o contrato garantido por hipoteca, penhor, anticrese ou outro direito real de garantia e aquele garantido por caução;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6036,
                                            "texto": "o contrato de seguro de vida em caso de morte;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6038,
                                            "texto": "o crédito decorrente de foro e laudêmio;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 6040,
                                            "texto": "o crédito, documentalmente comprovado, decorrente de aluguel de imóvel, bem como de encargos acessórios, tais como taxas e despesas de condomínio;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 6042,
                                            "texto": "a certidão de dívida ativa da Fazenda Pública da União, dos Estados, do Distrito Federal e dos Municípios, correspondente aos créditos inscritos na forma da lei;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 6044,
                                            "texto": "o crédito referente às contribuições ordinárias ou extraordinárias de condomínio edilício, previstas na respectiva convenção ou aprovadas em assembleia geral, desde que documentalmente comprovadas;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 6046,
                                            "texto": "a certidão expedida por serventia notarial ou de registro relativa a valores de emolumentos e demais despesas devidas pelos atos por ela praticados, fixados nas tabelas estabelecidas em lei;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 6048,
                                            "texto": "A - o contrato de contragarantia ou qualquer outro instrumento que materialize o direito de ressarcimento da seguradora contra tomadores de seguro-garantia e seus garantidores;"
                                        },
                                        {
                                            "numero": "XII",
                                            "rotulo": "XII",
                                            "linha": 6050,
                                            "texto": "todos os demais títulos aos quais, por disposição expressa, a lei atribuir força executiva."
                                        }
                                    ]
                                },
                                {
                                    "numero": "785º",
                                    "rotulo": "Art. 785º.",
                                    "linha": 6060,
                                    "caput": "A existência de título executivo extrajudicial não impede a parte de optar pelo processo de conhecimento, a fim de obter título executivo judicial. Seção II"
                                },
                                {
                                    "numero": "786º",
                                    "rotulo": "Art. 786º.",
                                    "linha": 6065,
                                    "caput": "A execução pode ser instaurada caso o devedor não satisfaça a obrigação certa, líquida e exigível consubstanciada em título executivo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6067,
                                            "texto": "A necessidade de simples operações aritméticas para apurar o crédito exequendo não retira a liquidez da obrigação constante do título."
                                        }
                                    ],
                                    "rubrica": "Da Exigibilidade da Obrigação",
                                    "linhaRubrica": 6063
                                },
                                {
                                    "numero": "787º",
                                    "rotulo": "Art. 787º.",
                                    "linha": 6069,
                                    "caput": "Se o devedor não for obrigado a satisfazer sua prestação senão mediante a contraprestação do credor, este deverá provar que a adimpliu ao requerer a execução, sob pena de extinção do processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6071,
                                            "texto": "O executado poderá eximir-se da obrigação, depositando em juízo a prestação ou a coisa, caso em que o juiz não permitirá que o credor a receba sem cumprir a contraprestação que lhe tocar."
                                        }
                                    ]
                                },
                                {
                                    "numero": "788º",
                                    "rotulo": "Art. 788º.",
                                    "linha": 6073,
                                    "caput": "O credor não poderá iniciar a execução ou nela prosseguir se o devedor cumprir a obrigação, mas poderá recusar o recebimento da prestação se ela não corresponder ao direito ou à obrigação estabelecidos no título executivo, caso em que poderá requerer a execução forçada, ressalvado ao devedor o direito de embargá-la."
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DOS REQUISITOS NECESSÁRIOS PARA REALIZAR QUALQUER EXECUÇÃO",
                            "linhaTitulo": 6017
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 6075,
                            "artigos": [
                                {
                                    "numero": "789º",
                                    "rotulo": "Art. 789º.",
                                    "linha": 6078,
                                    "caput": "O devedor responde com todos os seus bens presentes e futuros para o cumprimento de suas obrigações, salvo as restrições estabelecidas em lei."
                                },
                                {
                                    "numero": "790º",
                                    "rotulo": "Art. 790º.",
                                    "linha": 6080,
                                    "caput": "São sujeitos à execução os bens:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6082,
                                            "texto": "do sucessor a título singular, tratando-se de execução fundada em direito real ou obrigação reipersecutória;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6084,
                                            "texto": "do sócio, nos termos da lei;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6086,
                                            "texto": "do devedor, ainda que em poder de terceiros;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6088,
                                            "texto": "do cônjuge ou companheiro, nos casos em que seus bens próprios ou de sua meação respondem pela dívida;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6090,
                                            "texto": "alienados ou gravados com ônus real em fraude à execução;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6092,
                                            "texto": "cuja alienação ou gravação com ônus real tenha sido anulada em razão do reconhecimento, em ação autônoma, de fraude contra credores;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6094,
                                            "texto": "do responsável, nos casos de desconsideração da personalidade jurídica."
                                        }
                                    ]
                                },
                                {
                                    "numero": "791º",
                                    "rotulo": "Art. 791º.",
                                    "linha": 6096,
                                    "caput": "Se a execução tiver por objeto obrigação de que seja sujeito passivo o proprietário de terreno submetido ao regime do direito de superfície, ou o superficiário, responderá pela dívida, exclusivamente, o direito real do qual é titular o executado, recaindo a penhora ou outros atos de constrição exclusivamente sobre o terreno, no primeiro caso, ou sobre a construção ou a plantação, no segundo caso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6098,
                                            "texto": "Os atos de constrição a que se refere o caput serão averbados separadamente na matrícula do imóvel, com a identificação do executado, do valor do crédito e do objeto sobre o qual recai o gravame, devendo o oficial destacar o bem que responde pela dívida, se o terreno, a construção ou a plantação, de modo a assegurar a publicidade da responsabilidade patrimonial de cada um deles pelas dívidas e pelas obrigações que a eles estão vinculadas."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6100,
                                            "texto": "Aplica-se, no que couber, o disposto neste artigo à enfiteuse, à concessão de uso especial para fins de moradia e à concessão de direito real de uso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "792º",
                                    "rotulo": "Art. 792º.",
                                    "linha": 6102,
                                    "caput": "A alienação ou a oneração de bem é considerada fraude à execução:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6114,
                                            "texto": "A alienação em fraude à execução é ineficaz em relação ao exequente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6116,
                                            "texto": "No caso de aquisição de bem não sujeito a registro, o terceiro adquirente tem o ônus de provar que adotou as cautelas necessárias para a aquisição, mediante a exibição das certidões pertinentes, obtidas no domicílio do vendedor e no local onde se encontra o bem."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6118,
                                            "texto": "Nos casos de desconsideração da personalidade jurídica, a fraude à execução verifica-se a partir da citação da parte cuja personalidade se pretende desconsiderar."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6120,
                                            "texto": "Antes de declarar a fraude à execução, o juiz deverá intimar o terceiro adquirente, que, se quiser, poderá opor embargos de terceiro, no prazo de 15 (quinze) dias."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6104,
                                            "texto": "quando sobre o bem pender ação fundada em direito real ou com pretensão reipersecutória, desde que a pendência do processo tenha sido averbada no respectivo registro público, se houver;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6106,
                                            "texto": "quando tiver sido averbada, no registro do bem, a pendência do processo de execução, na forma do art. 828 ;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 828",
                                                    "href": "#art828",
                                                    "inicio": 97,
                                                    "fim": 105
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6108,
                                            "texto": "quando tiver sido averbado, no registro do bem, hipoteca judiciária ou outro ato de constrição judicial originário do processo onde foi arguida a fraude;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6110,
                                            "texto": "quando, ao tempo da alienação ou da oneração, tramitava contra o devedor ação capaz de reduzi-lo à insolvência;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6112,
                                            "texto": "nos demais casos expressos em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "793º",
                                    "rotulo": "Art. 793º.",
                                    "linha": 6122,
                                    "caput": "O exequente que estiver, por direito de retenção, na posse de coisa pertencente ao devedor não poderá promover a execução sobre outros bens senão depois de excutida a coisa que se achar em seu poder."
                                },
                                {
                                    "numero": "794º",
                                    "rotulo": "Art. 794º.",
                                    "linha": 6124,
                                    "caput": "O fiador, quando executado, tem o direito de exigir que primeiro sejam executados os bens do devedor situados na mesma comarca, livres e desembargados, indicando-os pormenorizadamente à penhora.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6126,
                                            "texto": "Os bens do fiador ficarão sujeitos à execução se os do devedor, situados na mesma comarca que os seus, forem insuficientes à satisfação do direito do credor."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6128,
                                            "texto": "O fiador que pagar a dívida poderá executar o afiançado nos autos do mesmo processo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6130,
                                            "texto": "O disposto no caput não se aplica se o fiador houver renunciado ao benefício de ordem."
                                        }
                                    ]
                                },
                                {
                                    "numero": "795º",
                                    "rotulo": "Art. 795º.",
                                    "linha": 6132,
                                    "caput": "Os bens particulares dos sócios não respondem pelas dívidas da sociedade, senão nos casos previstos em lei.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6134,
                                            "texto": "O sócio réu, quando responsável pelo pagamento da dívida da sociedade, tem o direito de exigir que primeiro sejam excutidos os bens da sociedade."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6136,
                                            "texto": "Incumbe ao sócio que alegar o benefício do § 1º nomear quantos bens da sociedade situados na mesma comarca, livres e desembargados, bastem para pagar o débito."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6138,
                                            "texto": "O sócio que pagar a dívida poderá executar a sociedade nos autos do mesmo processo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6140,
                                            "texto": "Para a desconsideração da personalidade jurídica é obrigatória a observância do incidente previsto neste Código."
                                        }
                                    ]
                                },
                                {
                                    "numero": "796º",
                                    "rotulo": "Art. 796º.",
                                    "linha": 6142,
                                    "caput": "O espólio responde pelas dívidas do falecido, mas, feita a partilha, cada herdeiro responde por elas dentro das forças da herança e na proporção da parte que lhe coube."
                                }
                            ],
                            "titulo": "DA RESPONSABILIDADE PATRIMONIAL",
                            "linhaTitulo": 6076
                        }
                    ],
                    "titulo": "DA EXECUÇÃO EM GERAL",
                    "linhaTitulo": 5909
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 6144,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 6147,
                            "artigos": [
                                {
                                    "numero": "797º",
                                    "rotulo": "Art. 797º.",
                                    "linha": 6150,
                                    "caput": "Ressalvado o caso de insolvência do devedor, em que tem lugar o concurso universal, realiza-se a execução no interesse do exequente que adquire, pela penhora, o direito de preferência sobre os bens penhorados.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6152,
                                            "texto": "Recaindo mais de uma penhora sobre o mesmo bem, cada exequente conservará o seu título de preferência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "798º",
                                    "rotulo": "Art. 798º.",
                                    "linha": 6154,
                                    "caput": "Ao propor a execução, incumbe ao exequente:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6174,
                                            "texto": "O demonstrativo do débito deverá conter:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6176,
                                                    "texto": "o índice de correção monetária adotado;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6178,
                                                    "texto": "a taxa de juros aplicada;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 6180,
                                                    "texto": "os termos inicial e final de incidência do índice de correção monetária e da taxa de juros utilizados;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 6182,
                                                    "texto": "a periodicidade da capitalização dos juros, se for o caso;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 6184,
                                                    "texto": "a especificação de desconto obrigatório realizado."
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6156,
                                            "texto": "instruir a petição inicial com:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 6158,
                                                    "texto": "o título executivo extrajudicial;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 6160,
                                                    "texto": "o demonstrativo do débito atualizado até a data de propositura da ação, quando se tratar de execução por quantia certa;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 6162,
                                                    "texto": "a prova de que se verificou a condição ou ocorreu o termo, se for o caso;"
                                                },
                                                {
                                                    "letra": "d",
                                                    "rotulo": "d)",
                                                    "linha": 6164,
                                                    "texto": "a prova, se for o caso, de que adimpliu a contraprestação que lhe corresponde ou que lhe assegura o cumprimento, se o executado não for obrigado a satisfazer a sua prestação senão mediante a contraprestação do exequente;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6166,
                                            "texto": "indicar:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 6168,
                                                    "texto": "a espécie de execução de sua preferência, quando por mais de um modo puder ser realizada;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 6170,
                                                    "texto": "os nomes completos do exequente e do executado e seus números de inscrição no Cadastro de Pessoas Físicas ou no Cadastro Nacional da Pessoa Jurídica;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 6172,
                                                    "texto": "os bens suscetíveis de penhora, sempre que possível."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "799º",
                                    "rotulo": "Art. 799º.",
                                    "linha": 6186,
                                    "caput": "Incumbe ainda ao exequente:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6188,
                                            "texto": "requerer a intimação do credor pignoratício, hipotecário, anticrético ou fiduciário, quando a penhora recair sobre bens gravados por penhor, hipoteca, anticrese ou alienação fiduciária;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6190,
                                            "texto": "requerer a intimação do titular de usufruto, uso ou habitação, quando a penhora recair sobre bem gravado por usufruto, uso ou habitação;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6192,
                                            "texto": "requerer a intimação do promitente comprador, quando a penhora recair sobre bem em relação ao qual haja promessa de compra e venda registrada;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6194,
                                            "texto": "requerer a intimação do promitente vendedor, quando a penhora recair sobre direito aquisitivo derivado de promessa de compra e venda registrada;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6196,
                                            "texto": "requerer a intimação do superficiário, enfiteuta ou concessionário, em caso de direito de superfície, enfiteuse, concessão de uso especial para fins de moradia ou concessão de direito real de uso, quando a penhora recair sobre imóvel submetido ao regime do direito de superfície, enfiteuse ou concessão;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6198,
                                            "texto": "requerer a intimação do proprietário de terreno com regime de direito de superfície, enfiteuse, concessão de uso especial para fins de moradia ou concessão de direito real de uso, quando a penhora recair sobre direitos do superficiário, do enfiteuta ou do concessionário;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6200,
                                            "texto": "requerer a intimação da sociedade, no caso de penhora de quota social ou de ação de sociedade anônima fechada, para o fim previsto no art. 876, § 7º ;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 6202,
                                            "texto": "pleitear, se for o caso, medidas urgentes;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 6204,
                                            "texto": "proceder à averbação em registro público do ato de propositura da execução e dos atos de constrição realizados, para conhecimento de terceiros."
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 6206,
                                            "texto": "requerer a intimação do titular da construção-base, bem como, se for o caso, do titular de lajes anteriores, quando a penhora recair sobre o direito real de laje;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 6208,
                                            "texto": "requerer a intimação do titular das lajes, quando a penhora recair sobre a construção-base."
                                        }
                                    ]
                                },
                                {
                                    "numero": "800º",
                                    "rotulo": "Art. 800º.",
                                    "linha": 6210,
                                    "caput": "Nas obrigações alternativas, quando a escolha couber ao devedor, esse será citado para exercer a opção e realizar a prestação dentro de 10 (dez) dias, se outro prazo não lhe foi determinado em lei ou em contrato.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6212,
                                            "texto": "Devolver-se-á ao credor a opção, se o devedor não a exercer no prazo determinado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6214,
                                            "texto": "A escolha será indicada na petição inicial da execução quando couber ao credor exercê-la."
                                        }
                                    ]
                                },
                                {
                                    "numero": "801º",
                                    "rotulo": "Art. 801º.",
                                    "linha": 6216,
                                    "caput": "Verificando que a petição inicial está incompleta ou que não está acompanhada dos documentos indispensáveis à propositura da execução, o juiz determinará que o exequente a corrija, no prazo de 15 (quinze) dias, sob pena de indeferimento."
                                },
                                {
                                    "numero": "802º",
                                    "rotulo": "Art. 802º.",
                                    "linha": 6218,
                                    "caput": "Na execução, o despacho que ordena a citação, desde que realizada em observância ao disposto no § 2º do art. 240 , interrompe a prescrição, ainda que proferido por juízo incompetente.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6220,
                                            "texto": "A interrupção da prescrição retroagirá à data de propositura da ação."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 240",
                                            "href": "#art240",
                                            "inicio": 104,
                                            "fim": 112
                                        }
                                    ]
                                },
                                {
                                    "numero": "803º",
                                    "rotulo": "Art. 803º.",
                                    "linha": 6222,
                                    "caput": "É nula a execução se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6230,
                                            "texto": "A nulidade de que cuida este artigo será pronunciada pelo juiz, de ofício ou a requerimento da parte, independentemente de embargos à execução."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6224,
                                            "texto": "o título executivo extrajudicial não corresponder a obrigação certa, líquida e exigível;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6226,
                                            "texto": "o executado não for regularmente citado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6228,
                                            "texto": "for instaurada antes de se verificar a condição ou de ocorrer o termo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "804º",
                                    "rotulo": "Art. 804º.",
                                    "linha": 6232,
                                    "caput": "A alienação de bem gravado por penhor, hipoteca ou anticrese será ineficaz em relação ao credor pignoratício, hipotecário ou anticrético não intimado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6234,
                                            "texto": "A alienação de bem objeto de promessa de compra e venda ou de cessão registrada será ineficaz em relação ao promitente comprador ou ao cessionário não intimado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6236,
                                            "texto": "A alienação de bem sobre o qual tenha sido instituído direito de superfície, seja do solo, da plantação ou da construção, será ineficaz em relação ao concedente ou ao concessionário não intimado."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6238,
                                            "texto": "A alienação de direito aquisitivo de bem objeto de promessa de venda, de promessa de cessão ou de alienação fiduciária será ineficaz em relação ao promitente vendedor, ao promitente cedente ou ao proprietário fiduciário não intimado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6240,
                                            "texto": "A alienação de imóvel sobre o qual tenha sido instituída enfiteuse, concessão de uso especial para fins de moradia ou concessão de direito real de uso será ineficaz em relação ao enfiteuta ou ao concessionário não intimado."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6242,
                                            "texto": "A alienação de direitos do enfiteuta, do concessionário de direito real de uso ou do concessionário de uso especial para fins de moradia será ineficaz em relação ao proprietário do respectivo imóvel não intimado."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 6244,
                                            "texto": "A alienação de bem sobre o qual tenha sido instituído usufruto, uso ou habitação será ineficaz em relação ao titular desses direitos reais não intimado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "805º",
                                    "rotulo": "Art. 805º.",
                                    "linha": 6246,
                                    "caput": "Quando por vários meios o exequente puder promover a execução, o juiz mandará que se faça pelo modo menos gravoso para o executado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6248,
                                            "texto": "Ao executado que alegar ser a medida executiva mais gravosa incumbe indicar outros meios mais eficazes e menos onerosos, sob pena de manutenção dos atos executivos já determinados."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 6148
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 6250,
                            "artigos": [
                                {
                                    "numero": "806º",
                                    "rotulo": "Art. 806º.",
                                    "linha": 6256,
                                    "caput": "O devedor de obrigação de entrega de coisa certa, constante de título executivo extrajudicial, será citado para, em 15 (quinze) dias, satisfazer a obrigação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6258,
                                            "texto": "Ao despachar a inicial, o juiz poderá fixar multa por dia de atraso no cumprimento da obrigação, ficando o respectivo valor sujeito a alteração, caso se revele insuficiente ou excessivo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6260,
                                            "texto": "Do mandado de citação constará ordem para imissão na posse ou busca e apreensão, conforme se tratar de bem imóvel ou móvel, cujo cumprimento se dará de imediato, se o executado não satisfizer a obrigação no prazo que lhe foi designado."
                                        }
                                    ],
                                    "rubrica": "Da Entrega de Coisa Certa",
                                    "linhaRubrica": 6254
                                },
                                {
                                    "numero": "807º",
                                    "rotulo": "Art. 807º.",
                                    "linha": 6262,
                                    "caput": "Se o executado entregar a coisa, será lavrado o termo respectivo e considerada satisfeita a obrigação, prosseguindo-se a execução para o pagamento de frutos ou o ressarcimento de prejuízos, se houver."
                                },
                                {
                                    "numero": "808º",
                                    "rotulo": "Art. 808º.",
                                    "linha": 6264,
                                    "caput": "Alienada a coisa quando já litigiosa, será expedido mandado contra o terceiro adquirente, que somente será ouvido após depositá-la."
                                },
                                {
                                    "numero": "809º",
                                    "rotulo": "Art. 809º.",
                                    "linha": 6266,
                                    "caput": "O exequente tem direito a receber, além de perdas e danos, o valor da coisa, quando essa se deteriorar, não lhe for entregue, não for encontrada ou não for reclamada do poder de terceiro adquirente.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6268,
                                            "texto": "Não constando do título o valor da coisa e sendo impossível sua avaliação, o exequente apresentará estimativa, sujeitando-a ao arbitramento judicial."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6270,
                                            "texto": "Serão apurados em liquidação o valor da coisa e os prejuízos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "810º",
                                    "rotulo": "Art. 810º.",
                                    "linha": 6272,
                                    "caput": "Havendo benfeitorias indenizáveis feitas na coisa pelo executado ou por terceiros de cujo poder ela houver sido tirada, a liquidação prévia é obrigatória.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6274,
                                            "texto": "Havendo saldo:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6276,
                                                    "texto": "em favor do executado ou de terceiros, o exequente o depositará ao requerer a entrega da coisa;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6278,
                                                    "texto": "em favor do exequente, esse poderá cobrá-lo nos autos do mesmo processo. Seção II"
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "811º",
                                    "rotulo": "Art. 811º.",
                                    "linha": 6283,
                                    "caput": "Quando a execução recair sobre coisa determinada pelo gênero e pela quantidade, o executado será citado para entregá-la individualizada, se lhe couber a escolha.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6285,
                                            "texto": "Se a escolha couber ao exequente, esse deverá indicá-la na petição inicial."
                                        }
                                    ],
                                    "rubrica": "Da Entrega de Coisa Incerta",
                                    "linhaRubrica": 6281
                                },
                                {
                                    "numero": "812º",
                                    "rotulo": "Art. 812º.",
                                    "linha": 6287,
                                    "caput": "Qualquer das partes poderá, no prazo de 15 (quinze) dias, impugnar a escolha feita pela outra, e o juiz decidirá de plano ou, se necessário, ouvindo perito de sua nomeação."
                                },
                                {
                                    "numero": "813º",
                                    "rotulo": "Art. 813º.",
                                    "linha": 6289,
                                    "caput": "Aplicar-se-ão à execução para entrega de coisa incerta, no que couber, as disposições da Seção I deste Capítulo."
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA EXECUÇÃO PARA A ENTREGA DE COISA",
                            "linhaTitulo": 6251
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 6291,
                            "artigos": [
                                {
                                    "numero": "814º",
                                    "rotulo": "Art. 814º.",
                                    "linha": 6297,
                                    "caput": "Na execução de obrigação de fazer ou de não fazer fundada em título extrajudicial, ao despachar a inicial, o juiz fixará multa por período de atraso no cumprimento da obrigação e a data a partir da qual será devida.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6299,
                                            "texto": "Se o valor da multa estiver previsto no título e for excessivo, o juiz poderá reduzi-lo. Seção II"
                                        }
                                    ],
                                    "rubrica": "Disposições Comuns",
                                    "linhaRubrica": 6295
                                },
                                {
                                    "numero": "815º",
                                    "rotulo": "Art. 815º.",
                                    "linha": 6304,
                                    "caput": "Quando o objeto da execução for obrigação de fazer, o executado será citado para satisfazê-la no prazo que o juiz lhe designar, se outro não estiver determinado no título executivo.",
                                    "rubrica": "Da Obrigação de Fazer",
                                    "linhaRubrica": 6302
                                },
                                {
                                    "numero": "816º",
                                    "rotulo": "Art. 816º.",
                                    "linha": 6306,
                                    "caput": "Se o executado não satisfizer a obrigação no prazo designado, é lícito ao exequente, nos próprios autos do processo, requerer a satisfação da obrigação à custa do executado ou perdas e danos, hipótese em que se converterá em indenização.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6308,
                                            "texto": "O valor das perdas e danos será apurado em liquidação, seguindo-se a execução para cobrança de quantia certa."
                                        }
                                    ]
                                },
                                {
                                    "numero": "817º",
                                    "rotulo": "Art. 817º.",
                                    "linha": 6310,
                                    "caput": "Se a obrigação puder ser satisfeita por terceiro, é lícito ao juiz autorizar, a requerimento do exequente, que aquele a satisfaça à custa do executado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6312,
                                            "texto": "O exequente adiantará as quantias previstas na proposta que, ouvidas as partes, o juiz houver aprovado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "818º",
                                    "rotulo": "Art. 818º.",
                                    "linha": 6314,
                                    "caput": "Realizada a prestação, o juiz ouvirá as partes no prazo de 10 (dez) dias e, não havendo impugnação, considerará satisfeita a obrigação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6316,
                                            "texto": "Caso haja impugnação, o juiz a decidirá."
                                        }
                                    ]
                                },
                                {
                                    "numero": "819º",
                                    "rotulo": "Art. 819º.",
                                    "linha": 6318,
                                    "caput": "Se o terceiro contratado não realizar a prestação no prazo ou se o fizer de modo incompleto ou defeituoso, poderá o exequente requerer ao juiz, no prazo de 15 (quinze) dias, que o autorize a concluí-la ou a repará-la à custa do contratante.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6320,
                                            "texto": "Ouvido o contratante no prazo de 15 (quinze) dias, o juiz mandará avaliar o custo das despesas necessárias e o condenará a pagá-lo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "820º",
                                    "rotulo": "Art. 820º.",
                                    "linha": 6322,
                                    "caput": "Se o exequente quiser executar ou mandar executar, sob sua direção e vigilância, as obras e os trabalhos necessários à realização da prestação, terá preferência, em igualdade de condições de oferta, em relação ao terceiro.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6324,
                                            "texto": "O direito de preferência deverá ser exercido no prazo de 5 (cinco) dias, após aprovada a proposta do terceiro."
                                        }
                                    ]
                                },
                                {
                                    "numero": "821º",
                                    "rotulo": "Art. 821º.",
                                    "linha": 6326,
                                    "caput": "Na obrigação de fazer, quando se convencionar que o executado a satisfaça pessoalmente, o exequente poderá requerer ao juiz que lhe assine prazo para cumpri-la.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6328,
                                            "texto": "Havendo recusa ou mora do executado, sua obrigação pessoal será convertida em perdas e danos, caso em que se observará o procedimento de execução por quantia certa. Seção III"
                                        }
                                    ]
                                },
                                {
                                    "numero": "822º",
                                    "rotulo": "Art. 822º.",
                                    "linha": 6333,
                                    "caput": "Se o executado praticou ato a cuja abstenção estava obrigado por lei ou por contrato, o exequente requererá ao juiz que assine prazo ao executado para desfazê-lo.",
                                    "rubrica": "Da Obrigação de Não Fazer",
                                    "linhaRubrica": 6331
                                },
                                {
                                    "numero": "823º",
                                    "rotulo": "Art. 823º.",
                                    "linha": 6335,
                                    "caput": "Havendo recusa ou mora do executado, o exequente requererá ao juiz que mande desfazer o ato à custa daquele, que responderá por perdas e danos.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6337,
                                            "texto": "Não sendo possível desfazer-se o ato, a obrigação resolve-se em perdas e danos, caso em que, após a liquidação, se observará o procedimento de execução por quantia certa."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA EXECUÇÃO DAS OBRIGAÇÕES DE FAZER OU DE NÃO FAZER",
                            "linhaTitulo": 6292
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 6339,
                            "artigos": [
                                {
                                    "numero": "824º",
                                    "rotulo": "Art. 824º.",
                                    "linha": 6345,
                                    "caput": "A execução por quantia certa realiza-se pela expropriação de bens do executado, ressalvadas as execuções especiais.",
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 6343
                                },
                                {
                                    "numero": "825º",
                                    "rotulo": "Art. 825º.",
                                    "linha": 6347,
                                    "caput": "A expropriação consiste em:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6349,
                                            "texto": "adjudicação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6351,
                                            "texto": "alienação;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6353,
                                            "texto": "apropriação de frutos e rendimentos de empresa ou de estabelecimentos e de outros bens."
                                        }
                                    ]
                                },
                                {
                                    "numero": "826º",
                                    "rotulo": "Art. 826º.",
                                    "linha": 6355,
                                    "caput": "Antes de adjudicados ou alienados os bens, o executado pode, a todo tempo, remir a execução, pagando ou consignando a importância atualizada da dívida, acrescida de juros, custas e honorários advocatícios. Seção II"
                                },
                                {
                                    "numero": "827º",
                                    "rotulo": "Art. 827º.",
                                    "linha": 6360,
                                    "caput": "Ao despachar a inicial, o juiz fixará, de plano, os honorários advocatícios de dez por cento, a serem pagos pelo executado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6362,
                                            "texto": "No caso de integral pagamento no prazo de 3 (três) dias, o valor dos honorários advocatícios será reduzido pela metade."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6364,
                                            "texto": "O valor dos honorários poderá ser elevado até vinte por cento, quando rejeitados os embargos à execução, podendo a majoração, caso não opostos os embargos, ocorrer ao final do procedimento executivo, levando-se em conta o trabalho realizado pelo advogado do exequente."
                                        }
                                    ],
                                    "rubrica": "Da Citação do Devedor e do Arresto",
                                    "linhaRubrica": 6358
                                },
                                {
                                    "numero": "828º",
                                    "rotulo": "Art. 828º.",
                                    "linha": 6366,
                                    "caput": "O exequente poderá obter certidão de que a execução foi admitida pelo juiz, com identificação das partes e do valor da causa, para fins de averbação no registro de imóveis, de veículos ou de outros bens sujeitos a penhora, arresto ou indisponibilidade.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6368,
                                            "texto": "No prazo de 10 (dez) dias de sua concretização, o exequente deverá comunicar ao juízo as averbações efetivadas."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6370,
                                            "texto": "Formalizada penhora sobre bens suficientes para cobrir o valor da dívida, o exequente providenciará, no prazo de 10 (dez) dias, o cancelamento das averbações relativas àqueles não penhorados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6372,
                                            "texto": "O juiz determinará o cancelamento das averbações, de ofício ou a requerimento, caso o exequente não o faça no prazo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6374,
                                            "texto": "Presume-se em fraude à execução a alienação ou a oneração de bens efetuada após a averbação."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6376,
                                            "texto": "O exequente que promover averbação manifestamente indevida ou não cancelar as averbações nos termos do § 2º indenizará a parte contrária, processando-se o incidente em autos apartados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "829º",
                                    "rotulo": "Art. 829º.",
                                    "linha": 6378,
                                    "caput": "O executado será citado para pagar a dívida no prazo de 3 (três) dias, contado da citação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6380,
                                            "texto": "Do mandado de citação constarão, também, a ordem de penhora e a avaliação a serem cumpridas pelo oficial de justiça tão logo verificado o não pagamento no prazo assinalado, de tudo lavrando-se auto, com intimação do executado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6382,
                                            "texto": "A penhora recairá sobre os bens indicados pelo exequente, salvo se outros forem indicados pelo executado e aceitos pelo juiz, mediante demonstração de que a constrição proposta lhe será menos onerosa e não trará prejuízo ao exequente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "830º",
                                    "rotulo": "Art. 830º.",
                                    "linha": 6384,
                                    "caput": "Se o oficial de justiça não encontrar o executado, arrestar-lhe-á tantos bens quantos bastem para garantir a execução.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6386,
                                            "texto": "Nos 10 (dez) dias seguintes à efetivação do arresto, o oficial de justiça procurará o executado 2 (duas) vezes em dias distintos e, havendo suspeita de ocultação, realizará a citação com hora certa, certificando pormenorizadamente o ocorrido."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6388,
                                            "texto": "Incumbe ao exequente requerer a citação por edital, uma vez frustradas a pessoal e a com hora certa."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6390,
                                            "texto": "Aperfeiçoada a citação e transcorrido o prazo de pagamento, o arresto converter-se-á em penhora, independentemente de termo. Seção III Da Penhora, do Depósito e da Avaliação Subseção I"
                                        }
                                    ]
                                },
                                {
                                    "numero": "831º",
                                    "rotulo": "Art. 831º.",
                                    "linha": 6398,
                                    "caput": "A penhora deverá recair sobre tantos bens quantos bastem para o pagamento do principal atualizado, dos juros, das custas e dos honorários advocatícios.",
                                    "rubrica": "Do Objeto da Penhora",
                                    "linhaRubrica": 6396
                                },
                                {
                                    "numero": "832º",
                                    "rotulo": "Art. 832º.",
                                    "linha": 6400,
                                    "caput": "Não estão sujeitos à execução os bens que a lei considera impenhoráveis ou inalienáveis."
                                },
                                {
                                    "numero": "833º",
                                    "rotulo": "Art. 833º.",
                                    "linha": 6402,
                                    "caput": "São impenhoráveis:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6428,
                                            "texto": "A impenhorabilidade não é oponível à execução de dívida relativa ao próprio bem, inclusive àquela contraída para sua aquisição."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6430,
                                            "texto": "O disposto nos incisos IV e X do caput não se aplica à hipótese de penhora para pagamento de prestação alimentícia, independentemente de sua origem, bem como às importâncias excedentes a 50 (cinquenta) salários-mínimos mensais, devendo a constrição observar o disposto no art. 528, § 8º , e no art. 529, § 3º ."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6432,
                                            "texto": "Incluem-se na impenhorabilidade prevista no inciso V do caput os equipamentos, os implementos e as máquinas agrícolas pertencentes a pessoa física ou a empresa individual produtora rural, exceto quando tais bens tenham sido objeto de financiamento e estejam vinculados em garantia a negócio jurídico ou quando respondam por dívida de natureza alimentar, trabalhista ou previdenciária."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6404,
                                            "texto": "os bens inalienáveis e os declarados, por ato voluntário, não sujeitos à execução;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6406,
                                            "texto": "os móveis, os pertences e as utilidades domésticas que guarnecem a residência do executado, salvo os de elevado valor ou os que ultrapassem as necessidades comuns correspondentes a um médio padrão de vida;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6408,
                                            "texto": "os vestuários, bem como os pertences de uso pessoal do executado, salvo se de elevado valor;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6410,
                                            "texto": "os vencimentos, os subsídios, os soldos, os salários, as remunerações, os proventos de aposentadoria, as pensões, os pecúlios e os montepios, bem como as quantias recebidas por liberalidade de terceiro e destinadas ao sustento do devedor e de sua família, os ganhos de trabalhador autônomo e os honorários de profissional liberal, ressalvado o § 2º ;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6412,
                                            "texto": "os livros, as máquinas, as ferramentas, os utensílios, os instrumentos ou outros bens móveis necessários ou úteis ao exercício da profissão do executado;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6414,
                                            "texto": "o seguro de vida;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6416,
                                            "texto": "os materiais necessários para obras em andamento, salvo se essas forem penhoradas;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 6418,
                                            "texto": "a pequena propriedade rural, assim definida em lei, desde que trabalhada pela família;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 6420,
                                            "texto": "os recursos públicos recebidos por instituições privadas para aplicação compulsória em educação, saúde ou assistência social;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 6422,
                                            "texto": "a quantia depositada em caderneta de poupança, até o limite de 40 (quarenta) salários-mínimos;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 6424,
                                            "texto": "os recursos públicos do fundo partidário recebidos por partido político, nos termos da lei;"
                                        },
                                        {
                                            "numero": "XII",
                                            "rotulo": "XII",
                                            "linha": 6426,
                                            "texto": "os créditos oriundos de alienação de unidades imobiliárias, sob regime de incorporação imobiliária, vinculados à execução da obra."
                                        }
                                    ]
                                },
                                {
                                    "numero": "834º",
                                    "rotulo": "Art. 834º.",
                                    "linha": 6434,
                                    "caput": "Podem ser penhorados, à falta de outros bens, os frutos e os rendimentos dos bens inalienáveis."
                                },
                                {
                                    "numero": "835º",
                                    "rotulo": "Art. 835º.",
                                    "linha": 6436,
                                    "caput": "A penhora observará, preferencialmente, a seguinte ordem:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6464,
                                            "texto": "É prioritária a penhora em dinheiro, podendo o juiz, nas demais hipóteses, alterar a ordem prevista no caput de acordo com as circunstâncias do caso concreto."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6466,
                                            "texto": "Para fins de substituição da penhora, equiparam-se a dinheiro a fiança bancária e o seguro garantia judicial, desde que em valor não inferior ao do débito constante da inicial, acrescido de trinta por cento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6468,
                                            "texto": "Na execução de crédito com garantia real, a penhora recairá sobre a coisa dada em garantia, e, se a coisa pertencer a terceiro garantidor, este também será intimado da penhora."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6438,
                                            "texto": "dinheiro, em espécie ou em depósito ou aplicação em instituição financeira;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6440,
                                            "texto": "títulos da dívida pública da União, dos Estados e do Distrito Federal com cotação em mercado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6442,
                                            "texto": "títulos e valores mobiliários com cotação em mercado;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6444,
                                            "texto": "veículos de via terrestre;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6446,
                                            "texto": "bens imóveis;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6448,
                                            "texto": "bens móveis em geral;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6450,
                                            "texto": "semoventes;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 6452,
                                            "texto": "navios e aeronaves;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 6454,
                                            "texto": "ações e quotas de sociedades simples e empresárias;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 6456,
                                            "texto": "percentual do faturamento de empresa devedora;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 6458,
                                            "texto": "pedras e metais preciosos;"
                                        },
                                        {
                                            "numero": "XII",
                                            "rotulo": "XII",
                                            "linha": 6460,
                                            "texto": "direitos aquisitivos derivados de promessa de compra e venda e de alienação fiduciária em garantia;"
                                        },
                                        {
                                            "numero": "XIII",
                                            "rotulo": "XIII",
                                            "linha": 6462,
                                            "texto": "outros direitos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "836º",
                                    "rotulo": "Art. 836º.",
                                    "linha": 6470,
                                    "caput": "Não se levará a efeito a penhora quando ficar evidente que o produto da execução dos bens encontrados será totalmente absorvido pelo pagamento das custas da execução.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6472,
                                            "texto": "Quando não encontrar bens penhoráveis, independentemente de determinação judicial expressa, o oficial de justiça descreverá na certidão os bens que guarnecem a residência ou o estabelecimento do executado, quando este for pessoa jurídica."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6474,
                                            "texto": "Elaborada a lista, o executado ou seu representante legal será nomeado depositário provisório de tais bens até ulterior determinação do juiz. Subseção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "837º",
                                    "rotulo": "Art. 837º.",
                                    "linha": 6479,
                                    "caput": "Obedecidas as normas de segurança instituídas sob critérios uniformes pelo Conselho Nacional de Justiça, a penhora de dinheiro e as averbações de penhoras de bens imóveis e móveis podem ser realizadas por meio eletrônico.",
                                    "rubrica": "Da Documentação da Penhora, de seu Registro e do Depósito",
                                    "linhaRubrica": 6477
                                },
                                {
                                    "numero": "838º",
                                    "rotulo": "Art. 838º.",
                                    "linha": 6481,
                                    "caput": "A penhora será realizada mediante auto ou termo, que conterá:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6483,
                                            "texto": "a indicação do dia, do mês, do ano e do lugar em que foi feita;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6485,
                                            "texto": "os nomes do exequente e do executado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6487,
                                            "texto": "a descrição dos bens penhorados, com as suas características;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6489,
                                            "texto": "a nomeação do depositário dos bens."
                                        }
                                    ]
                                },
                                {
                                    "numero": "839º",
                                    "rotulo": "Art. 839º.",
                                    "linha": 6491,
                                    "caput": "Considerar-se-á feita a penhora mediante a apreensão e o depósito dos bens, lavrando-se um só auto se as diligências forem concluídas no mesmo dia.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6493,
                                            "texto": "Havendo mais de uma penhora, serão lavrados autos individuais."
                                        }
                                    ]
                                },
                                {
                                    "numero": "840º",
                                    "rotulo": "Art. 840º.",
                                    "linha": 6495,
                                    "caput": "Serão preferencialmente depositados:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6503,
                                            "texto": "No caso do inciso II do caput , se não houver depositário judicial, os bens ficarão em poder do exequente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6505,
                                            "texto": "Os bens poderão ser depositados em poder do executado nos casos de difícil remoção ou quando anuir o exequente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6507,
                                            "texto": "As joias, as pedras e os objetos preciosos deverão ser depositados com registro do valor estimado de resgate."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6497,
                                            "texto": "as quantias em dinheiro, os papéis de crédito e as pedras e os metais preciosos, no Banco do Brasil, na Caixa Econômica Federal ou em banco do qual o Estado ou o Distrito Federal possua mais da metade do capital social integralizado, ou, na falta desses estabelecimentos, em qualquer instituição de crédito designada pelo juiz;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6499,
                                            "texto": "os móveis, os semoventes, os imóveis urbanos e os direitos aquisitivos sobre imóveis urbanos, em poder do depositário judicial;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6501,
                                            "texto": "os imóveis rurais, os direitos aquisitivos sobre imóveis rurais, as máquinas, os utensílios e os instrumentos necessários ou úteis à atividade agrícola, mediante caução idônea, em poder do executado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "841º",
                                    "rotulo": "Art. 841º.",
                                    "linha": 6509,
                                    "caput": "Formalizada a penhora por qualquer dos meios legais, dela será imediatamente intimado o executado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6511,
                                            "texto": "A intimação da penhora será feita ao advogado do executado ou à sociedade de advogados a que aquele pertença."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6513,
                                            "texto": "Se não houver constituído advogado nos autos, o executado será intimado pessoalmente, de preferência por via postal."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6515,
                                            "texto": "O disposto no § 1º não se aplica aos casos de penhora realizada na presença do executado, que se reputa intimado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6517,
                                            "texto": "Considera-se realizada a intimação a que se refere o § 2º quando o executado houver mudado de endereço sem prévia comunicação ao juízo, observado o disposto no parágrafo único do art. 274 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 274",
                                                    "href": "#art274",
                                                    "inicio": 179,
                                                    "fim": 187
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "842º",
                                    "rotulo": "Art. 842º.",
                                    "linha": 6519,
                                    "caput": "Recaindo a penhora sobre bem imóvel ou direito real sobre imóvel, será intimado também o cônjuge do executado, salvo se forem casados em regime de separação absoluta de bens."
                                },
                                {
                                    "numero": "843º",
                                    "rotulo": "Art. 843º.",
                                    "linha": 6521,
                                    "caput": "Tratando-se de penhora de bem indivisível, o equivalente à quota-parte do coproprietário ou do cônjuge alheio à execução recairá sobre o produto da alienação do bem.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6523,
                                            "texto": "É reservada ao coproprietário ou ao cônjuge não executado a preferência na arrematação do bem em igualdade de condições."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6525,
                                            "texto": "Não será levada a efeito expropriação por preço inferior ao da avaliação na qual o valor auferido seja incapaz de garantir, ao coproprietário ou ao cônjuge alheio à execução, o correspondente à sua quota-parte calculado sobre o valor da avaliação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "844º",
                                    "rotulo": "Art. 844º.",
                                    "linha": 6527,
                                    "caput": "Para presunção absoluta de conhecimento por terceiros, cabe ao exequente providenciar a averbação do arresto ou da penhora no registro competente, mediante apresentação de cópia do auto ou do termo, independentemente de mandado judicial. Subseção III"
                                },
                                {
                                    "numero": "845º",
                                    "rotulo": "Art. 845º.",
                                    "linha": 6532,
                                    "caput": "Efetuar-se-á a penhora onde se encontrem os bens, ainda que sob a posse, a detenção ou a guarda de terceiros.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6534,
                                            "texto": "A penhora de imóveis, independentemente de onde se localizem, quando apresentada certidão da respectiva matrícula, e a penhora de veículos automotores, quando apresentada certidão que ateste a sua existência, serão realizadas por termo nos autos."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6536,
                                            "texto": "Se o executado não tiver bens no foro do processo, não sendo possível a realização da penhora nos termos do § 1º, a execução será feita por carta, penhorando-se, avaliando-se e alienando-se os bens no foro da situação."
                                        }
                                    ],
                                    "rubrica": "Do Lugar de Realização da Penhora",
                                    "linhaRubrica": 6530
                                },
                                {
                                    "numero": "846º",
                                    "rotulo": "Art. 846º.",
                                    "linha": 6538,
                                    "caput": "Se o executado fechar as portas da casa a fim de obstar a penhora dos bens, o oficial de justiça comunicará o fato ao juiz, solicitando-lhe ordem de arrombamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6540,
                                            "texto": "Deferido o pedido, 2 (dois) oficiais de justiça cumprirão o mandado, arrombando cômodos e móveis em que se presuma estarem os bens, e lavrarão de tudo auto circunstanciado, que será assinado por 2 (duas) testemunhas presentes à diligência."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6542,
                                            "texto": "Sempre que necessário, o juiz requisitará força policial, a fim de auxiliar os oficiais de justiça na penhora dos bens."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6544,
                                            "texto": "Os oficiais de justiça lavrarão em duplicata o auto da ocorrência, entregando uma via ao escrivão ou ao chefe de secretaria, para ser juntada aos autos, e a outra à autoridade policial a quem couber a apuração criminal dos eventuais delitos de desobediência ou de resistência."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6546,
                                            "texto": "Do auto da ocorrência constará o rol de testemunhas, com a respectiva qualificação. Subseção IV"
                                        }
                                    ]
                                },
                                {
                                    "numero": "847º",
                                    "rotulo": "Art. 847º.",
                                    "linha": 6551,
                                    "caput": "O executado pode, no prazo de 10 (dez) dias contado da intimação da penhora, requerer a substituição do bem penhorado, desde que comprove que lhe será menos onerosa e não trará prejuízo ao exequente.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6553,
                                            "texto": "O juiz só autorizará a substituição se o executado:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6555,
                                                    "texto": "comprovar as respectivas matrículas e os registros por certidão do correspondente ofício, quanto aos bens imóveis;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6557,
                                                    "texto": "descrever os bens móveis, com todas as suas propriedades e características, bem como o estado deles e o lugar onde se encontram;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 6559,
                                                    "texto": "descrever os semoventes, com indicação de espécie, de número, de marca ou sinal e do local onde se encontram;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 6561,
                                                    "texto": "identificar os créditos, indicando quem seja o devedor, qual a origem da dívida, o título que a representa e a data do vencimento; e"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 6563,
                                                    "texto": "atribuir, em qualquer caso, valor aos bens indicados à penhora, além de especificar os ônus e os encargos a que estejam sujeitos."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6565,
                                            "texto": "Requerida a substituição do bem penhorado, o executado deve indicar onde se encontram os bens sujeitos à execução, exibir a prova de sua propriedade e a certidão negativa ou positiva de ônus, bem como abster-se de qualquer atitude que dificulte ou embarace a realização da penhora."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6567,
                                            "texto": "O executado somente poderá oferecer bem imóvel em substituição caso o requeira com a expressa anuência do cônjuge, salvo se o regime for o de separação absoluta de bens."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6569,
                                            "texto": "O juiz intimará o exequente para manifestar-se sobre o requerimento de substituição do bem penhorado."
                                        }
                                    ],
                                    "rubrica": "Das Modificações da Penhora",
                                    "linhaRubrica": 6549
                                },
                                {
                                    "numero": "848º",
                                    "rotulo": "Art. 848º.",
                                    "linha": 6571,
                                    "caput": "As partes poderão requerer a substituição da penhora se:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6587,
                                            "texto": "A penhora pode ser substituída por fiança bancária ou por seguro garantia judicial, em valor não inferior ao do débito constante da inicial, acrescido de trinta por cento."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6573,
                                            "texto": "ela não obedecer à ordem legal;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6575,
                                            "texto": "ela não incidir sobre os bens designados em lei, contrato ou ato judicial para o pagamento;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6577,
                                            "texto": "havendo bens no foro da execução, outros tiverem sido penhorados;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6579,
                                            "texto": "havendo bens livres, ela tiver recaído sobre bens já penhorados ou objeto de gravame;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6581,
                                            "texto": "ela incidir sobre bens de baixa liquidez;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6583,
                                            "texto": "fracassar a tentativa de alienação judicial do bem; ou"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6585,
                                            "texto": "o executado não indicar o valor dos bens ou omitir qualquer das indicações previstas em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "849º",
                                    "rotulo": "Art. 849º.",
                                    "linha": 6589,
                                    "caput": "Sempre que ocorrer a substituição dos bens inicialmente penhorados, será lavrado novo termo."
                                },
                                {
                                    "numero": "850º",
                                    "rotulo": "Art. 850º.",
                                    "linha": 6591,
                                    "caput": "Será admitida a redução ou a ampliação da penhora, bem como sua transferência para outros bens, se, no curso do processo, o valor de mercado dos bens penhorados sofrer alteração significativa."
                                },
                                {
                                    "numero": "851º",
                                    "rotulo": "Art. 851º.",
                                    "linha": 6593,
                                    "caput": "Não se procede à segunda penhora, salvo se:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6595,
                                            "texto": "a primeira for anulada;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6597,
                                            "texto": "executados os bens, o produto da alienação não bastar para o pagamento do exequente;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6599,
                                            "texto": "o exequente desistir da primeira penhora, por serem litigiosos os bens ou por estarem submetidos a constrição judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "852º",
                                    "rotulo": "Art. 852º.",
                                    "linha": 6601,
                                    "caput": "O juiz determinará a alienação antecipada dos bens penhorados quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6603,
                                            "texto": "se tratar de veículos automotores, de pedras e metais preciosos e de outros bens móveis sujeitos à depreciação ou à deterioração;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6605,
                                            "texto": "houver manifesta vantagem."
                                        }
                                    ]
                                },
                                {
                                    "numero": "853º",
                                    "rotulo": "Art. 853º.",
                                    "linha": 6607,
                                    "caput": "Quando uma das partes requerer alguma das medidas previstas nesta Subseção, o juiz ouvirá sempre a outra, no prazo de 3 (três) dias, antes de decidir.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6609,
                                            "texto": "O juiz decidirá de plano qualquer questão suscitada. Subseção V"
                                        }
                                    ]
                                },
                                {
                                    "numero": "854º",
                                    "rotulo": "Art. 854º.",
                                    "linha": 6614,
                                    "caput": "Para possibilitar a penhora de dinheiro em depósito ou em aplicação financeira, o juiz, a requerimento do exequente, sem dar ciência prévia do ato ao executado, determinará às instituições financeiras, por meio de sistema eletrônico gerido pela autoridade supervisora do sistema financeiro nacional, que torne indisponíveis ativos financeiros existentes em nome do executado, limitando-se a indisponibilidade ao valor indicado na execução.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6616,
                                            "texto": "No prazo de 24 (vinte e quatro) horas a contar da resposta, de ofício, o juiz determinará o cancelamento de eventual indisponibilidade excessiva, o que deverá ser cumprido pela instituição financeira em igual prazo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6618,
                                            "texto": "Tornados indisponíveis os ativos financeiros do executado, este será intimado na pessoa de seu advogado ou, não o tendo, pessoalmente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6620,
                                            "texto": "Incumbe ao executado, no prazo de 5 (cinco) dias, comprovar que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6622,
                                                    "texto": "as quantias tornadas indisponíveis são impenhoráveis;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6624,
                                                    "texto": "ainda remanesce indisponibilidade excessiva de ativos financeiros."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6626,
                                            "texto": "Acolhida qualquer das arguições dos incisos I e II do § 3º, o juiz determinará o cancelamento de eventual indisponibilidade irregular ou excessiva, a ser cumprido pela instituição financeira em 24 (vinte e quatro) horas."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6628,
                                            "texto": "Rejeitada ou não apresentada a manifestação do executado, converter-se-á a indisponibilidade em penhora, sem necessidade de lavratura de termo, devendo o juiz da execução determinar à instituição financeira depositária que, no prazo de 24 (vinte e quatro) horas, transfira o montante indisponível para conta vinculada ao juízo da execução."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 6630,
                                            "texto": "Realizado o pagamento da dívida por outro meio, o juiz determinará, imediatamente, por sistema eletrônico gerido pela autoridade supervisora do sistema financeiro nacional, a notificação da instituição financeira para que, em até 24 (vinte e quatro) horas, cancele a indisponibilidade."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 6632,
                                            "texto": "As transmissões das ordens de indisponibilidade, de seu cancelamento e de determinação de penhora previstas neste artigo far-se-ão por meio de sistema eletrônico gerido pela autoridade supervisora do sistema financeiro nacional."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 6634,
                                            "texto": "A instituição financeira será responsável pelos prejuízos causados ao executado em decorrência da indisponibilidade de ativos financeiros em valor superior ao indicado na execução ou pelo juiz, bem como na hipótese de não cancelamento da indisponibilidade no prazo de 24 (vinte e quatro) horas, quando assim determinar o juiz."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 6636,
                                            "texto": "Quando se tratar de execução contra partido político, o juiz, a requerimento do exequente, determinará às instituições financeiras, por meio de sistema eletrônico gerido por autoridade supervisora do sistema bancário, que tornem indisponíveis ativos financeiros somente em nome do órgão partidário que tenha contraído a dívida executada ou que tenha dado causa à violação de direito ou ao dano, ao qual cabe exclusivamente a responsabilidade pelos atos praticados, na forma da lei. Subseção VI"
                                        }
                                    ],
                                    "rubrica": "Da Penhora de Dinheiro em Depósito ou em Aplicação Financeira",
                                    "linhaRubrica": 6612
                                },
                                {
                                    "numero": "855º",
                                    "rotulo": "Art. 855º.",
                                    "linha": 6641,
                                    "caput": "Quando recair em crédito do executado, enquanto não ocorrer a hipótese prevista no art. 856 , considerar-se-á feita a penhora pela intimação:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6643,
                                            "texto": "ao terceiro devedor para que não pague ao executado, seu credor;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6645,
                                            "texto": "ao executado, credor do terceiro, para que não pratique ato de disposição do crédito."
                                        }
                                    ],
                                    "rubrica": "Da Penhora de Créditos",
                                    "linhaRubrica": 6639,
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 856",
                                            "href": "#art856",
                                            "inicio": 83,
                                            "fim": 91
                                        }
                                    ]
                                },
                                {
                                    "numero": "856º",
                                    "rotulo": "Art. 856º.",
                                    "linha": 6647,
                                    "caput": "A penhora de crédito representado por letra de câmbio, nota promissória, duplicata, cheque ou outros títulos far-se-á pela apreensão do documento, esteja ou não este em poder do executado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6649,
                                            "texto": "Se o título não for apreendido, mas o terceiro confessar a dívida, será este tido como depositário da importância."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6651,
                                            "texto": "O terceiro só se exonerará da obrigação depositando em juízo a importância da dívida."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6653,
                                            "texto": "Se o terceiro negar o débito em conluio com o executado, a quitação que este lhe der caracterizará fraude à execução."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6655,
                                            "texto": "A requerimento do exequente, o juiz determinará o comparecimento, em audiência especialmente designada, do executado e do terceiro, a fim de lhes tomar os depoimentos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "857º",
                                    "rotulo": "Art. 857º.",
                                    "linha": 6657,
                                    "caput": "Feita a penhora em direito e ação do executado, e não tendo ele oferecido embargos ou sendo estes rejeitados, o exequente ficará sub-rogado nos direitos do executado até a concorrência de seu crédito.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6659,
                                            "texto": "O exequente pode preferir, em vez da sub-rogação, a alienação judicial do direito penhorado, caso em que declarará sua vontade no prazo de 10 (dez) dias contado da realização da penhora."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6661,
                                            "texto": "A sub-rogação não impede o sub-rogado, se não receber o crédito do executado, de prosseguir na execução, nos mesmos autos, penhorando outros bens."
                                        }
                                    ]
                                },
                                {
                                    "numero": "858º",
                                    "rotulo": "Art. 858º.",
                                    "linha": 6663,
                                    "caput": "Quando a penhora recair sobre dívidas de dinheiro a juros, de direito a rendas ou de prestações periódicas, o exequente poderá levantar os juros, os rendimentos ou as prestações à medida que forem sendo depositados, abatendo-se do crédito as importâncias recebidas, conforme as regras de imputação do pagamento."
                                },
                                {
                                    "numero": "859º",
                                    "rotulo": "Art. 859º.",
                                    "linha": 6665,
                                    "caput": "Recaindo a penhora sobre direito a prestação ou a restituição de coisa determinada, o executado será intimado para, no vencimento, depositá-la, correndo sobre ela a execução."
                                },
                                {
                                    "numero": "860º",
                                    "rotulo": "Art. 860º.",
                                    "linha": 6667,
                                    "caput": "Quando o direito estiver sendo pleiteado em juízo, a penhora que recair sobre ele será averbada, com destaque, nos autos pertinentes ao direito e na ação correspondente à penhora, a fim de que esta seja efetivada nos bens que forem adjudicados ou que vierem a caber ao executado. Subseção VII"
                                },
                                {
                                    "numero": "861º",
                                    "rotulo": "Art. 861º.",
                                    "linha": 6672,
                                    "caput": "Penhoradas as quotas ou as ações de sócio em sociedade simples ou empresária, o juiz assinará prazo razoável, não superior a 3 (três) meses, para que a sociedade:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6680,
                                            "texto": "Para evitar a liquidação das quotas ou das ações, a sociedade poderá adquiri-las sem redução do capital social e com utilização de reservas, para manutenção em tesouraria."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6682,
                                            "texto": "O disposto no caput e no § 1º não se aplica à sociedade anônima de capital aberto, cujas ações serão adjudicadas ao exequente ou alienadas em bolsa de valores, conforme o caso."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6684,
                                            "texto": "Para os fins da liquidação de que trata o inciso III do caput , o juiz poderá, a requerimento do exequente ou da sociedade, nomear administrador, que deverá submeter à aprovação judicial a forma de liquidação."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6686,
                                            "texto": "O prazo previsto no caput poderá ser ampliado pelo juiz, se o pagamento das quotas ou das ações liquidadas:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6688,
                                                    "texto": "superar o valor do saldo de lucros ou reservas, exceto a legal, e sem diminuição do capital social, ou por doação; ou"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6690,
                                                    "texto": "colocar em risco a estabilidade financeira da sociedade simples ou empresária."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6692,
                                            "texto": "Caso não haja interesse dos demais sócios no exercício de direito de preferência, não ocorra a aquisição das quotas ou das ações pela sociedade e a liquidação do inciso III do caput seja excessivamente onerosa para a sociedade, o juiz poderá determinar o leilão judicial das quotas ou das ações. Subseção VIII"
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6674,
                                            "texto": "apresente balanço especial, na forma da lei;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6676,
                                            "texto": "ofereça as quotas ou as ações aos demais sócios, observado o direito de preferência legal ou contratual;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6678,
                                            "texto": "não havendo interesse dos sócios na aquisição das ações, proceda à liquidação das quotas ou das ações, depositando em juízo o valor apurado, em dinheiro."
                                        }
                                    ],
                                    "rubrica": "Da Penhora das Quotas ou das Ações de Sociedades Personificadas",
                                    "linhaRubrica": 6670
                                },
                                {
                                    "numero": "862º",
                                    "rotulo": "Art. 862º.",
                                    "linha": 6697,
                                    "caput": "Quando a penhora recair em estabelecimento comercial, industrial ou agrícola, bem como em semoventes, plantações ou edifícios em construção, o juiz nomeará administrador-depositário, determinando-lhe que apresente em 10 (dez) dias o plano de administração.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6699,
                                            "texto": "Ouvidas as partes, o juiz decidirá."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6701,
                                            "texto": "É lícito às partes ajustar a forma de administração e escolher o depositário, hipótese em que o juiz homologará por despacho a indicação."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6703,
                                            "texto": "Em relação aos edifícios em construção sob regime de incorporação imobiliária, a penhora somente poderá recair sobre as unidades imobiliárias ainda não comercializadas pelo incorporador."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6705,
                                            "texto": "Sendo necessário afastar o incorporador da administração da incorporação, será ela exercida pela comissão de representantes dos adquirentes ou, se se tratar de construção financiada, por empresa ou profissional indicado pela instituição fornecedora dos recursos para a obra, devendo ser ouvida, neste último caso, a comissão de representantes dos adquirentes."
                                        }
                                    ],
                                    "rubrica": "Da Penhora de Empresa, de Outros Estabelecimentos e de Semoventes",
                                    "linhaRubrica": 6695
                                },
                                {
                                    "numero": "863º",
                                    "rotulo": "Art. 863º.",
                                    "linha": 6707,
                                    "caput": "A penhora de empresa que funcione mediante concessão ou autorização far-se-á, conforme o valor do crédito, sobre a renda, sobre determinados bens ou sobre todo o patrimônio, e o juiz nomeará como depositário, de preferência, um de seus diretores.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6709,
                                            "texto": "Quando a penhora recair sobre a renda ou sobre determinados bens, o administrador-depositário apresentará a forma de administração e o esquema de pagamento, observando-se, quanto ao mais, o disposto em relação ao regime de penhora de frutos e rendimentos de coisa móvel e imóvel."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6711,
                                            "texto": "Recaindo a penhora sobre todo o patrimônio, prosseguirá a execução em seus ulteriores termos, ouvindo-se, antes da arrematação ou da adjudicação, o ente público que houver outorgado a concessão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "864º",
                                    "rotulo": "Art. 864º.",
                                    "linha": 6713,
                                    "caput": "A penhora de navio ou de aeronave não obsta que continuem navegando ou operando até a alienação, mas o juiz, ao conceder a autorização para tanto, não permitirá que saiam do porto ou do aeroporto antes que o executado faça o seguro usual contra riscos."
                                },
                                {
                                    "numero": "865º",
                                    "rotulo": "Art. 865º.",
                                    "linha": 6715,
                                    "caput": "A penhora de que trata esta Subseção somente será determinada se não houver outro meio eficaz para a efetivação do crédito. Subseção IX"
                                },
                                {
                                    "numero": "866º",
                                    "rotulo": "Art. 866º.",
                                    "linha": 6720,
                                    "caput": "Se o executado não tiver outros bens penhoráveis ou se, tendo-os, esses forem de difícil alienação ou insuficientes para saldar o crédito executado, o juiz poderá ordenar a penhora de percentual de faturamento de empresa.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6722,
                                            "texto": "O juiz fixará percentual que propicie a satisfação do crédito exequendo em tempo razoável, mas que não torne inviável o exercício da atividade empresarial."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6724,
                                            "texto": "O juiz nomeará administrador-depositário, o qual submeterá à aprovação judicial a forma de sua atuação e prestará contas mensalmente, entregando em juízo as quantias recebidas, com os respectivos balancetes mensais, a fim de serem imputadas no pagamento da dívida."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6726,
                                            "texto": "Na penhora de percentual de faturamento de empresa, observar-se-á, no que couber, o disposto quanto ao regime de penhora de frutos e rendimentos de coisa móvel e imóvel. Subseção X"
                                        }
                                    ],
                                    "rubrica": "Da Penhora de Percentual de Faturamento de Empresa",
                                    "linhaRubrica": 6718
                                },
                                {
                                    "numero": "867º",
                                    "rotulo": "Art. 867º.",
                                    "linha": 6731,
                                    "caput": "O juiz pode ordenar a penhora de frutos e rendimentos de coisa móvel ou imóvel quando a considerar mais eficiente para o recebimento do crédito e menos gravosa ao executado.",
                                    "rubrica": "Da Penhora de Frutos e Rendimentos de Coisa Móvel ou Imóvel",
                                    "linhaRubrica": 6729
                                },
                                {
                                    "numero": "868º",
                                    "rotulo": "Art. 868º.",
                                    "linha": 6733,
                                    "caput": "Ordenada a penhora de frutos e rendimentos, o juiz nomeará administrador-depositário, que será investido de todos os poderes que concernem à administração do bem e à fruição de seus frutos e utilidades, perdendo o executado o direito de gozo do bem, até que o exequente seja pago do principal, dos juros, das custas e dos honorários advocatícios.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6735,
                                            "texto": "A medida terá eficácia em relação a terceiros a partir da publicação da decisão que a conceda ou de sua averbação no ofício imobiliário, em caso de imóveis."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6737,
                                            "texto": "O exequente providenciará a averbação no ofício imobiliário mediante a apresentação de certidão de inteiro teor do ato, independentemente de mandado judicial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "869º",
                                    "rotulo": "Art. 869º.",
                                    "linha": 6739,
                                    "caput": "O juiz poderá nomear administrador-depositário o exequente ou o executado, ouvida a parte contrária, e, não havendo acordo, nomeará profissional qualificado para o desempenho da função.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6741,
                                            "texto": "O administrador submeterá à aprovação judicial a forma de administração e a de prestar contas periodicamente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6743,
                                            "texto": "Havendo discordância entre as partes ou entre essas e o administrador, o juiz decidirá a melhor forma de administração do bem."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6745,
                                            "texto": "Se o imóvel estiver arrendado, o inquilino pagará o aluguel diretamente ao exequente, salvo se houver administrador."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6747,
                                            "texto": "O exequente ou o administrador poderá celebrar locação do móvel ou do imóvel, ouvido o executado."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6749,
                                            "texto": "As quantias recebidas pelo administrador serão entregues ao exequente, a fim de serem imputadas ao pagamento da dívida."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 6751,
                                            "texto": "O exequente dará ao executado, por termo nos autos, quitação das quantias recebidas. Subseção XI"
                                        }
                                    ]
                                },
                                {
                                    "numero": "870º",
                                    "rotulo": "Art. 870º.",
                                    "linha": 6756,
                                    "caput": "A avaliação será feita pelo oficial de justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6758,
                                            "texto": "Se forem necessários conhecimentos especializados e o valor da execução o comportar, o juiz nomeará avaliador, fixando-lhe prazo não superior a 10 (dez) dias para entrega do laudo."
                                        }
                                    ],
                                    "rubrica": "Da Avaliação",
                                    "linhaRubrica": 6754
                                },
                                {
                                    "numero": "871º",
                                    "rotulo": "Art. 871º.",
                                    "linha": 6760,
                                    "caput": "Não se procederá à avaliação quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6770,
                                            "texto": "Ocorrendo a hipótese do inciso I deste artigo, a avaliação poderá ser realizada quando houver fundada dúvida do juiz quanto ao real valor do bem."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6762,
                                            "texto": "uma das partes aceitar a estimativa feita pela outra;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6764,
                                            "texto": "se tratar de títulos ou de mercadorias que tenham cotação em bolsa, comprovada por certidão ou publicação no órgão oficial;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6766,
                                            "texto": "se tratar de títulos da dívida pública, de ações de sociedades e de títulos de crédito negociáveis em bolsa, cujo valor será o da cotação oficial do dia, comprovada por certidão ou publicação no órgão oficial;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6768,
                                            "texto": "se tratar de veículos automotores ou de outros bens cujo preço médio de mercado possa ser conhecido por meio de pesquisas realizadas por órgãos oficiais ou de anúncios de venda divulgados em meios de comunicação, caso em que caberá a quem fizer a nomeação o encargo de comprovar a cotação de mercado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "872º",
                                    "rotulo": "Art. 872º.",
                                    "linha": 6772,
                                    "caput": "A avaliação realizada pelo oficial de justiça constará de vistoria e de laudo anexados ao auto de penhora ou, em caso de perícia realizada por avaliador, de laudo apresentado no prazo fixado pelo juiz, devendo-se, em qualquer hipótese, especificar:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6778,
                                            "texto": "Quando o imóvel for suscetível de cômoda divisão, a avaliação, tendo em conta o crédito reclamado, será realizada em partes, sugerindo-se, com a apresentação de memorial descritivo, os possíveis desmembramentos para alienação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6780,
                                            "texto": "Realizada a avaliação e, sendo o caso, apresentada a proposta de desmembramento, as partes serão ouvidas no prazo de 5 (cinco) dias."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6774,
                                            "texto": "os bens, com as suas características, e o estado em que se encontram;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6776,
                                            "texto": "o valor dos bens."
                                        }
                                    ]
                                },
                                {
                                    "numero": "873º",
                                    "rotulo": "Art. 873º.",
                                    "linha": 6782,
                                    "caput": "É admitida nova avaliação quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6790,
                                            "texto": "Aplica-se o art. 480 à nova avaliação prevista no inciso III do caput deste artigo.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 480",
                                                    "href": "#art480",
                                                    "inicio": 12,
                                                    "fim": 20
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6784,
                                            "texto": "qualquer das partes arguir, fundamentadamente, a ocorrência de erro na avaliação ou dolo do avaliador;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6786,
                                            "texto": "se verificar, posteriormente à avaliação, que houve majoração ou diminuição no valor do bem;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6788,
                                            "texto": "o juiz tiver fundada dúvida sobre o valor atribuído ao bem na primeira avaliação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "874º",
                                    "rotulo": "Art. 874º.",
                                    "linha": 6792,
                                    "caput": "Após a avaliação, o juiz poderá, a requerimento do interessado e ouvida a parte contrária, mandar:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6794,
                                            "texto": "reduzir a penhora aos bens suficientes ou transferi-la para outros, se o valor dos bens penhorados for consideravelmente superior ao crédito do exequente e dos acessórios;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6796,
                                            "texto": "ampliar a penhora ou transferi-la para outros bens mais valiosos, se o valor dos bens penhorados for inferior ao crédito do exequente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "875º",
                                    "rotulo": "Art. 875º.",
                                    "linha": 6798,
                                    "caput": "Realizadas a penhora e a avaliação, o juiz dará início aos atos de expropriação do bem. Seção IV Da Expropriação de Bens Subseção I"
                                },
                                {
                                    "numero": "876º",
                                    "rotulo": "Art. 876º.",
                                    "linha": 6806,
                                    "caput": "É lícito ao exequente, oferecendo preço não inferior ao da avaliação, requerer que lhe sejam adjudicados os bens penhorados.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6808,
                                            "texto": "Requerida a adjudicação, o executado será intimado do pedido:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6810,
                                                    "texto": "pelo Diário da Justiça, na pessoa de seu advogado constituído nos autos;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6812,
                                                    "texto": "por carta com aviso de recebimento, quando representado pela Defensoria Pública ou quando não tiver procurador constituído nos autos;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 6814,
                                                    "texto": "por meio eletrônico, quando, sendo o caso do § 1º do art. 246 , não tiver procurador constituído nos autos."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6816,
                                            "texto": "Considera-se realizada a intimação quando o executado houver mudado de endereço sem prévia comunicação ao juízo, observado o disposto no art. 274, parágrafo único .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 274",
                                                    "href": "#art274",
                                                    "inicio": 137,
                                                    "fim": 145
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6818,
                                            "texto": "Se o executado, citado por edital, não tiver procurador constituído nos autos, é dispensável a intimação prevista no § 1º."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6820,
                                            "texto": "Se o valor do crédito for:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6822,
                                                    "texto": "inferior ao dos bens, o requerente da adjudicação depositará de imediato a diferença, que ficará à disposição do executado;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6824,
                                                    "texto": "superior ao dos bens, a execução prosseguirá pelo saldo remanescente."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6826,
                                            "texto": "Idêntico direito pode ser exercido por aqueles indicados no art. 889, incisos II a VIII , pelos credores concorrentes que hajam penhorado o mesmo bem, pelo cônjuge, pelo companheiro, pelos descendentes ou pelos ascendentes do executado.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 889, incisos II a VIII",
                                                    "href": "#art889ii",
                                                    "inicio": 60,
                                                    "fim": 87
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 6828,
                                            "texto": "Se houver mais de um pretendente, proceder-se-á a licitação entre eles, tendo preferência, em caso de igualdade de oferta, o cônjuge, o companheiro, o descendente ou o ascendente, nessa ordem."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 6830,
                                            "texto": "No caso de penhora de quota social ou de ação de sociedade anônima fechada realizada em favor de exequente alheio à sociedade, esta será intimada, ficando responsável por informar aos sócios a ocorrência da penhora, assegurando-se a estes a preferência."
                                        }
                                    ],
                                    "rubrica": "Da Adjudicação",
                                    "linhaRubrica": 6804
                                },
                                {
                                    "numero": "877º",
                                    "rotulo": "Art. 877º.",
                                    "linha": 6832,
                                    "caput": "Transcorrido o prazo de 5 (cinco) dias, contado da última intimação, e decididas eventuais questões, o juiz ordenará a lavratura do auto de adjudicação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6834,
                                            "texto": "Considera-se perfeita e acabada a adjudicação com a lavratura e a assinatura do auto pelo juiz, pelo adjudicatário, pelo escrivão ou chefe de secretaria, e, se estiver presente, pelo executado, expedindo-se:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6836,
                                                    "texto": "a carta de adjudicação e o mandado de imissão na posse, quando se tratar de bem imóvel;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6838,
                                                    "texto": "a ordem de entrega ao adjudicatário, quando se tratar de bem móvel."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6840,
                                            "texto": "A carta de adjudicação conterá a descrição do imóvel, com remissão à sua matrícula e aos seus registros, a cópia do auto de adjudicação e a prova de quitação do imposto de transmissão."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6842,
                                            "texto": "No caso de penhora de bem hipotecado, o executado poderá remi-lo até a assinatura do auto de adjudicação, oferecendo preço igual ao da avaliação, se não tiver havido licitantes, ou ao do maior lance oferecido."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6844,
                                            "texto": "Na hipótese de falência ou de insolvência do devedor hipotecário, o direito de remição previsto no § 3º será deferido à massa ou aos credores em concurso, não podendo o exequente recusar o preço da avaliação do imóvel."
                                        }
                                    ]
                                },
                                {
                                    "numero": "878º",
                                    "rotulo": "Art. 878º.",
                                    "linha": 6846,
                                    "caput": "Frustradas as tentativas de alienação do bem, será reaberta oportunidade para requerimento de adjudicação, caso em que também se poderá pleitear a realização de nova avaliação. Subseção II"
                                },
                                {
                                    "numero": "879º",
                                    "rotulo": "Art. 879º.",
                                    "linha": 6851,
                                    "caput": "A alienação far-se-á:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6853,
                                            "texto": "por iniciativa particular;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6855,
                                            "texto": "em leilão judicial eletrônico ou presencial."
                                        }
                                    ],
                                    "rubrica": "Da Alienação",
                                    "linhaRubrica": 6849
                                },
                                {
                                    "numero": "880º",
                                    "rotulo": "Art. 880º.",
                                    "linha": 6857,
                                    "caput": "Não efetivada a adjudicação, o exequente poderá requerer a alienação por sua própria iniciativa ou por intermédio de corretor ou leiloeiro público credenciado perante o órgão judiciário.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6859,
                                            "texto": "O juiz fixará o prazo em que a alienação deve ser efetivada, a forma de publicidade, o preço mínimo, as condições de pagamento, as garantias e, se for o caso, a comissão de corretagem."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6861,
                                            "texto": "A alienação será formalizada por termo nos autos, com a assinatura do juiz, do exequente, do adquirente e, se estiver presente, do executado, expedindo-se:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 6863,
                                                    "texto": "a carta de alienação e o mandado de imissão na posse, quando se tratar de bem imóvel;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 6865,
                                                    "texto": "a ordem de entrega ao adquirente, quando se tratar de bem móvel."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6867,
                                            "texto": "Os tribunais poderão editar disposições complementares sobre o procedimento da alienação prevista neste artigo, admitindo, quando for o caso, o concurso de meios eletrônicos, e dispor sobre o credenciamento dos corretores e leiloeiros públicos, os quais deverão estar em exercício profissional por não menos que 3 (três) anos."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6869,
                                            "texto": "Nas localidades em que não houver corretor ou leiloeiro público credenciado nos termos do § 3º, a indicação será de livre escolha do exequente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "881º",
                                    "rotulo": "Art. 881º.",
                                    "linha": 6871,
                                    "caput": "A alienação far-se-á em leilão judicial se não efetivada a adjudicação ou a alienação por iniciativa particular.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6873,
                                            "texto": "O leilão do bem penhorado será realizado por leiloeiro público."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6875,
                                            "texto": "Ressalvados os casos de alienação a cargo de corretores de bolsa de valores, todos os demais bens serão alienados em leilão público."
                                        }
                                    ]
                                },
                                {
                                    "numero": "882º",
                                    "rotulo": "Art. 882º.",
                                    "linha": 6877,
                                    "caput": "Não sendo possível a sua realização por meio eletrônico, o leilão será presencial.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6879,
                                            "texto": "A alienação judicial por meio eletrônico será realizada, observando-se as garantias processuais das partes, de acordo com regulamentação específica do Conselho Nacional de Justiça."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6881,
                                            "texto": "A alienação judicial por meio eletrônico deverá atender aos requisitos de ampla publicidade, autenticidade e segurança, com observância das regras estabelecidas na legislação sobre certificação digital."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6883,
                                            "texto": "O leilão presencial será realizado no local designado pelo juiz."
                                        }
                                    ]
                                },
                                {
                                    "numero": "883º",
                                    "rotulo": "Art. 883º.",
                                    "linha": 6885,
                                    "caput": "Caberá ao juiz a designação do leiloeiro público, que poderá ser indicado pelo exequente."
                                },
                                {
                                    "numero": "884º",
                                    "rotulo": "Art. 884º.",
                                    "linha": 6887,
                                    "caput": "Incumbe ao leiloeiro público:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6899,
                                            "texto": "O leiloeiro tem o direito de receber do arrematante a comissão estabelecida em lei ou arbitrada pelo juiz."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6889,
                                            "texto": "publicar o edital, anunciando a alienação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6891,
                                            "texto": "realizar o leilão onde se encontrem os bens ou no lugar designado pelo juiz;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6893,
                                            "texto": "expor aos pretendentes os bens ou as amostras das mercadorias;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6895,
                                            "texto": "receber e depositar, dentro de 1 (um) dia, à ordem do juiz, o produto da alienação;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6897,
                                            "texto": "prestar contas nos 2 (dois) dias subsequentes ao depósito."
                                        }
                                    ]
                                },
                                {
                                    "numero": "885º",
                                    "rotulo": "Art. 885º.",
                                    "linha": 6901,
                                    "caput": "O juiz da execução estabelecerá o preço mínimo, as condições de pagamento e as garantias que poderão ser prestadas pelo arrematante."
                                },
                                {
                                    "numero": "886º",
                                    "rotulo": "Art. 886º.",
                                    "linha": 6903,
                                    "caput": "O leilão será precedido de publicação de edital, que conterá:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6917,
                                            "texto": "No caso de títulos da dívida pública e de títulos negociados em bolsa, constará do edital o valor da última cotação."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6905,
                                            "texto": "a descrição do bem penhorado, com suas características, e, tratando-se de imóvel, sua situação e suas divisas, com remissão à matrícula e aos registros;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6907,
                                            "texto": "o valor pelo qual o bem foi avaliado, o preço mínimo pelo qual poderá ser alienado, as condições de pagamento e, se for o caso, a comissão do leiloeiro designado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6909,
                                            "texto": "o lugar onde estiverem os móveis, os veículos e os semoventes e, tratando-se de créditos ou direitos, a identificação dos autos do processo em que foram penhorados;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6911,
                                            "texto": "o sítio, na rede mundial de computadores, e o período em que se realizará o leilão, salvo se este se der de modo presencial, hipótese em que serão indicados o local, o dia e a hora de sua realização;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6913,
                                            "texto": "a indicação de local, dia e hora de segundo leilão presencial, para a hipótese de não haver interessado no primeiro;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6915,
                                            "texto": "menção da existência de ônus, recurso ou processo pendente sobre os bens a serem leiloados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "887º",
                                    "rotulo": "Art. 887º.",
                                    "linha": 6919,
                                    "caput": "O leiloeiro público designado adotará providências para a ampla divulgação da alienação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6921,
                                            "texto": "A publicação do edital deverá ocorrer pelo menos 5 (cinco) dias antes da data marcada para o leilão."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6923,
                                            "texto": "O edital será publicado na rede mundial de computadores, em sítio designado pelo juízo da execução, e conterá descrição detalhada e, sempre que possível, ilustrada dos bens, informando expressamente se o leilão se realizará de forma eletrônica ou presencial."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6925,
                                            "texto": "Não sendo possível a publicação na rede mundial de computadores ou considerando o juiz, em atenção às condições da sede do juízo, que esse modo de divulgação é insuficiente ou inadequado, o edital será afixado em local de costume e publicado, em resumo, pelo menos uma vez em jornal de ampla circulação local."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 6927,
                                            "texto": "Atendendo ao valor dos bens e às condições da sede do juízo, o juiz poderá alterar a forma e a frequência da publicidade na imprensa, mandar publicar o edital em local de ampla circulação de pessoas e divulgar avisos em emissora de rádio ou televisão local, bem como em sítios distintos do indicado no § 2º."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 6929,
                                            "texto": "Os editais de leilão de imóveis e de veículos automotores serão publicados pela imprensa ou por outros meios de divulgação, preferencialmente na seção ou no local reservados à publicidade dos respectivos negócios."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 6931,
                                            "texto": "O juiz poderá determinar a reunião de publicações em listas referentes a mais de uma execução."
                                        }
                                    ]
                                },
                                {
                                    "numero": "888º",
                                    "rotulo": "Art. 888º.",
                                    "linha": 6933,
                                    "caput": "Não se realizando o leilão por qualquer motivo, o juiz mandará publicar a transferência, observando-se o disposto no art. 887 .",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6935,
                                            "texto": "O escrivão, o chefe de secretaria ou o leiloeiro que culposamente der causa à transferência responde pelas despesas da nova publicação, podendo o juiz aplicar-lhe a pena de suspensão por 5 (cinco) dias a 3 (três) meses, em procedimento administrativo regular."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 887",
                                            "href": "#art887",
                                            "inicio": 117,
                                            "fim": 125
                                        }
                                    ]
                                },
                                {
                                    "numero": "889º",
                                    "rotulo": "Art. 889º.",
                                    "linha": 6937,
                                    "caput": "Serão cientificados da alienação judicial, com pelo menos 5 (cinco) dias de antecedência:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6955,
                                            "texto": "Se o executado for revel e não tiver advogado constituído, não constando dos autos seu endereço atual ou, ainda, não sendo ele encontrado no endereço constante do processo, a intimação considerar-se-á feita por meio do próprio edital de leilão."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6939,
                                            "texto": "o executado, por meio de seu advogado ou, se não tiver procurador constituído nos autos, por carta registrada, mandado, edital ou outro meio idôneo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6941,
                                            "texto": "o coproprietário de bem indivisível do qual tenha sido penhorada fração ideal;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6943,
                                            "texto": "o titular de usufruto, uso, habitação, enfiteuse, direito de superfície, concessão de uso especial para fins de moradia ou concessão de direito real de uso, quando a penhora recair sobre bem gravado com tais direitos reais;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6945,
                                            "texto": "o proprietário do terreno submetido ao regime de direito de superfície, enfiteuse, concessão de uso especial para fins de moradia ou concessão de direito real de uso, quando a penhora recair sobre tais direitos reais;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6947,
                                            "texto": "o credor pignoratício, hipotecário, anticrético, fiduciário ou com penhora anteriormente averbada, quando a penhora recair sobre bens com tais gravames, caso não seja o credor, de qualquer modo, parte na execução;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6949,
                                            "texto": "o promitente comprador, quando a penhora recair sobre bem em relação ao qual haja promessa de compra e venda registrada;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 6951,
                                            "texto": "o promitente vendedor, quando a penhora recair sobre direito aquisitivo derivado de promessa de compra e venda registrada;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 6953,
                                            "texto": "a União, o Estado e o Município, no caso de alienação de bem tombado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "890º",
                                    "rotulo": "Art. 890º.",
                                    "linha": 6957,
                                    "caput": "Pode oferecer lance quem estiver na livre administração de seus bens, com exceção:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6959,
                                            "texto": "dos tutores, dos curadores, dos testamenteiros, dos administradores ou dos liquidantes, quanto aos bens confiados à sua guarda e à sua responsabilidade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6961,
                                            "texto": "dos mandatários, quanto aos bens de cuja administração ou alienação estejam encarregados;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 6963,
                                            "texto": "do juiz, do membro do Ministério Público e da Defensoria Pública, do escrivão, do chefe de secretaria e dos demais servidores e auxiliares da justiça, em relação aos bens e direitos objeto de alienação na localidade onde servirem ou a que se estender a sua autoridade;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 6965,
                                            "texto": "dos servidores públicos em geral, quanto aos bens ou aos direitos da pessoa jurídica a que servirem ou que estejam sob sua administração direta ou indireta;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 6967,
                                            "texto": "dos leiloeiros e seus prepostos, quanto aos bens de cuja venda estejam encarregados;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 6969,
                                            "texto": "dos advogados de qualquer das partes."
                                        }
                                    ]
                                },
                                {
                                    "numero": "891º",
                                    "rotulo": "Art. 891º.",
                                    "linha": 6971,
                                    "caput": "Não será aceito lance que ofereça preço vil.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 6973,
                                            "texto": "Considera-se vil o preço inferior ao mínimo estipulado pelo juiz e constante do edital, e, não tendo sido fixado preço mínimo, considera-se vil o preço inferior a cinquenta por cento do valor da avaliação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "892º",
                                    "rotulo": "Art. 892º.",
                                    "linha": 6975,
                                    "caput": "Salvo pronunciamento judicial em sentido diverso, o pagamento deverá ser realizado de imediato pelo arrematante, por depósito judicial ou por meio eletrônico.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6977,
                                            "texto": "Se o exequente arrematar os bens e for o único credor, não estará obrigado a exibir o preço, mas, se o valor dos bens exceder ao seu crédito, depositará, dentro de 3 (três) dias, a diferença, sob pena de tornar-se sem efeito a arrematação, e, nesse caso, realizar-se-á novo leilão, à custa do exequente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6979,
                                            "texto": "Se houver mais de um pretendente, proceder-se-á entre eles à licitação, e, no caso de igualdade de oferta, terá preferência o cônjuge, o companheiro, o descendente ou o ascendente do executado, nessa ordem."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 6981,
                                            "texto": "No caso de leilão de bem tombado, a União, os Estados e os Municípios terão, nessa ordem, o direito de preferência na arrematação, em igualdade de oferta."
                                        }
                                    ]
                                },
                                {
                                    "numero": "893º",
                                    "rotulo": "Art. 893º.",
                                    "linha": 6983,
                                    "caput": "Se o leilão for de diversos bens e houver mais de um lançador, terá preferência aquele que se propuser a arrematá-los todos, em conjunto, oferecendo, para os bens que não tiverem lance, preço igual ao da avaliação e, para os demais, preço igual ao do maior lance que, na tentativa de arrematação individualizada, tenha sido oferecido para eles."
                                },
                                {
                                    "numero": "894º",
                                    "rotulo": "Art. 894º.",
                                    "linha": 6985,
                                    "caput": "Quando o imóvel admitir cômoda divisão, o juiz, a requerimento do executado, ordenará a alienação judicial de parte dele, desde que suficiente para o pagamento do exequente e para a satisfação das despesas da execução.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6987,
                                            "texto": "Não havendo lançador, far-se-á a alienação do imóvel em sua integridade."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6989,
                                            "texto": "A alienação por partes deverá ser requerida a tempo de permitir a avaliação das glebas destacadas e sua inclusão no edital, e, nesse caso, caberá ao executado instruir o requerimento com planta e memorial descritivo subscritos por profissional habilitado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "895º",
                                    "rotulo": "Art. 895º.",
                                    "linha": 6991,
                                    "caput": "O interessado em adquirir o bem penhorado em prestações poderá apresentar, por escrito:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 6997,
                                            "texto": "A proposta conterá, em qualquer hipótese, oferta de pagamento de pelo menos vinte e cinco por cento do valor do lance à vista e o restante parcelado em até 30 (trinta) meses, garantido por caução idônea, quando se tratar de móveis, e por hipoteca do próprio bem, quando se tratar de imóveis."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 6999,
                                            "texto": "As propostas para aquisição em prestações indicarão o prazo, a modalidade, o indexador de correção monetária e as condições de pagamento do saldo."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7001,
                                            "texto": "No caso de atraso no pagamento de qualquer das prestações, incidirá multa de dez por cento sobre a soma da parcela inadimplida com as parcelas vincendas."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7003,
                                            "texto": "O inadimplemento autoriza o exequente a pedir a resolução da arrematação ou promover, em face do arrematante, a execução do valor devido, devendo ambos os pedidos ser formulados nos autos da execução em que se deu a arrematação."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7005,
                                            "texto": "A apresentação da proposta prevista neste artigo não suspende o leilão."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 7007,
                                            "texto": "A proposta de pagamento do lance à vista sempre prevalecerá sobre as propostas de pagamento parcelado."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 7009,
                                            "texto": "Havendo mais de uma proposta de pagamento parcelado:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7011,
                                                    "texto": "em diferentes condições, o juiz decidirá pela mais vantajosa, assim compreendida, sempre, a de maior valor;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7013,
                                                    "texto": "em iguais condições, o juiz decidirá pela formulada em primeiro lugar."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 7015,
                                            "texto": "No caso de arrematação a prazo, os pagamentos feitos pelo arrematante pertencerão ao exequente até o limite de seu crédito, e os subsequentes, ao executado."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 6993,
                                            "texto": "até o início do primeiro leilão, proposta de aquisição do bem por valor não inferior ao da avaliação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 6995,
                                            "texto": "até o início do segundo leilão, proposta de aquisição do bem por valor que não seja considerado vil."
                                        }
                                    ]
                                },
                                {
                                    "numero": "896º",
                                    "rotulo": "Art. 896º.",
                                    "linha": 7017,
                                    "caput": "Quando o imóvel de incapaz não alcançar em leilão pelo menos oitenta por cento do valor da avaliação, o juiz o confiará à guarda e à administração de depositário idôneo, adiando a alienação por prazo não superior a 1 (um) ano.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7019,
                                            "texto": "Se, durante o adiamento, algum pretendente assegurar, mediante caução idônea, o preço da avaliação, o juiz ordenará a alienação em leilão."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7021,
                                            "texto": "Se o pretendente à arrematação se arrepender, o juiz impor-lhe-á multa de vinte por cento sobre o valor da avaliação, em benefício do incapaz, valendo a decisão como título executivo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7023,
                                            "texto": "Sem prejuízo do disposto nos §§ 1º e 2º, o juiz poderá autorizar a locação do imóvel no prazo do adiamento."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7025,
                                            "texto": "Findo o prazo do adiamento, o imóvel será submetido a novo leilão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "897º",
                                    "rotulo": "Art. 897º.",
                                    "linha": 7027,
                                    "caput": "Se o arrematante ou seu fiador não pagar o preço no prazo estabelecido, o juiz impor-lhe-á, em favor do exequente, a perda da caução, voltando os bens a novo leilão, do qual não serão admitidos a participar o arrematante e o fiador remissos."
                                },
                                {
                                    "numero": "898º",
                                    "rotulo": "Art. 898º.",
                                    "linha": 7029,
                                    "caput": "O fiador do arrematante que pagar o valor do lance e a multa poderá requerer que a arrematação lhe seja transferida."
                                },
                                {
                                    "numero": "899º",
                                    "rotulo": "Art. 899º.",
                                    "linha": 7031,
                                    "caput": "Será suspensa a arrematação logo que o produto da alienação dos bens for suficiente para o pagamento do credor e para a satisfação das despesas da execução."
                                },
                                {
                                    "numero": "900º",
                                    "rotulo": "Art. 900º.",
                                    "linha": 7033,
                                    "caput": "O leilão prosseguirá no dia útil imediato, à mesma hora em que teve início, independentemente de novo edital, se for ultrapassado o horário de expediente forense."
                                },
                                {
                                    "numero": "901º",
                                    "rotulo": "Art. 901º.",
                                    "linha": 7035,
                                    "caput": "A arrematação constará de auto que será lavrado de imediato e poderá abranger bens penhorados em mais de uma execução, nele mencionadas as condições nas quais foi alienado o bem.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7037,
                                            "texto": "A ordem de entrega do bem móvel ou a carta de arrematação do bem imóvel, com o respectivo mandado de imissão na posse, será expedida depois de efetuado o depósito ou prestadas as garantias pelo arrematante, bem como realizado o pagamento da comissão do leiloeiro e das demais despesas da execução."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7039,
                                            "texto": "A carta de arrematação conterá a descrição do imóvel, com remissão à sua matrícula ou individuação e aos seus registros, a cópia do auto de arrematação e a prova de pagamento do imposto de transmissão, além da indicação da existência de eventual ônus real ou gravame."
                                        }
                                    ]
                                },
                                {
                                    "numero": "902º",
                                    "rotulo": "Art. 902º.",
                                    "linha": 7041,
                                    "caput": "No caso de leilão de bem hipotecado, o executado poderá remi-lo até a assinatura do auto de arrematação, oferecendo preço igual ao do maior lance oferecido.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7043,
                                            "texto": "No caso de falência ou insolvência do devedor hipotecário, o direito de remição previsto no caput defere-se à massa ou aos credores em concurso, não podendo o exequente recusar o preço da avaliação do imóvel."
                                        }
                                    ]
                                },
                                {
                                    "numero": "903º",
                                    "rotulo": "Art. 903º.",
                                    "linha": 7045,
                                    "caput": "Qualquer que seja a modalidade de leilão, assinado o auto pelo juiz, pelo arrematante e pelo leiloeiro, a arrematação será considerada perfeita, acabada e irretratável, ainda que venham a ser julgados procedentes os embargos do executado ou a ação autônoma de que trata o § 4º deste artigo, assegurada a possibilidade de reparação pelos prejuízos sofridos.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7047,
                                            "texto": "Ressalvadas outras situações previstas neste Código, a arrematação poderá, no entanto, ser:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7049,
                                                    "texto": "invalidada, quando realizada por preço vil ou com outro vício;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7051,
                                                    "texto": "considerada ineficaz, se não observado o disposto no art. 804 ;",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 804",
                                                            "href": "#art804",
                                                            "inicio": 53,
                                                            "fim": 61
                                                        }
                                                    ]
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 7053,
                                                    "texto": "resolvida, se não for pago o preço ou se não for prestada a caução."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7055,
                                            "texto": "O juiz decidirá acerca das situações referidas no § 1º, se for provocado em até 10 (dez) dias após o aperfeiçoamento da arrematação."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7057,
                                            "texto": "Passado o prazo previsto no § 2º sem que tenha havido alegação de qualquer das situações previstas no § 1º, será expedida a carta de arrematação e, conforme o caso, a ordem de entrega ou mandado de imissão na posse."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7059,
                                            "texto": "Após a expedição da carta de arrematação ou da ordem de entrega, a invalidação da arrematação poderá ser pleiteada por ação autônoma, em cujo processo o arrematante figurará como litisconsorte necessário."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7061,
                                            "texto": "O arrematante poderá desistir da arrematação, sendo-lhe imediatamente devolvido o depósito que tiver feito:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7063,
                                                    "texto": "se provar, nos 10 (dez) dias seguintes, a existência de ônus real ou gravame não mencionado no edital;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7065,
                                                    "texto": "se, antes de expedida a carta de arrematação ou a ordem de entrega, o executado alegar alguma das situações previstas no § 1º ;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 7067,
                                                    "texto": "uma vez citado para responder a ação autônoma de que trata o § 4º deste artigo, desde que apresente a desistência no prazo de que dispõe para responder a essa ação."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7069,
                                            "texto": "Considera-se ato atentatório à dignidade da justiça a suscitação infundada de vício com o objetivo de ensejar a desistência do arrematante, devendo o suscitante ser condenado, sem prejuízo da responsabilidade por perdas e danos, ao pagamento de multa, a ser fixada pelo juiz e devida ao exequente, em montante não superior a vinte por cento do valor atualizado do bem. Seção V"
                                        }
                                    ]
                                },
                                {
                                    "numero": "904º",
                                    "rotulo": "Art. 904º.",
                                    "linha": 7074,
                                    "caput": "A satisfação do crédito exequendo far-se-á:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7076,
                                            "texto": "pela entrega do dinheiro;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7078,
                                            "texto": "pela adjudicação dos bens penhorados."
                                        }
                                    ],
                                    "rubrica": "Da Satisfação do Crédito",
                                    "linhaRubrica": 7072
                                },
                                {
                                    "numero": "905º",
                                    "rotulo": "Art. 905º.",
                                    "linha": 7080,
                                    "caput": "O juiz autorizará que o exequente levante, até a satisfação integral de seu crédito, o dinheiro depositado para segurar o juízo ou o produto dos bens alienados, bem como do faturamento de empresa ou de outros frutos e rendimentos de coisas ou empresas penhoradas, quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7086,
                                            "texto": "Durante o plantão judiciário, veda-se a concessão de pedidos de levantamento de importância em dinheiro ou valores ou de liberação de bens apreendidos."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7082,
                                            "texto": "a execução for movida só a benefício do exequente singular, a quem, por força da penhora, cabe o direito de preferência sobre os bens penhorados e alienados;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7084,
                                            "texto": "não houver sobre os bens alienados outros privilégios ou preferências instituídos anteriormente à penhora."
                                        }
                                    ]
                                },
                                {
                                    "numero": "906º",
                                    "rotulo": "Art. 906º.",
                                    "linha": 7088,
                                    "caput": "Ao receber o mandado de levantamento, o exequente dará ao executado, por termo nos autos, quitação da quantia paga.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7090,
                                            "texto": "A expedição de mandado de levantamento poderá ser substituída pela transferência eletrônica do valor depositado em conta vinculada ao juízo para outra indicada pelo exequente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "907º",
                                    "rotulo": "Art. 907º.",
                                    "linha": 7092,
                                    "caput": "Pago ao exequente o principal, os juros, as custas e os honorários, a importância que sobrar será restituída ao executado."
                                },
                                {
                                    "numero": "908º",
                                    "rotulo": "Art. 908º.",
                                    "linha": 7094,
                                    "caput": "Havendo pluralidade de credores ou exequentes, o dinheiro lhes será distribuído e entregue consoante a ordem das respectivas preferências.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7096,
                                            "texto": "No caso de adjudicação ou alienação, os créditos que recaem sobre o bem, inclusive os de natureza propter rem , sub-rogam-se sobre o respectivo preço, observada a ordem de preferência."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7098,
                                            "texto": "Não havendo título legal à preferência, o dinheiro será distribuído entre os concorrentes, observando-se a anterioridade de cada penhora."
                                        }
                                    ]
                                },
                                {
                                    "numero": "909º",
                                    "rotulo": "Art. 909º.",
                                    "linha": 7100,
                                    "caput": "Os exequentes formularão as suas pretensões, que versarão unicamente sobre o direito de preferência e a anterioridade da penhora, e, apresentadas as razões, o juiz decidirá."
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DA EXECUÇÃO POR QUANTIA CERTA",
                            "linhaTitulo": 6340
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 7102,
                            "artigos": [
                                {
                                    "numero": "910º",
                                    "rotulo": "Art. 910º.",
                                    "linha": 7105,
                                    "caput": "Na execução fundada em título extrajudicial, a Fazenda Pública será citada para opor embargos em 30 (trinta) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7107,
                                            "texto": "Não opostos embargos ou transitada em julgado a decisão que os rejeitar, expedir-se-á precatório ou requisição de pequeno valor em favor do exequente, observando-se o disposto no art. 100 da Constituição Federal .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 10",
                                                    "href": "#art10",
                                                    "inicio": 179,
                                                    "fim": 186
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7109,
                                            "texto": "Nos embargos, a Fazenda Pública poderá alegar qualquer matéria que lhe seria lícito deduzir como defesa no processo de conhecimento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7111,
                                            "texto": "Aplica-se a este Capítulo, no que couber, o disposto nos artigos 534 e 535 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "artigos 534 e 535",
                                                    "href": "#art534",
                                                    "inicio": 57,
                                                    "fim": 74
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA EXECUÇÃO CONTRA A FAZENDA PÚBLICA",
                            "linhaTitulo": 7103
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VI",
                            "linha": 7113,
                            "artigos": [
                                {
                                    "numero": "911º",
                                    "rotulo": "Art. 911º.",
                                    "linha": 7116,
                                    "caput": "Na execução fundada em título executivo extrajudicial que contenha obrigação alimentar, o juiz mandará citar o executado para, em 3 (três) dias, efetuar o pagamento das parcelas anteriores ao início da execução e das que se vencerem no seu curso, provar que o fez ou justificar a impossibilidade de fazê-lo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7118,
                                            "texto": "Aplicam-se, no que couber, os §§ 2º a 7º do art. 528 ."
                                        }
                                    ]
                                },
                                {
                                    "numero": "912º",
                                    "rotulo": "Art. 912º.",
                                    "linha": 7120,
                                    "caput": "Quando o executado for funcionário público, militar, diretor ou gerente de empresa, bem como empregado sujeito à legislação do trabalho, o exequente poderá requerer o desconto em folha de pagamento de pessoal da importância da prestação alimentícia.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7122,
                                            "texto": "Ao despachar a inicial, o juiz oficiará à autoridade, à empresa ou ao empregador, determinando, sob pena de crime de desobediência, o desconto a partir da primeira remuneração posterior do executado, a contar do protocolo do ofício."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7124,
                                            "texto": "O ofício conterá os nomes e o número de inscrição no Cadastro de Pessoas Físicas do exequente e do executado, a importância a ser descontada mensalmente, a conta na qual deve ser feito o depósito e, se for o caso, o tempo de sua duração."
                                        }
                                    ]
                                },
                                {
                                    "numero": "913º",
                                    "rotulo": "Art. 913º.",
                                    "linha": 7126,
                                    "caput": "Não requerida a execução nos termos deste Capítulo, observar-se-á o disposto no art. 824 e seguintes, com a ressalva de que, recaindo a penhora em dinheiro, a concessão de efeito suspensivo aos embargos à execução não obsta a que o exequente levante mensalmente a importância da prestação.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 824",
                                            "href": "#art824",
                                            "inicio": 80,
                                            "fim": 88
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA EXECUÇÃO DE ALIMENTOS",
                            "linhaTitulo": 7114
                        }
                    ],
                    "titulo": "DAS DIVERSAS ESPÉCIES DE EXECUÇÃO",
                    "linhaTitulo": 6145
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO III",
                    "linha": 7128,
                    "artigos": [
                        {
                            "numero": "914º",
                            "rotulo": "Art. 914º.",
                            "linha": 7131,
                            "caput": "O executado, independentemente de penhora, depósito ou caução, poderá se opor à execução por meio de embargos.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 7133,
                                    "texto": "Os embargos à execução serão distribuídos por dependência, autuados em apartado e instruídos com cópias das peças processuais relevantes, que poderão ser declaradas autênticas pelo próprio advogado, sob sua responsabilidade pessoal."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 7135,
                                    "texto": "Na execução por carta, os embargos serão oferecidos no juízo deprecante ou no juízo deprecado, mas a competência para julgá-los é do juízo deprecante, salvo se versarem unicamente sobre vícios ou defeitos da penhora, da avaliação ou da alienação dos bens efetuadas no juízo deprecado."
                                }
                            ]
                        },
                        {
                            "numero": "915º",
                            "rotulo": "Art. 915º.",
                            "linha": 7137,
                            "caput": "Os embargos serão oferecidos no prazo de 15 (quinze) dias, contado, conforme o caso, na forma do art. 231 .",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 7139,
                                    "texto": "Quando houver mais de um executado, o prazo para cada um deles embargar conta-se a partir da juntada do respectivo comprovante da citação, salvo no caso de cônjuges ou de companheiros, quando será contado a partir da juntada do último."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 7141,
                                    "texto": "Nas execuções por carta, o prazo para embargos será contado:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7143,
                                            "texto": "da juntada, na carta, da certificação da citação, quando versarem unicamente sobre vícios ou defeitos da penhora, da avaliação ou da alienação dos bens;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7145,
                                            "texto": "da juntada, nos autos de origem, do comunicado de que trata o § 4º deste artigo ou, não havendo este, da juntada da carta devidamente cumprida, quando versarem sobre questões diversas da prevista no inciso I deste parágrafo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 7147,
                                    "texto": "Em relação ao prazo para oferecimento dos embargos à execução, não se aplica o disposto no art. 229 .",
                                    "links": [
                                        {
                                            "campo": "texto",
                                            "texto": "art. 229",
                                            "href": "#art229",
                                            "inicio": 91,
                                            "fim": 99
                                        },
                                        {
                                            "campo": "texto",
                                            "texto": "229",
                                            "href": "../../../LEIS/2002/L10406.htm#art229",
                                            "inicio": 96,
                                            "fim": 99
                                        }
                                    ]
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 7149,
                                    "texto": "Nos atos de comunicação por carta precatória, rogatória ou de ordem, a realização da citação será imediatamente informada, por meio eletrônico, pelo juiz deprecado ao juiz deprecante."
                                }
                            ],
                            "links": [
                                {
                                    "campo": "caput",
                                    "texto": "art. 231",
                                    "href": "#art231",
                                    "inicio": 97,
                                    "fim": 105
                                }
                            ]
                        },
                        {
                            "numero": "916º",
                            "rotulo": "Art. 916º.",
                            "linha": 7151,
                            "caput": "No prazo para embargos, reconhecendo o crédito do exequente e comprovando o depósito de trinta por cento do valor em execução, acrescido de custas e de honorários de advogado, o executado poderá requerer que lhe seja permitido pagar o restante em até 6 (seis) parcelas mensais, acrescidas de correção monetária e de juros de um por cento ao mês.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 7153,
                                    "texto": "O exequente será intimado para manifestar-se sobre o preenchimento dos pressupostos do caput , e o juiz decidirá o requerimento em 5 (cinco) dias."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 7155,
                                    "texto": "Enquanto não apreciado o requerimento, o executado terá de depositar as parcelas vincendas, facultado ao exequente seu levantamento."
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 7157,
                                    "texto": "Deferida a proposta, o exequente levantará a quantia depositada, e serão suspensos os atos executivos."
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 7159,
                                    "texto": "Indeferida a proposta, seguir-se-ão os atos executivos, mantido o depósito, que será convertido em penhora."
                                },
                                {
                                    "numero": "5º",
                                    "rotulo": "§ 5º",
                                    "linha": 7161,
                                    "texto": "O não pagamento de qualquer das prestações acarretará cumulativamente:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7163,
                                            "texto": "o vencimento das prestações subsequentes e o prosseguimento do processo, com o imediato reinício dos atos executivos;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7165,
                                            "texto": "a imposição ao executado de multa de dez por cento sobre o valor das prestações não pagas."
                                        }
                                    ]
                                },
                                {
                                    "numero": "6º",
                                    "rotulo": "§ 6º",
                                    "linha": 7167,
                                    "texto": "A opção pelo parcelamento de que trata este artigo importa renúncia ao direito de opor embargos"
                                },
                                {
                                    "numero": "7º",
                                    "rotulo": "§ 7º",
                                    "linha": 7169,
                                    "texto": "O disposto neste artigo não se aplica ao cumprimento da sentença."
                                }
                            ]
                        },
                        {
                            "numero": "917º",
                            "rotulo": "Art. 917º.",
                            "linha": 7171,
                            "caput": "Nos embargos à execução, o executado poderá alegar:",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 7185,
                                    "texto": "A incorreção da penhora ou da avaliação poderá ser impugnada por simples petição, no prazo de 15 (quinze) dias, contado da ciência do ato."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 7187,
                                    "texto": "Há excesso de execução quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7189,
                                            "texto": "o exequente pleiteia quantia superior à do título;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7191,
                                            "texto": "ela recai sobre coisa diversa daquela declarada no título;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7193,
                                            "texto": "ela se processa de modo diferente do que foi determinado no título;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7195,
                                            "texto": "o exequente, sem cumprir a prestação que lhe corresponde, exige o adimplemento da prestação do executado;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7197,
                                            "texto": "o exequente não prova que a condição se realizou."
                                        }
                                    ]
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 7199,
                                    "texto": "Quando alegar que o exequente, em excesso de execução, pleiteia quantia superior à do título, o embargante declarará na petição inicial o valor que entende correto, apresentando demonstrativo discriminado e atualizado de seu cálculo."
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 7201,
                                    "texto": "Não apontado o valor correto ou não apresentado o demonstrativo, os embargos à execução:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7203,
                                            "texto": "serão liminarmente rejeitados, sem resolução de mérito, se o excesso de execução for o seu único fundamento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7205,
                                            "texto": "serão processados, se houver outro fundamento, mas o juiz não examinará a alegação de excesso de execução."
                                        }
                                    ]
                                },
                                {
                                    "numero": "5º",
                                    "rotulo": "§ 5º",
                                    "linha": 7207,
                                    "texto": "Nos embargos de retenção por benfeitorias, o exequente poderá requerer a compensação de seu valor com o dos frutos ou dos danos considerados devidos pelo executado, cumprindo ao juiz, para a apuração dos respectivos valores, nomear perito, observando-se, então, o art. 464 .",
                                    "links": [
                                        {
                                            "campo": "texto",
                                            "texto": "art. 464",
                                            "href": "#art464",
                                            "inicio": 264,
                                            "fim": 272
                                        }
                                    ]
                                },
                                {
                                    "numero": "6º",
                                    "rotulo": "§ 6º",
                                    "linha": 7209,
                                    "texto": "O exequente poderá a qualquer tempo ser imitido na posse da coisa, prestando caução ou depositando o valor devido pelas benfeitorias ou resultante da compensação."
                                },
                                {
                                    "numero": "7º",
                                    "rotulo": "§ 7º",
                                    "linha": 7211,
                                    "texto": "A arguição de impedimento e suspeição observará o disposto nos arts. 146 e 148 .",
                                    "links": [
                                        {
                                            "campo": "texto",
                                            "texto": "arts. 146",
                                            "href": "#art146",
                                            "inicio": 63,
                                            "fim": 72
                                        },
                                        {
                                            "campo": "texto",
                                            "texto": "148",
                                            "href": "#art148",
                                            "inicio": 75,
                                            "fim": 78
                                        },
                                        {
                                            "campo": "texto",
                                            "texto": "arts. 146 e 148",
                                            "href": "#art146",
                                            "inicio": 63,
                                            "fim": 78
                                        }
                                    ]
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 7173,
                                    "texto": "inexequibilidade do título ou inexigibilidade da obrigação;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 7175,
                                    "texto": "penhora incorreta ou avaliação errônea;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 7177,
                                    "texto": "excesso de execução ou cumulação indevida de execuções;"
                                },
                                {
                                    "numero": "IV",
                                    "rotulo": "IV",
                                    "linha": 7179,
                                    "texto": "retenção por benfeitorias necessárias ou úteis, nos casos de execução para entrega de coisa certa;"
                                },
                                {
                                    "numero": "V",
                                    "rotulo": "V",
                                    "linha": 7181,
                                    "texto": "incompetência absoluta ou relativa do juízo da execução;"
                                },
                                {
                                    "numero": "VI",
                                    "rotulo": "VI",
                                    "linha": 7183,
                                    "texto": "qualquer matéria que lhe seria lícito deduzir como defesa em processo de conhecimento."
                                }
                            ]
                        },
                        {
                            "numero": "918º",
                            "rotulo": "Art. 918º.",
                            "linha": 7213,
                            "caput": "O juiz rejeitará liminarmente os embargos:",
                            "paragrafos": [
                                {
                                    "numero": "único",
                                    "rotulo": "Parágrafo único",
                                    "linha": 7221,
                                    "texto": "Considera-se conduta atentatória à dignidade da justiça o oferecimento de embargos manifestamente protelatórios."
                                }
                            ],
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 7215,
                                    "texto": "quando intempestivos;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 7217,
                                    "texto": "nos casos de indeferimento da petição inicial e de improcedência liminar do pedido;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 7219,
                                    "texto": "manifestamente protelatórios."
                                }
                            ]
                        },
                        {
                            "numero": "919º",
                            "rotulo": "Art. 919º.",
                            "linha": 7223,
                            "caput": "Os embargos à execução não terão efeito suspensivo.",
                            "paragrafos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "§ 1º",
                                    "linha": 7225,
                                    "texto": "O juiz poderá, a requerimento do embargante, atribuir efeito suspensivo aos embargos quando verificados os requisitos para a concessão da tutela provisória e desde que a execução já esteja garantida por penhora, depósito ou caução suficientes."
                                },
                                {
                                    "numero": "2º",
                                    "rotulo": "§ 2º",
                                    "linha": 7227,
                                    "texto": "Cessando as circunstâncias que a motivaram, a decisão relativa aos efeitos dos embargos poderá, a requerimento da parte, ser modificada ou revogada a qualquer tempo, em decisão fundamentada."
                                },
                                {
                                    "numero": "3º",
                                    "rotulo": "§ 3º",
                                    "linha": 7229,
                                    "texto": "Quando o efeito suspensivo atribuído aos embargos disser respeito apenas a parte do objeto da execução, esta prosseguirá quanto à parte restante."
                                },
                                {
                                    "numero": "4º",
                                    "rotulo": "§ 4º",
                                    "linha": 7231,
                                    "texto": "A concessão de efeito suspensivo aos embargos oferecidos por um dos executados não suspenderá a execução contra os que não embargaram quando o respectivo fundamento disser respeito exclusivamente ao embargante."
                                },
                                {
                                    "numero": "5º",
                                    "rotulo": "§ 5º",
                                    "linha": 7233,
                                    "texto": "A concessão de efeito suspensivo não impedirá a efetivação dos atos de substituição, de reforço ou de redução da penhora e de avaliação dos bens."
                                }
                            ]
                        },
                        {
                            "numero": "920º",
                            "rotulo": "Art. 920º.",
                            "linha": 7235,
                            "caput": "Recebidos os embargos:",
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 7237,
                                    "texto": "o exequente será ouvido no prazo de 15 (quinze) dias;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 7239,
                                    "texto": "a seguir, o juiz julgará imediatamente o pedido ou designará audiência;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 7241,
                                    "texto": "encerrada a instrução, o juiz proferirá sentença."
                                }
                            ]
                        }
                    ],
                    "titulo": "DOS EMBARGOS À EXECUÇÃO",
                    "linhaTitulo": 7129
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO IV",
                    "linha": 7243,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 7246,
                            "artigos": [
                                {
                                    "numero": "921º",
                                    "rotulo": "Art. 921º.",
                                    "linha": 7249,
                                    "caput": "Suspende-se a execução:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7262,
                                            "texto": "Na hipótese do inciso III, o juiz suspenderá a execução pelo prazo de 1 (um) ano, durante o qual se suspenderá a prescrição."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7264,
                                            "texto": "Decorrido o prazo máximo de 1 (um) ano sem que seja localizado o executado ou que sejam encontrados bens penhoráveis, o juiz ordenará o arquivamento dos autos."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7266,
                                            "texto": "Os autos serão desarquivados para prosseguimento da execução se a qualquer tempo forem encontrados bens penhoráveis."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7269,
                                            "texto": "O termo inicial da prescrição no curso do processo será a ciência da primeira tentativa infrutífera de localização do devedor ou de bens penhoráveis, e será suspensa, por uma única vez, pelo prazo máximo previsto no § 1º deste artigo."
                                        },
                                        {
                                            "numero": "4º-A",
                                            "rotulo": "§ 4º-A",
                                            "linha": 7271,
                                            "texto": "A efetiva citação, intimação do devedor ou constrição de bens penhoráveis interrompe o prazo de prescrição, que não corre pelo tempo necessário à citação e à intimação do devedor, bem como para as formalidades da constrição patrimonial, se necessária, desde que o credor cumpra os prazos previstos na lei processual ou fixados pelo juiz."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7274,
                                            "texto": "O juiz, depois de ouvidas as partes, no prazo de 15 (quinze) dias, poderá, de ofício, reconhecer a prescrição no curso do processo e extingui-lo, sem ônus para as partes."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7276,
                                            "texto": "A alegação de nulidade quanto ao procedimento previsto neste artigo somente será conhecida caso demonstrada a ocorrência de efetivo prejuízo, que será presumido apenas em caso de inexistência da intimação de que trata o § 4º deste artigo."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 7278,
                                            "texto": "Aplica-se o disposto neste artigo ao cumprimento de sentença de que trata o art. 523 deste Código.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 523",
                                                    "href": "#art523",
                                                    "inicio": 76,
                                                    "fim": 84
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7251,
                                            "texto": "nas hipóteses dos arts. 313 e 315 , no que couber;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "arts. 313 e 315",
                                                    "href": "#art313",
                                                    "inicio": 18,
                                                    "fim": 33
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7253,
                                            "texto": "no todo ou em parte, quando recebidos com efeito suspensivo os embargos à execução;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7256,
                                            "texto": "quando não for localizado o executado ou bens penhoráveis;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7258,
                                            "texto": "se a alienação dos bens penhorados não se realizar por falta de licitantes e o exequente, em 15 (quinze) dias, não requerer a adjudicação nem indicar outros bens penhoráveis;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7260,
                                            "texto": "quando concedido o parcelamento de que trata o art. 916 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 916",
                                                    "href": "#art916",
                                                    "inicio": 47,
                                                    "fim": 55
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "922º",
                                    "rotulo": "Art. 922º.",
                                    "linha": 7280,
                                    "caput": "Convindo as partes, o juiz declarará suspensa a execução durante o prazo concedido pelo exequente para que o executado cumpra voluntariamente a obrigação.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7282,
                                            "texto": "Findo o prazo sem cumprimento da obrigação, o processo retomará o seu curso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "923º",
                                    "rotulo": "Art. 923º.",
                                    "linha": 7284,
                                    "caput": "Suspensa a execução, não serão praticados atos processuais, podendo o juiz, entretanto, salvo no caso de arguição de impedimento ou de suspeição, ordenar providências urgentes."
                                }
                            ],
                            "titulo": "DA SUSPENSÃO DO PROCESSO DE EXECUÇÃO",
                            "linhaTitulo": 7247
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 7286,
                            "artigos": [
                                {
                                    "numero": "924º",
                                    "rotulo": "Art. 924º.",
                                    "linha": 7289,
                                    "caput": "Extingue-se a execução quando:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7291,
                                            "texto": "a petição inicial for indeferida;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7293,
                                            "texto": "a obrigação for satisfeita;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7295,
                                            "texto": "o executado obtiver, por qualquer outro meio, a extinção total da dívida;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7297,
                                            "texto": "o exequente renunciar ao crédito;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7299,
                                            "texto": "ocorrer a prescrição intercorrente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "925º",
                                    "rotulo": "Art. 925º.",
                                    "linha": 7301,
                                    "caput": "A extinção só produz efeito quando declarada por sentença."
                                }
                            ],
                            "titulo": "DA EXTINÇÃO DO PROCESSO DE EXECUÇÃO",
                            "linhaTitulo": 7287
                        }
                    ],
                    "titulo": "DA SUSPENSÃO E DA EXTINÇÃO DO PROCESSO DE EXECUÇÃO",
                    "linhaTitulo": 7244
                }
            ],
            "titulo": "DO PROCESSO DE EXECUÇÃO",
            "linhaTitulo": 5906
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO III",
            "linha": 7303,
            "divisoes": [
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO I",
                    "linha": 7306,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 7309,
                            "artigos": [
                                {
                                    "numero": "926º",
                                    "rotulo": "Art. 926º.",
                                    "linha": 7312,
                                    "caput": "Os tribunais devem uniformizar sua jurisprudência e mantê-la estável, íntegra e coerente.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7314,
                                            "texto": "Na forma estabelecida e segundo os pressupostos fixados no regimento interno, os tribunais editarão enunciados de súmula correspondentes a sua jurisprudência dominante."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7316,
                                            "texto": "Ao editar enunciados de súmula, os tribunais devem ater-se às circunstâncias fáticas dos precedentes que motivaram sua criação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "927º",
                                    "rotulo": "Art. 927º.",
                                    "linha": 7318,
                                    "caput": "Os juízes e os tribunais observarão:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7330,
                                            "texto": "Os juízes e os tribunais observarão o disposto no art. 10 e no art. 489, § 1º , quando decidirem com fundamento neste artigo.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 10",
                                                    "href": "#art10",
                                                    "inicio": 50,
                                                    "fim": 57
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7332,
                                            "texto": "A alteração de tese jurídica adotada em enunciado de súmula ou em julgamento de casos repetitivos poderá ser precedida de audiências públicas e da participação de pessoas, órgãos ou entidades que possam contribuir para a rediscussão da tese."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7334,
                                            "texto": "Na hipótese de alteração de jurisprudência dominante do Supremo Tribunal Federal e dos tribunais superiores ou daquela oriunda de julgamento de casos repetitivos, pode haver modulação dos efeitos da alteração no interesse social e no da segurança jurídica."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7336,
                                            "texto": "A modificação de enunciado de súmula, de jurisprudência pacificada ou de tese adotada em julgamento de casos repetitivos observará a necessidade de fundamentação adequada e específica, considerando os princípios da segurança jurídica, da proteção da confiança e da isonomia."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7338,
                                            "texto": "Os tribunais darão publicidade a seus precedentes, organizando-os por questão jurídica decidida e divulgando-os, preferencialmente, na rede mundial de computadores."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7320,
                                            "texto": "as decisões do Supremo Tribunal Federal em controle concentrado de constitucionalidade;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7322,
                                            "texto": "os enunciados de súmula vinculante;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7324,
                                            "texto": "os acórdãos em incidente de assunção de competência ou de resolução de demandas repetitivas e em julgamento de recursos extraordinário e especial repetitivos;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7326,
                                            "texto": "os enunciados das súmulas do Supremo Tribunal Federal em matéria constitucional e do Superior Tribunal de Justiça em matéria infraconstitucional;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7328,
                                            "texto": "a orientação do plenário ou do órgão especial aos quais estiverem vinculados."
                                        }
                                    ]
                                },
                                {
                                    "numero": "928º",
                                    "rotulo": "Art. 928º.",
                                    "linha": 7340,
                                    "caput": "Para os fins deste Código, considera-se julgamento de casos repetitivos a decisão proferida em:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7346,
                                            "texto": "O julgamento de casos repetitivos tem por objeto questão de direito material ou processual."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7342,
                                            "texto": "incidente de resolução de demandas repetitivas;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7344,
                                            "texto": "recursos especial e extraordinário repetitivos."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 7310
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 7348,
                            "artigos": [
                                {
                                    "numero": "929º",
                                    "rotulo": "Art. 929º.",
                                    "linha": 7351,
                                    "caput": "Os autos serão registrados no protocolo do tribunal no dia de sua entrada, cabendo à secretaria ordená-los, com imediata distribuição.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7353,
                                            "texto": "A critério do tribunal, os serviços de protocolo poderão ser descentralizados, mediante delegação a ofícios de justiça de primeiro grau."
                                        }
                                    ]
                                },
                                {
                                    "numero": "930º",
                                    "rotulo": "Art. 930º.",
                                    "linha": 7355,
                                    "caput": "Far-se-á a distribuição de acordo com o regimento interno do tribunal, observando-se a alternatividade, o sorteio eletrônico e a publicidade.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7357,
                                            "texto": "O primeiro recurso protocolado no tribunal tornará prevento o relator para eventual recurso subsequente interposto no mesmo processo ou em processo conexo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "931º",
                                    "rotulo": "Art. 931º.",
                                    "linha": 7359,
                                    "caput": "Distribuídos, os autos serão imediatamente conclusos ao relator, que, em 30 (trinta) dias, depois de elaborar o voto, restituí-los-á, com relatório, à secretaria."
                                },
                                {
                                    "numero": "932º",
                                    "rotulo": "Art. 932º.",
                                    "linha": 7361,
                                    "caput": "Incumbe ao relator:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7391,
                                            "texto": "Antes de considerar inadmissível o recurso, o relator concederá o prazo de 5 (cinco) dias ao recorrente para que seja sanado vício ou complementada a documentação exigível."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7363,
                                            "texto": "dirigir e ordenar o processo no tribunal, inclusive em relação à produção de prova, bem como, quando for o caso, homologar autocomposição das partes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7365,
                                            "texto": "apreciar o pedido de tutela provisória nos recursos e nos processos de competência originária do tribunal;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7367,
                                            "texto": "não conhecer de recurso inadmissível, prejudicado ou que não tenha impugnado especificamente os fundamentos da decisão recorrida;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7369,
                                            "texto": "negar provimento a recurso que for contrário a:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 7371,
                                                    "texto": "súmula do Supremo Tribunal Federal, do Superior Tribunal de Justiça ou do próprio tribunal;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 7373,
                                                    "texto": "acórdão proferido pelo Supremo Tribunal Federal ou pelo Superior Tribunal de Justiça em julgamento de recursos repetitivos;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 7375,
                                                    "texto": "entendimento firmado em incidente de resolução de demandas repetitivas ou de assunção de competência;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7377,
                                            "texto": "depois de facultada a apresentação de contrarrazões, dar provimento ao recurso se a decisão recorrida for contrária a:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 7379,
                                                    "texto": "súmula do Supremo Tribunal Federal, do Superior Tribunal de Justiça ou do próprio tribunal;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 7381,
                                                    "texto": "acórdão proferido pelo Supremo Tribunal Federal ou pelo Superior Tribunal de Justiça em julgamento de recursos repetitivos;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 7383,
                                                    "texto": "entendimento firmado em incidente de resolução de demandas repetitivas ou de assunção de competência;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 7385,
                                            "texto": "decidir o incidente de desconsideração da personalidade jurídica, quando este for instaurado originariamente perante o tribunal;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 7387,
                                            "texto": "determinar a intimação do Ministério Público, quando for o caso;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 7389,
                                            "texto": "exercer outras atribuições estabelecidas no regimento interno do tribunal."
                                        }
                                    ]
                                },
                                {
                                    "numero": "933º",
                                    "rotulo": "Art. 933º.",
                                    "linha": 7393,
                                    "caput": "Se o relator constatar a ocorrência de fato superveniente à decisão recorrida ou a existência de questão apreciável de ofício ainda não examinada que devam ser considerados no julgamento do recurso, intimará as partes para que se manifestem no prazo de 5 (cinco) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7395,
                                            "texto": "Se a constatação ocorrer durante a sessão de julgamento, esse será imediatamente suspenso a fim de que as partes se manifestem especificamente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7397,
                                            "texto": "Se a constatação se der em vista dos autos, deverá o juiz que a solicitou encaminhá-los ao relator, que tomará as providências previstas no caput e, em seguida, solicitará a inclusão do feito em pauta para prosseguimento do julgamento, com submissão integral da nova questão aos julgadores."
                                        }
                                    ]
                                },
                                {
                                    "numero": "934º",
                                    "rotulo": "Art. 934º.",
                                    "linha": 7399,
                                    "caput": "Em seguida, os autos serão apresentados ao presidente, que designará dia para julgamento, ordenando, em todas as hipóteses previstas neste Livro, a publicação da pauta no órgão oficial."
                                },
                                {
                                    "numero": "935º",
                                    "rotulo": "Art. 935º.",
                                    "linha": 7401,
                                    "caput": "Entre a data de publicação da pauta e a da sessão de julgamento decorrerá, pelo menos, o prazo de 5 (cinco) dias, incluindo-se em nova pauta os processos que não tenham sido julgados, salvo aqueles cujo julgamento tiver sido expressamente adiado para a primeira sessão seguinte.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7403,
                                            "texto": "Às partes será permitida vista dos autos em cartório após a publicação da pauta de julgamento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7405,
                                            "texto": "Afixar-se-á a pauta na entrada da sala em que se realizar a sessão de julgamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "936º",
                                    "rotulo": "Art. 936º.",
                                    "linha": 7407,
                                    "caput": "Ressalvadas as preferências legais e regimentais, os recursos, a remessa necessária e os processos de competência originária serão julgados na seguinte ordem:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7409,
                                            "texto": "aqueles nos quais houver sustentação oral, observada a ordem dos requerimentos;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7411,
                                            "texto": "os requerimentos de preferência apresentados até o início da sessão de julgamento;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7413,
                                            "texto": "aqueles cujo julgamento tenha iniciado em sessão anterior; e"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7415,
                                            "texto": "os demais casos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "937º",
                                    "rotulo": "Art. 937º.",
                                    "linha": 7417,
                                    "caput": "Na sessão de julgamento, depois da exposição da causa pelo relator, o presidente dará a palavra, sucessivamente, ao recorrente, ao recorrido e, nos casos de sua intervenção, ao membro do Ministério Público, pelo prazo improrrogável de 15 (quinze) minutos para cada um, a fim de sustentarem suas razões, nas seguintes hipóteses, nos termos da parte final do caput do art. 1.021 :",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7435,
                                            "texto": "A sustentação oral no incidente de resolução de demandas repetitivas observará o disposto no art. 984 , no que couber.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 984",
                                                    "href": "#art984",
                                                    "inicio": 93,
                                                    "fim": 101
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7437,
                                            "texto": "O procurador que desejar proferir sustentação oral poderá requerer, até o início da sessão, que o processo seja julgado em primeiro lugar, sem prejuízo das preferências legais."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7439,
                                            "texto": "Nos processos de competência originária previstos no inciso VI, caberá sustentação oral no agravo interno interposto contra decisão de relator que o extinga."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7441,
                                            "texto": "É permitido ao advogado com domicílio profissional em cidade diversa daquela onde está sediado o tribunal realizar sustentação oral por meio de videoconferência ou outro recurso tecnológico de transmissão de sons e imagens em tempo real, desde que o requeira até o dia anterior ao da sessão."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7419,
                                            "texto": "no recurso de apelação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7421,
                                            "texto": "no recurso ordinário;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7423,
                                            "texto": "no recurso especial;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7425,
                                            "texto": "no recurso extraordinário;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7427,
                                            "texto": "nos embargos de divergência;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 7429,
                                            "texto": "na ação rescisória, no mandado de segurança e na reclamação;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 7431,
                                            "texto": "no agravo de instrumento interposto contra decisões interlocutórias que versem sobre tutelas provisórias de urgência ou da evidência;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 7433,
                                            "texto": "em outras hipóteses previstas em lei ou no regimento interno do tribunal."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 1.021",
                                            "href": "#art1021",
                                            "inicio": 366,
                                            "fim": 376
                                        }
                                    ]
                                },
                                {
                                    "numero": "938º",
                                    "rotulo": "Art. 938º.",
                                    "linha": 7443,
                                    "caput": "A questão preliminar suscitada no julgamento será decidida antes do mérito, deste não se conhecendo caso seja incompatível com a decisão.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7445,
                                            "texto": "Constatada a ocorrência de vício sanável, inclusive aquele que possa ser conhecido de ofício, o relator determinará a realização ou a renovação do ato processual, no próprio tribunal ou em primeiro grau de jurisdição, intimadas as partes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7447,
                                            "texto": "Cumprida a diligência de que trata o § 1º, o relator, sempre que possível, prosseguirá no julgamento do recurso."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7449,
                                            "texto": "Reconhecida a necessidade de produção de prova, o relator converterá o julgamento em diligência, que se realizará no tribunal ou em primeiro grau de jurisdição, decidindo-se o recurso após a conclusão da instrução."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7451,
                                            "texto": "Quando não determinadas pelo relator, as providências indicadas nos §§ 1º e 3º poderão ser determinadas pelo órgão competente para julgamento do recurso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "939º",
                                    "rotulo": "Art. 939º.",
                                    "linha": 7453,
                                    "caput": "Se a preliminar for rejeitada ou se a apreciação do mérito for com ela compatível, seguir-se-ão a discussão e o julgamento da matéria principal, sobre a qual deverão se pronunciar os juízes vencidos na preliminar."
                                },
                                {
                                    "numero": "940º",
                                    "rotulo": "Art. 940º.",
                                    "linha": 7455,
                                    "caput": "O relator ou outro juiz que não se considerar habilitado a proferir imediatamente seu voto poderá solicitar vista pelo prazo máximo de 10 (dez) dias, após o qual o recurso será reincluído em pauta para julgamento na sessão seguinte à data da devolução.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7457,
                                            "texto": "Se os autos não forem devolvidos tempestivamente ou se não for solicitada pelo juiz prorrogação de prazo de no máximo mais 10 (dez) dias, o presidente do órgão fracionário os requisitará para julgamento do recurso na sessão ordinária subsequente, com publicação da pauta em que for incluído."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7459,
                                            "texto": "Quando requisitar os autos na forma do § 1º, se aquele que fez o pedido de vista ainda não se sentir habilitado a votar, o presidente convocará substituto para proferir voto, na forma estabelecida no regimento interno do tribunal."
                                        }
                                    ]
                                },
                                {
                                    "numero": "941º",
                                    "rotulo": "Art. 941º.",
                                    "linha": 7461,
                                    "caput": "Proferidos os votos, o presidente anunciará o resultado do julgamento, designando para redigir o acórdão o relator ou, se vencido este, o autor do primeiro voto vencedor.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7463,
                                            "texto": "O voto poderá ser alterado até o momento da proclamação do resultado pelo presidente, salvo aquele já proferido por juiz afastado ou substituído."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7465,
                                            "texto": "No julgamento de apelação ou de agravo de instrumento, a decisão será tomada, no órgão colegiado, pelo voto de 3 (três) juízes."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7467,
                                            "texto": "O voto vencido será necessariamente declarado e considerado parte integrante do acórdão para todos os fins legais, inclusive de pré-questionamento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "942º",
                                    "rotulo": "Art. 942º.",
                                    "linha": 7469,
                                    "caput": "Quando o resultado da apelação for não unânime, o julgamento terá prosseguimento em sessão a ser designada com a presença de outros julgadores, que serão convocados nos termos previamente definidos no regimento interno, em número suficiente para garantir a possibilidade de inversão do resultado inicial, assegurado às partes e a eventuais terceiros o direito de sustentar oralmente suas razões perante os novos julgadores.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7471,
                                            "texto": "Sendo possível, o prosseguimento do julgamento dar-se-á na mesma sessão, colhendo-se os votos de outros julgadores que porventura componham o órgão colegiado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7473,
                                            "texto": "Os julgadores que já tiverem votado poderão rever seus votos por ocasião do prosseguimento do julgamento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7475,
                                            "texto": "A técnica de julgamento prevista neste artigo aplica-se, igualmente, ao julgamento não unânime proferido em:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7477,
                                                    "texto": "ação rescisória, quando o resultado for a rescisão da sentença, devendo, nesse caso, seu prosseguimento ocorrer em órgão de maior composição previsto no regimento interno;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7479,
                                                    "texto": "agravo de instrumento, quando houver reforma da decisão que julgar parcialmente o mérito."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7481,
                                            "texto": "Não se aplica o disposto neste artigo ao julgamento:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7483,
                                                    "texto": "do incidente de assunção de competência e ao de resolução de demandas repetitivas;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7485,
                                                    "texto": "da remessa necessária;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 7487,
                                                    "texto": "não unânime proferido, nos tribunais, pelo plenário ou pela corte especial."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "943º",
                                    "rotulo": "Art. 943º.",
                                    "linha": 7489,
                                    "caput": "Os votos, os acórdãos e os demais atos processuais podem ser registrados em documento eletrônico inviolável e assinados eletronicamente, na forma da lei, devendo ser impressos para juntada aos autos do processo quando este não for eletrônico.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7491,
                                            "texto": "Todo acórdão conterá ementa."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7493,
                                            "texto": "Lavrado o acórdão, sua ementa será publicada no órgão oficial no prazo de 10 (dez) dias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "944º",
                                    "rotulo": "Art. 944º.",
                                    "linha": 7495,
                                    "caput": "Não publicado o acórdão no prazo de 30 (trinta) dias, contado da data da sessão de julgamento, as notas taquigráficas o substituirão, para todos os fins legais, independentemente de revisão.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7497,
                                            "texto": "No caso do caput , o presidente do tribunal lavrará, de imediato, as conclusões e a ementa e mandará publicar o acórdão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "946º",
                                    "rotulo": "Art. 946º.",
                                    "linha": 7509,
                                    "caput": "O agravo de instrumento será julgado antes da apelação interposta no mesmo processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7511,
                                            "texto": "Se ambos os recursos de que trata o caput houverem de ser julgados na mesma sessão, terá precedência o agravo de instrumento."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA ORDEM DOS PROCESSOS NO TRIBUNAL",
                            "linhaTitulo": 7349
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 7513,
                            "artigos": [
                                {
                                    "numero": "947º",
                                    "rotulo": "Art. 947º.",
                                    "linha": 7516,
                                    "caput": "É admissível a assunção de competência quando o julgamento de recurso, de remessa necessária ou de processo de competência originária envolver relevante questão de direito, com grande repercussão social, sem repetição em múltiplos processos.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7518,
                                            "texto": "Ocorrendo a hipótese de assunção de competência, o relator proporá, de ofício ou a requerimento da parte, do Ministério Público ou da Defensoria Pública, que seja o recurso, a remessa necessária ou o processo de competência originária julgado pelo órgão colegiado que o regimento indicar."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7520,
                                            "texto": "O órgão colegiado julgará o recurso, a remessa necessária ou o processo de competência originária se reconhecer interesse público na assunção de competência."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7522,
                                            "texto": "O acórdão proferido em assunção de competência vinculará todos os juízes e órgãos fracionários, exceto se houver revisão de tese."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7524,
                                            "texto": "Aplica-se o disposto neste artigo quando ocorrer relevante questão de direito a respeito da qual seja conveniente a prevenção ou a composição de divergência entre câmaras ou turmas do tribunal."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO INCIDENTE DE ASSUNÇÃO DE COMPETÊNCIA",
                            "linhaTitulo": 7514
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 7526,
                            "artigos": [
                                {
                                    "numero": "948º",
                                    "rotulo": "Art. 948º.",
                                    "linha": 7529,
                                    "caput": "Arguida, em controle difuso, a inconstitucionalidade de lei ou de ato normativo do poder público, o relator, após ouvir o Ministério Público e as partes, submeterá a questão à turma ou à câmara à qual competir o conhecimento do processo."
                                },
                                {
                                    "numero": "949º",
                                    "rotulo": "Art. 949º.",
                                    "linha": 7531,
                                    "caput": "Se a arguição for:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7537,
                                            "texto": "Os órgãos fracionários dos tribunais não submeterão ao plenário ou ao órgão especial a arguição de inconstitucionalidade quando já houver pronunciamento destes ou do plenário do Supremo Tribunal Federal sobre a questão."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7533,
                                            "texto": "rejeitada, prosseguirá o julgamento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7535,
                                            "texto": "acolhida, a questão será submetida ao plenário do tribunal ou ao seu órgão especial, onde houver."
                                        }
                                    ]
                                },
                                {
                                    "numero": "950º",
                                    "rotulo": "Art. 950º.",
                                    "linha": 7539,
                                    "caput": "Remetida cópia do acórdão a todos os juízes, o presidente do tribunal designará a sessão de julgamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7541,
                                            "texto": "As pessoas jurídicas de direito público responsáveis pela edição do ato questionado poderão manifestar-se no incidente de inconstitucionalidade se assim o requererem, observados os prazos e as condições previstos no regimento interno do tribunal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7543,
                                            "texto": "A parte legitimada à propositura das ações previstas no art. 103 da Constituição Federal poderá manifestar-se, por escrito, sobre a questão constitucional objeto de apreciação, no prazo previsto pelo regimento interno, sendo-lhe assegurado o direito de apresentar memoriais ou de requerer a juntada de documentos.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 10",
                                                    "href": "#art10",
                                                    "inicio": 56,
                                                    "fim": 63
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7545,
                                            "texto": "Considerando a relevância da matéria e a representatividade dos postulantes, o relator poderá admitir, por despacho irrecorrível, a manifestação de outros órgãos ou entidades."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO INCIDENTE DE ARGUIÇÃO DE INCONSTITUCIONALIDADE",
                            "linhaTitulo": 7527
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 7547,
                            "artigos": [
                                {
                                    "numero": "951º",
                                    "rotulo": "Art. 951º.",
                                    "linha": 7550,
                                    "caput": "O conflito de competência pode ser suscitado por qualquer das partes, pelo Ministério Público ou pelo juiz.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7552,
                                            "texto": "O Ministério Público somente será ouvido nos conflitos de competência relativos aos processos previstos no art. 178 , mas terá qualidade de parte nos conflitos que suscitar.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 178",
                                                    "href": "#art178",
                                                    "inicio": 107,
                                                    "fim": 115
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "952º",
                                    "rotulo": "Art. 952º.",
                                    "linha": 7554,
                                    "caput": "Não pode suscitar conflito a parte que, no processo, arguiu incompetência relativa.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7556,
                                            "texto": "O conflito de competência não obsta, porém, a que a parte que não o arguiu suscite a incompetência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "953º",
                                    "rotulo": "Art. 953º.",
                                    "linha": 7558,
                                    "caput": "O conflito será suscitado ao tribunal:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7564,
                                            "texto": "O ofício e a petição serão instruídos com os documentos necessários à prova do conflito."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7560,
                                            "texto": "pelo juiz, por ofício;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7562,
                                            "texto": "pela parte e pelo Ministério Público, por petição."
                                        }
                                    ]
                                },
                                {
                                    "numero": "954º",
                                    "rotulo": "Art. 954º.",
                                    "linha": 7566,
                                    "caput": "Após a distribuição, o relator determinará a oitiva dos juízes em conflito ou, se um deles for suscitante, apenas do suscitado.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7568,
                                            "texto": "No prazo designado pelo relator, incumbirá ao juiz ou aos juízes prestar as informações."
                                        }
                                    ]
                                },
                                {
                                    "numero": "955º",
                                    "rotulo": "Art. 955º.",
                                    "linha": 7570,
                                    "caput": "O relator poderá, de ofício ou a requerimento de qualquer das partes, determinar, quando o conflito for positivo, o sobrestamento do processo e, nesse caso, bem como no de conflito negativo, designará um dos juízes para resolver, em caráter provisório, as medidas urgentes.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7572,
                                            "texto": "O relator poderá julgar de plano o conflito de competência quando sua decisão se fundar em:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7574,
                                                    "texto": "súmula do Supremo Tribunal Federal, do Superior Tribunal de Justiça ou do próprio tribunal;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7576,
                                                    "texto": "tese firmada em julgamento de casos repetitivos ou em incidente de assunção de competência."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "956º",
                                    "rotulo": "Art. 956º.",
                                    "linha": 7578,
                                    "caput": "Decorrido o prazo designado pelo relator, será ouvido o Ministério Público, no prazo de 5 (cinco) dias, ainda que as informações não tenham sido prestadas, e, em seguida, o conflito irá a julgamento."
                                },
                                {
                                    "numero": "957º",
                                    "rotulo": "Art. 957º.",
                                    "linha": 7580,
                                    "caput": "Ao decidir o conflito, o tribunal declarará qual o juízo competente, pronunciando-se também sobre a validade dos atos do juízo incompetente.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7582,
                                            "texto": "Os autos do processo em que se manifestou o conflito serão remetidos ao juiz declarado competente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "958º",
                                    "rotulo": "Art. 958º.",
                                    "linha": 7584,
                                    "caput": "No conflito que envolva órgãos fracionários dos tribunais, desembargadores e juízes em exercício no tribunal, observar-se-á o que dispuser o regimento interno do tribunal."
                                },
                                {
                                    "numero": "959º",
                                    "rotulo": "Art. 959º.",
                                    "linha": 7586,
                                    "caput": "O regimento interno do tribunal regulará o processo e o julgamento do conflito de atribuições entre autoridade judiciária e autoridade administrativa."
                                }
                            ],
                            "titulo": "DO CONFLITO DE COMPETÊNCIA",
                            "linhaTitulo": 7548
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VI",
                            "linha": 7588,
                            "artigos": [
                                {
                                    "numero": "960º",
                                    "rotulo": "Art. 960º.",
                                    "linha": 7591,
                                    "caput": "A homologação de decisão estrangeira será requerida por ação de homologação de decisão estrangeira, salvo disposição especial em sentido contrário prevista em tratado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7593,
                                            "texto": "A decisão interlocutória estrangeira poderá ser executada no Brasil por meio de carta rogatória."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7595,
                                            "texto": "A homologação obedecerá ao que dispuserem os tratados em vigor no Brasil e o Regimento Interno do Superior Tribunal de Justiça."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7597,
                                            "texto": "A homologação de decisão arbitral estrangeira obedecerá ao disposto em tratado e em lei, aplicando-se, subsidiariamente, as disposições deste Capítulo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "961º",
                                    "rotulo": "Art. 961º.",
                                    "linha": 7599,
                                    "caput": "A decisão estrangeira somente terá eficácia no Brasil após a homologação de sentença estrangeira ou a concessão do exequatur às cartas rogatórias, salvo disposição em sentido contrário de lei ou tratado.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7601,
                                            "texto": "É passível de homologação a decisão judicial definitiva, bem como a decisão não judicial que, pela lei brasileira, teria natureza jurisdicional."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7603,
                                            "texto": "A decisão estrangeira poderá ser homologada parcialmente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7605,
                                            "texto": "A autoridade judiciária brasileira poderá deferir pedidos de urgência e realizar atos de execução provisória no processo de homologação de decisão estrangeira."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7607,
                                            "texto": "Haverá homologação de decisão estrangeira para fins de execução fiscal quando prevista em tratado ou em promessa de reciprocidade apresentada à autoridade brasileira."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7609,
                                            "texto": "A sentença estrangeira de divórcio consensual produz efeitos no Brasil, independentemente de homologação pelo Superior Tribunal de Justiça."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7611,
                                            "texto": "Na hipótese do § 5º, competirá a qualquer juiz examinar a validade da decisão, em caráter principal ou incidental, quando essa questão for suscitada em processo de sua competência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "962º",
                                    "rotulo": "Art. 962º.",
                                    "linha": 7613,
                                    "caput": "É passível de execução a decisão estrangeira concessiva de medida de urgência.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7615,
                                            "texto": "A execução no Brasil de decisão interlocutória estrangeira concessiva de medida de urgência dar-se-á por carta rogatória."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7617,
                                            "texto": "A medida de urgência concedida sem audiência do réu poderá ser executada, desde que garantido o contraditório em momento posterior."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7619,
                                            "texto": "O juízo sobre a urgência da medida compete exclusivamente à autoridade jurisdicional prolatora da decisão estrangeira."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7621,
                                            "texto": "Quando dispensada a homologação para que a sentença estrangeira produza efeitos no Brasil, a decisão concessiva de medida de urgência dependerá, para produzir efeitos, de ter sua validade expressamente reconhecida pelo juiz competente para dar-lhe cumprimento, dispensada a homologação pelo Superior Tribunal de Justiça."
                                        }
                                    ]
                                },
                                {
                                    "numero": "963º",
                                    "rotulo": "Art. 963º.",
                                    "linha": 7623,
                                    "caput": "Constituem requisitos indispensáveis à homologação da decisão:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7637,
                                            "texto": "Para a concessão do exequatur às cartas rogatórias, observar-se-ão os pressupostos previstos no caput deste artigo e no art. 962, § 2º ."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7625,
                                            "texto": "ser proferida por autoridade competente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7627,
                                            "texto": "ser precedida de citação regular, ainda que verificada a revelia;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7629,
                                            "texto": "ser eficaz no país em que foi proferida;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7631,
                                            "texto": "não ofender a coisa julgada brasileira;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7633,
                                            "texto": "estar acompanhada de tradução oficial, salvo disposição que a dispense prevista em tratado;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 7635,
                                            "texto": "não conter manifesta ofensa à ordem pública."
                                        }
                                    ]
                                },
                                {
                                    "numero": "964º",
                                    "rotulo": "Art. 964º.",
                                    "linha": 7639,
                                    "caput": "Não será homologada a decisão estrangeira na hipótese de competência exclusiva da autoridade judiciária brasileira.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7641,
                                            "texto": "O dispositivo também se aplica à concessão do exequatur à carta rogatória."
                                        }
                                    ]
                                },
                                {
                                    "numero": "965º",
                                    "rotulo": "Art. 965º.",
                                    "linha": 7643,
                                    "caput": "O cumprimento de decisão estrangeira far-se-á perante o juízo federal competente, a requerimento da parte, conforme as normas estabelecidas para o cumprimento de decisão nacional.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7645,
                                            "texto": "O pedido de execução deverá ser instruído com cópia autenticada da decisão homologatória ou do exequatur , conforme o caso."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA HOMOLOGAÇÃO DE DECISÃO ESTRANGEIRA E DA CONCESSÃO DO EXEQUATUR À CARTA ROGATÓRIA",
                            "linhaTitulo": 7589
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VII",
                            "linha": 7647,
                            "artigos": [
                                {
                                    "numero": "966º",
                                    "rotulo": "Art. 966º.",
                                    "linha": 7650,
                                    "caput": "A decisão de mérito, transitada em julgado, pode ser rescindida quando:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7668,
                                            "texto": "Há erro de fato quando a decisão rescindenda admitir fato inexistente ou quando considerar inexistente fato efetivamente ocorrido, sendo indispensável, em ambos os casos, que o fato não represente ponto controvertido sobre o qual o juiz deveria ter se pronunciado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7670,
                                            "texto": "Nas hipóteses previstas nos incisos do caput , será rescindível a decisão transitada em julgado que, embora não seja de mérito, impeça:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7672,
                                                    "texto": "nova propositura da demanda; ou"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7674,
                                                    "texto": "admissibilidade do recurso correspondente."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7676,
                                            "texto": "A ação rescisória pode ter por objeto apenas 1 (um) capítulo da decisão."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7678,
                                            "texto": "Os atos de disposição de direitos, praticados pelas partes ou por outros participantes do processo e homologados pelo juízo, bem como os atos homologatórios praticados no curso da execução, estão sujeitos à anulação, nos termos da lei."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7680,
                                            "texto": "Cabe ação rescisória, com fundamento no inciso V do caput deste artigo, contra decisão baseada em enunciado de súmula ou acórdão proferido em julgamento de casos repetitivos que não tenha considerado a existência de distinção entre a questão discutida no processo e o padrão decisório que lhe deu fundamento."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7682,
                                            "texto": "Quando a ação rescisória fundar-se na hipótese do § 5º deste artigo, caberá ao autor, sob pena de inépcia, demonstrar, fundamentadamente, tratar-se de situação particularizada por hipótese fática distinta ou de questão jurídica não examinada, a impor outra solução jurídica."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7652,
                                            "texto": "se verificar que foi proferida por força de prevaricação, concussão ou corrupção do juiz;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7654,
                                            "texto": "for proferida por juiz impedido ou por juízo absolutamente incompetente;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7656,
                                            "texto": "resultar de dolo ou coação da parte vencedora em detrimento da parte vencida ou, ainda, de simulação ou colusão entre as partes, a fim de fraudar a lei;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7658,
                                            "texto": "ofender a coisa julgada;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7660,
                                            "texto": "violar manifestamente norma jurídica;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 7662,
                                            "texto": "for fundada em prova cuja falsidade tenha sido apurada em processo criminal ou venha a ser demonstrada na própria ação rescisória;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 7664,
                                            "texto": "obtiver o autor, posteriormente ao trânsito em julgado, prova nova cuja existência ignorava ou de que não pôde fazer uso, capaz, por si só, de lhe assegurar pronunciamento favorável;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 7666,
                                            "texto": "for fundada em erro de fato verificável do exame dos autos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "967º",
                                    "rotulo": "Art. 967º.",
                                    "linha": 7684,
                                    "caput": "Têm legitimidade para propor a ação rescisória:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7700,
                                            "texto": "Nas hipóteses do art. 178 , o Ministério Público será intimado para intervir como fiscal da ordem jurídica quando não for parte.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 178",
                                                    "href": "#art178",
                                                    "inicio": 17,
                                                    "fim": 25
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7686,
                                            "texto": "quem foi parte no processo ou o seu sucessor a título universal ou singular;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7688,
                                            "texto": "o terceiro juridicamente interessado;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7690,
                                            "texto": "o Ministério Público:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 7692,
                                                    "texto": "se não foi ouvido no processo em que lhe era obrigatória a intervenção;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 7694,
                                                    "texto": "quando a decisão rescindenda é o efeito de simulação ou de colusão das partes, a fim de fraudar a lei;"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 7696,
                                                    "texto": "em outros casos em que se imponha sua atuação;"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7698,
                                            "texto": "aquele que não foi ouvido no processo em que lhe era obrigatória a intervenção."
                                        }
                                    ]
                                },
                                {
                                    "numero": "968º",
                                    "rotulo": "Art. 968º.",
                                    "linha": 7702,
                                    "caput": "A petição inicial será elaborada com observância dos requisitos essenciais do art. 319 , devendo o autor:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7708,
                                            "texto": "Não se aplica o disposto no inciso II à União, aos Estados, ao Distrito Federal, aos Municípios, às suas respectivas autarquias e fundações de direito público, ao Ministério Público, à Defensoria Pública e aos que tenham obtido o benefício de gratuidade da justiça."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7710,
                                            "texto": "O depósito previsto no inciso II do caput deste artigo não será superior a 1.000 (mil) salários-mínimos."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7712,
                                            "texto": "Além dos casos previstos no art. 330 , a petição inicial será indeferida quando não efetuado o depósito exigido pelo inciso II do caput deste artigo.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 330",
                                                    "href": "#art330",
                                                    "inicio": 28,
                                                    "fim": 36
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7714,
                                            "texto": "Aplica-se à ação rescisória o disposto no art. 332 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 332",
                                                    "href": "#art332",
                                                    "inicio": 42,
                                                    "fim": 50
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7716,
                                            "texto": "Reconhecida a incompetência do tribunal para julgar a ação rescisória, o autor será intimado para emendar a petição inicial, a fim de adequar o objeto da ação rescisória, quando a decisão apontada como rescindenda:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7718,
                                                    "texto": "não tiver apreciado o mérito e não se enquadrar na situação prevista no § 2º do art. 966 ;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7720,
                                                    "texto": "tiver sido substituída por decisão posterior."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7722,
                                            "texto": "Na hipótese do § 5º, após a emenda da petição inicial, será permitido ao réu complementar os fundamentos de defesa, e, em seguida, os autos serão remetidos ao tribunal competente."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7704,
                                            "texto": "cumular ao pedido de rescisão, se for o caso, o de novo julgamento do processo;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7706,
                                            "texto": "depositar a importância de cinco por cento sobre o valor da causa, que se converterá em multa caso a ação seja, por unanimidade de votos, declarada inadmissível ou improcedente."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 319",
                                            "href": "#art319",
                                            "inicio": 78,
                                            "fim": 86
                                        }
                                    ]
                                },
                                {
                                    "numero": "969º",
                                    "rotulo": "Art. 969º.",
                                    "linha": 7724,
                                    "caput": "A propositura da ação rescisória não impede o cumprimento da decisão rescindenda, ressalvada a concessão de tutela provisória."
                                },
                                {
                                    "numero": "970º",
                                    "rotulo": "Art. 970º.",
                                    "linha": 7726,
                                    "caput": "O relator ordenará a citação do réu, designando-lhe prazo nunca inferior a 15 (quinze) dias nem superior a 30 (trinta) dias para, querendo, apresentar resposta, ao fim do qual, com ou sem contestação, observar-se-á, no que couber, o procedimento comum."
                                },
                                {
                                    "numero": "971º",
                                    "rotulo": "Art. 971º.",
                                    "linha": 7728,
                                    "caput": "Na ação rescisória, devolvidos os autos pelo relator, a secretaria do tribunal expedirá cópias do relatório e as distribuirá entre os juízes que compuserem o órgão competente para o julgamento.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7730,
                                            "texto": "A escolha de relator recairá, sempre que possível, em juiz que não haja participado do julgamento rescindendo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "972º",
                                    "rotulo": "Art. 972º.",
                                    "linha": 7732,
                                    "caput": "Se os fatos alegados pelas partes dependerem de prova, o relator poderá delegar a competência ao órgão que proferiu a decisão rescindenda, fixando prazo de 1 (um) a 3 (três) meses para a devolução dos autos."
                                },
                                {
                                    "numero": "973º",
                                    "rotulo": "Art. 973º.",
                                    "linha": 7734,
                                    "caput": "Concluída a instrução, será aberta vista ao autor e ao réu para razões finais, sucessivamente, pelo prazo de 10 (dez) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7736,
                                            "texto": "Em seguida, os autos serão conclusos ao relator, procedendo-se ao julgamento pelo órgão competente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "974º",
                                    "rotulo": "Art. 974º.",
                                    "linha": 7738,
                                    "caput": "Julgando procedente o pedido, o tribunal rescindirá a decisão, proferirá, se for o caso, novo julgamento e determinará a restituição do depósito a que se refere o inciso II do art. 968 .",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7740,
                                            "texto": "Considerando, por unanimidade, inadmissível ou improcedente o pedido, o tribunal determinará a reversão, em favor do réu, da importância do depósito, sem prejuízo do disposto no § 2º do art. 82 ."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "inciso II do art. 968",
                                            "href": "#art968ii",
                                            "inicio": 163,
                                            "fim": 184
                                        }
                                    ]
                                },
                                {
                                    "numero": "975º",
                                    "rotulo": "Art. 975º.",
                                    "linha": 7742,
                                    "caput": "O direito à rescisão se extingue em 2 (dois) anos contados do trânsito em julgado da última decisão proferida no processo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7744,
                                            "texto": "Prorroga-se até o primeiro dia útil imediatamente subsequente o prazo a que se refere o caput , quando expirar durante férias forenses, recesso, feriados ou em dia em que não houver expediente forense."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7746,
                                            "texto": "Se fundada a ação no inciso VII do art. 966, o termo inicial do prazo será a data de descoberta da prova nova, observado o prazo máximo de 5 (cinco) anos, contado do trânsito em julgado da última decisão proferida no processo."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7748,
                                            "texto": "Nas hipóteses de simulação ou de colusão das partes, o prazo começa a contar, para o terceiro prejudicado e para o Ministério Público, que não interveio no processo, a partir do momento em que têm ciência da simulação ou da colusão."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DA AÇÃO RESCISÓRIA",
                            "linhaTitulo": 7648
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VIII",
                            "linha": 7750,
                            "artigos": [
                                {
                                    "numero": "976º",
                                    "rotulo": "Art. 976º.",
                                    "linha": 7753,
                                    "caput": "É cabível a instauração do incidente de resolução de demandas repetitivas quando houver, simultaneamente:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7759,
                                            "texto": "A desistência ou o abandono do processo não impede o exame de mérito do incidente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7761,
                                            "texto": "Se não for o requerente, o Ministério Público intervirá obrigatoriamente no incidente e deverá assumir sua titularidade em caso de desistência ou de abandono."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7763,
                                            "texto": "A inadmissão do incidente de resolução de demandas repetitivas por ausência de qualquer de seus pressupostos de admissibilidade não impede que, uma vez satisfeito o requisito, seja o incidente novamente suscitado."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7765,
                                            "texto": "É incabível o incidente de resolução de demandas repetitivas quando um dos tribunais superiores, no âmbito de sua respectiva competência, já tiver afetado recurso para definição de tese sobre questão de direito material ou processual repetitiva."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7767,
                                            "texto": "Não serão exigidas custas processuais no incidente de resolução de demandas repetitivas."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7755,
                                            "texto": "efetiva repetição de processos que contenham controvérsia sobre a mesma questão unicamente de direito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7757,
                                            "texto": "risco de ofensa à isonomia e à segurança jurídica."
                                        }
                                    ]
                                },
                                {
                                    "numero": "977º",
                                    "rotulo": "Art. 977º.",
                                    "linha": 7769,
                                    "caput": "O pedido de instauração do incidente será dirigido ao presidente de tribunal:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7777,
                                            "texto": "O ofício ou a petição será instruído com os documentos necessários à demonstração do preenchimento dos pressupostos para a instauração do incidente."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7771,
                                            "texto": "pelo juiz ou relator, por ofício;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7773,
                                            "texto": "pelas partes, por petição;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7775,
                                            "texto": "pelo Ministério Público ou pela Defensoria Pública, por petição."
                                        }
                                    ]
                                },
                                {
                                    "numero": "978º",
                                    "rotulo": "Art. 978º.",
                                    "linha": 7779,
                                    "caput": "O julgamento do incidente caberá ao órgão indicado pelo regimento interno dentre aqueles responsáveis pela uniformização de jurisprudência do tribunal.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7781,
                                            "texto": "O órgão colegiado incumbido de julgar o incidente e de fixar a tese jurídica julgará igualmente o recurso, a remessa necessária ou o processo de competência originária de onde se originou o incidente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "979º",
                                    "rotulo": "Art. 979º.",
                                    "linha": 7783,
                                    "caput": "A instauração e o julgamento do incidente serão sucedidos da mais ampla e específica divulgação e publicidade, por meio de registro eletrônico no Conselho Nacional de Justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7785,
                                            "texto": "Os tribunais manterão banco eletrônico de dados atualizados com informações específicas sobre questões de direito submetidas ao incidente, comunicando-o imediatamente ao Conselho Nacional de Justiça para inclusão no cadastro."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7787,
                                            "texto": "Para possibilitar a identificação dos processos abrangidos pela decisão do incidente, o registro eletrônico das teses jurídicas constantes do cadastro conterá, no mínimo, os fundamentos determinantes da decisão e os dispositivos normativos a ela relacionados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7789,
                                            "texto": "Aplica-se o disposto neste artigo ao julgamento de recursos repetitivos e da repercussão geral em recurso extraordinário."
                                        }
                                    ]
                                },
                                {
                                    "numero": "980º",
                                    "rotulo": "Art. 980º.",
                                    "linha": 7791,
                                    "caput": "O incidente será julgado no prazo de 1 (um) ano e terá preferência sobre os demais feitos, ressalvados os que envolvam réu preso e os pedidos de habeas corpus .",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7793,
                                            "texto": "Superado o prazo previsto no caput , cessa a suspensão dos processos prevista no art. 982 , salvo decisão fundamentada do relator em sentido contrário.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 982",
                                                    "href": "#art982",
                                                    "inicio": 81,
                                                    "fim": 89
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "981º",
                                    "rotulo": "Art. 981º.",
                                    "linha": 7795,
                                    "caput": "Após a distribuição, o órgão colegiado competente para julgar o incidente procederá ao seu juízo de admissibilidade, considerando a presença dos pressupostos do art. 976.",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 97",
                                            "href": "#art97",
                                            "inicio": 161,
                                            "fim": 168
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "art. 976.",
                                            "href": "#art976",
                                            "inicio": 161,
                                            "fim": 170
                                        }
                                    ]
                                },
                                {
                                    "numero": "982º",
                                    "rotulo": "Art. 982º.",
                                    "linha": 7797,
                                    "caput": "Admitido o incidente, o relator:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7805,
                                            "texto": "A suspensão será comunicada aos órgãos jurisdicionais competentes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7807,
                                            "texto": "Durante a suspensão, o pedido de tutela de urgência deverá ser dirigido ao juízo onde tramita o processo suspenso."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7809,
                                            "texto": "Visando à garantia da segurança jurídica, qualquer legitimado mencionado no art. 977, incisos II e III , poderá requerer, ao tribunal competente para conhecer do recurso extraordinário ou especial, a suspensão de todos os processos individuais ou coletivos em curso no território nacional que versem sobre a questão objeto do incidente já instaurado.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 97",
                                                    "href": "#art97",
                                                    "inicio": 76,
                                                    "fim": 83
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 977, incisos II e III",
                                                    "href": "#art977ii",
                                                    "inicio": 76,
                                                    "fim": 102
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7811,
                                            "texto": "Independentemente dos limites da competência territorial, a parte no processo em curso no qual se discuta a mesma questão objeto do incidente é legitimada para requerer a providência prevista no § 3º deste artigo."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7813,
                                            "texto": "Cessa a suspensão a que se refere o inciso I do caput deste artigo se não for interposto recurso especial ou recurso extraordinário contra a decisão proferida no incidente."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7799,
                                            "texto": "suspenderá os processos pendentes, individuais ou coletivos, que tramitam no Estado ou na região, conforme o caso;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7801,
                                            "texto": "poderá requisitar informações a órgãos em cujo juízo tramita processo no qual se discute o objeto do incidente, que as prestarão no prazo de 15 (quinze) dias;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7803,
                                            "texto": "intimará o Ministério Público para, querendo, manifestar-se no prazo de 15 (quinze) dias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "983º",
                                    "rotulo": "Art. 983º.",
                                    "linha": 7815,
                                    "caput": "O relator ouvirá as partes e os demais interessados, inclusive pessoas, órgãos e entidades com interesse na controvérsia, que, no prazo comum de 15 (quinze) dias, poderão requerer a juntada de documentos, bem como as diligências necessárias para a elucidação da questão de direito controvertida, e, em seguida, manifestar-se-á o Ministério Público, no mesmo prazo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7817,
                                            "texto": "Para instruir o incidente, o relator poderá designar data para, em audiência pública, ouvir depoimentos de pessoas com experiência e conhecimento na matéria."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7819,
                                            "texto": "Concluídas as diligências, o relator solicitará dia para o julgamento do incidente."
                                        }
                                    ]
                                },
                                {
                                    "numero": "984º",
                                    "rotulo": "Art. 984º.",
                                    "linha": 7821,
                                    "caput": "No julgamento do incidente, observar-se-á a seguinte ordem:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7831,
                                            "texto": "Considerando o número de inscritos, o prazo poderá ser ampliado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7833,
                                            "texto": "O conteúdo do acórdão abrangerá a análise de todos os fundamentos suscitados concernentes à tese jurídica discutida, sejam favoráveis ou contrários."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7823,
                                            "texto": "o relator fará a exposição do objeto do incidente;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7825,
                                            "texto": "poderão sustentar suas razões, sucessivamente:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 7827,
                                                    "texto": "o autor e o réu do processo originário e o Ministério Público, pelo prazo de 30 (trinta) minutos;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 7829,
                                                    "texto": "os demais interessados, no prazo de 30 (trinta) minutos, divididos entre todos, sendo exigida inscrição com 2 (dois) dias de antecedência."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "985º",
                                    "rotulo": "Art. 985º.",
                                    "linha": 7835,
                                    "caput": "Julgado o incidente, a tese jurídica será aplicada:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7841,
                                            "texto": "Não observada a tese adotada no incidente, caberá reclamação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7843,
                                            "texto": "Se o incidente tiver por objeto questão relativa a prestação de serviço concedido, permitido ou autorizado, o resultado do julgamento será comunicado ao órgão, ao ente ou à agência reguladora competente para fiscalização da efetiva aplicação, por parte dos entes sujeitos a regulação, da tese adotada."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7837,
                                            "texto": "a todos os processos individuais ou coletivos que versem sobre idêntica questão de direito e que tramitem na área de jurisdição do respectivo tribunal, inclusive àqueles que tramitem nos juizados especiais do respectivo Estado ou região;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7839,
                                            "texto": "aos casos futuros que versem idêntica questão de direito e que venham a tramitar no território de competência do tribunal, salvo revisão na forma do art. 986 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 986",
                                                    "href": "#art986",
                                                    "inicio": 149,
                                                    "fim": 157
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "986º",
                                    "rotulo": "Art. 986º.",
                                    "linha": 7845,
                                    "caput": "A revisão da tese jurídica firmada no incidente far-se-á pelo mesmo tribunal, de ofício ou mediante requerimento dos legitimados mencionados no art. 977, inciso III .",
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 97",
                                            "href": "#art97",
                                            "inicio": 144,
                                            "fim": 151
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "art. 977, inciso III",
                                            "href": "#art977iii",
                                            "inicio": 144,
                                            "fim": 164
                                        }
                                    ]
                                },
                                {
                                    "numero": "987º",
                                    "rotulo": "Art. 987º.",
                                    "linha": 7847,
                                    "caput": "Do julgamento do mérito do incidente caberá recurso extraordinário ou especial, conforme o caso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7849,
                                            "texto": "O recurso tem efeito suspensivo, presumindo-se a repercussão geral de questão constitucional eventualmente discutida."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7851,
                                            "texto": "Apreciado o mérito do recurso, a tese jurídica adotada pelo Supremo Tribunal Federal ou pelo Superior Tribunal de Justiça será aplicada no território nacional a todos os processos individuais ou coletivos que versem sobre idêntica questão de direito."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO INCIDENTE DE RESOLUÇÃO DE DEMANDAS REPETITIVAS",
                            "linhaTitulo": 7751
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IX",
                            "linha": 7853,
                            "artigos": [
                                {
                                    "numero": "988º",
                                    "rotulo": "Art. 988º.",
                                    "linha": 7856,
                                    "caput": "Caberá reclamação da parte interessada ou do Ministério Público para:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7868,
                                            "texto": "A reclamação pode ser proposta perante qualquer tribunal, e seu julgamento compete ao órgão jurisdicional cuja competência se busca preservar ou cuja autoridade se pretenda garantir."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7870,
                                            "texto": "A reclamação deverá ser instruída com prova documental e dirigida ao presidente do tribunal."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7872,
                                            "texto": "Assim que recebida, a reclamação será autuada e distribuída ao relator do processo principal, sempre que possível."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7874,
                                            "texto": "As hipóteses dos incisos III e IV compreendem a aplicação indevida da tese jurídica e sua não aplicação aos casos que a ela correspondam."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7877,
                                            "texto": "É inadmissível a reclamação:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7879,
                                                    "texto": "proposta após o trânsito em julgado da decisão reclamada;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7881,
                                                    "texto": "proposta para garantir a observância de acórdão de recurso extraordinário com repercussão geral reconhecida ou de acórdão proferido em julgamento de recursos extraordinário ou especial repetitivos, quando não esgotadas as instâncias ordinárias."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7883,
                                            "texto": "A inadmissibilidade ou o julgamento do recurso interposto contra a decisão proferida pelo órgão reclamado não prejudica a reclamação."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7858,
                                            "texto": "preservar a competência do tribunal;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7860,
                                            "texto": "garantir a autoridade das decisões do tribunal;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7863,
                                            "texto": "garantir a observância de enunciado de súmula vinculante e de decisão do Supremo Tribunal Federal em controle concentrado de constitucionalidade;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7866,
                                            "texto": "garantir a observância de acórdão proferido em julgamento de incidente de resolução de demandas repetitivas ou de incidente de assunção de competência;"
                                        }
                                    ]
                                },
                                {
                                    "numero": "989º",
                                    "rotulo": "Art. 989º.",
                                    "linha": 7885,
                                    "caput": "Ao despachar a reclamação, o relator:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7887,
                                            "texto": "requisitará informações da autoridade a quem for imputada a prática do ato impugnado, que as prestará no prazo de 10 (dez) dias;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7889,
                                            "texto": "se necessário, ordenará a suspensão do processo ou do ato impugnado para evitar dano irreparável;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7891,
                                            "texto": "determinará a citação do beneficiário da decisão impugnada, que terá prazo de 15 (quinze) dias para apresentar a sua contestação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "990º",
                                    "rotulo": "Art. 990º.",
                                    "linha": 7893,
                                    "caput": "Qualquer interessado poderá impugnar o pedido do reclamante."
                                },
                                {
                                    "numero": "991º",
                                    "rotulo": "Art. 991º.",
                                    "linha": 7895,
                                    "caput": "Na reclamação que não houver formulado, o Ministério Público terá vista do processo por 5 (cinco) dias, após o decurso do prazo para informações e para o oferecimento da contestação pelo beneficiário do ato impugnado."
                                },
                                {
                                    "numero": "992º",
                                    "rotulo": "Art. 992º.",
                                    "linha": 7897,
                                    "caput": "Julgando procedente a reclamação, o tribunal cassará a decisão exorbitante de seu julgado ou determinará medida adequada à solução da controvérsia."
                                },
                                {
                                    "numero": "993º",
                                    "rotulo": "Art. 993º.",
                                    "linha": 7899,
                                    "caput": "O presidente do tribunal determinará o imediato cumprimento da decisão, lavrando-se o acórdão posteriormente."
                                }
                            ],
                            "titulo": "DA RECLAMAÇÃO",
                            "linhaTitulo": 7854
                        }
                    ],
                    "titulo": "DA ORDEM DOS PROCESSOS E DOS PROCESSOS DE COMPETÊNCIA ORIGINÁRIA DOS TRIBUNAIS",
                    "linhaTitulo": 7307
                },
                {
                    "tipo": "titulo",
                    "rotulo": "TÍTULO II",
                    "linha": 7901,
                    "divisoes": [
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO I",
                            "linha": 7904,
                            "artigos": [
                                {
                                    "numero": "994º",
                                    "rotulo": "Art. 994º.",
                                    "linha": 7907,
                                    "caput": "São cabíveis os seguintes recursos:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 7909,
                                            "texto": "apelação;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 7911,
                                            "texto": "agravo de instrumento;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 7913,
                                            "texto": "agravo interno;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 7915,
                                            "texto": "embargos de declaração;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 7917,
                                            "texto": "recurso ordinário;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 7919,
                                            "texto": "recurso especial;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 7921,
                                            "texto": "recurso extraordinário;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 7923,
                                            "texto": "agravo em recurso especial ou extraordinário;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 7925,
                                            "texto": "embargos de divergência."
                                        }
                                    ]
                                },
                                {
                                    "numero": "995º",
                                    "rotulo": "Art. 995º.",
                                    "linha": 7927,
                                    "caput": "Os recursos não impedem a eficácia da decisão, salvo disposição legal ou decisão judicial em sentido diverso.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7929,
                                            "texto": "A eficácia da decisão recorrida poderá ser suspensa por decisão do relator, se da imediata produção de seus efeitos houver risco de dano grave, de difícil ou impossível reparação, e ficar demonstrada a probabilidade de provimento do recurso."
                                        }
                                    ]
                                },
                                {
                                    "numero": "996º",
                                    "rotulo": "Art. 996º.",
                                    "linha": 7931,
                                    "caput": "O recurso pode ser interposto pela parte vencida, pelo terceiro prejudicado e pelo Ministério Público, como parte ou como fiscal da ordem jurídica.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7933,
                                            "texto": "Cumpre ao terceiro demonstrar a possibilidade de a decisão sobre a relação jurídica submetida à apreciação judicial atingir direito de que se afirme titular ou que possa discutir em juízo como substituto processual."
                                        }
                                    ]
                                },
                                {
                                    "numero": "997º",
                                    "rotulo": "Art. 997º.",
                                    "linha": 7935,
                                    "caput": "Cada parte interporá o recurso independentemente, no prazo e com observância das exigências legais.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7937,
                                            "texto": "Sendo vencidos autor e réu, ao recurso interposto por qualquer deles poderá aderir o outro."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7939,
                                            "texto": "O recurso adesivo fica subordinado ao recurso independente, sendo-lhe aplicáveis as mesmas regras deste quanto aos requisitos de admissibilidade e julgamento no tribunal, salvo disposição legal diversa, observado, ainda, o seguinte:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 7941,
                                                    "texto": "será dirigido ao órgão perante o qual o recurso independente fora interposto, no prazo de que a parte dispõe para responder;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 7943,
                                                    "texto": "será admissível na apelação, no recurso extraordinário e no recurso especial;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 7945,
                                                    "texto": "não será conhecido, se houver desistência do recurso principal ou se for ele considerado inadmissível."
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "998º",
                                    "rotulo": "Art. 998º.",
                                    "linha": 7947,
                                    "caput": "O recorrente poderá, a qualquer tempo, sem a anuência do recorrido ou dos litisconsortes, desistir do recurso.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7949,
                                            "texto": "A desistência do recurso não impede a análise de questão cuja repercussão geral já tenha sido reconhecida e daquela objeto de julgamento de recursos extraordinários ou especiais repetitivos."
                                        }
                                    ]
                                },
                                {
                                    "numero": "999º",
                                    "rotulo": "Art. 999º.",
                                    "linha": 7951,
                                    "caput": "A renúncia ao direito de recorrer independe da aceitação da outra parte."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7953,
                                    "caput": "000. A parte que aceitar expressa ou tacitamente a decisão não poderá recorrer.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7955,
                                            "texto": "Considera-se aceitação tácita a prática, sem nenhuma reserva, de ato incompatível com a vontade de recorrer."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7957,
                                    "caput": "001. Dos despachos não cabe recurso."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7959,
                                    "caput": "002. A decisão pode ser impugnada no todo ou em parte."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7961,
                                    "caput": "003. O prazo para interposição de recurso conta-se da data em que os advogados, a sociedade de advogados, a Advocacia Pública, a Defensoria Pública ou o Ministério Público são intimados da decisão.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7963,
                                            "texto": "Os sujeitos previstos no caput considerar-se-ão intimados em audiência quando nesta for proferida a decisão."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7965,
                                            "texto": "Aplica-se o disposto no art. 231 , incisos I a VI, ao prazo de interposição de recurso pelo réu contra decisão proferida anteriormente à citação.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 231",
                                                    "href": "#art231",
                                                    "inicio": 24,
                                                    "fim": 32
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7967,
                                            "texto": "No prazo para interposição de recurso, a petição será protocolada em cartório ou conforme as normas de organização judiciária, ressalvado o disposto em regra especial."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7969,
                                            "texto": "Para aferição da tempestividade do recurso remetido pelo correio, será considerada como data de interposição a data de postagem."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7971,
                                            "texto": "Excetuados os embargos de declaração, o prazo para interpor os recursos e para responder-lhes é de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7974,
                                            "texto": "O recorrente comprovará a ocorrência de feriado local no ato de interposição do recurso, e, se não o fizer, o tribunal determinará a correção do vício formal, ou poderá desconsiderá-lo caso a informação já conste do processo eletrônico."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7976,
                                    "caput": "004. Se, durante o prazo para a interposição do recurso, sobrevier o falecimento da parte ou de seu advogado ou ocorrer motivo de força maior que suspenda o curso do processo, será tal prazo restituído em proveito da parte, do herdeiro ou do sucessor, contra quem começará a correr novamente depois da intimação."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7978,
                                    "caput": "005. O recurso interposto por um dos litisconsortes a todos aproveita, salvo se distintos ou opostos os seus interesses.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 7980,
                                            "texto": "Havendo solidariedade passiva, o recurso interposto por um devedor aproveitará aos outros quando as defesas opostas ao credor lhes forem comuns."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7982,
                                    "caput": "006. Certificado o trânsito em julgado, com menção expressa da data de sua ocorrência, o escrivão ou o chefe de secretaria, independentemente de despacho, providenciará a baixa dos autos ao juízo de origem, no prazo de 5 (cinco) dias."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 7984,
                                    "caput": "007. No ato de interposição do recurso, o recorrente comprovará, quando exigido pela legislação pertinente, o respectivo preparo, inclusive porte de remessa e de retorno, sob pena de deserção.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 7986,
                                            "texto": "São dispensados de preparo, inclusive porte de remessa e de retorno, os recursos interpostos pelo Ministério Público, pela União, pelo Distrito Federal, pelos Estados, pelos Municípios, e respectivas autarquias, e pelos que gozam de isenção legal."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 7988,
                                            "texto": "A insuficiência no valor do preparo, inclusive porte de remessa e de retorno, implicará deserção se o recorrente, intimado na pessoa de seu advogado, não vier a supri-lo no prazo de 5 (cinco) dias."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 7990,
                                            "texto": "É dispensado o recolhimento do porte de remessa e de retorno no processo em autos eletrônicos."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 7992,
                                            "texto": "O recorrente que não comprovar, no ato de interposição do recurso, o recolhimento do preparo, inclusive porte de remessa e de retorno, será intimado, na pessoa de seu advogado, para realizar o recolhimento em dobro, sob pena de deserção."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 7994,
                                            "texto": "É vedada a complementação se houver insuficiência parcial do preparo, inclusive porte de remessa e de retorno, no recolhimento realizado na forma do § 4º."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 7996,
                                            "texto": "Provando o recorrente justo impedimento, o relator relevará a pena de deserção, por decisão irrecorrível, fixando-lhe prazo de 5 (cinco) dias para efetuar o preparo."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 7998,
                                            "texto": "O equívoco no preenchimento da guia de custas não implicará a aplicação da pena de deserção, cabendo ao relator, na hipótese de dúvida quanto ao recolhimento, intimar o recorrente para sanar o vício no prazo de 5 (cinco) dias."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8000,
                                    "caput": "008. O julgamento proferido pelo tribunal substituirá a decisão impugnada no que tiver sido objeto de recurso."
                                }
                            ],
                            "titulo": "DISPOSIÇÕES GERAIS",
                            "linhaTitulo": 7905
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO II",
                            "linha": 8002,
                            "artigos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8005,
                                    "caput": "009. Da sentença cabe apelação.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8007,
                                            "texto": "As questões resolvidas na fase de conhecimento, se a decisão a seu respeito não comportar agravo de instrumento, não são cobertas pela preclusão e devem ser suscitadas em preliminar de apelação, eventualmente interposta contra a decisão final, ou nas contrarrazões."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8009,
                                            "texto": "Se as questões referidas no § 1º forem suscitadas em contrarrazões, o recorrente será intimado para, em 15 (quinze) dias, manifestar-se a respeito delas."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8011,
                                            "texto": "O disposto no caput deste artigo aplica-se mesmo quando as questões mencionadas no art. 1.015 integrarem capítulo da sentença.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.015",
                                                    "href": "#art1015",
                                                    "inicio": 83,
                                                    "fim": 93
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8013,
                                    "caput": "010. A apelação, interposta por petição dirigida ao juízo de primeiro grau, conterá:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8023,
                                            "texto": "O apelado será intimado para apresentar contrarrazões no prazo de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8025,
                                            "texto": "Se o apelado interpuser apelação adesiva, o juiz intimará o apelante para apresentar contrarrazões."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8027,
                                            "texto": "Após as formalidades previstas nos §§ 1º e 2º, os autos serão remetidos ao tribunal pelo juiz, independentemente de juízo de admissibilidade."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8015,
                                            "texto": "os nomes e a qualificação das partes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8017,
                                            "texto": "a exposição do fato e do direito;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8019,
                                            "texto": "as razões do pedido de reforma ou de decretação de nulidade;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 8021,
                                            "texto": "o pedido de nova decisão."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8029,
                                    "caput": "011. Recebido o recurso de apelação no tribunal e distribuído imediatamente, o relator:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8031,
                                            "texto": "decidi-lo-á monocraticamente apenas nas hipóteses do art. 932, incisos III a V ;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "932",
                                                    "href": "#art932",
                                                    "inicio": 58,
                                                    "fim": 61
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 932, incisos III a V",
                                                    "href": "#art932iii",
                                                    "inicio": 53,
                                                    "fim": 78
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8033,
                                            "texto": "se não for o caso de decisão monocrática, elaborará seu voto para julgamento do recurso pelo órgão colegiado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8035,
                                    "caput": "012. A apelação terá efeito suspensivo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8037,
                                            "texto": "Além de outras hipóteses previstas em lei, começa a produzir efeitos imediatamente após a sua publicação a sentença que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8039,
                                                    "texto": "homologa divisão ou demarcação de terras;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8041,
                                                    "texto": "condena a pagar alimentos;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 8043,
                                                    "texto": "extingue sem resolução do mérito ou julga improcedentes os embargos do executado;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 8045,
                                                    "texto": "julga procedente o pedido de instituição de arbitragem;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 8047,
                                                    "texto": "confirma, concede ou revoga tutela provisória;"
                                                },
                                                {
                                                    "numero": "VI",
                                                    "rotulo": "VI",
                                                    "linha": 8049,
                                                    "texto": "decreta a interdição."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8051,
                                            "texto": "Nos casos do § 1º, o apelado poderá promover o pedido de cumprimento provisório depois de publicada a sentença."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8053,
                                            "texto": "O pedido de concessão de efeito suspensivo nas hipóteses do § 1º poderá ser formulado por requerimento dirigido ao:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8055,
                                                    "texto": "tribunal, no período compreendido entre a interposição da apelação e sua distribuição, ficando o relator designado para seu exame prevento para julgá-la;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8057,
                                                    "texto": "relator, se já distribuída a apelação."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8059,
                                            "texto": "Nas hipóteses do § 1º, a eficácia da sentença poderá ser suspensa pelo relator se o apelante demonstrar a probabilidade de provimento do recurso ou se, sendo relevante a fundamentação, houver risco de dano grave ou de difícil reparação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8061,
                                    "caput": "013. A apelação devolverá ao tribunal o conhecimento da matéria impugnada.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8063,
                                            "texto": "Serão, porém, objeto de apreciação e julgamento pelo tribunal todas as questões suscitadas e discutidas no processo, ainda que não tenham sido solucionadas, desde que relativas ao capítulo impugnado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8065,
                                            "texto": "Quando o pedido ou a defesa tiver mais de um fundamento e o juiz acolher apenas um deles, a apelação devolverá ao tribunal o conhecimento dos demais."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8067,
                                            "texto": "Se o processo estiver em condições de imediato julgamento, o tribunal deve decidir desde logo o mérito quando:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8069,
                                                    "texto": "reformar sentença fundada no art. 485 ;",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 485",
                                                            "href": "#art485",
                                                            "inicio": 29,
                                                            "fim": 37
                                                        }
                                                    ]
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8071,
                                                    "texto": "decretar a nulidade da sentença por não ser ela congruente com os limites do pedido ou da causa de pedir;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 8073,
                                                    "texto": "constatar a omissão no exame de um dos pedidos, hipótese em que poderá julgá-lo;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 8075,
                                                    "texto": "decretar a nulidade de sentença por falta de fundamentação."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8077,
                                            "texto": "Quando reformar sentença que reconheça a decadência ou a prescrição, o tribunal, se possível, julgará o mérito, examinando as demais questões, sem determinar o retorno do processo ao juízo de primeiro grau."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8079,
                                            "texto": "O capítulo da sentença que confirma, concede ou revoga a tutela provisória é impugnável na apelação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8081,
                                    "caput": "014. As questões de fato não propostas no juízo inferior poderão ser suscitadas na apelação, se a parte provar que deixou de fazê-lo por motivo de força maior."
                                }
                            ],
                            "titulo": "DA APELAÇÃO",
                            "linhaTitulo": 8003
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO III",
                            "linha": 8083,
                            "artigos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8086,
                                    "caput": "015. Cabe agravo de instrumento contra as decisões interlocutórias que versarem sobre:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 8112,
                                            "texto": "Também caberá agravo de instrumento contra decisões interlocutórias proferidas na fase de liquidação de sentença ou de cumprimento de sentença, no processo de execução e no processo de inventário."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8088,
                                            "texto": "tutelas provisórias;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8090,
                                            "texto": "mérito do processo;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8092,
                                            "texto": "rejeição da alegação de convenção de arbitragem;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 8094,
                                            "texto": "incidente de desconsideração da personalidade jurídica;"
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 8096,
                                            "texto": "rejeição do pedido de gratuidade da justiça ou acolhimento do pedido de sua revogação;"
                                        },
                                        {
                                            "numero": "VI",
                                            "rotulo": "VI",
                                            "linha": 8098,
                                            "texto": "exibição ou posse de documento ou coisa;"
                                        },
                                        {
                                            "numero": "VII",
                                            "rotulo": "VII",
                                            "linha": 8100,
                                            "texto": "exclusão de litisconsorte;"
                                        },
                                        {
                                            "numero": "VIII",
                                            "rotulo": "VIII",
                                            "linha": 8102,
                                            "texto": "rejeição do pedido de limitação do litisconsórcio;"
                                        },
                                        {
                                            "numero": "IX",
                                            "rotulo": "IX",
                                            "linha": 8104,
                                            "texto": "admissão ou inadmissão de intervenção de terceiros;"
                                        },
                                        {
                                            "numero": "X",
                                            "rotulo": "X",
                                            "linha": 8106,
                                            "texto": "concessão, modificação ou revogação do efeito suspensivo aos embargos à execução;"
                                        },
                                        {
                                            "numero": "XI",
                                            "rotulo": "XI",
                                            "linha": 8108,
                                            "texto": "redistribuição do ônus da prova nos termos do art. 373, § 1º ;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 373",
                                                    "href": "#art373",
                                                    "inicio": 46,
                                                    "fim": 54
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "XIII",
                                            "rotulo": "XIII",
                                            "linha": 8110,
                                            "texto": "outros casos expressamente referidos em lei."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8114,
                                    "caput": "016. O agravo de instrumento será dirigido diretamente ao tribunal competente, por meio de petição com os seguintes requisitos:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8116,
                                            "texto": "os nomes das partes;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8118,
                                            "texto": "a exposição do fato e do direito;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8120,
                                            "texto": "as razões do pedido de reforma ou de invalidação da decisão e o próprio pedido;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 8122,
                                            "texto": "o nome e o endereço completo dos advogados constantes do processo."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8124,
                                    "caput": "017. A petição de agravo de instrumento será instruída:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8132,
                                            "texto": "Acompanhará a petição o comprovante do pagamento das respectivas custas e do porte de retorno, quando devidos, conforme tabela publicada pelos tribunais."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8134,
                                            "texto": "No prazo do recurso, o agravo será interposto por:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8136,
                                                    "texto": "protocolo realizado diretamente no tribunal competente para julgá-lo;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8138,
                                                    "texto": "protocolo realizado na própria comarca, seção ou subseção judiciárias;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 8140,
                                                    "texto": "postagem, sob registro, com aviso de recebimento;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 8142,
                                                    "texto": "transmissão de dados tipo fac-símile, nos termos da lei;"
                                                },
                                                {
                                                    "numero": "V",
                                                    "rotulo": "V",
                                                    "linha": 8144,
                                                    "texto": "outra forma prevista em lei."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8146,
                                            "texto": "Na falta da cópia de qualquer peça ou no caso de algum outro vício que comprometa a admissibilidade do agravo de instrumento, deve o relator aplicar o disposto no art. 932, parágrafo único .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "932",
                                                    "href": "#art932",
                                                    "inicio": 168,
                                                    "fim": 171
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8148,
                                            "texto": "Se o recurso for interposto por sistema de transmissão de dados tipo fac-símile ou similar, as peças devem ser juntadas no momento de protocolo da petição original."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8150,
                                            "texto": "Sendo eletrônicos os autos do processo, dispensam-se as peças referidas nos incisos I e II do caput , facultando-se ao agravante anexar outros documentos que entender úteis para a compreensão da controvérsia."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8126,
                                            "texto": "obrigatoriamente, com cópias da petição inicial, da contestação, da petição que ensejou a decisão agravada, da própria decisão agravada, da certidão da respectiva intimação ou outro documento oficial que comprove a tempestividade e das procurações outorgadas aos advogados do agravante e do agravado;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8128,
                                            "texto": "com declaração de inexistência de qualquer dos documentos referidos no inciso I, feita pelo advogado do agravante, sob pena de sua responsabilidade pessoal;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8130,
                                            "texto": "facultativamente, com outras peças que o agravante reputar úteis."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8152,
                                    "caput": "018. O agravante poderá requerer a juntada, aos autos do processo, de cópia da petição do agravo de instrumento, do comprovante de sua interposição e da relação dos documentos que instruíram o recurso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8154,
                                            "texto": "Se o juiz comunicar que reformou inteiramente a decisão, o relator considerará prejudicado o agravo de instrumento."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8156,
                                            "texto": "Não sendo eletrônicos os autos, o agravante tomará a providência prevista no caput , no prazo de 3 (três) dias a contar da interposição do agravo de instrumento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8158,
                                            "texto": "O descumprimento da exigência de que trata o § 2º, desde que arguido e provado pelo agravado, importa inadmissibilidade do agravo de instrumento."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8160,
                                    "caput": "019. Recebido o agravo de instrumento no tribunal e distribuído imediatamente, se não for o caso de aplicação do art. 932, incisos III e IV , o relator, no prazo de 5 (cinco) dias:",
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8162,
                                            "texto": "poderá atribuir efeito suspensivo ao recurso ou deferir, em antecipação de tutela, total ou parcialmente, a pretensão recursal, comunicando ao juiz sua decisão;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8164,
                                            "texto": "ordenará a intimação do agravado pessoalmente, por carta com aviso de recebimento, quando não tiver procurador constituído, ou pelo Diário da Justiça ou por carta com aviso de recebimento dirigida ao seu advogado, para que responda no prazo de 15 (quinze) dias, facultando-lhe juntar a documentação que entender necessária ao julgamento do recurso;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8166,
                                            "texto": "determinará a intimação do Ministério Público, preferencialmente por meio eletrônico, quando for o caso de sua intervenção, para que se manifeste no prazo de 15 (quinze) dias."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "932",
                                            "href": "#art932",
                                            "inicio": 118,
                                            "fim": 121
                                        },
                                        {
                                            "campo": "caput",
                                            "texto": "art. 932, incisos III e IV",
                                            "href": "#art932iii",
                                            "inicio": 113,
                                            "fim": 139
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8168,
                                    "caput": "020. O relator solicitará dia para julgamento em prazo não superior a 1 (um) mês da intimação do agravado."
                                }
                            ],
                            "titulo": "DO AGRAVO DE INSTRUMENTO",
                            "linhaTitulo": 8084
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO IV",
                            "linha": 8170,
                            "artigos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8173,
                                    "caput": "021. Contra decisão proferida pelo relator caberá agravo interno para o respectivo órgão colegiado, observadas, quanto ao processamento, as regras do regimento interno do tribunal.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8175,
                                            "texto": "Na petição de agravo interno, o recorrente impugnará especificadamente os fundamentos da decisão agravada."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8177,
                                            "texto": "O agravo será dirigido ao relator, que intimará o agravado para manifestar-se sobre o recurso no prazo de 15 (quinze) dias, ao final do qual, não havendo retratação, o relator levá-lo-á a julgamento pelo órgão colegiado, com inclusão em pauta."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8179,
                                            "texto": "É vedado ao relator limitar-se à reprodução dos fundamentos da decisão agravada para julgar improcedente o agravo interno."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8181,
                                            "texto": "Quando o agravo interno for declarado manifestamente inadmissível ou improcedente em votação unânime, o órgão colegiado, em decisão fundamentada, condenará o agravante a pagar ao agravado multa fixada entre um e cinco por cento do valor atualizado da causa."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8183,
                                            "texto": "A interposição de qualquer outro recurso está condicionada ao depósito prévio do valor da multa prevista no § 4º, à exceção da Fazenda Pública e do beneficiário de gratuidade da justiça, que farão o pagamento ao final."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DO AGRAVO INTERNO",
                            "linhaTitulo": 8171
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO V",
                            "linha": 8185,
                            "artigos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8188,
                                    "caput": "022. Cabem embargos de declaração contra qualquer decisão judicial para:",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 8196,
                                            "texto": "Considera-se omissa a decisão que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8198,
                                                    "texto": "deixe de se manifestar sobre tese firmada em julgamento de casos repetitivos ou em incidente de assunção de competência aplicável ao caso sob julgamento;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8200,
                                                    "texto": "incorra em qualquer das condutas descritas no art. 489, § 1º ."
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8190,
                                            "texto": "esclarecer obscuridade ou eliminar contradição;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8192,
                                            "texto": "suprir omissão de ponto ou questão sobre o qual devia se pronunciar o juiz de ofício ou a requerimento;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8194,
                                            "texto": "corrigir erro material."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8202,
                                    "caput": "023. Os embargos serão opostos, no prazo de 5 (cinco) dias, em petição dirigida ao juiz, com indicação do erro, obscuridade, contradição ou omissão, e não se sujeitam a preparo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8204,
                                            "texto": "Aplica-se aos embargos de declaração o art. 229 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 229",
                                                    "href": "#art229",
                                                    "inicio": 39,
                                                    "fim": 47
                                                },
                                                {
                                                    "campo": "texto",
                                                    "texto": "229",
                                                    "href": "../../../LEIS/2002/L10406.htm#art229",
                                                    "inicio": 44,
                                                    "fim": 47
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8206,
                                            "texto": "O juiz intimará o embargado para, querendo, manifestar-se, no prazo de 5 (cinco) dias, sobre os embargos opostos, caso seu eventual acolhimento implique a modificação da decisão embargada."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8208,
                                    "caput": "024. O juiz julgará os embargos em 5 (cinco) dias.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8210,
                                            "texto": "Nos tribunais, o relator apresentará os embargos em mesa na sessão subsequente, proferindo voto, e, não havendo julgamento nessa sessão, será o recurso incluído em pauta automaticamente."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8212,
                                            "texto": "Quando os embargos de declaração forem opostos contra decisão de relator ou outra decisão unipessoal proferida em tribunal, o órgão prolator da decisão embargada decidi-los-á monocraticamente."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8214,
                                            "texto": "O órgão julgador conhecerá dos embargos de declaração como agravo interno se entender ser este o recurso cabível, desde que determine previamente a intimação do recorrente para, no prazo de 5 (cinco) dias, complementar as razões recursais, de modo a ajustá-las às exigências do art. 1.021, § 1º .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.021",
                                                    "href": "#art1021",
                                                    "inicio": 278,
                                                    "fim": 288
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8216,
                                            "texto": "Caso o acolhimento dos embargos de declaração implique modificação da decisão embargada, o embargado que já tiver interposto outro recurso contra a decisão originária tem o direito de complementar ou alterar suas razões, nos exatos limites da modificação, no prazo de 15 (quinze) dias, contado da intimação da decisão dos embargos de declaração."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8218,
                                            "texto": "Se os embargos de declaração forem rejeitados ou não alterarem a conclusão do julgamento anterior, o recurso interposto pela outra parte antes da publicação do julgamento dos embargos de declaração será processado e julgado independentemente de ratificação."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8220,
                                    "caput": "025. Consideram-se incluídos no acórdão os elementos que o embargante suscitou, para fins de pré-questionamento, ainda que os embargos de declaração sejam inadmitidos ou rejeitados, caso o tribunal superior considere existentes erro, omissão, contradição ou obscuridade."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8222,
                                    "caput": "026. Os embargos de declaração não possuem efeito suspensivo e interrompem o prazo para a interposição de recurso.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8224,
                                            "texto": "A eficácia da decisão monocrática ou colegiada poderá ser suspensa pelo respectivo juiz ou relator se demonstrada a probabilidade de provimento do recurso ou, sendo relevante a fundamentação, se houver risco de dano grave ou de difícil reparação."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8226,
                                            "texto": "Quando manifestamente protelatórios os embargos de declaração, o juiz ou o tribunal, em decisão fundamentada, condenará o embargante a pagar ao embargado multa não excedente a dois por cento sobre o valor atualizado da causa."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8228,
                                            "texto": "Na reiteração de embargos de declaração manifestamente protelatórios, a multa será elevada a até dez por cento sobre o valor atualizado da causa, e a interposição de qualquer recurso ficará condicionada ao depósito prévio do valor da multa, à exceção da Fazenda Pública e do beneficiário de gratuidade da justiça, que a recolherão ao final."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8230,
                                            "texto": "Não serão admitidos novos embargos de declaração se os 2 (dois) anteriores houverem sido considerados protelatórios."
                                        }
                                    ]
                                }
                            ],
                            "titulo": "DOS EMBARGOS DE DECLARAÇÃO",
                            "linhaTitulo": 8186
                        },
                        {
                            "tipo": "capitulo",
                            "rotulo": "CAPÍTULO VI",
                            "linha": 8232,
                            "artigos": [
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8238,
                                    "caput": "027. Serão julgados em recurso ordinário:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8248,
                                            "texto": "Nos processos referidos no inciso II, alínea “b”, contra as decisões interlocutórias caberá agravo de instrumento dirigido ao Superior Tribunal de Justiça, nas hipóteses do art. 1.015 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.015",
                                                    "href": "#art1015",
                                                    "inicio": 173,
                                                    "fim": 183
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8250,
                                            "texto": "Aplica-se ao recurso ordinário o disposto nos arts. 1.013, § 3º , e 1.029, § 5º ."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8240,
                                            "texto": "pelo Supremo Tribunal Federal, os mandados de segurança, os habeas data e os mandados de injunção decididos em única instância pelos tribunais superiores, quando denegatória a decisão;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8242,
                                            "texto": "pelo Superior Tribunal de Justiça:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 8244,
                                                    "texto": "os mandados de segurança decididos em única instância pelos tribunais regionais federais ou pelos tribunais de justiça dos Estados e do Distrito Federal e Territórios, quando denegatória a decisão;"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 8246,
                                                    "texto": "os processos em que forem partes, de um lado, Estado estrangeiro ou organismo internacional e, de outro, Município ou pessoa residente ou domiciliada no País."
                                                }
                                            ]
                                        }
                                    ],
                                    "rubrica": "Do Recurso Ordinário",
                                    "linhaRubrica": 8236
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8252,
                                    "caput": "028. Ao recurso mencionado no art. 1.027, inciso II, alínea “b”, aplicam-se, quanto aos requisitos de admissibilidade e ao procedimento, as disposições relativas à apelação e o Regimento Interno do Superior Tribunal de Justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8254,
                                            "texto": "Na hipótese do art. 1.027, § 1º , aplicam-se as disposições relativas ao agravo de instrumento e o Regimento Interno do Superior Tribunal de Justiça."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8256,
                                            "texto": "O recurso previsto no art. 1.027, incisos I e II, alínea “a”, deve ser interposto perante o tribunal de origem, cabendo ao seu presidente ou vice-presidente determinar a intimação do recorrido para, em 15 (quinze) dias, apresentar as contrarrazões.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.027, incisos I",
                                                    "href": "#art1027i",
                                                    "inicio": 22,
                                                    "fim": 43
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8258,
                                            "texto": "Findo o prazo referido no § 2º, os autos serão remetidos ao respectivo tribunal superior, independentemente de juízo de admissibilidade. Seção II Do Recurso Extraordinário e do Recurso Especial Subseção I"
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8266,
                                    "caput": "029. O recurso extraordinário e o recurso especial, nos casos previstos na Constituição Federal , serão interpostos perante o presidente ou o vice-presidente do tribunal recorrido, em petições distintas que conterão:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8274,
                                            "texto": "Quando o recurso fundar-se em dissídio jurisprudencial, o recorrente fará a prova da divergência com a certidão, cópia ou citação do repositório de jurisprudência, oficial ou credenciado, inclusive em mídia eletrônica, em que houver sido publicado o acórdão divergente, ou ainda com a reprodução de julgado disponível na rede mundial de computadores, com indicação da respectiva fonte, devendo-se, em qualquer caso, mencionar as circunstâncias que identifiquem ou assemelhem os casos confrontados."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8277,
                                            "texto": "O Supremo Tribunal Federal ou o Superior Tribunal de Justiça poderá desconsiderar vício formal de recurso tempestivo ou determinar sua correção, desde que não o repute grave."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8279,
                                            "texto": "Quando, por ocasião do processamento do incidente de resolução de demandas repetitivas, o presidente do Supremo Tribunal Federal ou do Superior Tribunal de Justiça receber requerimento de suspensão de processos em que se discuta questão federal constitucional ou infraconstitucional, poderá, considerando razões de segurança jurídica ou de excepcional interesse social, estender a suspensão a todo o território nacional, até ulterior decisão do recurso extraordinário ou do recurso especial a ser interposto."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8281,
                                            "texto": "O pedido de concessão de efeito suspensivo a recurso extraordinário ou a recurso especial poderá ser formulado por requerimento dirigido:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8284,
                                                    "texto": "ao tribunal superior respectivo, no período compreendido entre a publicação da decisão de admissão do recurso e sua distribuição, ficando o relator designado para seu exame prevento para julgá-lo;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8286,
                                                    "texto": "ao relator, se já distribuído o recurso;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 8289,
                                                    "texto": "ao presidente ou ao vice-presidente do tribunal recorrido, no período compreendido entre a interposição do recurso e a publicação da decisão de admissão do recurso, assim como no caso de o recurso ter sido sobrestado, nos termos do art. 1.037 .",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 1.037",
                                                            "href": "#art1037",
                                                            "inicio": 232,
                                                            "fim": 242
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8268,
                                            "texto": "a exposição do fato e do direito;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8270,
                                            "texto": "a demonstração do cabimento do recurso interposto;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8272,
                                            "texto": "as razões do pedido de reforma ou de invalidação da decisão recorrida."
                                        }
                                    ],
                                    "rubrica": "Disposições Gerais",
                                    "linhaRubrica": 8264
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8293,
                                    "caput": "030. Recebida a petição do recurso pela secretaria do tribunal, o recorrido será intimado para apresentar contrarrazões no prazo de 15 (quinze) dias, findo o qual os autos serão conclusos ao presidente ou ao vice-presidente do tribunal recorrido, que deverá:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8315,
                                            "texto": "Da decisão de inadmissibilidade proferida com fundamento no inciso V caberá agravo ao tribunal superior, nos termos do art. 1.042."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8317,
                                            "texto": "Da decisão proferida com fundamento nos incisos I e III caberá agravo interno, nos termos do art. 1.021.",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.021",
                                                    "href": "#art1021",
                                                    "inicio": 93,
                                                    "fim": 103
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8295,
                                            "texto": "negar seguimento:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 8297,
                                                    "texto": "a recurso extraordinário que discuta questão constitucional à qual o Supremo Tribunal Federal não tenha reconhecido a existência de repercussão geral ou a recurso extraordinário interposto contra acórdão que esteja em conformidade com entendimento do Supremo Tribunal Federal exarado no regime de repercussão geral; (Incluída pela Lei nº 13.256, de 2016)"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 8299,
                                                    "texto": "a recurso extraordinário ou a recurso especial interposto contra acórdão que esteja em conformidade com entendimento do Supremo Tribunal Federal ou do Superior Tribunal de Justiça, respectivamente, exarado no regime de julgamento de recursos repetitivos; (Incluída pela Lei nº 13.256, de 2016)"
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8301,
                                            "texto": "encaminhar o processo ao órgão julgador para realização do juízo de retratação, se o acórdão recorrido divergir do entendimento do Supremo Tribunal Federal ou do Superior Tribunal de Justiça exarado, conforme o caso, nos regimes de repercussão geral ou de recursos repetitivos;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8303,
                                            "texto": "sobrestar o recurso que versar sobre controvérsia de caráter repetitivo ainda não decidida pelo Supremo Tribunal Federal ou pelo Superior Tribunal de Justiça, conforme se trate de matéria constitucional ou infraconstitucional;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 8305,
                                            "texto": "selecionar o recurso como representativo de controvérsia constitucional ou infraconstitucional, nos termos do § 6º do art. 1.036;",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.036",
                                                    "href": "#art1036",
                                                    "inicio": 118,
                                                    "fim": 128
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "V",
                                            "rotulo": "V",
                                            "linha": 8307,
                                            "texto": "realizar o juízo de admissibilidade e, se positivo, remeter o feito ao Supremo Tribunal Federal ou ao Superior Tribunal de Justiça, desde que:",
                                            "alineas": [
                                                {
                                                    "letra": "a",
                                                    "rotulo": "a)",
                                                    "linha": 8309,
                                                    "texto": "o recurso ainda não tenha sido submetido ao regime de repercussão geral ou de julgamento de recursos repetitivos; (Incluída pela Lei nº 13.256, de 2016)"
                                                },
                                                {
                                                    "letra": "b",
                                                    "rotulo": "b)",
                                                    "linha": 8311,
                                                    "texto": "o recurso tenha sido selecionado como representativo da controvérsia; ou (Incluída pela Lei nº 13.256, de 2016)"
                                                },
                                                {
                                                    "letra": "c",
                                                    "rotulo": "c)",
                                                    "linha": 8313,
                                                    "texto": "o tribunal recorrido tenha refutado o juízo de retratação. (Incluída pela Lei nº 13.256, de 2016)"
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8319,
                                    "caput": "031. Na hipótese de interposição conjunta de recurso extraordinário e recurso especial, os autos serão remetidos ao Superior Tribunal de Justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8321,
                                            "texto": "Concluído o julgamento do recurso especial, os autos serão remetidos ao Supremo Tribunal Federal para apreciação do recurso extraordinário, se este não estiver prejudicado."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8323,
                                            "texto": "Se o relator do recurso especial considerar prejudicial o recurso extraordinário, em decisão irrecorrível, sobrestará o julgamento e remeterá os autos ao Supremo Tribunal Federal."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8325,
                                            "texto": "Na hipótese do § 2º, se o relator do recurso extraordinário, em decisão irrecorrível, rejeitar a prejudicialidade, devolverá os autos ao Superior Tribunal de Justiça para o julgamento do recurso especial."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8327,
                                    "caput": "032. Se o relator, no Superior Tribunal de Justiça, entender que o recurso especial versa sobre questão constitucional, deverá conceder prazo de 15 (quinze) dias para que o recorrente demonstre a existência de repercussão geral e se manifeste sobre a questão constitucional.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 8329,
                                            "texto": "Cumprida a diligência de que trata o caput , o relator remeterá o recurso ao Supremo Tribunal Federal, que, em juízo de admissibilidade, poderá devolvê-lo ao Superior Tribunal de Justiça."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8331,
                                    "caput": "033. Se o Supremo Tribunal Federal considerar como reflexa a ofensa à Constituição afirmada no recurso extraordinário, por pressupor a revisão da interpretação de lei federal ou de tratado, remetê-lo-á ao Superior Tribunal de Justiça para julgamento como recurso especial."
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8333,
                                    "caput": "034. Admitido o recurso extraordinário ou o recurso especial, o Supremo Tribunal Federal ou o Superior Tribunal de Justiça julgará o processo, aplicando o direito.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 8335,
                                            "texto": "Admitido o recurso extraordinário ou o recurso especial por um fundamento, devolve-se ao tribunal superior o conhecimento dos demais fundamentos para a solução do capítulo impugnado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8337,
                                    "caput": "035. O Supremo Tribunal Federal, em decisão irrecorrível, não conhecerá do recurso extraordinário quando a questão constitucional nele versada não tiver repercussão geral, nos termos deste artigo.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8339,
                                            "texto": "Para efeito de repercussão geral, será considerada a existência ou não de questões relevantes do ponto de vista econômico, político, social ou jurídico que ultrapassem os interesses subjetivos do processo."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8341,
                                            "texto": "O recorrente deverá demonstrar a existência de repercussão geral para apreciação exclusiva pelo Supremo Tribunal Federal."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8343,
                                            "texto": "Haverá repercussão geral sempre que o recurso impugnar acórdão que:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8345,
                                                    "texto": "contrarie súmula ou jurisprudência dominante do Supremo Tribunal Federal;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 8348,
                                                    "texto": "tenha reconhecido a inconstitucionalidade de tratado ou de lei federal, nos termos do art. 97 da Constituição Federal .",
                                                    "links": [
                                                        {
                                                            "campo": "texto",
                                                            "texto": "art. 97",
                                                            "href": "#art97",
                                                            "inicio": 86,
                                                            "fim": 93
                                                        }
                                                    ]
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8350,
                                            "texto": "O relator poderá admitir, na análise da repercussão geral, a manifestação de terceiros, subscrita por procurador habilitado, nos termos do Regimento Interno do Supremo Tribunal Federal."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8352,
                                            "texto": "Reconhecida a repercussão geral, o relator no Supremo Tribunal Federal determinará a suspensão do processamento de todos os processos pendentes, individuais ou coletivos, que versem sobre a questão e tramitem no território nacional."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 8354,
                                            "texto": "O interessado pode requerer, ao presidente ou ao vice-presidente do tribunal de origem, que exclua da decisão de sobrestamento e inadmita o recurso extraordinário que tenha sido interposto intempestivamente, tendo o recorrente o prazo de 5 (cinco) dias para manifestar-se sobre esse requerimento."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 8357,
                                            "texto": "Da decisão que indeferir o requerimento referido no § 6º ou que aplicar entendimento firmado em regime de repercussão geral ou em julgamento de recursos repetitivos caberá agravo interno."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 8359,
                                            "texto": "Negada a repercussão geral, o presidente ou o vice-presidente do tribunal de origem negará seguimento aos recursos extraordinários sobrestados na origem que versem sobre matéria idêntica."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 8361,
                                            "texto": "O recurso que tiver a repercussão geral reconhecida deverá ser julgado no prazo de 1 (um) ano e terá preferência sobre os demais feitos, ressalvados os que envolvam réu preso e os pedidos de habeas corpus ."
                                        },
                                        {
                                            "numero": "11º",
                                            "rotulo": "§ 11º",
                                            "linha": 8364,
                                            "texto": "A súmula da decisão sobre a repercussão geral constará de ata, que será publicada no diário oficial e valerá como acórdão. Subseção II"
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8369,
                                    "caput": "036. Sempre que houver multiplicidade de recursos extraordinários ou especiais com fundamento em idêntica questão de direito, haverá afetação para julgamento de acordo com as disposições desta Subseção, observado o disposto no Regimento Interno do Supremo Tribunal Federal e no do Superior Tribunal de Justiça.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8371,
                                            "texto": "O presidente ou o vice-presidente de tribunal de justiça ou de tribunal regional federal selecionará 2 (dois) ou mais recursos representativos da controvérsia, que serão encaminhados ao Supremo Tribunal Federal ou ao Superior Tribunal de Justiça para fins de afetação, determinando a suspensão do trâmite de todos os processos pendentes, individuais ou coletivos, que tramitem no Estado ou na região, conforme o caso."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8373,
                                            "texto": "O interessado pode requerer, ao presidente ou ao vice-presidente, que exclua da decisão de sobrestamento e inadmita o recurso especial ou o recurso extraordinário que tenha sido interposto intempestivamente, tendo o recorrente o prazo de 5 (cinco) dias para manifestar-se sobre esse requerimento."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8376,
                                            "texto": "Da decisão que indeferir o requerimento referido no § 2º caberá apenas agravo interno."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8378,
                                            "texto": "A escolha feita pelo presidente ou vice-presidente do tribunal de justiça ou do tribunal regional federal não vinculará o relator no tribunal superior, que poderá selecionar outros recursos representativos da controvérsia."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8380,
                                            "texto": "O relator em tribunal superior também poderá selecionar 2 (dois) ou mais recursos representativos da controvérsia para julgamento da questão de direito independentemente da iniciativa do presidente ou do vice-presidente do tribunal de origem."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 8382,
                                            "texto": "Somente podem ser selecionados recursos admissíveis que contenham abrangente argumentação e discussão a respeito da questão a ser decidida."
                                        }
                                    ],
                                    "rubrica": "Do Julgamento dos Recursos Extraordinário e Especial Repetitivos",
                                    "linhaRubrica": 8367
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8384,
                                    "caput": "037. Selecionados os recursos, o relator, no tribunal superior, constatando a presença do pressuposto do caput do art. 1.036 , proferirá decisão de afetação, na qual:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8392,
                                            "texto": "Se, após receber os recursos selecionados pelo presidente ou pelo vice-presidente de tribunal de justiça ou de tribunal regional federal, não se proceder à afetação, o relator, no tribunal superior, comunicará o fato ao presidente ou ao vice-presidente que os houver enviado, para que seja revogada a decisão de suspensão referida no art. 1.036, § 1º .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.036",
                                                    "href": "#art1036",
                                                    "inicio": 334,
                                                    "fim": 344
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8396,
                                            "texto": "Havendo mais de uma afetação, será prevento o relator que primeiro tiver proferido a decisão a que se refere o inciso I do caput ."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8398,
                                            "texto": "Os recursos afetados deverão ser julgados no prazo de 1 (um) ano e terão preferência sobre os demais feitos, ressalvados os que envolvam réu preso e os pedidos de habeas corpus ."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 8401,
                                            "texto": "Ocorrendo a hipótese do § 5º, é permitido a outro relator do respectivo tribunal superior afetar 2 (dois) ou mais recursos representativos da controvérsia na forma do art. 1.036 .",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "art. 1.036",
                                                    "href": "#art1036",
                                                    "inicio": 167,
                                                    "fim": 177
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 8403,
                                            "texto": "Quando os recursos requisitados na forma do inciso III do caput contiverem outras questões além daquela que é objeto da afetação, caberá ao tribunal decidir esta em primeiro lugar e depois as demais, em acórdão específico para cada processo."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 8405,
                                            "texto": "As partes deverão ser intimadas da decisão de suspensão de seu processo, a ser proferida pelo respectivo juiz ou relator quando informado da decisão a que se refere o inciso II do caput ."
                                        },
                                        {
                                            "numero": "9º",
                                            "rotulo": "§ 9º",
                                            "linha": 8407,
                                            "texto": "Demonstrando distinção entre a questão a ser decidida no processo e aquela a ser julgada no recurso especial ou extraordinário afetado, a parte poderá requerer o prosseguimento do seu processo."
                                        },
                                        {
                                            "numero": "10º",
                                            "rotulo": "§ 10º",
                                            "linha": 8409,
                                            "texto": "O requerimento a que se refere o § 9º será dirigido:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8411,
                                                    "texto": "ao juiz, se o processo sobrestado estiver em primeiro grau;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8413,
                                                    "texto": "ao relator, se o processo sobrestado estiver no tribunal de origem;"
                                                },
                                                {
                                                    "numero": "III",
                                                    "rotulo": "III",
                                                    "linha": 8415,
                                                    "texto": "ao relator do acórdão recorrido, se for sobrestado recurso especial ou recurso extraordinário no tribunal de origem;"
                                                },
                                                {
                                                    "numero": "IV",
                                                    "rotulo": "IV",
                                                    "linha": 8417,
                                                    "texto": "ao relator, no tribunal superior, de recurso especial ou de recurso extraordinário cujo processamento houver sido sobrestado."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "11º",
                                            "rotulo": "§ 11º",
                                            "linha": 8419,
                                            "texto": "A outra parte deverá ser ouvida sobre o requerimento a que se refere o § 9º, no prazo de 5 (cinco) dias."
                                        },
                                        {
                                            "numero": "12º",
                                            "rotulo": "§ 12º",
                                            "linha": 8421,
                                            "texto": "Reconhecida a distinção no caso:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8423,
                                                    "texto": "dos incisos I, II e IV do § 10, o próprio juiz ou relator dará prosseguimento ao processo;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8425,
                                                    "texto": "do inciso III do § 10, o relator comunicará a decisão ao presidente ou ao vice-presidente que houver determinado o sobrestamento, para que o recurso especial ou o recurso extraordinário seja encaminhado ao respectivo tribunal superior, na forma do art. 1.030, parágrafo único ."
                                                }
                                            ]
                                        },
                                        {
                                            "numero": "13º",
                                            "rotulo": "§ 13º",
                                            "linha": 8427,
                                            "texto": "Da decisão que resolver o requerimento a que se refere o § 9º caberá:",
                                            "incisos": [
                                                {
                                                    "numero": "I",
                                                    "rotulo": "I",
                                                    "linha": 8429,
                                                    "texto": "agravo de instrumento, se o processo estiver em primeiro grau;"
                                                },
                                                {
                                                    "numero": "II",
                                                    "rotulo": "II",
                                                    "linha": 8431,
                                                    "texto": "agravo interno, se a decisão for de relator."
                                                }
                                            ]
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8386,
                                            "texto": "identificará com precisão a questão a ser submetida a julgamento;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8388,
                                            "texto": "determinará a suspensão do processamento de todos os processos pendentes, individuais ou coletivos, que versem sobre a questão e tramitem no território nacional;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8390,
                                            "texto": "poderá requisitar aos presidentes ou aos vice-presidentes dos tribunais de justiça ou dos tribunais regionais federais a remessa de um recurso representativo da controvérsia."
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 1.036",
                                            "href": "#art1036",
                                            "inicio": 114,
                                            "fim": 124
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8433,
                                    "caput": "038. O relator poderá:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8441,
                                            "texto": "No caso do inciso III, os prazos respectivos são de 15 (quinze) dias, e os atos serão praticados, sempre que possível, por meio eletrônico."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8443,
                                            "texto": "Transcorrido o prazo para o Ministério Público e remetida cópia do relatório aos demais ministros, haverá inclusão em pauta, devendo ocorrer o julgamento com preferência sobre os demais feitos, ressalvados os que envolvam réu preso e os pedidos de habeas corpus ."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8446,
                                            "texto": "O conteúdo do acórdão abrangerá a análise dos fundamentos relevantes da tese jurídica discutida."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8435,
                                            "texto": "solicitar ou admitir manifestação de pessoas, órgãos ou entidades com interesse na controvérsia, considerando a relevância da matéria e consoante dispuser o regimento interno;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8437,
                                            "texto": "fixar data para, em audiência pública, ouvir depoimentos de pessoas com experiência e conhecimento na matéria, com a finalidade de instruir o procedimento;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8439,
                                            "texto": "requisitar informações aos tribunais inferiores a respeito da controvérsia e, cumprida a diligência, intimará o Ministério Público para manifestar-se."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8448,
                                    "caput": "039. Decididos os recursos afetados, os órgãos colegiados declararão prejudicados os demais recursos versando sobre idêntica controvérsia ou os decidirão aplicando a tese firmada.",
                                    "paragrafos": [
                                        {
                                            "numero": "único",
                                            "rotulo": "Parágrafo único",
                                            "linha": 8450,
                                            "texto": "Negada a existência de repercussão geral no recurso extraordinário afetado, serão considerados automaticamente inadmitidos os recursos extraordinários cujo processamento tenha sido sobrestado."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8452,
                                    "caput": "040. Publicado o acórdão paradigma:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8462,
                                            "texto": "A parte poderá desistir da ação em curso no primeiro grau de jurisdição, antes de proferida a sentença, se a questão nela discutida for idêntica à resolvida pelo recurso representativo da controvérsia."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8464,
                                            "texto": "Se a desistência ocorrer antes de oferecida contestação, a parte ficará isenta do pagamento de custas e de honorários de sucumbência."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8466,
                                            "texto": "A desistência apresentada nos termos do § 1º independe de consentimento do réu, ainda que apresentada contestação."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8454,
                                            "texto": "o presidente ou o vice-presidente do tribunal de origem negará seguimento aos recursos especiais ou extraordinários sobrestados na origem, se o acórdão recorrido coincidir com a orientação do tribunal superior;"
                                        },
                                        {
                                            "numero": "II",
                                            "rotulo": "II",
                                            "linha": 8456,
                                            "texto": "o órgão que proferiu o acórdão recorrido, na origem, reexaminará o processo de competência originária, a remessa necessária ou o recurso anteriormente julgado, se o acórdão recorrido contrariar a orientação do tribunal superior;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8458,
                                            "texto": "os processos suspensos em primeiro e segundo graus de jurisdição retomarão o curso para julgamento e aplicação da tese firmada pelo tribunal superior;"
                                        },
                                        {
                                            "numero": "IV",
                                            "rotulo": "IV",
                                            "linha": 8460,
                                            "texto": "se os recursos versarem sobre questão relativa a prestação de serviço público objeto de concessão, permissão ou autorização, o resultado do julgamento será comunicado ao órgão, ao ente ou à agência reguladora competente para fiscalização da efetiva aplicação, por parte dos entes sujeitos a regulação, da tese adotada."
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8468,
                                    "caput": "041. Mantido o acórdão divergente pelo tribunal de origem, o recurso especial ou extraordinário será remetido ao respectivo tribunal superior, na forma do art. 1.036, § 1º .",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8470,
                                            "texto": "Realizado o juízo de retratação, com alteração do acórdão divergente, o tribunal de origem, se for o caso, decidirá as demais questões ainda não decididas cujo enfrentamento se tornou necessário em decorrência da alteração."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8473,
                                            "texto": "Quando ocorrer a hipótese do inciso II do caput do art. 1.040 e o recurso versar sobre outras questões, caberá ao presidente ou ao vice-presidente do tribunal recorrido, depois do reexame pelo órgão de origem e independentemente de ratificação do recurso, sendo positivo o juízo de admissibilidade, determinar a remessa do recurso ao tribunal superior para julgamento das demais questões. Seção III",
                                            "links": [
                                                {
                                                    "campo": "texto",
                                                    "texto": "inciso II do caput do art. 1.040",
                                                    "href": "#art1040ii",
                                                    "inicio": 29,
                                                    "fim": 61
                                                }
                                            ]
                                        }
                                    ],
                                    "links": [
                                        {
                                            "campo": "caput",
                                            "texto": "art. 1.036",
                                            "href": "#art1036",
                                            "inicio": 155,
                                            "fim": 165
                                        }
                                    ]
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8479,
                                    "caput": "042. Cabe agravo contra decisão do presidente ou do vice-presidente do tribunal recorrido que inadmitir recurso extraordinário ou recurso especial, salvo quando fundada na aplicação de entendimento firmado em regime de repercussão geral ou em julgamento de recursos repetitivos.",
                                    "paragrafos": [
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8483,
                                            "texto": "A petição de agravo será dirigida ao presidente ou ao vice-presidente do tribunal de origem e independe do pagamento de custas e despesas postais, aplicando-se a ela o regime de repercussão geral e de recursos repetitivos, inclusive quanto à possibilidade de sobrestamento e do juízo de retratação."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8485,
                                            "texto": "O agravado será intimado, de imediato, para oferecer resposta no prazo de 15 (quinze) dias."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8487,
                                            "texto": "Após o prazo de resposta, não havendo retratação, o agravo será remetido ao tribunal superior competente."
                                        },
                                        {
                                            "numero": "5º",
                                            "rotulo": "§ 5º",
                                            "linha": 8489,
                                            "texto": "O agravo poderá ser julgado, conforme o caso, conjuntamente com o recurso especial ou extraordinário, assegurada, neste caso, sustentação oral, observando-se, ainda, o disposto no regimento interno do tribunal respectivo."
                                        },
                                        {
                                            "numero": "6º",
                                            "rotulo": "§ 6º",
                                            "linha": 8491,
                                            "texto": "Na hipótese de interposição conjunta de recursos extraordinário e especial, o agravante deverá interpor um agravo para cada recurso não admitido."
                                        },
                                        {
                                            "numero": "7º",
                                            "rotulo": "§ 7º",
                                            "linha": 8493,
                                            "texto": "Havendo apenas um agravo, o recurso será remetido ao tribunal competente, e, havendo interposição conjunta, os autos serão remetidos ao Superior Tribunal de Justiça."
                                        },
                                        {
                                            "numero": "8º",
                                            "rotulo": "§ 8º",
                                            "linha": 8495,
                                            "texto": "Concluído o julgamento do agravo pelo Superior Tribunal de Justiça e, se for o caso, do recurso especial, independentemente de pedido, os autos serão remetidos ao Supremo Tribunal Federal para apreciação do agravo a ele dirigido, salvo se estiver prejudicado. Seção IV"
                                        }
                                    ],
                                    "rubrica": "Do Agravo em Recurso Especial e em Recurso Extraordinário",
                                    "linhaRubrica": 8476
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8500,
                                    "caput": "043. É embargável o acórdão de órgão fracionário que:",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8510,
                                            "texto": "Poderão ser confrontadas teses jurídicas contidas em julgamentos de recursos e de ações de competência originária."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8512,
                                            "texto": "A divergência que autoriza a interposição de embargos de divergência pode verificar-se na aplicação do direito material ou do direito processual."
                                        },
                                        {
                                            "numero": "3º",
                                            "rotulo": "§ 3º",
                                            "linha": 8514,
                                            "texto": "Cabem embargos de divergência quando o acórdão paradigma for da mesma turma que proferiu a decisão embargada, desde que sua composição tenha sofrido alteração em mais da metade de seus membros."
                                        },
                                        {
                                            "numero": "4º",
                                            "rotulo": "§ 4º",
                                            "linha": 8516,
                                            "texto": "O recorrente provará a divergência com certidão, cópia ou citação de repositório oficial ou credenciado de jurisprudência, inclusive em mídia eletrônica, onde foi publicado o acórdão divergente, ou com a reprodução de julgado disponível na rede mundial de computadores, indicando a respectiva fonte, e mencionará as circunstâncias que identificam ou assemelham os casos confrontados."
                                        }
                                    ],
                                    "incisos": [
                                        {
                                            "numero": "I",
                                            "rotulo": "I",
                                            "linha": 8502,
                                            "texto": "em recurso extraordinário ou em recurso especial, divergir do julgamento de qualquer outro órgão do mesmo tribunal, sendo os acórdãos, embargado e paradigma, de mérito;"
                                        },
                                        {
                                            "numero": "III",
                                            "rotulo": "III",
                                            "linha": 8506,
                                            "texto": "em recurso extraordinário ou em recurso especial, divergir do julgamento de qualquer outro órgão do mesmo tribunal, sendo um acórdão de mérito e outro que não tenha conhecido do recurso, embora tenha apreciado a controvérsia;"
                                        }
                                    ],
                                    "rubrica": "Dos Embargos de Divergência",
                                    "linhaRubrica": 8498
                                },
                                {
                                    "numero": "1º",
                                    "rotulo": "Art. 1º.",
                                    "linha": 8520,
                                    "caput": "044. No recurso de embargos de divergência, será observado o procedimento estabelecido no regimento interno do respectivo tribunal superior.",
                                    "paragrafos": [
                                        {
                                            "numero": "1º",
                                            "rotulo": "§ 1º",
                                            "linha": 8522,
                                            "texto": "A interposição de embargos de divergência no Superior Tribunal de Justiça interrompe o prazo para interposição de recurso extraordinário por qualquer das partes."
                                        },
                                        {
                                            "numero": "2º",
                                            "rotulo": "§ 2º",
                                            "linha": 8524,
                                            "texto": "Se os embargos de divergência forem desprovidos ou não alterarem a conclusão do julgamento anterior, o recurso extraordinário interposto pela outra parte antes da publicação do julgamento dos embargos de divergência será processado e julgado independentemente de ratificação."
                                        }
                                    ]
                                }
                            ],
                            "itens": [
                                {
                                    "tipo": "texto",
                                    "texto": "Seção I"
                                }
                            ],
                            "titulo": "DOS RECURSOS PARA O SUPREMO TRIBUNAL FEDERAL E PARA O SUPERIOR TRIBUNAL DE JUSTIÇA",
                            "linhaTitulo": 8233
                        }
                    ],
                    "titulo": "DOS RECURSOS",
                    "linhaTitulo": 7902
                }
            ],
            "titulo": "DOS PROCESSOS NOS TRIBUNAIS E DOS MEIOS DE IMPUGNAÇÃO DAS DECISÕES JUDICIAIS",
            "linhaTitulo": 7304
        },
        {
            "tipo": "livro",
            "rotulo": "LIVRO COMPLEMENTAR",
            "linha": 8526,
            "artigos": [
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8529,
                    "caput": "045. Este Código entra em vigor após decorrido 1 (um) ano da data de sua publicação oficial."
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8531,
                    "caput": "046. Ao entrar em vigor este Código, suas disposições se aplicarão desde logo aos processos pendentes, ficando revogada a Lei nº 5.869, de 11 de janeiro de 1973.",
                    "paragrafos": [
                        {
                            "numero": "1º",
                            "rotulo": "§ 1º",
                            "linha": 8533,
                            "texto": "As disposições da Lei nº 5.869, de 11 de janeiro de 1973 , relativas ao procedimento sumário e aos procedimentos especiais que forem revogadas aplicar-se-ão às ações propostas e não sentenciadas até o início da vigência deste Código.",
                            "links": [
                                {
                                    "campo": "texto",
                                    "texto": "11",
                                    "href": "../../../LEIS/L1060.htm#art11",
                                    "inicio": 35,
                                    "fim": 37
                                }
                            ]
                        },
                        {
                            "numero": "2º",
                            "rotulo": "§ 2º",
                            "linha": 8535,
                            "texto": "Permanecem em vigor as disposições especiais dos procedimentos regulados em outras leis, aos quais se aplicará supletivamente este Código."
                        },
                        {
                            "numero": "3º",
                            "rotulo": "§ 3º",
                            "linha": 8537,
                            "texto": "Os processos mencionados no art. 1.218 da Lei nº 5.869, de 11 de janeiro de 1973 , cujo procedimento ainda não tenha sido incorporado por lei submetem-se ao procedimento comum previsto neste Código.",
                            "links": [
                                {
                                    "campo": "texto",
                                    "texto": "11",
                                    "href": "../../../LEIS/L1060.htm#art11",
                                    "inicio": 59,
                                    "fim": 61
                                }
                            ]
                        },
                        {
                            "numero": "4º",
                            "rotulo": "§ 4º",
                            "linha": 8539,
                            "texto": "As remissões a disposições do Código de Processo Civil revogado, existentes em outras leis, passam a referir-se às que lhes são correspondentes neste Código."
                        },
                        {
                            "numero": "5º",
                            "rotulo": "§ 5º",
                            "linha": 8541,
                            "texto": "A primeira lista de processos para julgamento em ordem cronológica observará a antiguidade da distribuição entre os já conclusos na data da entrada em vigor deste Código ."
                        }
                    ],
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "11",
                            "href": "../../../LEIS/L1060.htm#art11",
                            "inicio": 139,
                            "fim": 141
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8543,
                    "caput": "047. As disposições de direito probatório adotadas neste Código aplicam-se apenas às provas requeridas ou determinadas de ofício a partir da data de início de sua vigência."
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8545,
                    "caput": "048. Terão prioridade de tramitação, em qualquer juízo ou tribunal, os procedimentos judiciais:",
                    "paragrafos": [
                        {
                            "numero": "1º",
                            "rotulo": "§ 1º",
                            "linha": 8555,
                            "texto": "A pessoa interessada na obtenção do benefício, juntando prova de sua condição, deverá requerê-lo à autoridade judiciária competente para decidir o feito, que determinará ao cartório do juízo as providências a serem cumpridas."
                        },
                        {
                            "numero": "2º",
                            "rotulo": "§ 2º",
                            "linha": 8557,
                            "texto": "Deferida a prioridade, os autos receberão identificação própria que evidencie o regime de tramitação prioritária."
                        },
                        {
                            "numero": "3º",
                            "rotulo": "§ 3º",
                            "linha": 8559,
                            "texto": "Concedida a prioridade, essa não cessará com a morte do beneficiado, estendendo-se em favor do cônjuge supérstite ou do companheiro em união estável."
                        },
                        {
                            "numero": "4º",
                            "rotulo": "§ 4º",
                            "linha": 8561,
                            "texto": "A tramitação prioritária independe de deferimento pelo órgão jurisdicional e deverá ser imediatamente concedida diante da prova da condição de beneficiário."
                        }
                    ],
                    "incisos": [
                        {
                            "numero": "I",
                            "rotulo": "I",
                            "linha": 8547,
                            "texto": "em que figure como parte ou interessado pessoa com idade igual ou superior a 60 (sessenta) anos ou portadora de doença grave, assim compreendida qualquer das enumeradas no art. 6º, inciso XIV, da Lei nº 7.713, de 22 de dezembro de 1988 ;"
                        },
                        {
                            "numero": "II",
                            "rotulo": "II",
                            "linha": 8549,
                            "texto": "regulados pela Lei nº 8.069, de 13 de julho de 1990 (Estatuto da Criança e do Adolescente) ."
                        },
                        {
                            "numero": "III",
                            "rotulo": "III",
                            "linha": 8551,
                            "texto": "em que figure como parte a vítima de violência doméstica e familiar, nos termos da Lei nº 11.340, de 7 de agosto de 2006 (Lei Maria da Penha).",
                            "links": [
                                {
                                    "campo": "texto",
                                    "texto": "11",
                                    "href": "../../../LEIS/L1060.htm#art11",
                                    "inicio": 90,
                                    "fim": 92
                                }
                            ]
                        },
                        {
                            "numero": "IV",
                            "rotulo": "IV",
                            "linha": 8553,
                            "texto": "em que se discuta a aplicação do disposto nas normas gerais de licitação e contratação a que se refere o inciso XXVII do caput do art. 22 da Constituição Federal."
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8563,
                    "caput": "049. Sempre que a lei remeter a procedimento previsto na lei processual sem especificá-lo, será observado o procedimento comum previsto neste Código.",
                    "paragrafos": [
                        {
                            "numero": "único",
                            "rotulo": "Parágrafo único",
                            "linha": 8565,
                            "texto": "Na hipótese de a lei remeter ao procedimento sumário, será observado o procedimento comum previsto neste Código, com as modificações previstas na própria lei especial, se houver."
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8567,
                    "caput": "050. A União, os Estados, o Distrito Federal, os Municípios, suas respectivas entidades da administração indireta, o Ministério Público, a Defensoria Pública e a Advocacia Pública, no prazo de 30 (trinta) dias a contar da data da entrada em vigor deste Código , deverão se cadastrar perante a administração do tribunal no qual atuem para cumprimento do disposto nos arts. 246, § 2º , e 270, parágrafo único ."
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8569,
                    "caput": "051. As empresas públicas e privadas devem cumprir o disposto no art. 246, § 1º , no prazo de 30 (trinta) dias, a contar da data de inscrição do ato constitutivo da pessoa jurídica, perante o juízo onde tenham sede ou filial.",
                    "paragrafos": [
                        {
                            "numero": "único",
                            "rotulo": "Parágrafo único",
                            "linha": 8571,
                            "texto": "O disposto no caput não se aplica às microempresas e às empresas de pequeno porte."
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8573,
                    "caput": "052. Até a edição de lei específica, as execuções contra devedor insolvente, em curso ou que venham a ser propostas, permanecem reguladas pelo Livro II, Título IV, da Lei nº 5.869, de 11 de janeiro de 1973 .",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "11",
                            "href": "../../../LEIS/L1060.htm#art11",
                            "inicio": 184,
                            "fim": 186
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8575,
                    "caput": "053. Os atos processuais praticados por meio eletrônico até a transição definitiva para certificação digital ficam convalidados, ainda que não tenham observado os requisitos mínimos estabelecidos por este Código, desde que tenham atingido sua finalidade e não tenha havido prejuízo à defesa de qualquer das partes."
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8577,
                    "caput": "054. O disposto no art. 503, § 1º , somente se aplica aos processos iniciados após a vigência deste Código, aplicando-se aos anteriores o disposto nos arts. 5º , 325 e 470 da Lei nº 5.869, de 11 de janeiro de 1973 .",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "325",
                            "href": "../../../LEIS/L5869.htm#art325",
                            "inicio": 162,
                            "fim": 165
                        },
                        {
                            "campo": "caput",
                            "texto": "11",
                            "href": "../../../LEIS/L1060.htm#art11",
                            "inicio": 192,
                            "fim": 194
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8579,
                    "caput": "056. Considerar-se-á como termo inicial do prazo da prescrição prevista no art. 924, inciso V , inclusive para as execuções em curso, a data de vigência deste Código.",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "art. 924, inciso V",
                            "href": "#art924v",
                            "inicio": 75,
                            "fim": 93
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8581,
                    "caput": "057. O disposto no art. 525, §§ 14 e 15 , e no art. 535, §§ 7º e 8º , aplica-se às decisões transitadas em julgado após a entrada em vigor deste Código , e, às decisões transitadas em julgado anteriormente, aplica-se o disposto no art. 475-L, § 1º , e no art. 741, parágrafo único, da Lei nº 5.869, de 11 de janeiro de 1973 .",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "art. 525",
                            "href": "#art525",
                            "inicio": 19,
                            "fim": 27
                        },
                        {
                            "campo": "caput",
                            "texto": "11",
                            "href": "../../../LEIS/L1060.htm#art11",
                            "inicio": 302,
                            "fim": 304
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8583,
                    "caput": "058. Em todos os casos em que houver recolhimento de importância em dinheiro, esta será depositada em nome da parte ou do interessado, em conta especial movimentada por ordem do juiz, nos termos do art. 840, inciso I .",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "art. 840, inciso I",
                            "href": "#art840i",
                            "inicio": 198,
                            "fim": 216
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8585,
                    "caput": "059. À tutela provisória requerida contra a Fazenda Pública aplica-se o disposto nos arts. 1º a 4º da Lei nº 8.437, de 30 de junho de 1992 , e no art. 7º, § 2º, da Lei nº 12.016, de 7 de agosto de 2009 .",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "12",
                            "href": "../../../LEIS/L1060.htm#art12",
                            "inicio": 171,
                            "fim": 173
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8587,
                    "caput": "060. O inciso II do art. 14 da Lei nº 9.289, de 4 de julho de 1996 , passa a vigorar com a seguinte redação:",
                    "incisos": [
                        {
                            "numero": "II",
                            "rotulo": "II",
                            "linha": 8593,
                            "texto": "aquele que recorrer da sentença adiantará a outra metade das custas, comprovando o adiantamento no ato de interposição do recurso, sob pena de deserção, observado o disposto nos §§ 1º a 7º do art. 1.007 do Código de Processo Civil ;",
                            "rubrica": "“Art. 14.",
                            "linhaRubrica": 8589
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8597,
                    "caput": "061. O § 3º do art. 33 da Lei nº 9.307, de 23 de setembro de 1996 (Lei de Arbitragem) , passa a vigorar com a seguinte redação:",
                    "paragrafos": [
                        {
                            "numero": "3º",
                            "rotulo": "§ 3º",
                            "linha": 8603,
                            "texto": "A decretação da nulidade da sentença arbitral também poderá ser requerida na impugnação ao cumprimento da sentença, nos termos dos arts. 525 e seguintes do Código de Processo Civil , se houver execução judicial.” (NR)",
                            "rubrica": "“Art. 33.",
                            "linhaRubrica": 8599
                        }
                    ],
                    "rubrica": "” (NR)",
                    "linhaRubrica": 8595
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8605,
                    "caput": "062. O incidente de desconsideração da personalidade jurídica aplica-se ao processo de competência dos juizados especiais."
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8608,
                    "caput": "063. Os juizados especiais cíveis previstos na Lei nº 9.099, de 26 de setembro de 1995, continuam competentes para o processamento e o julgamento das causas previstas no inciso II do art. 275 da Lei nº 5.869, de 11 de janeiro de 1973.",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "11",
                            "href": "../../../LEIS/L1060.htm#art11",
                            "inicio": 212,
                            "fim": 214
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8610,
                    "caput": "064. O caput do art. 48 da Lei nº 9.099, de 26 de setembro de 1995 , passa a vigorar com a seguinte redação: “ Art. 48. Caberão embargos de declaração contra sentença ou acórdão nos casos previstos no Código de Processo Civil .",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "Art. 48.",
                            "href": "../../../LEIS/L9099.htm#art48.",
                            "inicio": 111,
                            "fim": 119
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8616,
                    "caput": "065. O art. 50 da Lei nº 9.099, de 26 de setembro de 1995 , passa a vigorar com a seguinte redação:",
                    "rubrica": "” (NR)",
                    "linhaRubrica": 8614
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8620,
                    "caput": "066. O art. 83 da Lei nº 9.099, de 26 de setembro de 1995 , passam a vigorar com a seguinte redação:",
                    "paragrafos": [
                        {
                            "numero": "2º",
                            "rotulo": "§ 2º",
                            "linha": 8626,
                            "texto": "Os embargos de declaração interrompem o prazo para a interposição de recurso.",
                            "rubrica": "“ Art. 83. Cabem embargos de declaração quando, em sentença ou acórdão, houver obscuridade, contradição ou omissão.",
                            "linhaRubrica": 8622,
                            "links": [
                                {
                                    "campo": "rubrica",
                                    "texto": "Art. 83.",
                                    "href": "../../../LEIS/L9099.htm#art83.",
                                    "inicio": 2,
                                    "fim": 10
                                }
                            ]
                        }
                    ],
                    "rubrica": "“ Art. 50. Os embargos de declaração interrompem o prazo para a interposição de recurso.” (NR)",
                    "linhaRubrica": 8618,
                    "links": [
                        {
                            "campo": "rubrica",
                            "texto": "Art. 50.",
                            "href": "../../../LEIS/L9099.htm#art50.",
                            "inicio": 2,
                            "fim": 10
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8630,
                    "caput": "067. O art. 275 da Lei nº 4.737, de 15 de julho de 1965 (Código Eleitoral) , passa a vigorar com a seguinte redação:",
                    "paragrafos": [
                        {
                            "numero": "1º",
                            "rotulo": "§ 1º",
                            "linha": 8634,
                            "texto": "Os embargos de declaração serão opostos no prazo de 3 (três) dias, contado da data de publicação da decisão embargada, em petição dirigida ao juiz ou relator, com a indicação do ponto que lhes deu causa.",
                            "rubrica": "“ Art. 275. São admissíveis embargos de declaração nas hipóteses previstas no Código de Processo Civil .",
                            "linhaRubrica": 8632,
                            "links": [
                                {
                                    "campo": "rubrica",
                                    "texto": "Art. 275.",
                                    "href": "../../../LEIS/L4737.htm#art275.",
                                    "inicio": 2,
                                    "fim": 11
                                }
                            ]
                        },
                        {
                            "numero": "2º",
                            "rotulo": "§ 2º",
                            "linha": 8636,
                            "texto": "Os embargos de declaração não estão sujeitos a preparo."
                        },
                        {
                            "numero": "3º",
                            "rotulo": "§ 3º",
                            "linha": 8638,
                            "texto": "O juiz julgará os embargos em 5 (cinco) dias."
                        },
                        {
                            "numero": "4º",
                            "rotulo": "§ 4º",
                            "linha": 8640,
                            "texto": "Nos tribunais:",
                            "incisos": [
                                {
                                    "numero": "I",
                                    "rotulo": "I",
                                    "linha": 8642,
                                    "texto": "o relator apresentará os embargos em mesa na sessão subsequente, proferindo voto;"
                                },
                                {
                                    "numero": "II",
                                    "rotulo": "II",
                                    "linha": 8644,
                                    "texto": "não havendo julgamento na sessão referida no inciso I, será o recurso incluído em pauta;"
                                },
                                {
                                    "numero": "III",
                                    "rotulo": "III",
                                    "linha": 8646,
                                    "texto": "vencido o relator, outro será designado para lavrar o acórdão."
                                }
                            ]
                        },
                        {
                            "numero": "5º",
                            "rotulo": "§ 5º",
                            "linha": 8648,
                            "texto": "Os embargos de declaração interrompem o prazo para a interposição de recurso."
                        },
                        {
                            "numero": "6º",
                            "rotulo": "§ 6º",
                            "linha": 8650,
                            "texto": "Quando manifestamente protelatórios os embargos de declaração, o juiz ou o tribunal, em decisão fundamentada, condenará o embargante a pagar ao embargado multa não excedente a 2 (dois) salários-mínimos."
                        },
                        {
                            "numero": "7º",
                            "rotulo": "§ 7º",
                            "linha": 8652,
                            "texto": "Na reiteração de embargos de declaração manifestamente protelatórios, a multa será elevada a até 10 (dez) salários-mínimos.” (NR)"
                        }
                    ],
                    "rubrica": "” (NR)",
                    "linhaRubrica": 8628
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8654,
                    "caput": "068. O art. 274 e o caput do art. 2.027 da Lei nº 10.406, de 10 de janeiro de 2002 (Código Civil) , passam a vigorar com a seguinte redação: “Art. 274. O julgamento contrário a um dos credores solidários não atinge os demais, mas o julgamento favorável aproveita-lhes, sem prejuízo de exceção pessoal que o devedor tenha direito de invocar em relação a qualquer deles.” (NR) “Art. 2.027. A partilha é anulável pelos vícios e defeitos que invalidam, em geral, os negócios jurídicos.",
                    "links": [
                        {
                            "campo": "caput",
                            "texto": "art. 274",
                            "href": "#art274",
                            "inicio": 7,
                            "fim": 15
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8662,
                    "caput": "069. O Conselho Nacional de Justiça promoverá, periodicamente, pesquisas estatísticas para avaliação da efetividade das normas previstas neste Código.",
                    "rubrica": "” (NR)",
                    "linhaRubrica": 8660
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8664,
                    "caput": "070. É de 15 (quinze) dias o prazo para a interposição de qualquer agravo, previsto em lei ou em regimento interno de tribunal, contra decisão de relator ou outra decisão unipessoal proferida em tribunal."
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8666,
                    "caput": "071. O Capítulo III do Título V da Lei nº 6.015, de 31 de dezembro de 1973 (Lei de Registros Públicos), passa a vigorar acrescida do seguinte art. 216-A:",
                    "paragrafos": [
                        {
                            "numero": "1º",
                            "rotulo": "§ 1º",
                            "linha": 8678,
                            "texto": "O pedido será autuado pelo registrador, prorrogando-se o prazo da prenotação até o acolhimento ou a rejeição do pedido."
                        },
                        {
                            "numero": "2º",
                            "rotulo": "§ 2º",
                            "linha": 8680,
                            "texto": "Se a planta não contiver a assinatura de qualquer um dos titulares de direitos reais e de outros direitos registrados ou averbados na matrícula do imóvel usucapiendo e na matrícula dos imóveis confinantes, esse será notificado pelo registrador competente, pessoalmente ou pelo correio com aviso de recebimento, para manifestar seu consentimento expresso em 15 (quinze) dias, interpretado o seu silêncio como discordância."
                        },
                        {
                            "numero": "3º",
                            "rotulo": "§ 3º",
                            "linha": 8682,
                            "texto": "O oficial de registro de imóveis dará ciência à União, ao Estado, ao Distrito Federal e ao Município, pessoalmente, por intermédio do oficial de registro de títulos e documentos, ou pelo correio com aviso de recebimento, para que se manifestem, em 15 (quinze) dias, sobre o pedido."
                        },
                        {
                            "numero": "4º",
                            "rotulo": "§ 4º",
                            "linha": 8684,
                            "texto": "O oficial de registro de imóveis promoverá a publicação de edital em jornal de grande circulação, onde houver, para a ciência de terceiros eventualmente interessados, que poderão se manifestar em 15 (quinze) dias."
                        },
                        {
                            "numero": "5º",
                            "rotulo": "§ 5º",
                            "linha": 8686,
                            "texto": "Para a elucidação de qualquer ponto de dúvida, poderão ser solicitadas ou realizadas diligências pelo oficial de registro de imóveis."
                        },
                        {
                            "numero": "6º",
                            "rotulo": "§ 6º",
                            "linha": 8688,
                            "texto": "Transcorrido o prazo de que trata o § 4º deste artigo, sem pendência de diligências na forma do § 5º deste artigo e achando-se em ordem a documentação, com inclusão da concordância expressa dos titulares de direitos reais e de outros direitos registrados ou averbados na matrícula do imóvel usucapiendo e na matrícula dos imóveis confinantes, o oficial de registro de imóveis registrará a aquisição do imóvel com as descrições apresentadas, sendo permitida a abertura de matrícula, se for o caso."
                        },
                        {
                            "numero": "7º",
                            "rotulo": "§ 7º",
                            "linha": 8690,
                            "texto": "Em qualquer caso, é lícito ao interessado suscitar o procedimento de dúvida, nos termos desta Lei."
                        },
                        {
                            "numero": "8º",
                            "rotulo": "§ 8º",
                            "linha": 8692,
                            "texto": "Ao final das diligências, se a documentação não estiver em ordem, o oficial de registro de imóveis rejeitará o pedido."
                        },
                        {
                            "numero": "9º",
                            "rotulo": "§ 9º",
                            "linha": 8694,
                            "texto": "A rejeição do pedido extrajudicial não impede o ajuizamento de ação de usucapião."
                        },
                        {
                            "numero": "10º",
                            "rotulo": "§ 10º",
                            "linha": 8696,
                            "texto": "Em caso de impugnação do pedido de reconhecimento extrajudicial de usucapião, apresentada por qualquer um dos titulares de direito reais e de outros direitos registrados ou averbados na matrícula do imóvel usucapiendo e na matrícula dos imóveis confinantes, por algum dos entes públicos ou por algum terceiro interessado, o oficial de registro de imóveis remeterá os autos ao juízo competente da comarca da situação do imóvel, cabendo ao requerente emendar a petição inicial para adequá-la ao procedimento comum.”"
                        }
                    ],
                    "incisos": [
                        {
                            "numero": "I",
                            "rotulo": "I",
                            "linha": 8670,
                            "texto": "ata notarial lavrada pelo tabelião, atestando o tempo de posse do requerente e seus antecessores, conforme o caso e suas circunstâncias;",
                            "rubrica": "“Art. 216-A. Sem prejuízo da via jurisdicional, é admitido o pedido de reconhecimento extrajudicial de usucapião, que será processado diretamente perante o cartório do registro de imóveis da comarca em que estiver situado o imóvel usucapiendo, a requerimento do interessado, representado por advogado, instruído com:",
                            "linhaRubrica": 8668
                        },
                        {
                            "numero": "II",
                            "rotulo": "II",
                            "linha": 8672,
                            "texto": "planta e memorial descritivo assinado por profissional legalmente habilitado, com prova de anotação de responsabilidade técnica no respectivo conselho de fiscalização profissional, e pelos titulares de direitos reais e de outros direitos registrados ou averbados na matrícula do imóvel usucapiendo e na matrícula dos imóveis confinantes;"
                        },
                        {
                            "numero": "III",
                            "rotulo": "III",
                            "linha": 8674,
                            "texto": "certidões negativas dos distribuidores da comarca da situação do imóvel e do domicílio do requerente;"
                        },
                        {
                            "numero": "IV",
                            "rotulo": "IV",
                            "linha": 8676,
                            "texto": "justo título ou quaisquer outros documentos que demonstrem a origem, a continuidade, a natureza e o tempo da posse, tais como o pagamento dos impostos e das taxas que incidirem sobre o imóvel."
                        }
                    ]
                },
                {
                    "numero": "1º",
                    "rotulo": "Art. 1º.",
                    "linha": 8698,
                    "caput": "072. Revogam-se:",
                    "incisos": [
                        {
                            "numero": "I",
                            "rotulo": "I",
                            "linha": 8700,
                            "texto": "o art. 22 do Decreto-Lei nº 25, de 30 de novembro de 1937;"
                        },
                        {
                            "numero": "II",
                            "rotulo": "II",
                            "linha": 8702,
                            "texto": "os arts. 227, caput, 229, 230, 456, 1.482, 1.483 e 1.768 a 1.773 da Lei nº 10.406, de 10 de janeiro de 2002 (Código Civil);",
                            "links": [
                                {
                                    "campo": "texto",
                                    "texto": "arts. 227",
                                    "href": "../../../LEIS/2002/L10406.htm#art227",
                                    "inicio": 3,
                                    "fim": 12
                                },
                                {
