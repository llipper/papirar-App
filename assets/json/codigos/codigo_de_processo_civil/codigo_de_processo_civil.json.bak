                                }
                            ]
                        },
                        {
                            "numero": "III",
                            "rotulo": "III",
                            "linha": 8704,
                            "texto": "os arts. 2º, 3º, 4º, 6º, 7º, 11, 12 e 17 da Lei nº 1.060, de 5 de fevereiro de 1950;",
                            "links": [
                                {
