                            "texto": "os arts. 16 a 18 da Lei nº 5.478, de 25 de julho de 1968; e"
                        },
                        {
                            "numero": "VI",
                            "rotulo": "VI",
                            "linha": 8710,
                            "texto": "o art. 98, § 4º, da Lei nº 12.529, de 30 de novembro de 2011.",
                            "links": [
                                {
